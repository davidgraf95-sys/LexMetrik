    "titelDe": {
      "type": "literal",
      "xml:lang": "de",
      "value": "Änderung des Bundesgesetzes über den Erwerbsersatz für Dienstleistende und bei Mutterschaft (EOG). Länger dauernde Mutterschaftsentschädigung bei längerem Spitalaufenthalt des Neugeborenen."
    },
    "titelFr": {
      "type": "literal",
      "xml:lang": "fr",
      "value": "Modification de la loi fédérale sur les allocations pour perte de gain en cas de service et de maternité (LAPG). Rallonger la durée de l'allocation de maternité en cas de séjour prolongé du nouveau-né à l'hôpital. "
    },
    "titelIt": {
      "type": "literal",
      "xml:lang": "it",
      "value": "Modifica della legge federale sulle indennità di perdita di guadagno per chi presta servizio e in caso di maternità (LIPG). Prolungare la durata dell'indennità di maternità in caso di soggiorno ospedaliero prolungato del neonato."
    },
    "start": {
      "type": "typed-literal",
      "datatype": "http://www.w3.org/2001/XMLSchema#date",
      "value": "2018-03-02"
    },
