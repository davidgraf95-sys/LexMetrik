{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/main.tsx",
    "src/entry-server.tsx",
    "scripts/**/*.{ts,tsx,mjs}",
    "api/**/*.ts",
    "e2e/**/*.e2e.ts",
    "src/lib/pdf/html2canvas-stub.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "scripts/**/*.{ts,tsx,mjs}",
    "api/**/*.ts",
    "e2e/**/*.ts"
  ],
  "ignore": [
    "scripts/archiv/**",
    "**/*.generated.ts"
  ],
  "ignoreDependencies": [
    "html2canvas"
  ],
  "includeEntryExports": false
}
