{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npm test *)",
      "Bash(npm run golden:vergleich)",
      "Bash(npm run gate)",
      "Bash(npm run gate:schnell)",
      "Bash(npm run check)",
      "Bash(npm run check:inventur)",
      "Bash(npm run check:bibliothek)",
      "Bash(npm run check:verfall)",
      "Bash(npm run check:sweep)",
      "Bash(npm run check:smoke)",
      "Bash(npm run check:caches)",
      "Bash(npm run check:zitate)",
      "Bash(npm run check:fedlex-versionen)",
      "Bash(npm run test:e2e)",
      "Bash(npx --package @ast-grep/cli ast-grep *)",
      "Bash(ast-grep *)",
      "Bash(sg run *)",
      "Bash(npm run map)",
      "Bash(npm run map *)",
      "Bash(npm run ci:log)",
      "Bash(npm run ci:log *)",
      "Bash(npm run test:kurz)",
      "Bash(npm run test:e2e:kurz)",
      "Bash(npx tsc -b)",
      "Bash(npx eslint *)",
      "Bash(curl -s https://www.fedlex.admin.ch/*)",
      "Bash(curl -s https://fedlex.data.admin.ch/*)",
      "Bash(curl -s http://localhost:*)",
      "mcp__Claude_Preview__preview_screenshot"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/struktur-rotieren.py\" --hook",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/tor-schutz.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/lese-schutz.py\""
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/lese-schutz.py\""
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatch-schutz.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/gate-stopp.py\"",
            "timeout": 240
          }
        ]
      }
    ]
  }
}
