{
  "name": "lexmetrik",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run gen:suchindex && tsc -b && vite build && vite-node scripts/prerender.ts",
    "gen:suchindex": "vite-node scripts/such-index-generieren.ts",
    "check:suchindex": "vite-node scripts/such-index-generieren.ts -- --check",
    "prerender": "vite-node scripts/prerender.ts",
    "og:bild": "vite-node scripts/og-bild.ts",
    "messung:cwv": "vite-node scripts/messung-cwv.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "npm run check:inventur && npm run check:design-tokens && npm run check:bibliothek && npm run check:verfall && npm run check:verfall-ui && npm run check:sweep && npm run check:smoke && npm run check:normtext && npm run check:tabellen && npm run check:vollstaendigkeit && npm run check:struktur-konsistenz && npm run check:entscheide && npm run check:materialien && npm run check:pdf",
    "check:netz": "npm run check:caches && npm run check:zitate && npm run check:fedlex-versionen && npm run check:normtext-netz && npm run check:pdf-netz",
    "check:inventur": "vite-node scripts/katalog-inventur.ts",
    "check:design-tokens": "vite-node scripts/check-design-tokens.ts",
    "check:bibliothek": "bash scripts/bibliothek-check.sh",
    "check:verfall": "vite-node scripts/verfall-pruefen.ts",
    "gen:verfall": "vite-node scripts/verfall-generieren.ts",
    "check:verfall-ui": "vite-node scripts/verfall-generieren.ts -- --check",
    "check:sweep": "vite-node scripts/logik-sweep.ts",
    "check:smoke": "vite-node scripts/smoke-render.tsx",
    "check:caches": "bash scripts/fedlex-cache.sh",
    "check:zitate": "vite-node scripts/norm-zitate-pruefen.ts",
    "check:fedlex-versionen": "vite-node scripts/fedlex-versionen-pruefen.ts",
    "check:vollstaendigkeit": "vite-node scripts/normtext/check-vollstaendigkeit.ts",
    "check:struktur-konsistenz": "vite-node scripts/normtext/check-struktur-konsistenz.ts",
    "check:normtext": "vite-node scripts/normtext/check-drift.ts",
    "check:tabellen": "vite-node scripts/normtext/check-tabellen.ts",
    "check:entscheide": "vite-node scripts/normtext/check-entscheide.ts",
    "check:materialien": "vite-node scripts/materialien/check-materialien.ts",
    "materialien": "vite-node scripts/materialien/material-manifest-run.ts --",
    "check:normtext-netz": "vite-node scripts/normtext/check-drift.ts -- --netz",
    "entscheide": "vite-node scripts/normtext-entscheide.ts --",
    "entscheide:seed": "vite-node scripts/normtext/seed-aus-cache.ts --",
    "renormalisiere:entscheide": "vite-node scripts/normtext/renormalisiere-bestand.ts --",
    "check:confidence": "vite-node scripts/normtext/check-confidence.ts",
    "golden": "vite-node scripts/golden-outputs.ts",
    "golden:vergleich": "vite-node scripts/golden-outputs.ts vergleich",
    "golden:diff": "vite-node scripts/golden-outputs.ts diff",
    "gate": "bash scripts/gate.sh voll",
    "gate:schnell": "bash scripts/gate.sh schnell",
    "normtext": "vite-node scripts/normtext-snapshot.ts --",
    "normtext:register": "vite-node scripts/normtext/browse-manifest-run.ts --",
    "normtext:struktur": "vite-node scripts/normtext/struktur-run.ts --",
    "normtext:struktur-kanton": "vite-node scripts/normtext/struktur-kanton-run.ts --",
    "normtext:bund-stubs": "vite-node scripts/normtext/bund-stubs-generieren.ts --",
    "fedlex:eli": "vite-node scripts/fedlex-eli-aufloesen.ts --",
    "normtext:pdf": "vite-node scripts/normtext/pdf-fetch.ts --",
    "check:pdf": "vite-node scripts/normtext/check-pdf.ts",
    "check:pdf-netz": "vite-node scripts/normtext/check-pdf.ts -- --netz",
    "check:perf-budget": "vite-node scripts/check-perf-budget.ts"
