{
  "erzeugt": "2026-06-30",
  "eintraege": [
    {
      "id": "bund/GEBV_HREG/art_1",
      "ebene": "bund",
      "quelle": "GEBV_HREG",
      "erlass": "GebV-HReg",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer eine Verfügung einer Handelsregisterbehörde veranlasst oder von dieser eine Dienstleistung beansprucht, hat eine Gebühr zu bezahlen."
        },
        {
          "absatz": "2",
          "text": "Haben mehrere Personen gemeinsam eine Verfügung veranlasst oder eine Dienstleistung beansprucht, so haften sie für die Gebühr solidarisch."
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/2020/180/de#art_1",
      "abgerufen": "2026-06-30",
      "fassungsToken": "20210101",
      "sha": "aa04e1648d58106a652236c34693bb0b8be50388c6480230947e271ad3d0a6f5"
    },
    {
      "id": "bund/GEBV_HREG/art_2",
      "ebene": "bund",
      "quelle": "GEBV_HREG",
      "erlass": "GebV-HReg",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Handelsregisterbehörde erhebt keine Gebühr für:",
          "items": [
            {
              "marke": "a",
              "text": "Eintragungen, die ein Gericht oder eine Verwaltungsbehörde in einem Urteil oder in einer Verfügung anordnet;"
            },
            {
              "marke": "b",
              "text": "Mitteilungen und Auskünfte an andere Behörden."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Auf die Gebührenerhebung kann verzichtet werden:",
          "items": [
            {
              "marke": "a",
              "text": "wenn ein überwiegendes öffentliches Interesse an der Verfügung oder Dienstleistung besteht;"
            },
            {
              "marke": "b",
              "text": "wenn es sich um Verfügungen oder Dienstleistungen mit geringem Aufwand, insbesondere um einfache Auskünfte, handelt;"
            },
            {
              "marke": "c",
              "text": "soweit die Gebühr voraussichtlich uneinbringlich ist, namentlich weil die gebührenpflichtige Person nachweislich mittellos, ohne bekannte Adresse oder im Ausland ist."
            }
          ]
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/2020/180/de#art_2",
      "abgerufen": "2026-06-30",
      "fassungsToken": "20210101",
      "sha": "3ac14d1f5ee787cabccf95d6d7e5890e9f5494171000dc3be9bdd472986746c3"
    },
    {
      "id": "bund/GEBV_HREG/art_3",
      "ebene": "bund",
      "quelle": "GEBV_HREG",
      "erlass": "GebV-HReg",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Bemessung der Gebühren gelten die Ansätze im Anhang."
        },
        {
          "absatz": "2",
          "text": "Ist im Anhang kein Ansatz oder statt einer Pauschale ein Gebührenrahmen festgelegt, so werden die Gebühren, gegebenenfalls innerhalb des Rahmens, nach Zeitaufwand berechnet. Der Stundenansatz beträgt je nach erforderlicher Sachkenntnis des ausführenden Personals 100–250 Franken."
        },
        {
          "absatz": "3",
          "text": "Für Verfügungen und Dienstleistungen von aussergewöhnlichem Umfang, besonderer Schwierigkeit oder Dringlichkeit kann die Handelsregisterbehörde Zuschläge bis zu 50 Prozent der Gebühr erheben."
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/2020/180/de#art_3",
      "abgerufen": "2026-06-30",
      "fassungsToken": "20210101",
      "sha": "f48a4f0c7949d042aea14eea829d3484e3b53a3086dc48f7bebe27f960c97995"
    },
    {
      "id": "bund/GEBV_HREG/art_4",
      "ebene": "bund",
      "quelle": "GEBV_HREG",
      "erlass": "GebV-HReg",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Auslagen sind Bestandteil der Gebühr und werden gesondert berechnet."
        },
        {
          "absatz": "2",
          "text": "Als Auslagen gelten Kosten, die im Zusammenhang mit einer Verfügung oder Dienstleistung zusätzlich anfallen, insbesondere:",
          "items": [
            {
              "marke": "a",
              "text": "Übermittlungs- und Kommunikationskosten;"
            },
            {
              "marke": "b",
              "text": "Kosten für die Beschaffung der notwendigen Informationen, insbesondere von Unterlagen;"
            },
            {
              "marke": "c",
              "text": "Übersetzungskosten."
            }
          ]
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/2020/180/de#art_4",
      "abgerufen": "2026-06-30",
      "fassungsToken": "20210101",
      "sha": "209dba31459d9993b37b9bca0191784cf0778686adc433623d0615f1ad87496a"
    },
    {
      "id": "bund/GEBV_HREG/art_5",
      "ebene": "bund",
      "quelle": "GEBV_HREG",
      "erlass": "GebV-HReg",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": null,
          "text": "Die Handelsregisterbehörde kann von der gebührenpflichtigen Person einen Vorschuss oder eine Vorauszahlung verlangen."
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/2020/180/de#art_5",
      "abgerufen": "2026-06-30",
      "fassungsToken": "20210101",
      "sha": "b67e278d79f04392d64c3bbfb4b850d15e4d824b75975b3f56c5c445294384c2"
    },
    {
      "id": "bund/GEBV_HREG/art_6",
      "ebene": "bund",
      "quelle": "GEBV_HREG",
      "erlass": "GebV-HReg",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": null,
          "text": "Die Gebühr wird mit der Rechnungsstellung oder mit Rechtskraft der Verfügung fällig."
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/2020/180/de#art_6",
      "abgerufen": "2026-06-30",
      "fassungsToken": "20210101",
      "sha": "b1c44cc557f9d423a29fda547ebdce5ab490b80b0c062e8201ac2b352d2e6b12"
    },
    {
      "id": "bund/GEBV_HREG/art_7",
      "ebene": "bund",
      "quelle": "GEBV_HREG",
      "erlass": "GebV-HReg",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebührenforderung verjährt fünf Jahre nach Eintritt der Fälligkeit."
        },
        {
          "absatz": "2",
          "text": "Die Verjährung wird durch jede Verwaltungshandlung unterbrochen, mit der die Gebührenforderung bei der gebührenpflichtigen Person geltend gemacht wird."
        },
        {
          "absatz": "3",
          "text": "Mit der Unterbrechung beginnt die Verjährung von Neuem."
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/2020/180/de#art_7",
      "abgerufen": "2026-06-30",
      "fassungsToken": "20210101",
      "sha": "1aaa1ce454cf80f928481ad82149b810bd324c5f6c7a98cbfcef9d1fa5b976c8"
    },
    {
      "id": "bund/GEBV_HREG/art_8",
      "ebene": "bund",
      "quelle": "GEBV_HREG",
      "erlass": "GebV-HReg",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Einnahmen aus den Gebühren für Handelsregistereintragungen nach den Ziffern 1–3 des Anhangs fallen zu 90 Prozent dem Kanton zu, der die Eintragung vorgenommen hat, und zu 10 Prozent der Eidgenossenschaft."
        },
        {
          "absatz": "2",
          "text": "Die Einnahmen aus den Gebühren nach den Ziffern 4 und 5 des Anhangs erhält der betreffende Kanton oder die Eidgenossenschaft, je nachdem, wer die Verfügung erlassen oder die Dienstleistung erbracht hat."
        },
        {
          "absatz": "3",
          "text": "Der Anteil des Bundes an den von den kantonalen Handelsregisterämtern im vorangehenden Jahr bezogenen Gebühren ist zu Beginn jedes neuen Jahres der Eidgenossenschaft zu überweisen."
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/2020/180/de#art_8",
      "abgerufen": "2026-06-30",
      "fassungsToken": "20210101",
      "sha": "9aacb0f1af70d25798ad32676ef5a2e53576af4be26d757451c3b32aaba644dc"
    },
    {
      "id": "bund/GEBV_HREG/art_9",
      "ebene": "bund",
      "quelle": "GEBV_HREG",
      "erlass": "GebV-HReg",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": null,
          "text": "Die Zahlungsmodalitäten und die Höhe von Gebühren für Verfügungen und Dienstleistungen, die vor Inkrafttreten dieser Verordnung ergehen beziehungsweise erbracht wurden, richten sich nach bisherigem Recht."
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/2020/180/de#art_9",
      "abgerufen": "2026-06-30",
      "fassungsToken": "20210101",
      "sha": "6d02ffae942ffd8b7ee3b7b5d22816f634a32b234375d39c7cebfd65ef19d405"
    },
    {
      "id": "bund/GEBV_HREG/art_10",
      "ebene": "bund",
      "quelle": "GEBV_HREG",
      "erlass": "GebV-HReg",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": null,
          "text": "Die Verordnung vom 3. Dezember 1954 über die Gebühren für das Handelsregister wird aufgehoben."
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/2020/180/de#art_10",
      "abgerufen": "2026-06-30",
      "fassungsToken": "20210101",
      "sha": "63b83395ea105bcfa44efe5251387938c0125a44b3306f04efdf0f77f566d835"
    },
