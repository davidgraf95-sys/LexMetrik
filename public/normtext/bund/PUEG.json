      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "26",
      "artikelLabel": "Art. 26",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Preisüberwacher und die zuständigen Behörden (Art. 15) vollziehen dieses Gesetz."
        },
        {
          "absatz": "2",
          "text": "Der Bundesrat erlässt die Ausführungsbestimmungen. Insbesondere kann er Bestimmungen über die Koordination der Tätigkeiten des Preisüberwachers und der zuständigen Behörden (Art. 15) erlassen."
        }
      ],
      "stand": "2026-05-08",
