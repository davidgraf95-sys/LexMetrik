      "erlass": "PUEG",
      "artikel": "25",
      "artikelLabel": "Art. 25",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Verfolgung und Beurteilung der strafbaren Handlungen gilt das Verwaltungsstrafrechtsgesetz vom 22. März 1974."
        },
        {
          "absatz": "2",
          "text": "Verfolgende und urteilende Verwaltungsbehörde ist das Eidgenössische Departement für Wirtschaft, Bildung und Forschung."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_25",
      "abgerufen": "2026-06-29",
