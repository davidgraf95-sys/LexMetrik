      "artikel": "23",
      "artikelLabel": "Art. 23",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer vorsätzlich:",
          "items": [
            {
              "marke": "a",
              "text": "eine verfügte Preissenkung nicht vornimmt,"
            },
            {
              "marke": "b",
              "text": "trotz Untersagung einen Preis erhöht oder"
            },
            {
              "marke": "c",
              "text": "einvernehmlich geregelte Preise überschreitet,"
            }
          ]
        },
        {
          "absatz": null,
          "text": "wird mit Busse bis zu 100 000 Franken bestraft."
        },
        {
          "absatz": "2",
          "text": "Der Versuch ist strafbar."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_23",
