{
  "erzeugt": "2026-06-29",
  "eintraege": [
    {
      "id": "bund/PUEG/art_1",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": null,
          "text": "Das Gesetz gilt für Preise von Waren und Dienstleistungen einschliesslich der Kredite. Ausgenommen sind Löhne und andere Leistungen aus dem Arbeitsverhältnis sowie die Kredittätigkeit der Schweizerischen Nationalbank."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_1",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "ff72efbb699401e7d1102e5e20050a5a07720dfd9e85f320a1ae5a2c47fa244a"
    },
    {
      "id": "bund/PUEG/art_2",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": null,
          "text": "Das Gesetz gilt für Wettbewerbsabreden im Sinne des Kartellgesetzes vom 6. Oktober 1995 und für marktmächtige Unternehmen des privaten und des öffentlichen Rechts."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_2",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "3929bd3b8065b4b9f0ce7c65f13e816ee8c8c777b74257f607ee7ecc19177cae"
    },
    {
      "id": "bund/PUEG/art_3",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Bundesrat wählt einen Beauftragten für die Überwachung der Preise (Preisüberwacher)."
        },
        {
          "absatz": "2",
          "text": "Der Preisüberwacher ist dem Eidgenössischen Departement für Wirtschaft, Bildung und Forschung unterstellt. Es steht ihm ein Mitarbeiterstab zur Verfügung."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_3",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "8a3ff2db7f1fb0d4c3a7be550eab166578b0316ccc2bd0d6ce38e279ae708039"
    },
    {
      "id": "bund/PUEG/art_4",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Preisüberwacher beobachtet die Preisentwicklung."
        },
        {
          "absatz": "2",
          "text": "Er verhindert oder beseitigt die missbräuchliche Erhöhung und Beibehaltung von Preisen. Vorbehalten bleibt die Überwachung bestimmter Preise durch andere Behörden (Art. 15)."
        },
        {
          "absatz": "3",
          "text": "Er orientiert die Öffentlichkeit über seine Tätigkeit."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_4",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "c08d2b0343a42e6de674ec4f6a1cf15ddf0bfbfdde51c4bd313d5527280e9a64"
    },
    {
      "id": "bund/PUEG/art_5",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Preisüberwachung erfolgt in Zusammenarbeit mit den interessierten Kreisen. Bei Kreditzinsen handelt der Preisüberwacher insbesondere nach eingehender Konsultation mit der Nationalbank und der Eidgenössischen Finanzmarktaufsicht."
        },
        {
          "absatz": "2",
          "text": "Der Preisüberwacher arbeitet mit der Wettbewerbskommission zusammen. Er nimmt mit beratender Stimme an deren Sitzungen teil."
        },
        {
          "absatz": "3",
          "text": "Preisüberwacher und Wettbewerbskommission orientieren sich gegenseitig über wichtige Entscheidungen."
        },
        {
          "absatz": "4",
          "text": "Sind Fragen des persönlichen Geltungsbereichs (Art. 2) und des wirksamen Wettbewerbes (Art. 12) zu beurteilen, so haben der Preisüberwacher oder die zuständige Behörde (Art. 15) die Wettbewerbskommission zu konsultieren, bevor sie eine Verfügung treffen. Die Wettbewerbskommission kann die Stellungnahmen veröffentlichen."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_5",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "d8baa8558cf95113bf3793c65bc5e374d6c051e64dbd8599dd6cdf81b84eb13e"
    },
    {
      "id": "bund/PUEG/art_6",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": null,
          "text": "Beabsichtigen Beteiligte an Wettbewerbsabreden oder marktmächtige Unternehmen eine Preiserhöhung, können sie diese dem Preisüberwacher unterbreiten. Dieser erklärt innert 30 Tagen, ob er die Preiserhöhung für unbedenklich hält."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_6",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "6083c8798ccbdac3c508a9de81fc296a1c36cd82c0418359da7b97e3e6b0b272"
    },
    {
      "id": "bund/PUEG/art_7",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": null,
          "text": "Wer vermutet, die Erhöhung oder Beibehaltung eines Preises sei missbräuchlich, kann dies dem Preisüberwacher schriftlich melden."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_7",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "37f5a78287933319812f066f7ffc764fd8bd349dc36f994d0959a9e2c71255e8"
    },
    {
      "id": "bund/PUEG/art_8",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": null,
          "text": "Aufgrund der Meldungen oder eigener Beobachtungen klärt der Preisüberwacher ab, ob Anhaltspunkte für eine missbräuchliche Preiserhöhung oder -beibehaltung bestehen."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_8",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "54d75f85e1ffca17f7ff4e5cdfbea606805795e29e831c77cf59befc9c06f62c"
    },
    {
      "id": "bund/PUEG/art_9",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": null,
          "text": "Stellt der Preisüberwacher einen Missbrauch fest, strebt er mit den Betroffenen eine einvernehmliche Regelung an; diese bedarf keiner besonderen Form."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_9",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "58a1346646f1e036f4e2deb22ba6df5a0b2a892ca61c9f05fd35b1ff36d8b3fc"
    },
    {
      "id": "bund/PUEG/art_10",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": null,
          "text": "Kommt keine einvernehmliche Regelung zustande, untersagt der Preisüberwacher die Erhöhung ganz oder teilweise oder verfügt eine Preissenkung."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_10",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "c8c841f4d10eca952a338ab65aea93419269fd695728b2074d1149a206d18e36"
    },
    {
      "id": "bund/PUEG/art_11",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die einvernehmliche Regelung oder der Entscheid sind in ihrer Gültigkeit zu befristen."
        },
        {
          "absatz": "2",
          "text": "Der Preisüberwacher erklärt sie auf Antrag des Betroffenen vor Fristablauf als hinfällig, sofern sich die tatsächlichen Verhältnisse inzwischen wesentlich geändert haben."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_11",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "2319a7ae2699b62e0a17a06c28a09cd370e80003452893b236ebd00b84f99de0"
    },
    {
      "id": "bund/PUEG/art_12",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Preismissbrauch im Sinne dieses Gesetzes kann nur vorliegen, wenn die Preise auf dem betreffenden Markt nicht das Ergebnis wirksamen Wettbewerbs sind."
        },
        {
          "absatz": "2",
          "text": "Wirksamer Wettbewerb besteht insbesondere, wenn die Abnehmer die Möglichkeit haben, ohne erheblichen Aufwand auf vergleichbare Angebote auszuweichen."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_12",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "9ff1aa98f129c8b2683d55d8866dce1fda069d70ce1d17b95b5505b54ff60a43"
    },
    {
      "id": "bund/PUEG/art_13",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Prüfung, ob eine missbräuchliche Erhöhung oder Beibehaltung eines Preises vorliegt, hat der Preisüberwacher insbesondere zu berücksichtigen:",
          "items": [
            {
              "marke": "a",
              "text": "die Preisentwicklung auf Vergleichsmärkten;"
            },
            {
              "marke": "b",
              "text": "die Notwendigkeit der Erzielung angemessener Gewinne;"
            },
            {
              "marke": "c",
              "text": "die Kostenentwicklung;"
            },
            {
              "marke": "d",
              "text": "besondere Unternehmerleistungen;"
            },
            {
              "marke": "e",
              "text": "besondere Marktverhältnisse."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Bei der Überprüfung der Kosten kann der Preisüberwacher auch den Ausgangspreis (Preissockel) berücksichtigen."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_13",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "d5c1990434008b1ae5cd13af40dbc766af75b3b9482760c0099ec5e6ef987a98"
    },
    {
      "id": "bund/PUEG/art_14",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ist die Legislative oder die Exekutive des Bundes, eines Kantons oder einer Gemeinde zuständig für die Festsetzung oder Genehmigung einer Preiserhöhung, die von den Beteiligten an einer Wettbewerbsabrede oder einem marktmächtigen Unternehmen beantragt wird, so hört sie zuvor den Preisüberwacher an. Er kann beantragen, auf die Preiserhöhung ganz oder teilweise zu verzichten oder einen missbräuchlich beibehaltenen Preis zu senken."
        },
        {
          "absatz": "2",
          "text": "Die Behörde führt die Stellungnahme in ihrem Entscheid an. Folgt sie ihr nicht, so begründet sie dies."
        },
        {
          "absatz": "3",
          "text": "Bei der Prüfung der Frage, ob ein Preismissbrauch vorliegt, berücksichtigt der Preisüberwacher allfällige übergeordnete öffentliche Interessen."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_14",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "973eec6768e13566fb8719a6aee7ddc191fbe33cd65130edcd2226aedbc76ef5"
    },
    {
      "id": "bund/PUEG/art_15",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "15",
      "artikelLabel": "Art. 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Werden verabredete Preise oder Preise eines marktmächtigen Unternehmens bereits aufgrund anderer bundesrechtlicher Vorschriften überwacht, so beurteilt sie die zuständige Behörde anstelle des Preisüberwachers."
        },
        {
          "absatz": "2",
          "text": "Die Behörde richtet sich dabei nach dem vorliegenden Gesetz, soweit dies mit den Zielen ihrer Überwachung vereinbar ist."
        },
        {
          "absatz": "2bis",
          "text": "Die Behörde orientiert den Preisüberwacher über die von ihr vorzunehmenden Preisbeurteilungen. Der Preisüberwacher kann beantragen, auf eine Preiserhöhung ganz oder teilweise zu verzichten oder einen missbräuchlich beibehaltenen Preis zu senken."
        },
        {
          "absatz": "2ter",
          "text": "Die Behörde führt die Stellungnahme des Preisüberwachers in ihrem Entscheid an. Folgt sie ihr nicht, so begründet sie dies."
        },
        {
          "absatz": "3",
          "text": "Verfahren, Rechtsschutz und Straffolgen richten sich nach den entsprechenden bundesrechtlichen Erlassen."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_15",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "20550486d87367fbc3de0cfcd0a99731239e756e28cfa08901c1f8f88f6b0660"
    },
    {
      "id": "bund/PUEG/art_16",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "16",
      "artikelLabel": "Art. 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Wettbewerbskommission kann Untersuchungen gegen Wettbewerbsabreden oder marktmächtige Unternehmen einleiten, auch wenn der Preisüberwacher den Preis herabgesetzt oder das Verfahren eingestellt hat."
        },
        {
          "absatz": "2",
          "text": "Dem Preisüberwacher bleibt die Überprüfung der Missbräuchlichkeit von verabredeten Preisen oder Preisen von marktmächtigen Unternehmen vorbehalten."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_16",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "3cf9011ded2853aa708cf94e16839bf266f89a8186fe39511468602b305bb1f5"
    },
    {
      "id": "bund/PUEG/art_17",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "17",
      "artikelLabel": "Art. 17",
      "bloecke": [
        {
          "absatz": null,
          "text": "Beteiligte an Wettbewerbsabreden, marktmächtige Unternehmen sowie am Markt beteiligte Dritte müssen dem Preisüberwacher alle erforderlichen Auskünfte erteilen und die notwendigen Unterlagen zur Verfügung stellen. Dritte sind zur Offenbarung von Fabrikations- oder Geschäftsgeheimnissen nicht verpflichtet."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_17",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "a1b148c44945c58d9c18997184bc771f482327c10f285aa1d9ad40f6c90cbf04"
    },
    {
      "id": "bund/PUEG/art_18",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": null,
          "text": "Der Preisüberwacher kann von Amtsstellen und Aufsichtsbehörden des Bundes, der Kantone und Gemeinden sowie von Organisationen der Wirtschaft verlangen, bei seinen Abklärungen mitzuwirken und die notwendigen Unterlagen zur Verfügung zu stellen."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_18",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "78d720a51bfbdda70591d620a190539443034aa6b641c5696c7b6999b2025f79"
    },
    {
      "id": "bund/PUEG/art_19",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "19",
      "artikelLabel": "Art. 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Preisüberwacher wahrt das Amtsgeheimnis."
        },
        {
          "absatz": "2",
          "text": "Er darf keine Geschäftsgeheimnisse preisgeben."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_19",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "9b3ef5634d43482d17abd7b2e4fa2e5905c241261153a01bbbc94535dcefb0e9"
    },
    {
      "id": "bund/PUEG/art_20",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "20",
      "artikelLabel": "Art. 20",
      "bloecke": [
        {
          "absatz": null,
          "text": "Der Rechtsschutz richtet sich nach den allgemeinen Bestimmungen über die Bundesrechtspflege."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_20",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "e95d1ac167505d707707e2eebaed158e18693651825dca62b2ad8bfb261d5870"
    },
    {
      "id": "bund/PUEG/art_21",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "21",
      "artikelLabel": "Art. 21",
      "bloecke": [
        {
          "absatz": null,
          "text": "Den Organisationen von nationaler oder regionaler Bedeutung, die sich statutengemäss dem Konsumentenschutz widmen, steht das Beschwerderecht zu."
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_21",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "e10686b700ec5753eff8763e53cc25fd8d31a4576efc9e0643a7e263008a720c"
    },
    {
      "id": "bund/PUEG/art_22",
      "ebene": "bund",
      "quelle": "PUEG",
      "erlass": "PUEG",
      "artikel": "22",
      "artikelLabel": "Art. 22",
      "bloecke": [
        {
          "absatz": null,
          "text": "…"
        }
      ],
      "stand": "2026-05-08",
      "quelleUrl": "https://www.fedlex.admin.ch/eli/cc/1986/895_895_895/de#art_22",
      "abgerufen": "2026-06-29",
      "fassungsToken": "20260508",
      "sha": "b4935894c8ce16bde67bbffc672428b1533c4f1e1e8b1ce21a2933183db6bfa5"
    },
    {
