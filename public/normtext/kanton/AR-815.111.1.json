    },
    {
      "id": "kanton/AR/815.111.1/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif für die Lebensmittelkontrolle (815.111.1)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Wert eines Aufwandpunktes beträgt Fr. 1.90. Das Departement Gesundheit und Soziales passt diesen Wert in Absprache mit den Partnerkantonen der Teuerung an (LIKP von 103,0 Punkten, Stand September 1995/Basis Mai 1993 = 100)."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/815.111.1",
      "abgerufen": "2026-06-23",
