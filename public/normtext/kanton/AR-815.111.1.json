    },
    {
      "id": "kanton/AR/815.111.1/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif für die Lebensmittelkontrolle (815.111.1)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Einzelpositionen für die technischen Untersuchungen können beim Kantonschemiker und beim Lebensmittelinspektorat beider Appenzell eingesehen werden."
        }
      ],
      "stand": "2016-01-01",
