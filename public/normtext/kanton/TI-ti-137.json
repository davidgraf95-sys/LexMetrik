      "sha": "d9345da8aa3fee0493a8d89baa529ba60eb54bd9d3684296bf4f4c8c13d31fb4"
    },
    {
      "id": "kanton/TI/ti-137/art_12",
      "ebene": "kanton",
      "quelle": "TI",
      "erlass": "Legge sulla tariffa giudiziaria (LTG) (RL 178.200)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": null,
          "text": "La tariffa delle decisioni in istanza cantonale unica del Tribunale di appello è il doppio di quella delle decisioni del pretore nella procedura ordinaria."
        }
      ],
      "stand": "2015-02-10",
      "quelleUrl": "https://m3.ti.ch/CAN/RLeggi/public/index.php/raccolta-leggi/pdfatto/atto/137",
      "abgerufen": "2026-06-17",
      "fassungsToken": "4f34df0b316445d9cea970e91db5868100d94a6823ee24bdd8e4514897d71300",
      "sha": "0adb52d9d65532fcbc3c6fabeab84659e34bb37994f5d88b394ba8e7077da0a6"
    },
    {
      "id": "kanton/TI/ti-137/art_13",
      "ebene": "kanton",
      "quelle": "TI",
      "erlass": "Legge sulla tariffa giudiziaria (LTG) (RL 178.200)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": null,
          "text": "La tariffa delle decisioni su appello del Tribunale di appello è uguale a quella delle decisioni del pretore nella procedura originaria."
        }
      ],
      "stand": "2015-02-10",
      "quelleUrl": "https://m3.ti.ch/CAN/RLeggi/public/index.php/raccolta-leggi/pdfatto/atto/137",
      "abgerufen": "2026-06-17",
      "fassungsToken": "4f34df0b316445d9cea970e91db5868100d94a6823ee24bdd8e4514897d71300",
