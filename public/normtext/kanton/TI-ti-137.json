{
  "erzeugt": "2026-06-17",
  "eintraege": [
    {
      "id": "kanton/TI/ti-137/art_1",
      "ebene": "kanton",
      "quelle": "TI",
      "erlass": "Legge sulla tariffa giudiziaria (LTG) (RL 178.200)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "La presente legge stabilisce la tariffa delle spese processuali per l’amministrazione della giustizia civile e penale."
        },
        {
          "absatz": "2",
          "text": "Sono riservate le leggi speciali."
        }
      ],
      "stand": "2015-02-10",
      "quelleUrl": "https://m3.ti.ch/CAN/RLeggi/public/index.php/raccolta-leggi/pdfatto/atto/137",
      "abgerufen": "2026-06-17",
      "fassungsToken": "4f34df0b316445d9cea970e91db5868100d94a6823ee24bdd8e4514897d71300",
      "sha": "c24c6f910922a27a16b7b045f53e3ef73717f38a57d0f929ebb627b93d978e56"
    },
    {
      "id": "kanton/TI/ti-137/art_2",
      "ebene": "kanton",
      "quelle": "TI",
      "erlass": "Legge sulla tariffa giudiziaria (LTG) (RL 178.200)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "La tassa di giustizia è fissata in considerazione del valore, della natura e della complessità dell’atto o della causa."
        },
        {
          "absatz": "2",
          "text": "Nel caso di manifesta sproporzione tra il valore, la natura e la complessità della causa e la tariffa della presente legge, l’autorità competente può derogare ai limiti imposti dalla tariffa."
        }
      ],
      "stand": "2015-02-10",
      "quelleUrl": "https://m3.ti.ch/CAN/RLeggi/public/index.php/raccolta-leggi/pdfatto/atto/137",
      "abgerufen": "2026-06-17",
      "fassungsToken": "4f34df0b316445d9cea970e91db5868100d94a6823ee24bdd8e4514897d71300",
      "sha": "c966d51715a65554a906f6000b323b5c3d21539f09a517fae64496129649bb69"
    },
    {
      "id": "kanton/TI/ti-137/art_3",
      "ebene": "kanton",
      "quelle": "TI",
      "erlass": "Legge sulla tariffa giudiziaria (LTG) (RL 178.200)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ogni autorità giudiziaria incassa da sé le spese processuali, le pene pecuniarie e le multe, riservato il cpv. 2."
        },
        {
          "absatz": "2",
          "text": "Il Consiglio di Stato può istituire un servizio centrale di incasso per le autorità giudiziarie."
        }
      ],
      "stand": "2015-02-10",
      "quelleUrl": "https://m3.ti.ch/CAN/RLeggi/public/index.php/raccolta-leggi/pdfatto/atto/137",
      "abgerufen": "2026-06-17",
      "fassungsToken": "4f34df0b316445d9cea970e91db5868100d94a6823ee24bdd8e4514897d71300",
      "sha": "294ec0931ccb60fb6923a25b9656d40ba05b60374609b7dedcdd311138917ce5"
    },
    {
      "id": "kanton/TI/ti-137/art_4",
      "ebene": "kanton",
      "quelle": "TI",
      "erlass": "Legge sulla tariffa giudiziaria (LTG) (RL 178.200)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Le spese processuali spettano allo Stato."
        },
        {
          "absatz": "2",
          "text": "Le spese processuali per le procedure davanti al giudice di pace spettano a quest’ultimo."
        },
        {
          "absatz": null,
          "text": "TITOLO II"
        },
        {
          "absatz": null,
          "text": "Capitolo primo"
        }
      ],
      "stand": "2015-02-10",
      "quelleUrl": "https://m3.ti.ch/CAN/RLeggi/public/index.php/raccolta-leggi/pdfatto/atto/137",
      "abgerufen": "2026-06-17",
      "fassungsToken": "4f34df0b316445d9cea970e91db5868100d94a6823ee24bdd8e4514897d71300",
      "sha": "b8432c7d6e732d1e738cf060563f6512ed6971522c503017471dcb7dd96984ee"
    },
    {
      "id": "kanton/TI/ti-137/art_5",
      "ebene": "kanton",
      "quelle": "TI",
      "erlass": "Legge sulla tariffa giudiziaria (LTG) (RL 178.200)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Nelle procedure di conciliazione, è fissata una tassa entro i limiti seguenti:",
          "items": [
            {
              "marke": "Valore litigioso in franchi",
              "text": "Tassa in franchi"
            },
            {
              "marke": "fino a 2'000",
              "text": "50 - 150"
            },
            {
              "marke": "2'000 - 5'000",
              "text": "100 - 300"
            },
            {
              "marke": "5'000 - 30'000",
              "text": "200 - 1'500"
            },
            {
              "marke": "30'000 - 100'000",
              "text": "500 - 3'000"
            },
            {
              "marke": "100'000 - 1'000'000",
              "text": "1'000 - 5'000"
            },
            {
              "marke": "oltre 1'000'000",
              "text": "3'000 - 0,5%"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Nel caso in cui il valore litigioso non sia determinabile, la tassa è fissata tra 50 e 5000 franchi."
        },
        {
          "absatz": "3",
          "text": "L’autorità di conciliazione può rinunciare a prelevare la tassa nel caso di riuscita del tentativo di conciliazione."
        },
        {
          "absatz": null,
          "text": "Capitolo secondo"
        }
      ],
      "stand": "2015-02-10",
      "quelleUrl": "https://m3.ti.ch/CAN/RLeggi/public/index.php/raccolta-leggi/pdfatto/atto/137",
      "abgerufen": "2026-06-17",
      "fassungsToken": "4f34df0b316445d9cea970e91db5868100d94a6823ee24bdd8e4514897d71300",
      "sha": "46c21f5a09893dabe1431b9022e22768c9b429753d11c3b054d6fffd8c01b49d"
    },
    {
      "id": "kanton/TI/ti-137/art_6",
      "ebene": "kanton",
      "quelle": "TI",
      "erlass": "Legge sulla tariffa giudiziaria (LTG) (RL 178.200)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": null,
          "text": "La tassa di giustizia delle decisioni del giudice di pace è fissata tra 50 e 300 franchi."
        },
        {
          "absatz": null,
          "text": "Capitolo terzo"
        }
      ],
      "stand": "2015-02-10",
      "quelleUrl": "https://m3.ti.ch/CAN/RLeggi/public/index.php/raccolta-leggi/pdfatto/atto/137",
      "abgerufen": "2026-06-17",
      "fassungsToken": "4f34df0b316445d9cea970e91db5868100d94a6823ee24bdd8e4514897d71300",
      "sha": "e035cc42628c81e4845786cfda3e7b5f5f01c0cb982b32ddcb1d187236f319f0"
    },
    {
      "id": "kanton/TI/ti-137/art_7",
      "ebene": "kanton",
      "quelle": "TI",
      "erlass": "Legge sulla tariffa giudiziaria (LTG) (RL 178.200)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "La tassa di giustizia delle decisioni del pretore nella procedura ordinaria è fissata entro i limiti seguenti:",
          "items": [
            {
              "marke": "Valore litigioso in franchi",
              "text": "Tassa di giustizia in franchi"
            },
            {
              "marke": "fino a 30’000",
              "text": "500 - 4’000"
            },
            {
              "marke": "30’000 - 50’000",
              "text": "2’500 - 5’000"
            },
            {
              "marke": "50’000 - 100’000",
              "text": "3’000 - 8’000"
            },
            {
              "marke": "100’000 - 200’000",
              "text": "5’000 - 12’000"
            },
            {
              "marke": "200’000 - 500’000",
              "text": "8’000 - 20’000"
            },
            {
              "marke": "500’000 - 1’000’000",
              "text": "15’000 - 40’000"
            },
            {
              "marke": "1’000’000 - 2’000’000",
              "text": "25’000 - 60’000"
            },
            {
              "marke": "2’000’000 - 5’000’000",
              "text": "35’000 - 80’000"
            },
            {
              "marke": "5’000’000 - 10’000’000",
              "text": "55’000 - 100’000"
            },
            {
              "marke": "oltre 10’000’000",
              "text": "75’000 a 1% del valore"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Nelle cause con un valore litigioso non determinabile e in quelle della procedura di divorzio, la tassa di giustizia è fissata tra 250 e 20'000 franchi."
        },
        {
          "absatz": "3",
          "text": "È inoltre applicabile il capoverso 1 nelle cause della procedura di divorzio che hanno per oggetto anche rapporti patrimoniali, salvo i contributi di mantenimento."
        }
      ],
      "stand": "2015-02-10",
      "quelleUrl": "https://m3.ti.ch/CAN/RLeggi/public/index.php/raccolta-leggi/pdfatto/atto/137",
      "abgerufen": "2026-06-17",
      "fassungsToken": "4f34df0b316445d9cea970e91db5868100d94a6823ee24bdd8e4514897d71300",
      "sha": "6f1b9a84dc522170b0424ec6abfbeab32a6fda249e06cc211bec8da2635869e1"
    },
    {
      "id": "kanton/TI/ti-137/art_8",
      "ebene": "kanton",
      "quelle": "TI",
      "erlass": "Legge sulla tariffa giudiziaria (LTG) (RL 178.200)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "La tariffa delle decisioni del pretore nella procedura semplificata è uguale a quella nella procedura ordinaria."
        },
        {
          "absatz": "2",
          "text": "Nelle controversie fino a un valore litigioso di 30'000 franchi in materia di locazione e affitto di abitazioni e di locali commerciali come pure di affitto agricolo, la tassa è fissata tra 100 e 200 franchi; in quelle controversie, senza riguardo al valore litigioso, il giudice può esentare la parte soccombente che agisce senza malafede o temerarietà processuali dalle spese dell’assunzione delle prove se queste hanno effetti finanziariamente gravosi."
        }
      ],
      "stand": "2015-02-10",
      "quelleUrl": "https://m3.ti.ch/CAN/RLeggi/public/index.php/raccolta-leggi/pdfatto/atto/137",
      "abgerufen": "2026-06-17",
      "fassungsToken": "4f34df0b316445d9cea970e91db5868100d94a6823ee24bdd8e4514897d71300",
      "sha": "7c6c1f8b5de77b427a210c382a1d012a93704411b788070c7fddd790c475f7d1"
    },
    {
      "id": "kanton/TI/ti-137/art_9",
      "ebene": "kanton",
      "quelle": "TI",
      "erlass": "Legge sulla tariffa giudiziaria (LTG) (RL 178.200)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "La tariffa delle decisioni del pretore nella procedura sommaria è la metà di quella nella procedura ordinaria."
        },
        {
          "absatz": "2",
          "text": "Nelle cause con un valore litigioso non determinabile e in quelle nelle quali si domanda la tutela giurisdizionale nei casi manifesti la tassa di giustizia è fissata tra 100 e 20’000 franchi."
        },
        {
          "absatz": "3",
          "text": "Nelle controversie in materia di locazione e di affitto di abitazioni e di locali commerciali come pure di affitto agricolo, la tassa è fissata tra 100 e 200 franchi."
        }
      ],
      "stand": "2015-02-10",
      "quelleUrl": "https://m3.ti.ch/CAN/RLeggi/public/index.php/raccolta-leggi/pdfatto/atto/137",
      "abgerufen": "2026-06-17",
      "fassungsToken": "4f34df0b316445d9cea970e91db5868100d94a6823ee24bdd8e4514897d71300",
      "sha": "64de41347fe27e1c68ed9b8bc917ea3c60cbd8f39100fe1c0f5f118287a0d28d"
    },
    {
      "id": "kanton/TI/ti-137/art_10",
      "ebene": "kanton",
      "quelle": "TI",
      "erlass": "Legge sulla tariffa giudiziaria (LTG) (RL 178.200)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": null,
          "text": "La tassa di giustizia dei provvedimenti cautelari è fissata tra 100 e 20’000 franchi."
        }
      ],
      "stand": "2015-02-10",
      "quelleUrl": "https://m3.ti.ch/CAN/RLeggi/public/index.php/raccolta-leggi/pdfatto/atto/137",
      "abgerufen": "2026-06-17",
      "fassungsToken": "4f34df0b316445d9cea970e91db5868100d94a6823ee24bdd8e4514897d71300",
      "sha": "84c7a2865a6fba1709b80ccdadb9c860c0588ff47358897240db9714fb76d29f"
    },
    {
      "id": "kanton/TI/ti-137/art_11",
