          "text": "Nelle altre procedure la tassa di giustizia è fissata tra 100 e 10'000 franchi."
        },
        {
          "absatz": null,
          "text": "Capitolo quarto"
        }
      ],
      "stand": "2015-02-10",
      "quelleUrl": "https://m3.ti.ch/CAN/RLeggi/public/index.php/raccolta-leggi/pdfatto/atto/137",
      "abgerufen": "2026-06-17",
