      "erlass": "Ausführungsbestimmungen zur Vereinbarung über die Beitragsleistung an Fahrten von mobilitätseingeschränkten Personen (953.940)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Fahrtenkontingent",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Pro Jahr stehen einer anspruchsberechtigten Person mit zivilrechtlichem Wohnsitz im Kanton Basel-Stadt 168 beitragsberechtigte Fahrten zur Verfügung."
        },
        {
          "absatz": "2",
          "text": "Das Amt für Mobilität kann bei Bedarf unterjährig das Kontingent an beitragsberechtigten Fahrten anpassen."
        }
      ],
      "stand": "2018-03-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/953.940",
