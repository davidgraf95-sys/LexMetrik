      "titel": "Zweck",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Ausführungsbestimmungen regeln den Vollzug der Vereinbarung über die Beitragsleistung an Fahrten von mobilitätseingeschränkten Personen."
        }
      ],
      "stand": "2018-03-01",
