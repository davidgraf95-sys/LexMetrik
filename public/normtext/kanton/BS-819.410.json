{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/819.410/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gesetz über die steuerbegünstigten Arbeitsbeschaffungsreserven (819.410)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "titel": "1. Grundsatz",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Kanton und Gemeinden gewähren den Unternehmen, die nach dem Bundesgesetz über die Bildung steuerbegünstigter Arbeitsbeschaffungsreserven vom 20. Dezember 1985 Reserven ausscheiden, Steuervergünstigungen."
        },
        {
          "absatz": "2",
          "text": "Soweit dieses Gesetz nicht Abweichendes bestimmt, gelten die Bestimmungen des Bundesrechts."
        }
      ],
      "stand": "2009-12-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.410",
      "abgerufen": "2026-06-23",
      "fassungsToken": "75ab6c7ba185ce56f80c7dd3904eb4e3",
      "sha": "bb59f8d3ead3167648858e5adb52cdcfcc6905d2fc33ad277e1deaa336d65596"
    },
    {
      "id": "kanton/BS/819.410/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gesetz über die steuerbegünstigten Arbeitsbeschaffungsreserven (819.410)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "2. Berechtigte Unternehmen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zur Bildung von Reserven sind Unternehmen mit mindestens zehn Arbeitnehmern berechtigt."
        }
      ],
      "stand": "2009-12-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.410",
      "abgerufen": "2026-06-23",
      "fassungsToken": "75ab6c7ba185ce56f80c7dd3904eb4e3",
      "sha": "798ecb09a9057532f223644b3b3799da71570defff97b6fad1e7898851927b53"
    },
    {
      "id": "kanton/BS/819.410/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gesetz über die steuerbegünstigten Arbeitsbeschaffungsreserven (819.410)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "3. Jährliche Einlagen und Höchstbestand",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die jährliche Einlage beträgt höchstens 15% der bundesrechtlichen Berechnungsgrundlage. Erreicht dieser Anteil nicht Fr. 10'000.-, darf das Unternehmen die Einlage nicht vornehmen."
        },
        {
          "absatz": "2",
          "text": "Die Reserven dürfen 20% der massgebenden jährlichen Lohnsumme im Sinne der AHV-Gesetzgebung nicht übersteigen."
        }
      ],
      "stand": "2009-12-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.410",
      "abgerufen": "2026-06-23",
      "fassungsToken": "75ab6c7ba185ce56f80c7dd3904eb4e3",
      "sha": "67fcc4da04961f48e780a690d85ca9967b22fe9123b9eaa70f3130b1b88687a2"
    },
    {
      "id": "kanton/BS/819.410/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gesetz über die steuerbegünstigten Arbeitsbeschaffungsreserven (819.410)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "4. Bemessung der Steuervergünstigung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die jährlichen Einlagen in die Arbeitsbeschaffungsreserven gelten bei den direkten Steuern als geschäftsmässig begründete Aufwendungen."
        },
        {
          "absatz": "2",
          "text": "Die Arbeitsbeschaffungsreserven sind steuerrechtlich den offenen Reserven gleichgestellt, die aus versteuertem Einkommen oder Reinertrag gebildet werden."
        }
      ],
      "stand": "2009-12-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.410",
      "abgerufen": "2026-06-23",
      "fassungsToken": "75ab6c7ba185ce56f80c7dd3904eb4e3",
      "sha": "8e175b96ac13115c442425f971162eb204545ee2b156076cd3112db20cc6d630"
    },
    {
      "id": "kanton/BS/819.410/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gesetz über die steuerbegünstigten Arbeitsbeschaffungsreserven (819.410)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "titel": "5. Nachträgliche Besteuerung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Kanton und Gemeinden besteuern den aufgelösten Reservenbetrag, wenn das Unternehmen",
          "items": [
            {
              "marke": "a",
              "text": "den Verwendungsnachweis nicht ordnungsgemäss erbringt;"
            },
            {
              "marke": "b",
              "text": "die Betriebstätigkeit einstellt;"
            },
            {
              "marke": "c",
              "text": "den Sitz oder eine Betriebsstätte ins Ausland verlegt."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Auf dem aufgelösten Reservenbetrag ist getrennt vom übrigen Einkommen oder Ertrag die Steuer zum Höchstsatz geschuldet. Die Verrechnung mit Verlusten aus dem laufenden oder aus früheren Geschäftsjahren ist ausgeschlossen."
        }
      ],
      "stand": "2009-12-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.410",
      "abgerufen": "2026-06-23",
      "fassungsToken": "75ab6c7ba185ce56f80c7dd3904eb4e3",
      "sha": "da6edbcfe62cab7b3bd0ba19fca8802d61d6c6b3309dfb4a75c4f8c39260a88c"
    },
    {
      "id": "kanton/BS/819.410/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gesetz über die steuerbegünstigten Arbeitsbeschaffungsreserven (819.410)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "titel": "6. Anwendung des Steuergesetzes",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Verfahren über die Festsetzung der Steuervergünstigung und die nachträgliche Besteuerung richten sich nach den Bestimmungen des Steuergesetzes."
        }
      ],
      "stand": "2009-12-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.410",
      "abgerufen": "2026-06-23",
      "fassungsToken": "75ab6c7ba185ce56f80c7dd3904eb4e3",
      "sha": "68362441b89091c608951fa67a657d511ef5814e13ec4e280ee6b4e404185ed2"
    },
    {
      "id": "kanton/BS/819.410/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gesetz über die steuerbegünstigten Arbeitsbeschaffungsreserven (819.410)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "titel": "7. Strafbestimmungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die unrechtmässige Erlangung einer Steuervergünstigung unterliegt den Strafbestimmungen des Steuergesetzes."
        }
      ],
      "stand": "2009-12-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.410",
      "abgerufen": "2026-06-23",
      "fassungsToken": "75ab6c7ba185ce56f80c7dd3904eb4e3",
      "sha": "09f77a6d175cfaf79b6156018dcc1b3717d8e797f0e042cc7d7fb37e8c3345ac"
    },
    {
      "id": "kanton/BS/819.410/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gesetz über die steuerbegünstigten Arbeitsbeschaffungsreserven (819.410)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "titel": "8. Vollzug",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat erlässt die zum Vollzug dieses Gesetzes erforderlichen Vorschriften."
        }
      ],
      "stand": "2009-12-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.410",
      "abgerufen": "2026-06-23",
      "fassungsToken": "75ab6c7ba185ce56f80c7dd3904eb4e3",
      "sha": "b7aa3a6f277260eeac2289e80adb7a4a9be1bc7cb46658d04d4ca26fd23c691b"
    },
    {
      "id": "kanton/BS/819.410/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gesetz über die steuerbegünstigten Arbeitsbeschaffungsreserven (819.410)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "titel": "9. Verhältnis zum bisherigen Recht",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Führt das Unternehmen Arbeitsbeschaffungsmassnahmen durch, muss es vorab die nach dem bisherigen Recht gebildeten Reserven verwenden."
        }
      ],
      "stand": "2009-12-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.410",
      "abgerufen": "2026-06-23",
      "fassungsToken": "75ab6c7ba185ce56f80c7dd3904eb4e3",
      "sha": "34939d8bed375ca6a032ef6532bb4567e9bde59d8ed96135d342ab5605cab2db"
    },
    {
      "id": "kanton/BS/819.410/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gesetz über die steuerbegünstigten Arbeitsbeschaffungsreserven (819.410)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "titel": "10. Änderung bisherigen Rechts",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Gesetz betreffend die Gewährung von Steuervergütungen auf Arbeitsbeschaffungsreserven (Arbeitsbeschaffungsreservengesetz) vom 29. Mai 1952 wird wie folgt geändert und ergänzt:"
        }
      ],
      "stand": "2009-12-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.410",
      "abgerufen": "2026-06-23",
      "fassungsToken": "75ab6c7ba185ce56f80c7dd3904eb4e3",
      "sha": "f93f687c3b767f31e720b5f1fa9a0e04a6865e79024915c372f06f0125013bbb"
    },
    {
      "id": "kanton/BS/819.410/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gesetz über die steuerbegünstigten Arbeitsbeschaffungsreserven (819.410)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "titel": "11. Aufhebung bisherigen Rechts",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat hebt das bisherige Recht auf, sobald alle nach dem bisherigen Recht gebildeten Reserven aufgelöst oder verwendet sind."
        }
      ],
      "stand": "2009-12-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.410",
      "abgerufen": "2026-06-23",
      "fassungsToken": "75ab6c7ba185ce56f80c7dd3904eb4e3",
      "sha": "535eba0d7ea0e3f17acc0fbda276840f16220b536579cda50c8990e885a617f5"
    },
    {
      "id": "kanton/BS/819.410/art_12",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gesetz über die steuerbegünstigten Arbeitsbeschaffungsreserven (819.410)",
      "artikel": "12",
      "artikelLabel": "§ 12",
      "titel": "12. Erstmalige Anwendung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieses Gesetz findet erstmals Anwendung für die Steuern, die im Jahre 1989 fällig werden."
        },
        {
          "absatz": "2",
          "text": "Reserven nach diesem Gesetz können erstmals für die in das Jahr 1988 fallenden Geschäftsabschlüsse gebildet werden."
        }
      ],
      "stand": "2009-12-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.410",
      "abgerufen": "2026-06-23",
      "fassungsToken": "75ab6c7ba185ce56f80c7dd3904eb4e3",
      "sha": "606d121641617974db55d3d119d1fb32b31445e8a1412a05cec3a7a72aa89c03"
    },
    {
      "id": "kanton/BS/819.410/art_12 a",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gesetz über die steuerbegünstigten Arbeitsbeschaffungsreserven (819.410)",
      "artikel": "12 a",
      "artikelLabel": "§ 12a",
      "titel": "12a. Übergangsbestimmung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Auflösung der bestehenden Arbeitsbeschaffungsreserven richtet sich nach Bundesrecht."
        },
        {
          "absatz": "2",
          "text": "Der Regierungsrat hebt dieses Gesetz auf, solbald alle nach diesem Gesetz gebildeten Reserven aufgelöst sind."
        }
      ],
      "stand": "2009-12-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.410",
      "abgerufen": "2026-06-23",
      "fassungsToken": "75ab6c7ba185ce56f80c7dd3904eb4e3",
      "sha": "4a053fc092628ca9620d5732c724931f1cdd50d62a5c978b611481a5f3218ab5"
    }
  ]
}