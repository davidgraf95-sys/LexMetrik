{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/RiE 890.100/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfeordnung (RiE 890.100)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "titel": "Gegenstand",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Aufgaben der öffentlichen Sozialhilfe werden von der Einwohnergemeinde Riehen wahrgenommen und finanziert."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "317f9a834d318b54c374d2e2740b822e",
      "sha": "f78c0762c6cb7a11c3756d7970db5d7db309d3ccc1f797cee32b1cb729201013"
    },
    {
      "id": "kanton/BS/RiE 890.100/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfeordnung (RiE 890.100)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Sozialhilfeleistungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gemeinde gewährt bedürftigen Einwohnerinnen und Einwohnern von Riehen unentgeltliche Beratung und wirtschaftliche Hilfe nach Massgabe des übergeordneten Rechts."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "317f9a834d318b54c374d2e2740b822e",
      "sha": "61274cc994f9121b013b7570941397604d492b562f8bad503c76f3574a444b99"
    },
    {
      "id": "kanton/BS/RiE 890.100/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfeordnung (RiE 890.100)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Gesuche",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gesuche um Gewährung von Leistungen der Sozialhilfe werden bei der zuständigen Sozialhilfestelle der Gemeindeverwaltung eingereicht."
        },
        {
          "absatz": "2",
          "text": "Dem Unterstützungsgesuch sind alle Dokumente beizulegen und es sind diejenigen Auskünfte zu erteilen, die zur Abklärung der Bedürftigkeit nötig sind."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "317f9a834d318b54c374d2e2740b822e",
      "sha": "313bf9ad55d5c8d587ae4fd1834e098ea0f221b9bb0845509643695a8f842296"
    },
    {
      "id": "kanton/BS/RiE 890.100/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfeordnung (RiE 890.100)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Verfügungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die zuständige Sozialhilfestelle entscheidet in Form einer rekursfähigen Verfügung über die Gesuche um Gewährung von Sozialhilfeleistungen."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "317f9a834d318b54c374d2e2740b822e",
      "sha": "36ed1da42a06b372581ecd37b0d0987d927c0540354a3693756987c7e1ea1723"
    },
    {
      "id": "kanton/BS/RiE 890.100/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfeordnung (RiE 890.100)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "titel": "Rechtsschutz",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gegen Verfügungen der Sozialhilfestelle kann Rekurs an den Gemeinderat ergriffen werden."
        },
        {
          "absatz": "2",
          "text": "Gegen Verfügungen und Entscheide des Gemeinderats kann gemäss den kantonalen Bestimmungen Rekurs an den Regierungsrat ergriffen werden."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "317f9a834d318b54c374d2e2740b822e",
      "sha": "10cbaf31744902ff6a2a7502f7c15aa1027ae5f1cf993dd2396c2570a4a6da91"
    },
    {
      "id": "kanton/BS/RiE 890.100/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfeordnung (RiE 890.100)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "titel": "Fristen und Begründung der Rekurse",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Rekurse sind innert 10 Tagen seit Eröffnung bei der Sozialhilfestelle anzumelden. Innert 30 Tagen, vom gleichen Zeitpunkt an gerechnet, ist die Rekursbegründung einzureichen. Diese hat die Anträge der Rekurrentin oder des Rekurrenten und deren Begründung mit Angabe der Beweismittel zu enthalten."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "317f9a834d318b54c374d2e2740b822e",
      "sha": "0e0a690c9f0e49d125e1b90ad78b9cd0577feb4f265dfe0e3cb7a29144e7cccf"
    },
    {
      "id": "kanton/BS/RiE 890.100/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfeordnung (RiE 890.100)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "titel": "Entscheid",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Gemeinderat holt in der Regel vor seinem Entscheid die Stellungnahme des Sozialhilfebeirats ein. Der Entscheid wird schriftlich eröffnet."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "317f9a834d318b54c374d2e2740b822e",
      "sha": "d3cd370cd8aef0466da30371780c700b1dc9c56b9c83403f9026702683a27d8d"
    },
    {
      "id": "kanton/BS/RiE 890.100/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfeordnung (RiE 890.100)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "titel": "Sozialhilfebeirat",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Gemeinderat bestellt auf seine eigene Amtszeit von vier Jahren einen weisungsunabhängigen Sozialhilfebeirat."
        },
        {
          "absatz": "2",
          "text": "Der Sozialhilfebeirat berät den Gemeinderat bei Rekursen, die im Zusammenhang mit der Ausrichtung von Sozialhilfebeiträgen erhoben werden. Er hört bei Bedarf die Rekurrierenden an."
        },
        {
          "absatz": "3",
          "text": "Der Sozialhilfebeirat ist ein interdisziplinär zusammengesetztes Gremium und besteht aus drei bis fünf Mitgliedern und einem Sekretariat."
        },
        {
          "absatz": "4",
          "text": "Als Mitglieder des Sozialhilfebeirats werden Personen bestellt, die über ausgewiesene fachliche Kenntnisse oder breite Erfahrungen im Sozialbereich verfügen."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "317f9a834d318b54c374d2e2740b822e",
      "sha": "54fe2eb18591a4eb7e8dbcb31a8774827ad85eb6700813d49fb26af6a7787ebe"
    },
    {
      "id": "kanton/BS/RiE 890.100/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfeordnung (RiE 890.100)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "titel": "Delegation von Spezialaufgaben",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Gemeinderat kann einzelne Spezialaufgaben der Sozialhilfe an dafür geeignete Dritte übertragen."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "317f9a834d318b54c374d2e2740b822e",
      "sha": "704c4b982faf9173c8c7f42d6944d3c61ef452d711a163bf11033f5da158da81"
    },
    {
      "id": "kanton/BS/RiE 890.100/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfeordnung (RiE 890.100)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "titel": "Ausführungsbestimmungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Gemeinderat erlässt die erforderlichen Ausführungsbestimmungen. Er regelt insbesondere",
          "items": [
            {
              "marke": "a",
              "text": "die Wahl, das Verfahren und die Organisation des Sozialhilfebeirats,"
            },
            {
              "marke": "b",
              "text": "das Übertragen von einzelnen Spezialaufgaben an Dritte."
            }
          ]
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "317f9a834d318b54c374d2e2740b822e",
      "sha": "7a13dd5c67783fa652e83e1d772d657ca92aacc8c37cdd423b95a30fd273f70e"
    },
    {
      "id": "kanton/BS/RiE 890.100/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfeordnung (RiE 890.100)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "titel": "Publikation und Wirksamkeit",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Ordnung wird publiziert; sie unterliegt dem Referendum."
        },
        {
          "absatz": "2",
          "text": "Sie wird am 1. Januar 2005 wirksam."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "317f9a834d318b54c374d2e2740b822e",
      "sha": "7c4a35547000c3aec2ec8c7fe739a6bc8a123e0499df2bfbdf007bf9ccbd8fa4"
    }
  ]
}