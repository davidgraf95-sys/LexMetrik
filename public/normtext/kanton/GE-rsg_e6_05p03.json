{
  "erzeugt": "2026-06-19",
  "eintraege": [
    {
      "id": "kanton/GE/rsg_e6_05p03/art_1",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Le présent règlement est applicable aux émoluments et aux débours des notaires pour leur activité en tant qu’officiers publics."
        },
        {
          "absatz": "2",
          "text": "Est réservé le droit du notaire de réclamer des honoraires, s’il y a lieu."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "d212f59197e86009937a64a3ddfb576a469c301cedcacd042975e43e7ed11d38"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_2",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Les émoluments couvrent l’étude, la préparation, l’instrumentation de l’acte, ainsi que l’expédition nécessaire aux registres officiels."
        },
        {
          "absatz": "2",
          "text": "L’émolument calculé suivant la somme de l’acte est déterminé sauf disposition contraire en répartissant cette somme en catégories et en appliquant à chacune d’elles le taux correspondant."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "36b17c34c0e4e3458f5c4224c23afb97d5f1982a9b55b5819fd71757a90fa762"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_3",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": null,
          "text": "Les débours comprennent :"
        },
        {
          "absatz": null,
          "text": "a) les droits et taxes payés à l’Etat;"
        },
        {
          "absatz": null,
          "text": "b) les frais de traduction;"
        },
        {
          "absatz": null,
          "text": "c) le coût des extraits des registres officiels;"
        },
        {
          "absatz": null,
          "text": "d) les frais postaux et téléphoniques;"
        },
        {
          "absatz": null,
          "text": "e) les frais de photocopies."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "7cb40dff70d4bbbaa7fbfaa17646a6096ccef88f7a830634d08777452eb9799d"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_4",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": null,
          "text": "L’émolument dû pour un acte non prévu par le présent règlement est calculé par rapport à l’acte avec lequel il présente le plus d’analogie."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "fd30943c7a068d310f21c72090d48963d3e0cf18bc8cb717da88639a12d62066"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_5",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": null,
          "text": "Selon les circonstances et la situation de l’intéressé, les émoluments peuvent être réduits."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "da10dd2023320fbcfe29cfa8cac41b7241af0f871379dd469afe1ae191df62f0"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_6",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": null,
          "text": "Lorsque l’acte préparé n’est pas réalisé, seuls des honoraires sont dus."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "c5abdb3f4206c38e4f7a530721b095c1c2799564ce6348f7d32975fd858ff69b"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_7",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": null,
          "text": "Si un seul acte est dressé pour plusieurs opérations, l’émolument est calculé sur chaque opération."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "c99a5aa2b6699c62d101c0ef3b747030812aa41c007414750b9eb304c017d0ec"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_8",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": null,
          "text": "La note présentée au client distingue les émoluments, les honoraires et les débours."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "3abb363f5f27ccfdee7b3f4585e04012de2ef268ec6aa5e0b44c69e0e44ef692"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_9",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Les contestations sont adressées par simple lettre au greffier du Tribunal de première instance (art. 36, al. 3, de la loi)."
        },
        {
          "absatz": "2",
          "text": "La décision est prise après citation des parties."
        },
        {
          "absatz": "3",
          "text": "La procédure est gratuite."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "d7f5c21f20f6fb36a7f4e13a554a88e481ad93da6f1764f502d1abbf6e4dc5e4"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_10",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": null,
          "text": "en matière immobilière",
          "items": [
            {
              "marke": "7‰",
              "text": "jusqu’à 200 000 francs, au minimum 200 francs"
            },
            {
              "marke": "6‰",
              "text": "de 200 001 francs à 400 000 francs"
            },
            {
              "marke": "4,5‰",
              "text": "de 400 001 francs à 800 000 francs"
            },
            {
              "marke": "4‰",
              "text": "de 800 001 francs à 1 000 000 de francs"
            },
            {
              "marke": "3,5‰",
              "text": "de 1 000 001 francs à 1 500 000 francs"
            },
            {
              "marke": "3‰",
              "text": "de 1 500 001 francs à 2 000 000 de francs"
            },
            {
              "marke": "2,5‰",
              "text": "de 2 000 001 francs à 3 500 000 francs"
            },
            {
              "marke": "2‰",
              "text": "de 3 500 001 francs à 5 000 000 de francs"
            },
            {
              "marke": "1,5‰",
              "text": "de 5 000 001 francs à 7 500 000 francs"
            },
            {
              "marke": "1‰",
              "text": "de 7 500 001 francs à 10 000 000 de francs"
            },
            {
              "marke": "0,75‰",
              "text": "de 10 000 001 francs à 20 000 000 de francs"
            },
            {
              "marke": "0,5‰",
              "text": "au-dessus de 20 000 000 de francs."
            }
          ]
        },
        {
          "absatz": "1",
          "text": "Pour les actes translatifs de propriété, tels que vente, échange, donation et droit de superficie distinct et permanent, l’émolument est fixé selon la valeur énoncée dans l’acte, ou retenue par l’enregistrement, soit :"
        },
        {
          "absatz": "2",
          "text": "Pour les droits de superficie distincts et permanents, l’émolument est calculé selon la valeur de la rente capitalisée au taux de 5%."
        },
        {
          "absatz": null,
          "text": "en matière mobilière"
        },
        {
          "absatz": "3",
          "text": "L’émolument pour les actes relatifs à des biens mobiliers est réduit de moitié."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "e7f012898bb6f86fa9d58dfcec1b8f712590c481a020526354688c2f321ae4a5"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_11",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": null,
          "text": "L’émolument pour les actes translatifs de propriété entre un particulier et une collectivité publique ou un établissement de droit public cantonal est réduit à la moitié de ceux fixés à l’article précédent, respectivement au tiers lorsque toutes les parties à l’acte sont des collectivités publiques."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "9d1290fbc2ea1afcee685bd041d62094dc7f31ca92046fd0ca98dd71aa36586a"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_12",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "L’émolument pour les promesses de vente ou droit d’emption est fixé au tiers de ceux prévus à l’article 10, mais au minimum à 200 francs."
        },
        {
          "absatz": "2",
          "text": "Pour les actes de préemption, reçus séparément, l’émolument est de 200 francs à 500 francs."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "1163791a7234c2aa8a89f017615e56da141918d1b7debfa063fdc52b0e1ed058"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_13",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": null,
          "text": "Pour un acte constitutif ou modificatif de propriété par étages, l’émolument est fixé selon la valeur vénale des parts, soit à :",
          "items": [
            {
              "marke": "2‰",
              "text": "jusqu’à 1 000 000 de francs"
            },
            {
              "marke": "1‰",
              "text": "de 1 000 001 francs à 5 000 000 de francs"
            },
            {
              "marke": "½‰",
              "text": "dès 5 000 000 de francs, sans toutefois être supérieur à 25 000 francs."
            }
          ]
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "f0f8ffcc01bdc32a290019d1ed3c6692a6732464ac53f396303972b03e81071b"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_14",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": null,
          "text": "L’émolument en cas d’échange est perçu sur la valeur du bien le plus élevé."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "5d22a572a7b11c7aca3f2fe79c34f12eac20375e87e964c0ccaa85b5876f8fa2"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_15",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "15",
      "artikelLabel": "Art. 15",
      "bloecke": [
        {
          "absatz": null,
          "text": "En matière de donation de biens-fonds agricoles, l’émolument est perçu sur la valeur vénale, conformément à l’article 10, alinéa 1."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "ec7ae1e7484a16d0cdbe993e37b522ad93e1639cd9096a31386ad6d6817d3092"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_16",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "16",
      "artikelLabel": "Art. 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Pour constituer ou augmenter des gages immobiliers, l’émolument est fixé d’après le montant du gage ou de son augmentation, soit :",
          "items": [
            {
              "marke": "5‰",
              "text": "jusqu’à 200 000 francs, mais au minimum 100 francs"
            },
            {
              "marke": "4‰",
              "text": "de 200 001 francs à 500 000 francs"
            },
            {
              "marke": "3‰",
              "text": "de 500 001 francs à 2 000 000 de francs"
            },
            {
              "marke": "2‰",
              "text": "de 2 000 001 francs à 5 000 000 de francs"
            },
            {
              "marke": "1‰",
              "text": "au-dessus de 5 000 000 de francs."
            }
          ]
        },
        {
          "absatz": null,
          "text": "Hypothèque légale"
        },
        {
          "absatz": "2",
          "text": "Pour une hypothèque légale fondée sur l’acte du notaire, aucun émolument n’est dû."
        },
        {
          "absatz": null,
          "text": "Transformation d’un gage"
        },
        {
          "absatz": "3",
          "text": "Pour la transformation ou novation d’un gage immobilier sans modification du montant, l’émolument est réduit au tiers."
        },
        {
          "absatz": null,
          "text": "Titre hypothécaire"
        },
        {
          "absatz": "4",
          "text": "Pour la confection d’un titre hypothécaire, l’émolument est de 100 francs à 200 francs."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "6b49539ffb3a8fdf06b520a917bac239d839f64aa2cd477aa2c53504f53de9c5"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_17",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "17",
      "artikelLabel": "Art. 17",
      "bloecke": [
        {
          "absatz": null,
          "text": "Pour un acte constitutif ou modificatif de servitude, il est perçu un émolument de base de 500 francs, auquel s’ajoute 100 francs par droit créé ou modifié."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "631ce5352e6cd00d55ef817952ce602477aaf886184ebcde25eb02205d5d7c28"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_18",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "L’émolument pour l’établissement d’un contrat de mariage, d’un testament public et d’un pacte successoral est de 200 francs au minimum et de 2 000 francs au maximum."
        },
        {
          "absatz": "2",
          "text": "Si l’un de ces actes a un effet translatif de propriété ou si l’acte successoral a lieu à titre onéreux, l’émolument est fixé conformément à l’article 10."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "4882be436cfcecde3453a7e9d9065346202de0148a688b02bc65daae39f78b40"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_19",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "19",
      "artikelLabel": "Art. 19",
      "bloecke": [
        {
          "absatz": null,
          "text": "Pour une attestation de la qualité d’héritier, l’émolument est de 100 francs à 500 francs."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "420a062b1ed04ce7385e2cba2ddc5d09d04ba7b87f00e2498a9af9157ff6fd31"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_19_a",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "19_a",
      "artikelLabel": "Art. 19a",
      "bloecke": [
        {
          "absatz": "1",
          "text": "L’ouverture de dispositions testamentaires donne lieu aux émoluments suivants :",
          "items": [
            {
              "marke": "a) testament ou pacte successoral",
              "text": "250 francs"
            },
            {
              "marke": "b) codicille",
              "text": "100 francs"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "L’émolument peut être réduit ou supprimé si la succession est insolvable ou si le testament est caduc, révoqué ou sans objet."
        },
        {
          "absatz": "3",
          "text": "Un avis à un exécuteur testamentaire ou une communication de dispositions testamentaires en vertu des articles 517 et 558 du code civil suisse donne lieu à un émolument de 50 francs."
        },
        {
          "absatz": "4",
          "text": "La préparation d'une insertion dans la Feuille d'avis officielle donne lieu, en sus des frais d'insertion, à un émolument de 50 francs."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "4b3155b6cdfc23b29b18c9d88053b71f053a710e2db04d7d4b90a506c65eb1d6"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_20",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "20",
      "artikelLabel": "Art. 20",
      "bloecke": [
        {
          "absatz": null,
          "text": "Pour la mutation d’immeubles après décès, l’émolument est de 200 francs à 1 000 francs."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "1985ed56e898454976eb0d3d842b3b8585f23a7f45b5b362c470bc2c57322565"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_22",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "22",
      "artikelLabel": "Art. 22",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Pour l’inventaire fiscal, l’émolument est de 25 francs à 10 000 francs, calculé sur la base de l’article 4, alinéa 2 du règlement sur l’inventaire au décès, du 23 décembre 1960."
        },
        {
          "absatz": "2",
          "text": "Toutefois, dans tous les cas, l’émolument s’élève au minimum à 300 francs."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "f42f448f11ea5d175db8bd7981893e0a9f91240f8c151a2142331153aa02c66f"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_23",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "23",
      "artikelLabel": "Art. 23",
      "bloecke": [
        {
          "absatz": null,
          "text": "Pour les inventaires autres que celui prévu à l’article 22, l’émolument est fixé en tenant compte de l’actif brut diminué des dettes à l’égard des tiers. Il est de :",
          "items": [
            {
              "marke": "4‰",
              "text": "des premiers 200 000 francs, au minimum 300 francs"
            },
            {
              "marke": "3‰",
              "text": "des 800 000 francs suivants"
            },
            {
              "marke": "2‰",
              "text": "de 1 000 001 francs à 5 000 000 de francs"
            },
            {
              "marke": "1‰",
              "text": "de 5 000 001 francs à 10 000 000 de francs"
            },
            {
              "marke": "½‰",
              "text": "au-dessus de 10 000 000 de francs."
            }
          ]
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "7da99e71083f1f950eee460f11fcef7bfa20210baed7ee28be6de58bfb251b1f"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_24",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "24",
      "artikelLabel": "Art. 24",
      "bloecke": [
        {
          "absatz": null,
          "text": "Pour les contrats de partage, l’émolument est calculé sur la part revenant à chaque ayant droit. Il est de :",
          "items": [
            {
              "marke": "7,5‰",
              "text": "jusqu’à 100 000 francs"
            },
            {
              "marke": "5‰",
              "text": "de 100 001 francs à 200 000 francs"
            },
            {
              "marke": "2,5‰",
              "text": "au-dessus de 200 000 francs."
            }
          ]
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "76b8c40b2855da9f9ad9d672e6f4509100d18ea26d6f846d97ec1ae2f570fc7c"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_25",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "25",
      "artikelLabel": "Art. 25",
      "bloecke": [
        {
          "absatz": "1",
          "text": "L'émolument relatif aux actes constitutifs est de 500 francs à 2 000 francs. Pour les fondations de sociétés unipersonnelles, l'émolument maximum est de 1 000 francs.",
          "items": [
            {
              "marke": "7‰",
              "text": "jusqu’à 50 000 francs"
            },
            {
              "marke": "6‰",
              "text": "de 50 001 francs à 100 000 francs"
            },
            {
              "marke": "5‰",
              "text": "de 100 001 francs à 200 000 francs"
            },
            {
              "marke": "4‰",
              "text": "de 200 001 francs à 300 000 francs"
            },
            {
              "marke": "3‰",
              "text": "de 300 001 francs à 400 000 francs"
            },
            {
              "marke": "2‰",
              "text": "de 400 001 francs à 500 000 francs"
            },
            {
              "marke": "1‰",
              "text": "de 500 001 francs à 10 000 000 de francs"
            },
            {
              "marke": "0,5‰",
              "text": "au-dessus de 10 000 000 de francs."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "En outre, un émolument proportionnel au capital de fondation ou de dotation, ou d’augmentation, est perçu; il est de :"
        },
        {
          "absatz": "3",
          "text": "L’émolument de vente sur les apports immobiliers est compté en sus."
        },
        {
          "absatz": null,
          "text": "Réduction de capital"
        },
        {
          "absatz": "4",
          "text": "Pour les réductions de capital, le quart de l'émolument proportionnel mentionné ci-dessus est perçu. L'émolument fixe est au maximum de 1 000 francs pour les réductions de capital en vue d'un assainissement."
        },
        {
          "absatz": null,
          "text": "Autre procès-verbal"
        },
        {
          "absatz": "5",
          "text": "Un émolument de 150 francs à 2 000 francs est perçu pour tout autre procès-verbal."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "06f63c1192190f638042996ddf9172dafd766be027ee8c622b5017bd288199ee"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_26",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "26",
      "artikelLabel": "Art. 26",
      "bloecke": [
        {
          "absatz": null,
          "text": "Pour un acte de cautionnement, l’émolument est fixé à 1‰ de la créance, au minimum 100 francs et au maximum 500 francs."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "7b922f5d738ec7a46c6e4bf005192bbebcbe14b6aa1aa4fafb624567ae2316ac"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_26_a",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "26_a",
      "artikelLabel": "Art. 26a",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Pour les titres authentiques exécutoires, l'émolument est fixé en tenant compte de la valeur de la prestation énoncée dans l'acte, soit :",
          "items": [
            {
              "marke": "4‰",
              "text": "des premiers 100 000 francs, au minimum 350 francs"
            },
            {
              "marke": "2,5‰",
              "text": "de 100 001 francs à 400 000 francs"
            },
            {
              "marke": "1,2‰",
              "text": "de 400 001 francs à 1 000 000 de francs"
            },
            {
              "marke": "0,75‰",
              "text": "de 1 000 001 francs à 5 000 000 de francs"
            },
            {
              "marke": "0,5‰",
              "text": "au-dessus de 5 000 000 de francs."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "L'émolument est majoré de 20% pour chaque clause exécutoire supplémentaire en rapport de réciprocité ou de subsidiarité, le total de l'émolument ne pouvant toutefois excéder 140% de l'émolument de base."
        },
        {
          "absatz": "3",
          "text": "Pour une clause exécutoire insérée dans un acte pour lequel le présent règlement prévoit un émolument proportionnel, l'émolument est de 350 francs, indépendamment de la valeur de la prestation."
        },
        {
          "absatz": "4",
          "text": "Pour la notification d'une copie certifiée conforme d'un titre exécutoire relatif à une prestation non pécuniaire, l'émolument est fixé à 1‰ de la valeur de la contre-prestation, au minimum 300 francs et au maximum 1 000 francs. Les débours et émoluments relatifs à l'établissement de la copie certifiée conforme sont comptés en supplément."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "663a600165572649fc48d25b28083976f1677078d99572f9c24b1d104beb86f1"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_27",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "27",
      "artikelLabel": "Art. 27",
      "bloecke": [
        {
          "absatz": null,
          "text": "Pour tous les autres actes authentiques non prévus par le règlement et ne présentant aucune analogie avec ceux mentionnés, l’émolument est de 100 francs à 2 000 francs."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "33c768087da7277a5e256025411fecded7c1d70f49469d6e65380b7e1c7d837e"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_28",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "28",
      "artikelLabel": "Art. 28",
      "bloecke": [
        {
          "absatz": null,
          "text": "Pour les expéditions supplémentaires d’actes, l’émolument est de 50 francs à 100 francs."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "30746d3f464529e93a7db013c931ede77e79c52db198b2aecabc051ccaa44ab8"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_29",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "29",
      "artikelLabel": "Art. 29",
      "bloecke": [
        {
          "absatz": null,
          "text": "Pour la légalisation d’une signature avec ou sans attestations diverses ou pour l’authentification d’une copie ou pour l’attestation de la date, l’émolument est de 15 francs à 100 francs."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "d5e94afc4e7956899ce10adeeb9b10a367228c1c4a2396b72dcaa9933796ba5a"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_30",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "30",
      "artikelLabel": "Art. 30",
      "bloecke": [
        {
          "absatz": null,
          "text": "Le règlement fixant le tarif des émoluments des notaires, du 20 avril 1951, est abrogé."
        }
      ],
      "stand": "2015-04-30",
      "quelleUrl": "https://silgeneve.ch/legis/program/books/rsg/htm/rsg_e6_05p03.htm",
      "abgerufen": "2026-06-19",
      "fassungsToken": "7cedbe71d910107a3ffb6e10ad8611f78e5fd42157a57f3f94182646380a556e",
      "sha": "6bf44868dfdde2e726ab4c20133838bb1d252060aa05db8d698da3fd0622edf4"
    },
    {
      "id": "kanton/GE/rsg_e6_05p03/art_31",
      "ebene": "kanton",
      "quelle": "GE",
      "erlass": "Règlement sur les émoluments des notaires (REmNot) (RSG E 6 05.03)",
      "artikel": "31",
      "artikelLabel": "Art. 31",
      "bloecke": [
        {
          "absatz": null,
          "text": "Le présent règlement entre en vigueur le 1er septembre 1985.",
          "items": [
            {
              "marke": "RSG Intitulé Date d'adoption",
              "text": "Entrée en vigueur"
