            {
              "beschreibung": "112 Urteil",
              "betrag": "500.– bis 5000.–"
            },
            {
              "beschreibung": "12 Kollegialgericht 121 Verfügung (Verfahrensleitung)",
              "betrag": "200.– bis 2000.–"
