            },
            {
              "beschreibung": "3 Kantonsgericht 31 Verfügung (Verfahrensleitung)",
              "betrag": "200.– bis 2000.–"
            },
            {
              "beschreibung": "32 Beschluss",
              "betrag": "500.– bis 5000.–"
            },
            {
              "beschreibung": "33 Urteil",
