              "betrag": "500.– bis 5000.–"
            },
            {
              "beschreibung": "123 Urteil",
              "betrag": "500.– bis 15000.–"
            },
            {
              "beschreibung": "2 Anklagekammer 21 Verfügung (Verfahrensleitung)",
              "betrag": "200.– bis 2000.–"
            },
            {
              "beschreibung": "22 Beschluss",
              "betrag": "500.– bis 5000.–"
            },
            {
              "beschreibung": "23 Urteil",
