      "bloecke": [
        {
          "absatz": null,
          "text": "Prüfungsgebühr"
        },
        {
          "absatz": "1",
          "text": "Die Prüfungsgebühren betragen: Fr.",
          "items": [
            {
              "marke": "a",
              "text": "für Rechtsanwältinnen und Rechtsanwälte . . . . . . . . . . . . . . . . . . . . 2200.–"
            },
            {
              "marke": "b",
              "text": "für Rechtsagentinnen und Rechtsagenten . . . . . . . . . . . . . . . . . . . . . 1800.–"
            },
            {
              "marke": "c",
              "text": "für Notarinnen und Notare (Beurkundungsrecht) . . . . . . . . . . . . . . 800.–"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Für eine Ergänzungsprüfung wird die Hälfte des Ansatzes nach Abs.1 dieser Bestimmung erhoben."
        },
        {
          "absatz": "3",
          "text": "Die Gebühr ist mit der Anmeldung zur Prüfung zu entrichten. Bei Rückzug der Anmeldung vor der schriftlichen Prüfung werden 80 Prozent, bei Rückzug vor der mündlichen Prüfung 50 Prozent der Gebühr zurückerstattet."
        }
