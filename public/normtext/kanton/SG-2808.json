      "sha": "c72a751f9e87cf74441745345ecbf2060b1a46a2e105426651f840382ce724a8"
    },
    {
      "id": "kanton/SG/2808/art_20",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "20",
      "artikelLabel": "Art. 20",
      "bloecke": [
        {
          "absatz": null,
          "text": "",
          "items": [
            {
              "marke": "b",
              "text": "Jugendstrafrechtspflege"
            }
          ]
        },
        {
          "absatz": "1",
          "text": "Die Gebühren in der Jugendstrafrechtspflege betragen: 1 Verfügung, Entscheid oder Antrag, wenn keine andere Gebühr festgesetzt ist . . . . . . . . . . . . . . . . . . 50.– bis 1000.– 2 Ausstandsentscheid . . . . . . . . . . . . . . . . . . . . . . . . . . 100.– bis 3000.– 3 Nichtanhandnahmeverfügung . . . . . . . . . . . . . . . . . 50.– bis 1000.– 4 Sistierungsverfügung . . . . . . . . . . . . . . . . . . . . . . . . . 50.– bis 1000.– 5 Einstellungsverfügung . . . . . . . . . . . . . . . . . . . . . . . . 50.– bis 3000.– 6 Strafbefehl . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . 50.– bis 3000.– 7 Anklage oder Schlussbericht . . . . . . . . . . . . . . . . . . . 100.– bis 3000.– 8 Schlussbericht . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . 100.– bis 3000.– 9 Vertretung der Anklage vor Gericht . . . . . . . . . . . . . 100.– bis 6000.– 10 Schriftlicher Antrag im Gerichtsverfahren . . . . . . . 100.– bis 500.– 11 Antrag im Rechtsmittelverfahren . . . . . . . . . . . . . . . 100.– bis 500.– IV. Zusätzliche Gerichts- und Untersuchungskosten"
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "a6344c08e371b801eaaee9a7bbf7e6af3d5c6da541ee70e6e112b561ca845e6b"
    },
    {
      "id": "kanton/SG/2808/art_21",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "21",
      "artikelLabel": "Art. 21",
      "bloecke": [
        {
          "absatz": null,
          "text": "Gerichte und Staatsanwaltschaft"
        },
        {
          "absatz": "1",
          "text": "Der Aufwand des Gerichtes oder der Staatsanwaltschaft wird nach den tatsächlichen Kosten berechnet, wenn er aussergewöhnlich ist, wie bei auswärtiger Beweiserhebung."
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "272dd4c8a95c2ff167a10217ce8c0138e7a45835468cfba31221a163b1d14605"
    },
    {
      "id": "kanton/SG/2808/art_22",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "22",
      "artikelLabel": "Art. 22",
      "bloecke": [
        {
          "absatz": null,
          "text": "Amtliche Verteidigung und Vertretung des Kindes"
        },
        {
          "absatz": "1",
          "text": "Die Kosten für die amtliche Verteidigung , die unentgeltliche Verbeiständung und die Vertretung des Kindes richten sich nach dem Anwaltsgesetz vom 11.November 1993 und der Honorarordnung für Rechtsanwälte und Rechtsagenten vom 22.April 1994 ."
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "3310f49eb4adb077b34e28074cdd69dfc95327e684a01684b3449844c3d82a94"
    },
    {
      "id": "kanton/SG/2808/art_23",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "23",
      "artikelLabel": "Art. 23",
      "bloecke": [
        {
          "absatz": null,
          "text": "Entschädigungen",
          "items": [
            {
              "marke": "a",
              "text": "Zeugen und Auskunftspersonen"
            }
          ]
        },
        {
          "absatz": "1",
          "text": "Zeugen und Auskunftspersonen werden nach Massgabe des ausgewiesenen Verdienstausfalls oder nach Zeitaufwand entschädigt."
        },
        {
          "absatz": "2",
          "text": "Bei Entschädigung nach Zeitaufwand beträgt diese: Fr.",
          "items": [
            {
              "marke": "a",
              "text": "bei einem Zeitaufwand bis vier Stunden . . . . . . . . . . . . . . . . . . . . . . 160.–"
            },
            {
              "marke": "b",
              "text": "bei einem Zeitaufwand über vier Stunden . . . . . . . . . . . . . . . . . . . . . 320.–"
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Für die Entschädigung von ausgewiesenen Spesen wird die Spesenverordnung vom 6.Dezember 2004 sachgemäss angewendet."
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "d1529feb799a50b877f99179047454c02d2145e9dc62e6959ea099f56e59fac8"
    },
    {
      "id": "kanton/SG/2808/art_24",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "24",
      "artikelLabel": "Art. 24",
      "bloecke": [
        {
          "absatz": null,
          "text": "",
          "items": [
            {
              "marke": "b",
              "text": "Sachverständige sowie Übersetzerinnen und Übersetzer"
            }
          ]
        },
        {
          "absatz": "1",
          "text": "Für die Entschädigung von ärztlichen Sachverständigen wird die Verordnung über die Entschädigung der Ärzte für amtliche Verrichtungen vom 10.Januar 1989 sachgemäss angewendet."
        },
        {
          "absatz": "2",
          "text": "Andere Sachverständige sowie Übersetzerinnen und Übersetzer werden nach branchenüblichen Ansätzen entschädigt, soweit kein amtlicher Tarif besteht."
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "a78ff64b1e817378a2c9aa20eb25261f6700f4f367e14bfc65b10e551a10cd56"
    },
    {
      "id": "kanton/SG/2808/art_25",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "25",
      "artikelLabel": "Art. 25",
      "bloecke": [
        {
          "absatz": null,
          "text": "",
          "items": [
            {
              "marke": "c",
              "text": "andere Drittpersonen"
            }
          ]
        },
        {
          "absatz": "1",
          "text": "Anderen Drittpersonen, die auf Anordnung der Gerichte oder der Staatsanwaltschaft am Verfahren mitwirken, erhalten die gleiche Entschädigung wie Zeugen und Auskunftspersonen nach Art.23 dieses Erlasses."
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "5fd65203d46ecebb94ef9e0f199c8cbc0980627ab25ca280793ddabc69734b02"
    },
    {
      "id": "kanton/SG/2808/art_26",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "26",
      "artikelLabel": "Art. 26",
      "bloecke": [
        {
          "absatz": null,
          "text": "Amtliche Veröffentlichungen"
        },
        {
          "absatz": "1",
          "text": "Die Kosten der amtlichen Veröffentlichung werden nach dem Tarif des Publikationsorgans berechnet. V. Kanzleigebühren"
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "08bfe5a89f0cd1d246ca0cb9c25239dd7ee6357b9a2b2d0478ae39bcedf3c12a"
    },
    {
      "id": "kanton/SG/2808/art_27",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "27",
      "artikelLabel": "Art. 27",
      "bloecke": [
        {
          "absatz": null,
          "text": "Grundsatz"
        },
        {
          "absatz": "1",
          "text": "Kanzleigebühren werden erhoben, wenn die entsprechenden Leistungen nicht Bestandteil des ordentlichen Geschäftsgangs eines Verfahrens sind."
        }
      ],
      "stand": "2012-03-01",
