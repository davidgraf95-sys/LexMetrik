    {
      "id": "kanton/SG/2808/art_29",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "29",
      "artikelLabel": "Art. 29",
      "bloecke": [
        {
          "absatz": null,
          "text": "Verzugszins"
        },
        {
          "absatz": "1",
          "text": "Für Kosten nach diesem Erlass, die aufgrund eines rechtskräftigen Urteils oder Entscheids geschuldet sind, ist im Fall einer Betreibung ein Verzugszins von 5 Prozent geschuldet."
        },
        {
          "absatz": "2",
          "text": "Der Verzugszins wird ab dem Zeitpunkt der ersten Mahnung berechnet."
        },
        {
          "absatz": "3",
          "text": "Vorbehalten bleiben abweichende bundesrechtliche Vorschriften. VI. Prüfungs- und Bewilligungsgebühren für Rechtsanwältinnen und Rechtsanwälte, Rechtsagentinnen und Rechtsagenten sowie Notarinnen und Notare"
        }
      ],
      "stand": "2012-03-01",
