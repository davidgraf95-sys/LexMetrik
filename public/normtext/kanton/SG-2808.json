{
  "erzeugt": "2026-06-22",
  "eintraege": [
    {
      "id": "kanton/SG/2808/art_1",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": null,
          "text": "Geltungsbereich"
        },
        {
          "absatz": "1",
          "text": "Dieser Erlass gilt für die amtlichen Kosten , die Gerichtskosten und die Verfahrenskosten vor:",
          "items": [
            {
              "marke": "a",
              "text": "den Gerichten und den von diesen gewählten Behörden;"
            },
            {
              "marke": "b",
              "text": "der Staatsanwaltschaft."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Er regelt die Entschädigung an Verfahrensbeteiligte, die nicht Partei sind, und die Kanzleigebühren."
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "d66dc2950b3aba7c03560a83ddea8b0672988486977f06e2f729be0db180abb6"
    },
    {
      "id": "kanton/SG/2808/art_2",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": null,
          "text": "Kostenvorschüsse und Sicherheitsleistungen"
        },
        {
          "absatz": "1",
          "text": "Vorschüsse und Sicherheitsleistungen werden erhoben, wenn das Gesetz solche vorsieht."
        },
        {
          "absatz": "2",
          "text": "In der Verwaltungsrechtspflege werden bei der Bemessung insbesondere die voraussichtliche Gebühr und die Art des Falls berücksichtigt."
        },
        {
          "absatz": "3",
          "text": "In der Zivil- und Strafrechtspflege werden Vorschüsse und Sicherheitsleistungen nach den Bestimmungen der eidgenössischen Prozessgesetze bemessen."
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "1a447d308d1670595a403c0c7ae2342044b8ae049268197158da15e180c8d24f"
    },
    {
      "id": "kanton/SG/2808/art_3",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": null,
          "text": "Einschreibgebühren im Strafverfahren"
        },
        {
          "absatz": "1",
          "text": "Ergreift die beschuldigte Person im Strafverfahren ein Rechtsmittel , erhebt die Rechtsmittelinstanz eine Einschreibgebühr."
        },
        {
          "absatz": "2",
          "text": "Die Einschreibgebühr beträgt Fr.500.–. II. Entscheidgebühren 1. Allgemeines"
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "99215092d6042c710236ae8dfef218e7a1c9600c45956ae22f09001f234dbf99"
    },
    {
      "id": "kanton/SG/2808/art_4",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": null,
          "text": "Gebührenbemessung"
        },
        {
          "absatz": "1",
          "text": "Mit der Entscheidgebühr wird der Aufwand des Gerichtes und der Staatsanwaltschaft als Pauschale abgegolten. Dies gilt sinngemäss für die Gebühr des Verfahrens vor den Schlichtungsbehörden."
        },
        {
          "absatz": "2",
          "text": "Enthält dieser Erlass einen Mindest- und einen Höchstansatz, werden bei der Gebührenbemessung berücksichtigt:",
          "items": [
            {
              "marke": "a",
              "text": "die Art des Falls;"
            },
            {
              "marke": "b",
              "text": "die finanziellen Interessen der Beteiligten;"
            },
            {
              "marke": "c",
              "text": "die Umtriebe;"
            },
            {
              "marke": "d",
              "text": "die finanziellen Verhältnisse des oder der Kostenpflichtigen;"
            },
            {
              "marke": "e",
              "text": "die Art der Prozessführung der Beteiligten."
            }
          ]
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "7da5e2321f81601165f73e8120e9cac4cc2a79f3e2be2816492147076a240655"
    },
    {
      "id": "kanton/SG/2808/art_5",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": null,
          "text": "Unterschreitung des Ansatzes"
        },
        {
          "absatz": "1",
          "text": "Der nach Massgabe dieses Erlasses anzuwendende Gebührenansatz kann unterschritten werden, wenn dieser ein offensichtliches Missverhältnis zwischen Gebühr und Aufwand des Gerichtes zur Folge hat oder der Aufwand aussergewöhnlich gering ist."
        },
        {
          "absatz": "2",
          "text": "Ist der Aufwand vernachlässigbar gering, kann von einer Gebühr Umgang genommen werden."
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "c49d55ef4aaf881a1e8579bc00d7da2a4d37616a76bc97f3799b563b362bb042"
    },
    {
      "id": "kanton/SG/2808/art_6",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": null,
          "text": "Erhöhung des Ansatzes"
        },
        {
          "absatz": "1",
          "text": "Wenn das finanzielle Interesse, die Umtriebe oder die Schwierigkeiten des Falls aussergewöhnlich sind, kann die Gebühr bis auf das Vierfache erhöht werden. 2. Behörden der Verwaltungsgerichtsbarkeit"
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "258ad50bc59d70ddfdeee3b60985c129b0164dcc591eea37350b31a3947d7be9"
    },
    {
      "id": "kanton/SG/2808/art_7",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": null,
          "text": "Entscheidgebühren"
        },
        {
          "absatz": "1",
          "text": "Die Entscheidgebühren betragen: 1 Verwaltungsrekurskommission und Versicherungsgericht 11 Einzelrichterin oder Einzelrichter; Präsidentin oder Präsident 111 Zwischenentscheid, verfahrensleitende Verfügung, Abschreibungsverfügung und Ähnliches . . . . . . . . . 200.– bis 2000.– 112 Endentscheid . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . 400.– bis 4000.– 12 Abteilung oder Kammer 121 Zwischenentscheid, verfahrensleitende Verfügungen und Ähnliches . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . 300.– bis 3000.– 122 Endentscheid . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . 500.– bis 15000.– 2 Verwaltungsgericht 21 Einzelrichterin oder Einzelrichter; Präsidentin oder Präsident 211 Zwischenentscheid, verfahrensleitende Verfügung, Abschreibungsverfügung und Ähnliches . . . . . . . . . 200.– bis 2000.– 212 Endentscheid . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . 400.– bis 4000.– 22 Gericht 221 Zwischenentscheid, verfahrensleitende Verfügung und Ähnliches . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . 300.– bis 3000.– 222 Endentscheid . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . 500.– bis 15000.– 3 Anwaltskammer 31 Präsidentin oder Präsident 311 Zwischenentscheid, verfahrensleitende Verfügung und Ähnliches . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . 200.– bis 2000.– 312 Endentscheid . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . 400.– bis 4000.– 32 Kammer 321 Zwischenentscheid, verfahrensleitende Verfügung und Ähnliches . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . 300.– bis 3000.– 322 Endentscheid . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . 500.– bis 6000.– 3. Behörden der Zivilgerichtsbarkeit"
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "61f097e88c5c8bc190a0e7cd65f9a60f81b401f8d432f34900275138fd80354b"
    },
    {
      "id": "kanton/SG/2808/art_8",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": null,
          "text": "",
          "items": [
            {
              "marke": "a",
              "text": "Schlichtungsbehörden"
            }
          ]
        },
        {
          "absatz": "1",
          "text": "",
          "tabelle": [
            {
              "beschreibung": "Die Gebühren für Verfahren vor dem Vermittlungsamt und den Schlichtungsstellen, soweit nicht Kostenlosigkeit vorgeschrieben ist , betragen: 1 Erteilung der Klagebewilligung",
              "betrag": "200.– bis 1000.–"
            },
            {
              "beschreibung": "2 Urteilsvorschlag und Entscheid",
              "betrag": "300.– bis 1000.–"
            },
            {
              "beschreibung": "3 Einigung , Säumnis der klagenden Partei und Rückzug des Schlichtungsgesuchs",
              "betrag": "100.– bis 600.–"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die Gebühr kann für besonders aufwendige Verfahren bis zum doppelten Ansatz erhöht werden. Art.6 dieses Erlasses wird nicht angewendet."
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "89624e95d1ccde026277345bd068aac2101785cf62f6268e54c34b8ea8393a66"
    },
    {
      "id": "kanton/SG/2808/art_9",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": null,
          "text": "",
          "items": [
            {
              "marke": "b",
              "text": "Zivilgerichte Grundsätze"
            }
          ]
        },
        {
          "absatz": "1",
          "text": "Die Entscheidgebühr wird für Zwischen- und Endentscheide erhoben. Vorbehalten bleiben Verfahren, in denen Kostenlosigkeit vorgeschrieben ist."
        },
        {
          "absatz": "2",
          "text": "Die Kosten für vorsorgliche Massnahmen können separat oder zusammen mit den Kosten der Hauptsache erhoben werden."
        },
        {
          "absatz": "3",
          "text": "Der Aufwand für prozessleitende Verfügungen wird in der Regel mit der Entscheidgebühr des Endentscheids abgegolten."
        },
        {
          "absatz": "4",
          "text": "Eine separate Entscheidgebühr kann namentlich für die folgenden prozessleitenden Verfügungen erhoben werden:",
          "items": [
            {
              "marke": "a",
              "text": "Ausstand;"
            },
            {
              "marke": "b",
              "text": "Sistierung;"
            },
            {
              "marke": "c",
              "text": "Zulassung der Nebenintervention;"
            },
            {
              "marke": "d",
              "text": "Zulassung der Streitverkündungsklage;"
            },
            {
              "marke": "e",
              "text": "Sicherheitsleistung für die Parteientschädigung;"
            },
            {
              "marke": "f",
              "text": "Verpflichtung zur Nachzahlung;"
            },
            {
              "marke": "g",
              "text": "Überweisung bei zusammenhängenden Verfahren;"
            },
            {
              "marke": "h",
              "text": "Wiederherstellung;"
            },
            {
              "marke": "i",
              "text": "Verweigerung der Mitwirkung durch Drittpersonen;"
            },
            {
              "marke": "j",
              "text": "Abschreibung des Verfahrens."
            }
          ]
        },
        {
          "absatz": "5",
          "text": "Bei Entscheiden über Revisionsgesuche, Entscheiden des Einzelrichters für Schiedsgerichtssachen sowie des Kantonsgerichtes betreffend Hinterlegung des Schiedsspruchs und Bescheinigung dessen Vollstreckbarkeit gilt der Tarif für prozessleitende Verfügungen."
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "7fe275b15abaeed93e922552ac0c86e50d2535c939ba098dd4db4c5bbd35c154"
    },
    {
      "id": "kanton/SG/2808/art_10",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": null,
          "text": "Entscheidgebühren"
        },
        {
          "absatz": "1",
          "text": "",
          "tabelle": [
            {
              "beschreibung": "Die Entscheidgebühren betragen: 1 Kreisgericht 11 Einzelrichterin oder Einzelrichter; Präsidentin oder Präsident 111 Endentscheide und Zwischenentscheide",
              "betrag": "500.– bis 5000.–"
            },
            {
              "beschreibung": "112 Prozessleitende Verfügungen und Summarentscheide 200.– bis 3000.– 12 Kollegialgericht 121 Endentscheide und Zwischenentscheide",
              "betrag": "500.– bis 6000.–"
            },
            {
              "beschreibung": "122 Prozessleitende Verfügungen (Kollegialgericht) . . . 300.– bis 3000.– 123 Prozessleitende Verfügungen und vorsorgliche Massnahmen (verfahrensleitende Richterin oder verfahrensleitender Richter)",
              "betrag": "200.– bis 2000.–"
            },
            {
              "beschreibung": "2 Kantonsgericht 21 Einzelrichterin oder Einzelrichter; Präsidentin oder Präsident 211 Endentscheide und Zwischenentscheide",
              "betrag": "300.– bis 5000.–"
            },
            {
              "beschreibung": "212 Prozessleitende Verfügungen und vorsorgliche Massnahmen",
              "betrag": "200.– bis 3000.–"
            },
            {
              "beschreibung": "22 Kammer 221 Endentscheide und Zwischenentscheide",
              "betrag": "800.– bis 8000.–"
            },
            {
              "beschreibung": "222 Prozessleitende Verfügungen (Kammer)",
              "betrag": "400.– bis 4000.–"
            },
            {
              "beschreibung": "223 Prozessleitende Verfügungen und vorsorgliche Massnahmen (verfahrensleitende Richterin oder verfahrensleitender Richter)",
              "betrag": "200.– bis 2000.–"
            },
            {
              "beschreibung": "3 Handelsgericht 31 Präsidentin oder Präsident; prozessleitende Richterin oder prozessleitender Richter 311 Prozessleitende Verfügungen und vorsorgliche Massnahmen",
              "betrag": "300.– bis 3000.–"
            },
            {
              "beschreibung": "312 Entscheide nach Art.11 Abs.2 EG-ZPO",
              "betrag": "300.– bis 3000.–"
            },
            {
              "beschreibung": "32 Gericht 321 Endentscheide und Zwischenentscheide",
              "betrag": "1000.– bis 15000.–"
            },
            {
              "beschreibung": "322 Prozessleitende Verfügungen",
              "betrag": "400.– bis 4000.–"
            }
          ]
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "93796719415ca2d37041026544b85c9ad1579f5962cdf5d1b46ff9debe193e62"
    },
    {
      "id": "kanton/SG/2808/art_11",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": null,
          "text": "Streitwert"
        },
        {
          "absatz": "1",
          "text": "Die Entscheidgebühren für Zwischen- und Endentscheide werden abhängig vom Streitwert wie folgt erhöht:",
          "items": [
            {
              "marke": "a",
              "text": "bei einem Streitwert über Fr.50000.– bis Fr.100000.– . . . . . . . . . . . . . . . . . . auf höchstens 200 Prozent"
            },
            {
              "marke": "b",
              "text": "bei einem Streitwert über Fr.100000.– bis Fr.250000.– . . . . . . . . . . . . . . . . . auf höchstens 300 Prozent"
            },
            {
              "marke": "c",
              "text": "bei einem Streitwert von je weiteren Fr.250000.– . . . . . . . . . . . . . . . . . . . . . je weitere 100 Prozent"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Eine weitere Erhöhung nach Art.6 kann nur noch erfolgen, wenn die Umtriebe oder die Schwierigkeiten des Falls aussergewöhnlich sind."
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "4e5a226007dc171b71871a79b6564d3c5f1c49d4eb9cce789eeb5ff8bc3b2951"
    },
    {
      "id": "kanton/SG/2808/art_12",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": null,
          "text": "Begründung"
        },
        {
          "absatz": "1",
          "text": "Soweit eine Eröffnung ohne Begründung erfolgt, enthält der Entscheid je einen Gebührenansatz für die begründete und nicht begründete Ausfertigung. Der Ansatz für den nicht begründeten Entscheid ist ein Drittel tiefer."
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "456c7cfdc53f4a144608ab2873deff1ddab24950454a2cfc0904c156e79e1ca6"
    },
    {
      "id": "kanton/SG/2808/art_13",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": null,
          "text": "Abschreibung"
        },
        {
          "absatz": "1",
          "text": "Bei Abschreibung des Verfahrens kann die Gebühr bis zum Ansatz für den Entscheid in der betreffenden Sache erhöht werden. 4. Behörden der Strafgerichtsbarkeit"
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
