      "sha": "b67ecce02ced02fd64a106906862afd748e5db2059cb944c69dc226da3aad372"
    },
    {
      "id": "kanton/SG/2808/art_14",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": null,
          "text": "Grundsätze"
        },
        {
          "absatz": "1",
          "text": "Die Entscheidgebühr wird für instanzabschliessende schriftliche Entscheide erhoben."
        },
        {
          "absatz": "2",
          "text": "Der Aufwand des Gerichtes für verfahrensleitende Verfügungen und Beschlüsse wird in der Regel mit der Gebühr für den instanzabschliessenden Entscheid abgegolten."
        },
        {
          "absatz": "3",
          "text": "Eine separate Gebühr kann insbesondere erhoben werden für verfahrensleitende Verfügungen und Beschlüsse über:",
          "items": [
            {
              "marke": "a",
              "text": "Wiederherstellung;"
            },
            {
              "marke": "b",
              "text": "Sicherheitsleistung;"
            },
            {
              "marke": "c",
              "text": "Sistierung."
            }
          ]
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
