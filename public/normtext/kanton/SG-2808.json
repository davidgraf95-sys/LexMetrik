    {
      "id": "kanton/SG/2808/art_16",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "16",
      "artikelLabel": "Art. 16",
      "bloecke": [
        {
          "absatz": null,
          "text": "Zivilklage"
        },
        {
          "absatz": "1",
          "text": "Die Gebühr wird bei der Beurteilung einer Zivilklage im Strafurteil auf höchstens den doppelten Ansatz erhöht."
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "9ec040ddd072a74c32a88db37e9a859e181ee07f8fd44f82d2263c93dd5c1e02"
    },
    {
      "id": "kanton/SG/2808/art_17",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "17",
      "artikelLabel": "Art. 17",
      "bloecke": [
        {
          "absatz": null,
          "text": "Begründung"
        },
        {
          "absatz": "1",
          "text": "Soweit eine Eröffnung ohne Begründung erfolgt, enthält der Entscheid je einen Gebührenansatz für die begründete und nicht begründete Ausfertigung. Der Ansatz für den nicht begründeten Entscheid ist ein Drittel tiefer."
        },
        {
          "absatz": "2",
          "text": "Bei Entscheiden des Kreis- oder Kantonsgerichtes, die von Gesetzes wegen zu begründen sind, wird der Gebührenansatz um einen Drittel ermässigt, wenn die Parteien und andere legitimierte Verfahrensbeteiligte nach Eröffnung des Dispositivs auf ein Rechtsmittel verzichten. III. Staatsanwaltschaft"
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
      "fassungsToken": "5cef57044150f72206cbdbdc73bfd10aa8f41fd2c66fe9ab9cc4ddab3b7f0f77",
      "sha": "577124bc7cf25d07f040ae314360c08b68744b58df13ae1ad733950226480825"
    },
    {
      "id": "kanton/SG/2808/art_18",
      "ebene": "kanton",
      "quelle": "SG",
      "erlass": "Gerichtskostenverordnung (GKV) (sGS 941.12)",
      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": null,
          "text": "Grundsätze"
        },
        {
          "absatz": "1",
          "text": "Gebühren werden erhoben für:",
          "items": [
            {
              "marke": "a",
              "text": "schriftlich eröffnete Verfügungen und Entscheide;"
            },
            {
              "marke": "b",
              "text": "schriftliche Anträge, soweit sie nicht Beschwerden gegen eigene Entscheide betreffen;"
            },
            {
              "marke": "c",
              "text": "mündliche Vertretung der Anklage."
            }
          ]
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
      "abgerufen": "2026-06-22",
