              "marke": "a",
              "text": "Erwachsenenstrafrechtspflege"
            }
          ]
        },
        {
          "absatz": "1",
          "text": "",
          "tabelle": [
            {
              "beschreibung": "Die Gebühren in der Erwachsenenstrafrechtspflege betragen: 1 Verfügung, Entscheid oder Antrag, wenn keine andere Gebühr festgesetzt ist",
              "betrag": "50.– bis 1000.–"
            },
            {
              "beschreibung": "2 Ausstandsentscheid",
              "betrag": "300.– bis 3000.–"
            },
            {
              "beschreibung": "3 Nichtanhandnahmeverfügung",
              "betrag": "100.– bis 1000.–"
            },
            {
              "beschreibung": "4 Sistierungsverfügung",
              "betrag": "100.– bis 1000.–"
            },
            {
              "beschreibung": "5 Einstellungsverfügung",
              "betrag": "100.– bis 3000.–"
            },
            {
              "beschreibung": "6 Strafbefehl",
              "betrag": "100.– bis 3000.–"
            },
            {
              "beschreibung": "7 Anklage",
              "betrag": "300.– bis 3000.–"
            },
            {
              "beschreibung": "8 Schlussbericht",
              "betrag": "300.– bis 3000.–"
            },
            {
              "beschreibung": "9 Vertretung der Anklage vor Gericht",
              "betrag": "300.– bis 6000.–"
            },
            {
              "beschreibung": "10 Schriftlicher Antrag im Gerichtsverfahren",
              "betrag": "300.– bis 1000.–"
            },
            {
              "beschreibung": "11 Antrag im Rechtsmittelverfahren",
              "betrag": "300.– bis 1000.–"
            }
          ]
        }
      ],
      "stand": "2012-03-01",
      "quelleUrl": "https://www.gesetzessammlung.sg.ch/api/de/versions/2808/pdf_file",
