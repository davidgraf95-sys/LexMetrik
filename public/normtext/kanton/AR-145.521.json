{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/145.521/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Anwaltsprüfung (145.521)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Anwaltsprüfung soll ergeben, ob die für die Bewilligung zur Berufsausübung erforderlichen wissenschaftlichen Kenntnisse und praktischen Fähigkeiten vorhanden sind."
        }
      ],
      "stand": "2005-07-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.521",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93c8a5b99aaa26f7c6331c47f02f96d7",
      "sha": "6ed8276d100b5effa982fed32b0c879e6afcf3e7b7b9c3518a6622d5c1e1774d"
    },
    {
      "id": "kanton/AR/145.521/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Anwaltsprüfung (145.521)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Anwaltsprüfung umfasst einen schriftlichen und einen mündlichen Teil."
        },
        {
          "absatz": "2",
          "text": "Sie erstreckt sich auf folgende Gebiete des Bundesrechts und des kantonalen Rechts:",
          "items": [
            {
              "marke": "a",
              "text": "Staatsrecht sowie Verwaltungsrecht mit Schwergewicht auf Abgaberecht, Bau-, Planungs-, Enteignungs- und Strassenrecht, Grundzüge des Sozialversicherungsrechts und dazugehöriges Verfahrensrecht."
            },
            {
              "marke": "b",
              "text": "Einleitungsartikel ZGB, Personenrecht, Familienrecht, Erbrecht, Sachenrecht und Nebengesetze dazu."
            },
            {
              "marke": "c",
              "text": "Allgemeine Bestimmungen des Obligationenrechts, Vertragsverhältnisse, Gesellschaftsrecht, Wertpapierrecht, Grundzüge des Immaterialgüterrechts und Nebengesetze zum OR."
            },
            {
              "marke": "d",
              "text": "Zivilprozessrecht, Schuldbetreibungs- und Konkursrecht, Anwaltsrecht."
            },
            {
              "marke": "e",
              "text": "Straf- und Strafprozessrecht."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Internationales Privatrecht wird im Rahmen von Abs. 2 lit. b) bis d) geprüft."
        }
      ],
      "stand": "2005-07-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.521",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93c8a5b99aaa26f7c6331c47f02f96d7",
      "sha": "7bab8eeda460a736322ee2ab0b1418dd701077532c602a5e81dd5faa3088fafc"
    },
    {
      "id": "kanton/AR/145.521/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Anwaltsprüfung (145.521)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die schriftliche Prüfung dauert höchstens neun Stunden und findet in Klausur statt."
        },
        {
          "absatz": "2",
          "text": "Die Prüfungskommission bestimmt die Prüfungsaufgabe. Diese umfasst einen oder mehrere Rechtsfälle zur Ausarbeitung eines Gutachtens, Urteils, Vertrages, Plädoyers oder einer Rechtsschrift."
        },
        {
          "absatz": "3",
          "text": "Für die Prüfung werden die eidgenössische und die kantonale Gesetzessammlung sowie Literatur nach Ermessen der Prüfungskommission zur Verfügung gestellt."
        }
      ],
      "stand": "2005-07-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.521",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93c8a5b99aaa26f7c6331c47f02f96d7",
      "sha": "bd07cd05dd527cbaff074bb8b208a8e91ab1be8ad55236c8356a9bf7de0ee7fc"
    },
    {
      "id": "kanton/AR/145.521/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Anwaltsprüfung (145.521)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Aufgrund der schriftlichen Prüfung entscheidet die Prüfungskommission über die Zulassung zur mündlichen Prüfung. Ein Mitglied referiert über die Examensarbeit und stellt Antrag."
        },
        {
          "absatz": "2",
          "text": "Der Entscheid der Kommission wird schriftlich mitgeteilt."
        }
      ],
      "stand": "2005-07-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.521",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93c8a5b99aaa26f7c6331c47f02f96d7",
      "sha": "fccafd8cb9b3f67b9a902efcf3a8255706c464019f7d9b33265ba5c64aeee441"
    },
    {
      "id": "kanton/AR/145.521/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Anwaltsprüfung (145.521)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zur mündlichen Prüfung wird nur zugelassen, wer die schriftliche bestanden hat."
        }
      ],
      "stand": "2005-07-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.521",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93c8a5b99aaa26f7c6331c47f02f96d7",
      "sha": "e683ecb4cbaea2879eefcf14bc17a04ef75a1a1a6c4da03ced23807046b3cd3a"
    },
    {
      "id": "kanton/AR/145.521/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Anwaltsprüfung (145.521)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die mündliche Prüfung dauert zwei Stunden."
        },
        {
          "absatz": "2",
          "text": "Die prüfenden Mitglieder sind während der ganzen Prüfung anwesend."
        }
      ],
      "stand": "2005-07-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.521",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93c8a5b99aaa26f7c6331c47f02f96d7",
      "sha": "dc818c6046e0ffe83323e7aa2107a86a23295e91d7bcb185c0c05b0b9a5c8019"
    },
    {
      "id": "kanton/AR/145.521/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Anwaltsprüfung (145.521)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Eine Prüfung wird von der Kommission als bestanden oder nicht bestanden erklärt. Noten oder Qualifikationen werden nicht erteilt. Der Beschluss wird auf Verlangen mündlich begründet."
        },
        {
          "absatz": "2",
          "text": "Eine freiwillig abgebrochene Prüfung gilt als nicht bestanden."
        },
        {
          "absatz": "3",
          "text": "Die mündliche und schriftliche Prüfung können höchstens je zweimal wiederholt werden."
        }
      ],
      "stand": "2005-07-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.521",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93c8a5b99aaa26f7c6331c47f02f96d7",
      "sha": "4b261374acc6d269a8645948f94691b8f44234105c535d4e858d4d4ab3cb77e3"
    },
    {
      "id": "kanton/AR/145.521/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Anwaltsprüfung (145.521)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Nach Beendigung der mündlichen Prüfung setzt die Prüfungskommission den Antrag an das Obergericht fest und eröffnet ihn mündlich."
        },
        {
          "absatz": "2",
          "text": "Die Erteilung der Bewilligung setzt voraus, dass sowohl die schriftliche als auch die mündliche Prüfung als bestanden erklärt wurden."
        }
      ],
      "stand": "2005-07-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.521",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93c8a5b99aaa26f7c6331c47f02f96d7",
      "sha": "732d9771b195697fcf3bab40e3496aa60332c0d665117835c0ad6b4e3a19a72b"
    },
    {
      "id": "kanton/AR/145.521/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Anwaltsprüfung (145.521)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Hat ein Kandidat oder eine Kandidatin die schriftliche oder die mündliche Prüfung trotz den möglichen Wiederholungen nicht bestanden, so beantragt die Prüfungskommission dem Obergericht, es sei eine Frist zu bestimmen, innerhalb welcher eine neue Anmeldung zur Prüfung nicht zulässig ist."
        }
      ],
      "stand": "2005-07-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.521",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93c8a5b99aaa26f7c6331c47f02f96d7",
      "sha": "d41ef08063f60b4bfb459de26b8ed2601f750aa3392811666fc3ec453bba9fdd"
    },
    {
      "id": "kanton/AR/145.521/art_9_a",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Anwaltsprüfung (145.521)",
      "artikel": "9_a",
      "artikelLabel": "Art. 9a",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Entschädigung an die Mitglieder der Prüfungskommission wird vom Regierungsrat nach Antrag des Obergerichtes festgesetzt."
        }
      ],
      "stand": "2005-07-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.521",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93c8a5b99aaa26f7c6331c47f02f96d7",
      "sha": "2ebd52d6939402e2b6fee7563e424fe48990239bf1fc5058ee7e61efda944c8e"
    },
    {
      "id": "kanton/AR/145.521/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Anwaltsprüfung (145.521)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung ersetzt die Verordnung über die Prüfung der Rechtsanwälte vom 24. Juni 1958 und tritt sofort in Kraft."
        },
        {
          "absatz": "2",
          "text": "Wer zum Zeitpunkt des Inkrafttretens dieser Verordnung vom Obergericht zur Anwaltsprüfung zugelassen ist, kann wählen, ob die Prüfung nach den alten oder den neuen Bestimmungen erfolgen soll."
        }
      ],
      "stand": "2005-07-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.521",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93c8a5b99aaa26f7c6331c47f02f96d7",
      "sha": "b930f2a3cbade2b2fca6982a439ebf8f9d49f895f8c9b499149e433b31962065"
    }
  ]
}