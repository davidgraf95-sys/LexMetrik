{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/365.500/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Tierschutzverordnung (365.500)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Gesundheitsdepartement ist für die Aufsicht über den Vollzug der Tierschutzgesetzgebung zuständig, soweit nicht eine andere Behörde bezeichnet ist."
        },
        {
          "absatz": "2",
          "text": "Es erlässt ein Reglement über das Halten gefährlicher Tiere in Absprache mit dem Justiz- und Sicherheitsdepartement hinsichtlich der Sicherheitsaspekte."
        }
      ],
      "stand": "2024-04-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/365.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2f8807ba103b27eb3099d1e206f3f6b6",
      "sha": "1f6d613bf1da56234444874b81a0c081bfe8354d5057c0feabdb9b810426893e"
    },
    {
      "id": "kanton/BS/365.500/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Tierschutzverordnung (365.500)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Kantonale Veterinäramt ist die kantonale Fachstelle gemäss Art. 33 TSchG. Es vollzieht die Tierschutzgesetzgebung, soweit nichts anderes bestimmt ist."
        },
        {
          "absatz": "2",
          "text": "Es bestimmt eine Meldestelle für gefundene Tiere gemäss Art. 720a ZGB."
        }
      ],
      "stand": "2024-04-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/365.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2f8807ba103b27eb3099d1e206f3f6b6",
      "sha": "c13fc98c070f5a9618e44b4df289668dbf9828c4dfb0f8dcb6f9556695abaf30"
    },
    {
      "id": "kanton/BS/365.500/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Tierschutzverordnung (365.500)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gemeinden sind in ihrem Bereich zur Mithilfe beim Vollzug der Tierschutzgesetzgebung verpflichtet."
        }
      ],
      "stand": "2024-04-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/365.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2f8807ba103b27eb3099d1e206f3f6b6",
      "sha": "41c93d63d6657cd1760bb94b80d8c99cc30a44495fe1c3b05e70664d610a5fc0"
    },
    {
      "id": "kanton/BS/365.500/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Tierschutzverordnung (365.500)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kantonspolizei leistet dem Kantonalen Veterinäramt die nötige Amts- und Vollzugshilfe."
        },
        {
          "absatz": "2",
          "text": "Sie ist neben dem Kantonalen Veterinäramt zuständig für die Verfolgung von Widerhandlungen gegen die Tierschutzgesetzgebung."
        },
        {
          "absatz": "3",
          "text": "…"
        },
        {
          "absatz": "4",
          "text": "Die Einzelheiten der Zusammenarbeit zwischen der Kantonspolizei und dem Kantonalen Veterinäramt werden in einer Vereinbarung geregelt."
        }
      ],
      "stand": "2024-04-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/365.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2f8807ba103b27eb3099d1e206f3f6b6",
      "sha": "d96bbdea0da4bc3276b5f2335971c40c6771e49bda8994ab001fc88b516b327d"
    },
    {
      "id": "kanton/BS/365.500/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Tierschutzverordnung (365.500)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat setzt eine Tierversuchskommission ein. Fachpersonen der Tierschutzorganisationen, der versuchsdurchführenden Institute und Laboratorien sowie der Universität Basel sind darin angemessen vertreten."
        },
        {
          "absatz": "2",
          "text": "Der Regierungsrat wählt die Mitglieder der Kommission und bestimmt deren Präsidentin oder Präsidenten."
        },
        {
          "absatz": "3",
          "text": "Die Tierversuchskommission vollzieht die ihr durch die eidgenössische Tierschutzgesetzgebung zugewiesenen Aufgaben."
        },
        {
          "absatz": "4",
          "text": "Das Gesundheitsdepartement erlässt ein Reglement, das die Aufgaben der Kommission näher umschreibt und deren Geschäftsgang regelt. Das Sekretariat der Kommission wird vom Kantonalen Veterinäramt geführt."
        },
        {
          "absatz": "5",
          "text": "Das Gesundheitsdepartement kann mit anderen Kantonen Vereinbarungen über die Einsetzung einer gemeinsamen Tierversuchskommission abschliessen."
        }
      ],
      "stand": "2024-04-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/365.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2f8807ba103b27eb3099d1e206f3f6b6",
      "sha": "3ed6b27707f3d6c49163fa4865378b5cb057d3bfadd07d6d6cc15dd4028eaba3"
    },
    {
      "id": "kanton/BS/365.500/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Tierschutzverordnung (365.500)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Kantonale Veterinäramt prüft eingegangene Gesuche auf Vollständigkeit und fordert gegebenenfalls ergänzende Informationen ein."
        },
        {
          "absatz": "2",
          "text": "Es unterbreitet Gesuche für belastende Tierversuche der Tierversuchskommission."
        },
        {
          "absatz": "3",
          "text": "Bewilligungen werden vom Kantonalen Veterinäramt in der Regel innerhalb von drei Monaten erteilt."
        }
      ],
      "stand": "2024-04-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/365.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2f8807ba103b27eb3099d1e206f3f6b6",
      "sha": "7bb3ffe58346e7b09a052853b59d6fbe7ccfb6295d1fb1fd04f290da80796016"
    },
    {
      "id": "kanton/BS/365.500/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Tierschutzverordnung (365.500)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Kantonale Veterinäramt kontrolliert Versuchstierhaltungen und die Durchführung von Tierversuchen; die Mitglieder der Tierversuchskommission werden beigezogen."
        },
        {
          "absatz": "2",
          "text": "Die Kontrollen erfolgen in der Regel unangemeldet."
        }
      ],
      "stand": "2024-04-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/365.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2f8807ba103b27eb3099d1e206f3f6b6",
      "sha": "482d1d3ddc32b4043e3bb93248422319157f52a34fd5bfa8606f453743461904"
    },
    {
      "id": "kanton/BS/365.500/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Tierschutzverordnung (365.500)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Kantonale Veterinäramt kann für Teilaufgaben des Vollzugs geeignete Stellen oder Sachverständige beiziehen."
        }
      ],
      "stand": "2024-04-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/365.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2f8807ba103b27eb3099d1e206f3f6b6",
      "sha": "b38a49a0ddab5a0c671e075be61882743232abc23b9457a363eb7fb863f023b7"
    },
    {
      "id": "kanton/BS/365.500/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Tierschutzverordnung (365.500)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Bau- und Verkehrsdepartement unterbreitet Baugesuche, welche Tierhaltungen betreffen, dem Kantonalen Veterinäramt zur Stellungnahme."
        }
      ],
      "stand": "2024-04-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/365.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2f8807ba103b27eb3099d1e206f3f6b6",
      "sha": "d352b12534c95ce7a6f37ab729d3eba7a4903f51bd3b3f01e0ce1790b8b9f6ca"
    },
    {
      "id": "kanton/BS/365.500/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Tierschutzverordnung (365.500)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Kantonale Veterinäramt überwacht die Einhaltung der Tierschutzgesetzgebung in Schlachtbetrieben im Rahmen der Schlachttier- und Fleischuntersuchung."
        }
      ],
      "stand": "2024-04-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/365.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2f8807ba103b27eb3099d1e206f3f6b6",
      "sha": "3e14fb2e56fca238186856881cf82372a97f439ef0e89c18b856c5468d5b8a42"
    },
    {
      "id": "kanton/BS/365.500/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Tierschutzverordnung (365.500)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Beschwerdeverfahren gegenüber Verfügungen der Vollzugsorgane richtet sich nach dem Gesetz betreffend die Organisation des Regierungsrates und der Verwaltung des Kantons Basel-Stadt vom 22. April 1976."
        }
      ],
      "stand": "2024-04-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/365.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2f8807ba103b27eb3099d1e206f3f6b6",
      "sha": "65d8692c97588fbe94ce827ddf1156bf305db4eef8cb68368b28e01f321a602d"
    },
    {
      "id": "kanton/BS/365.500/art_12",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Tierschutzverordnung (365.500)",
      "artikel": "12",
      "artikelLabel": "§ 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kantonspolizei sowie die übrigen Vollzugsorgane melden dem Kantonalen Veterinäramt Verstösse gegen die Tierschutzgesetzgebung."
        },
        {
          "absatz": "2",
          "text": "Die urteilende Behörde stellt Strafurteile, Strafbefehle und Einstellungsverfügungen betreffend Widerhandlungen gegen die Tierschutzgesetzgebung dem Kantonalen Veterinäramt zu, sobald sie in Rechtskraft erwachsen sind."
        }
      ],
      "stand": "2024-04-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/365.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2f8807ba103b27eb3099d1e206f3f6b6",
      "sha": "a5fb8aefeb9f373682281a7b90763848eec47c8283bbbb9372e286db58487bf2"
    }
  ]
}