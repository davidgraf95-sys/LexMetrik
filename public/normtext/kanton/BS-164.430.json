      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung regelt die Gewährung von Lohnnebenleistungen an die Mitarbeitenden des Kan-tons Basel-Stadt."
        }
      ],
      "stand": "2025-06-26",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/164.430",
      "abgerufen": "2026-06-23",
