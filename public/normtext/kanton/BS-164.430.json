      "sha": "1f22cbb80507292136b453169966e6e85dad3e806647c78ef2ca5d7204d168f8"
    },
    {
      "id": "kanton/BS/164.430/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "LNV (164.430)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Verantwortlich für die Evaluation der Anspruchsberechtigungen gemäss dieser Verordnung sind die HR-Leitungen der Departemente."
        }
      ],
      "stand": "2025-06-26",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/164.430",
      "abgerufen": "2026-06-23",
      "fassungsToken": "fc96b6c3053d6edf54ac068e524fffe1",
      "sha": "d718b31906e3f61ac0f37d119216ef4deed1725a56c5661dc7f77566ccfb73bd"
    },
    {
      "id": "kanton/BS/164.430/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "LNV (164.430)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Mitarbeitenden können unter folgenden Voraussetzungen das U-Abo des Tarifverbunds Nord-westschweiz (TNW) als Jobticket erwerben:",
          "items": [
            {
              "marke": "a",
              "text": "unbefristetes oder befristetes Arbeitsverhältnis von mindestens sechs Monaten;"
            },
            {
              "marke": "b",
              "text": "ungekündigtes Arbeitsverhältnis."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Das Jobticket kann als Jahres- oder Monatsabonnement erworben werden."
        }
      ],
      "stand": "2025-06-26",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/164.430",
      "abgerufen": "2026-06-23",
      "fassungsToken": "fc96b6c3053d6edf54ac068e524fffe1",
      "sha": "6398cf425ee1d5bb808dea5dd13f7523fe4a3bc7a71c9a796549369fbd992f79"
    },
    {
      "id": "kanton/BS/164.430/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "LNV (164.430)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Lernenden und die Praktikantinnen und Praktikanten in der beruflichen Grundbildung haben nach dem Erwerb eines U-Abos des Tarifverbunds Nordwestschweiz als Jahresabonnement einen Rückerstattungsanspruch in Höhe des Preises des für sie günstigsten nicht übertragbaren Abonnements."
        }
      ],
      "stand": "2025-06-26",
