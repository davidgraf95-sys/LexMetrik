{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/BeE 890.510/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfeordnung (BeE 890.510)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "titel": "Sozialhilfeleistungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gemeinde gewährt bedürftigen Einwohnerinnen und Einwohnern von Bettingen unentgeltliche Beratung und wirtschaftliche Hilfe nach Massgabe des übergeordneten Rechts."
        }
      ],
      "stand": "2017-05-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 890.510",
      "abgerufen": "2026-06-23",
      "fassungsToken": "811e66bfe417ae34cf8276088a736045",
      "sha": "6e3ad0efd605e2e1944f69ec643ddc6d1a9ce88a6a31adda84fb4a8b15ec8c73"
    },
    {
      "id": "kanton/BS/BeE 890.510/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfeordnung (BeE 890.510)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Gegenstand",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Aufgaben der öffentlichen Sozialhilfe werden von der Einwohnergemeinde Bettingen im Rahmen des Zusammenarbeitsvertrags betreffend «Leistungserbringung im Bereich Sozialhilfe» mit der Gemeinde Riehen wahrgenommen."
        }
      ],
      "stand": "2017-05-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 890.510",
      "abgerufen": "2026-06-23",
      "fassungsToken": "811e66bfe417ae34cf8276088a736045",
      "sha": "fe37ee6761277553a799f1a0ef5e04e92ffba607f4d55c79da7d01c8ce7685a1"
    },
    {
      "id": "kanton/BS/BeE 890.510/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfeordnung (BeE 890.510)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Rechtsschutz",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gegen Verfügungen der Sozialhilfestelle kann Rekurs an den Gemeinderat Bettingen ergriffen werden. Der Rekurs ist innert 10 Tagen seit Eröffnung bei der Sozialhilfestelle Riehen anzumelden. Innert 30 Tagen, vom gleichen Zeitpunkt an gerechnet, ist die Rekursbegründung einzureichen. Diese hat die Anträge der Rekurrentin oder des Rekurrenten und deren Begründung mit Angabe der Beweismittel zu enthalten."
        },
        {
          "absatz": "2",
          "text": "Gegen Verfügungen und Entscheide des Gemeinderats kann gemäss den kantonalen Bestimmungen Rekurs an den Regierungsrat ergriffen werden."
        }
      ],
      "stand": "2017-05-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 890.510",
      "abgerufen": "2026-06-23",
      "fassungsToken": "811e66bfe417ae34cf8276088a736045",
      "sha": "ec206772b51fd1590045382c8a73f62bc6a1448c7a5d7f287688dcf3b84d29c0"
    },
    {
      "id": "kanton/BS/BeE 890.510/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfeordnung (BeE 890.510)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Entscheid",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Gemeinderat Bettingen holt in der Regel vor seinem Entscheid die Stellungnahme des Sozialhilfebeirats Riehen ein. Der Entscheid wird schriftlich eröffnet."
        }
      ],
      "stand": "2017-05-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 890.510",
      "abgerufen": "2026-06-23",
      "fassungsToken": "811e66bfe417ae34cf8276088a736045",
      "sha": "1f6ec320aee55b3e1afe696581e0d090083759261999c2eb5b48a46af5d222d5"
    },
    {
