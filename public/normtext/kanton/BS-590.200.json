    {
      "id": "kanton/BS/590.200/art_1_a",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die von der Feuerwehr zu erhebenden Gebühren, FWGeV (590.200)",
      "artikel": "1_a",
      "artikelLabel": "§ 1a",
      "titel": "Sport- und Konzertveranstaltungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Leistungen der Feuerwehr im Zusammenhang mit Sport- und Konzertveranstaltungen werden nach Massgabe von § 18 Abs. 1 Ziff. 7 der Verordnung betreffend die Kantonspolizei des Kantons Basel-Stadt (Polizeiverordnung, PolV) vom 3. Juni 1997 in Rechnung gestellt."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b3d86fa3ef105c59b512b4a93d16ca7e",
      "sha": "91a914f569bd2ea08e6497a645f81fd314cf0d70aec52b0c6acaa5259f7eae06"
    },
    {
      "id": "kanton/BS/590.200/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die von der Feuerwehr zu erhebenden Gebühren, FWGeV (590.200)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Gebührenbefreiung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für folgende Hilfe- und Dienstleistungen werden gestützt auf § 4 Abs. 5 des Gesetzes keine Gebühren erhoben:",
          "items": [
            {
              "marke": "1",
              "text": "Bewässerung von öffentlichen Grünanlagen durch die Milizfeuerwehr ab Gefahrenstufe 5 im Bereich Wald (sehr grosse Waldbrandgefahr)"
            },
            {
              "marke": "2",
              "text": "Hilfeleistungen im Zoologischen Garten oder im Tierpark Lange Erlen"
            },
            {
              "marke": "3",
              "text": "Hilfeleistungen bei gemeinnützigen Anlässen"
            },
            {
              "marke": "4",
              "text": "Transporte für Museen des Kantons Basel-Stadt"
            }
          ]
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b3d86fa3ef105c59b512b4a93d16ca7e",
      "sha": "35fcc4e0d299cb0ccb9dc437b17b3793e90da43b5abe98315bde721cbcac7988"
    },
    {
      "id": "kanton/BS/590.200/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die von der Feuerwehr zu erhebenden Gebühren, FWGeV (590.200)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Kaution",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Feuerwehr kann eine Kaution im Betrag der mutmasslich zu erwartenden Gebührenhöhe erheben, wenn die Bezahlung der Gebühren als nicht gesichert erscheint oder wenn die gebührenpflichtige Person keinen Wohnsitz in der Schweiz hat."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b3d86fa3ef105c59b512b4a93d16ca7e",
      "sha": "558b846a16013ffb4f35b796e57549b2a5d93a4c0c030577e5144f162f17f262"
    },
    {
      "id": "kanton/BS/590.200/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die von der Feuerwehr zu erhebenden Gebühren, FWGeV (590.200)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Verzugszins, Mahngebühren",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Zahlungsfrist von Gebühren beträgt 30 Tage."
        },
        {
          "absatz": "2",
          "text": "Nach Ablauf der Zahlungsfrist kann ein Verzugszins von 5% erhoben werden."
        },
        {
          "absatz": "3",
          "text": "Für nicht rechtzeitig bezahlte Gebühren können Mahngebühren und Umtriebsgebühren für Inkassomassnahmen erhoben werden. Diese betragen:",
          "items": [
            {
              "marke": "a",
              "text": "erste Mahnung gratis"
            },
            {
              "marke": "b",
              "text": "ab zweiter Mahnung je Fr. 40"
            },
            {
              "marke": "c",
              "text": "Umtriebsgebühr für Inkassomassnahmen Fr. 50"
            }
          ]
        },
        {
          "absatz": "4",
          "text": "Vorbehalten bleibt die Einforderung weiterer Gebühren im Zusammenhang mit Betreibungsverfahren."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.200",
      "abgerufen": "2026-06-23",
