{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/511.21/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung regelt den Vollzug der dem Kanton und den Gemeinden übertragenen Aufgaben im Zivilschutz."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "cef52f405e95017b4abf96f3f634143972c2fe1630d08e13e8ecfd356e0ca292"
    },
    {
      "id": "kanton/AR/511.21/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Amt für Militär und Bevölkerungsschutz (nachfolgend Amt genannt) ist die für den Zivilschutz zuständige Stelle im Kanton."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "e45a3edfe41d98e4a895a7ff8f7e348012bddb26d4a71f1b7129f46d4915547e"
    },
    {
      "id": "kanton/AR/511.21/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat erlässt den Leistungsauftrag und ist zuständig für die Festlegung der Ausbildungsdauer, für die Grundausbildung im Sinne von Art. 33 des Bevölkerungs- und Zivilschutzgesetzes und für die Behandlung von Schadenersatzansprüchen im Sinne von Art. 60 BZG."
        },
        {
          "absatz": "2",
          "text": "Das Departement Inneres und Sicherheit erlässt Weisungen für Zivilschutzeinsätze bei Instandstellungsarbeiten und für Einsätze zu Gunsten der Gemeinschaft, legt Fachbereiche in der Zivilschutzorganisation (ZSO) fest und bewilligt Ausnahmen; es bezeichnet Zivilschutzmassnahmen, für die Ersatzbeiträge verwendet werden können."
        },
        {
          "absatz": "3",
          "text": "Das Amt ist zuständig für alle übrigen Aufgaben und Entscheide im Zivilschutz, die dem Kanton übertragen sind und für die nicht ausdrücklich eine andere Behörde, Organisation oder Einzelpersonen zuständig ist. Es erlässt die erforderlichen Weisungen für den Vollzug, insbesondere zu den Organisationsstrukturen und Beständen, zu den Funktionen und Graden, zur Enthebung aus Funktionen, für die Zuweisung sowie die vorzeitige Entlassung, zur Art und Zeitdauer der Ausbildungsdienste sowie für die gemeinsame Ausbildung mit Partnerorganisationen."
        },
        {
          "absatz": "4",
          "text": "Die Gemeinden bezeichnen eine Melde- und Kontaktstelle für die kantonale Zivilschutzstelle."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "ce05bbd2d6ce70fde32d94c8ca99815f9fcd65c1bcbdc08b3a505494c2564d75"
    },
    {
      "id": "kanton/AR/511.21/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Amt schafft in Zusammenarbeit mit den Partnerorganisationen Kantonspolizei und Feuerwehr die nötigen technischen und organisatorischen Voraussetzungen für die Alarmierung und das Aufgebot der Zivilschutzorganisation und erlässt die erforderlichen Weisungen."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "65dd2c8965e34dce8c3057b59990933821f44b2d61f717f31d33ea6d8dc050fd"
    },
    {
      "id": "kanton/AR/511.21/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die für die Kontrollführung im Zivilschutz erforderlichen Personal- und Rekrutierungsdaten werden von der kantonalen Zivilschutzstelle von einer durch die Gemeinde bezeichneten Melde- und Kontaktstelle und aus dem Personal-Informations-System der Armee zur Weiterbearbeitung übernommen."
        },
        {
          "absatz": "2",
          "text": "Das Amt verwaltet die für den Vollzug des Zivilschutzes erforderlichen Personaldaten."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "a69a1b2b637910b0f9c58f3e8cba7bc944df2b596883f456adad718dded65a72"
    },
    {
      "id": "kanton/AR/511.21/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Einteilung der Schutzdienstpflichtigen nach Grundfunktionen erfolgt aufgrund des kantonalen Zahlenbuches für die Rekrutierung."
        },
        {
          "absatz": "2",
          "text": "Schutzdiensttaugliche, für die momentan keine Einteilungsmöglichkeiten bestehen, können für maximal drei Jahre zurückgestellt oder der Personalreserve zugewiesen werden."
        },
        {
          "absatz": "3",
          "text": "Es besteht kein Anspruch auf Einteilung in den Aktivbestand der Zivilschutzorganisation."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "eba666c9891f051864820be82490e1d9e334dc0f0943af9061d0cb72187c5b7a"
    },
    {
      "id": "kanton/AR/511.21/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Beförderungen von Schutzdienstpflichtigen sind erst nach erfolgreicher Absolvierung der funktionsbezogenen Ausbildung möglich. Das Amt kann ausnahmsweise die Übernahme bestimmter Funktionen durch Schutzdienstpflichtige bewilligen, welche die entsprechende Ausbildung noch nicht absolviert haben."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "45157af5cecf71c45ec4198e18024ec54174aceab7316ba7d7a46739be552ad0"
    },
    {
      "id": "kanton/AR/511.21/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Orientierung der Dienstleistenden über die bevorstehenden Zivilschutzkurse erfolgt durch die aufbietende Stelle in der Regel mindestens drei Monate vor der Dienstleistung."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "206c81928a491fc09c20efea7f7c0fd1c054cbb5a0a32dffd82f6d0bfdb2d844"
    },
    {
      "id": "kanton/AR/511.21/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Grund-, Zusatz-, Kader- und Weiterausbildung erstellt das Amt Dienstanzeigen und erlässt formelle Aufgebote."
        },
        {
          "absatz": "2",
          "text": "Schutzdienstpflichtige, die vier Wochen vor Dienstbeginn nicht im Besitz eines formellen Aufgebots sind, haben sich auf der kantonalen Zivilschutzstelle zu melden."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "e348f608665ed1e70ee530303b095ba9b4155e5389cfb81871a21b47738a135d"
    },
    {
      "id": "kanton/AR/511.21/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für Wiederholungskurse von Formationen der kantonalen Zivilschutzorganisation erstellt das Amt Dienstanzeigen und erlässt schriftliche Aufgebote."
        },
        {
          "absatz": "2",
          "text": "Aufgebote für Einsätze können kurzfristig erfolgen."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "75ed9205ebc390f82cc38a0be7165f729f8c3c783da7ab110987cc55b0086004"
    },
    {
      "id": "kanton/AR/511.21/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Von der Dienstleistung dispensierte Schutzdienstpflichtige haben keinen Anspruch auf Nachholung des Dienstes im selben Jahr."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "cc8a1c06197d4b8c8afc274188059ab58d6943f9da09db1d5e230d16f8831f6a"
    },
    {
      "id": "kanton/AR/511.21/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Besoldung erfolgt nach der Tabelle «Funktionen/Sold» des Amtes."
        },
        {
          "absatz": "2",
          "text": "Bei Ausbildungsanlässen des Zivilschutzes gelten die effektiven Arbeitstage als Teilnehmertage."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "3dee6ce4634aed024eb3ca3c2a379cfc0000792c87a8b3a03f6579a006e4ebd3"
    },
    {
      "id": "kanton/AR/511.21/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Amt kann Ausbildungskurse vorschreiben."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "46b9934385d304dd260cafd7c25ccc21af20f41c278fb973b7e2c9f15916feb2"
    },
    {
      "id": "kanton/AR/511.21/art_14",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Amt überprüft jährlich das Erreichen der vereinbarten Ausbildungs- und Leistungsziele. Es inspiziert periodisch die Einsatzbereitschaft der Zivilschutzkompanien und stellt dem Departement Inneres und Sicherheit die Resultate zur Überprüfung zu."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "a580652eee1fad859fe45859d970beba568dd10be5318083d5e331037367c082"
    },
    {
      "id": "kanton/AR/511.21/art_15",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "15",
      "artikelLabel": "Art. 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gemeinden haben dem Amt Gesuche für Einsätze spätestens sechs Monate vor Beginn einzureichen."
        },
        {
          "absatz": "2",
          "text": "Das Amt bewilligt Einsätze in der Regel nur, wenn sie mit dem Zweck und den Aufgaben des Zivilschutzes übereinstimmen. Solche Einsätze dürfen die Privatwirtschaft nicht konkurrenzieren."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "4d92e54795cca0d6d2761a964a327a029b41280fe52511f324b508b1f9a15a9e"
    },
    {
      "id": "kanton/AR/511.21/art_16",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "16",
      "artikelLabel": "Art. 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Amt legt im Einverständnis mit den Gemeinden die Grenzen der Beurteilungsgebiete fest."
        },
        {
          "absatz": "2",
          "text": "Sind im Beurteilungsgebiet für 100 % der ständigen Wohnbevölkerung Schutzplätze vorhanden, so können Ersatzbeiträge geleistet werden."
        },
        {
          "absatz": "3",
          "text": "Die Festlegung der Höhe der Ersatzbeiträge erfolgt durch das Amt für Immobilien."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "ea6fd089954d2e65aed7937281edd6e50f446985becf7f18a01f34dc6f9bd671"
    },
    {
      "id": "kanton/AR/511.21/art_17",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "17",
      "artikelLabel": "Art. 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Verwendung der Ersatzbeiträge gilt in der Regel die folgende Prioritätenordnung:",
          "items": [
            {
              "marke": "a",
              "text": "Erstellung, Ausrüstung, Betrieb, Unterhalt und Werterhaltung von öffentlichen Schutzräumen;"
            },
            {
              "marke": "b",
              "text": "Deckung der Betriebs- und Unterhaltskosten der Schutzanlagen, soweit sie den jährlichen Pauschalbeitrag des Bundes übersteigen;"
            },
            {
              "marke": "c",
              "text": "Alarmierungs- und Telematikeinrichtungen;"
            },
            {
              "marke": "d",
              "text": "Zivilschutzmaterial."
            }
          ]
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "82d8da36ba150d1361c673af8d717cd118736798baa5199872319b0930e895ab"
    },
    {
      "id": "kanton/AR/511.21/art_18",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Amt kontrolliert die Anlagen und Schutzräume mindestens alle sieben Jahre."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "5c16b057c3c902117a05507888fcc19330cfae0823f09625f1a46fe2cc14b502"
    },
    {
      "id": "kanton/AR/511.21/art_19",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "19",
      "artikelLabel": "Art. 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Amt bestimmt die Ausrüstung der Zivilschutzorganisation und regelt die Beschaffung und Verteilung."
        },
        {
          "absatz": "2",
          "text": "Evaluation und Beschaffung sind nach Möglichkeit mit den Partnerorganisationen zu koordinieren."
        },
        {
          "absatz": "3",
          "text": "Das Amt kann mit anderen Kantonen, dem Bundesamt für Bevölkerungsschutz und mit Partnerorganisationen Vereinbarungen über die gemeinsame Beschaffung abschliessen."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "3943209fb765db5251dc9155310b52851714e125b8aca64c096beb97214db3f7"
    },
    {
      "id": "kanton/AR/511.21/art_20",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "20",
      "artikelLabel": "Art. 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Amt regelt mit dem Bund, den Gemeinden, den Partnern und Dritten die Verrechnung der Kosten und Entschädigungen."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "e1b6bbb9427946294af30074e03ebf874caefecaf896163d9bb7e181f1ef5f42"
    },
    {
      "id": "kanton/AR/511.21/art_21",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Zivilschutzgesetz (511.21)",
      "artikel": "21",
      "artikelLabel": "Art. 21",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung tritt am 1. Januar 2005 in Kraft."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cc8e60bf2e28abecfc55509950619341",
      "sha": "0d1e20aa6e6cb4436ac8e7a7e95b5dbe494116079f3dd22201286e7d9678d8ce"
    }
  ]
}