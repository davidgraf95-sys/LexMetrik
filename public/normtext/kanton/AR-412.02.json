      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Lehrpersonen der Volksschule werden aufgrund ihrer Anstellung in folgende Lohnkategorien eingeteilt:",
          "items": [
            {
              "marke": "a",
              "text": "Lehrpersonen im 1. und 2. Zyklus Lohnkategorie I"
            },
            {
              "marke": "b",
              "text": "Lehrpersonen im 3. Zyklus Lohnkategorie II"
            },
            {
              "marke": "c",
              "text": "Förderlehrpersonen aller Zyklen Lohnkategorie II"
            }
          ]
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/412.02",
      "abgerufen": "2026-06-23",
