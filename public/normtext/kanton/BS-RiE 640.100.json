{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/RiE 640.100/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Ordnung regelt die Steuererhebung der Einwohnergemeinde Riehen."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "a7649f51f3b7bbfde6864dd1762e393425e10bc6c684c068d8251bb15d48254e"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Einwohnergemeinde Riehen erhebt eine Steuer auf dem Einkommen, dem Vermögen und auf den Grundstückgewinnen der natürlichen Personen."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "d2992c665ef0d61c76231428629e83fa23082a5a3498952c536ec543c4aebc0b"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Steuergesetz und die darauf erlassenen Verordnungen sind sinngemäss anwendbar, soweit diese Ordnung und die darauf erlassenen Reglemente nichts anderes vorschreiben."
        },
        {
          "absatz": "2",
          "text": "Wo das Steuergesetz Kompetenzen an den Regierungsrat delegiert, ist im Rahmen der Riehener Steuerhoheit der Gemeinderat zuständig, soweit diese Ordnung und die darauf erlassenen Reglemente nichts anderes vorschreiben. Solange der Gemeinderat diese Kompetenzen nicht wahrnimmt, sind die Verordnungen und Beschlüsse des Regierungsrats sinngemäss anwendbar."
        },
        {
          "absatz": "3",
          "text": "Wo das Steuergesetz Kompetenzen an die Steuerverwaltung delegiert, ist im Rahmen der Riehener Steuerhoheit die Gemeindeverwaltung zuständig, soweit diese Ordnung und die darauf erlassenen Reglemente nichts anderes vorschreiben."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "c11ef8b145895c031cf9d2e024b423aaff05e37ba010592fa7b6ff2b75b19cf6"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Steuerpflichtig sind natürliche Personen mit persönlicher oder wirtschaftlicher Zugehörigkeit zur Einwohnergemeinde Riehen."
        },
        {
          "absatz": "2",
          "text": "Natürliche Personen mit persönlicher Zugehörigkeit zu einer anderen Einwohnergemeinde des Kantons Basel-Stadt sind aufgrund wirtschaftlicher Zugehörigkeit in Riehen nur steuerpflichtig, wenn sie an hier gelegenen Grundstücken Eigentum, dingliche oder diesen wirtschaftlich gleichkommende persönliche Nutzungsrechte haben."
        },
        {
          "absatz": "3",
          "text": "Im Übrigen gelten für die Steuerpflicht die §§ 3–13 des Steuergesetzes sinngemäss."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "77398dcf819af5047f6d2276959553bae3bc4bc19d2a8ac5baa9540d1b981500"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Besteuerung nach dem Aufwand sowie die Steuerbefreiung gelten die §§ 14 und 15 des Steuergesetzes sinngemäss."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "4b40ce3a7e5ede820b5b96b50665a87ea15c3c0b617adb5cc2729f7abde0bb80"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für Personenunternehmen, die neu gegründet werden, ihren Sitz in den Kanton verlegen oder deren betriebliche Tätigkeit wesentlich ändert, und die dem wirtschaftlichen Interesse der Einwohnergemeinde Riehen oder des Kantons Basel-Stadt dienen, kann der Gemeinderat Steuererleichterungen für das Gründungsjahr oder das Jahr der Sitzverlegung und die neun folgenden Jahre gewähren."
        },
        {
          "absatz": "2",
          "text": "Der Gemeinderat setzt in seinem Entscheid die Bedingungen der Steuererleichterungen fest. Er kann die Steuererleichterungen auf den Zeitpunkt der Gewährung widerrufen, wenn diese Bedingungen nicht eingehalten werden."
        },
        {
          "absatz": "3",
          "text": "Gegen den Entscheid des Gemeinderats kann Rekurs an den Regierungsrat erhoben werden."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "4057cc40c69fbd2c1a49179063ceadeb6afad481bd7cc2bf843d33e33ae7b9ff"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Ermittlung des steuerbaren Einkommens und Vermögens richtet sich nach den §§ 17–35 bzw. den §§ 45–48 des Steuergesetzes."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "134a6e4a656ed8c4e474ea1f711d3cb12b65009256ee414ddc82282f9356bcfe"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Berechnung der Steuern richtet sich nach den §§ 36–39 bzw. den §§ 49–52 des Steuergesetzes unter Beachtung von § 9 dieser Steuerordnung."
        },
        {
          "absatz": "2",
          "text": "Für die Bemessung der kommunalen Steuern ist die rechtskräftige Veranlagung der kantonalen Steuer massgebend."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "6f63508be96f92433bde8c76bff61166fb60ac1ba6768fcddf29b19953daa135"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Steuerfuss der Einkommenssteuer und der Steuerfuss der Vermögenssteuer bestimmen sich gemäss § 2 Abs. 2 des Steuergesetzes."
        },
        {
          "absatz": "2",
          "text": "Der Einwohnerrat beschliesst den Steuerfuss jeweils vor Beginn der neuen Steuerperiode. Dieser Beschluss unterliegt dem Referendum."
        },
        {
          "absatz": "3",
          "text": "Wird der Steuerfussbeschluss des Einwohnerrats vom Volk verworfen, so fasst der Einwohnerrat einen neuen Beschluss."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "0c7b24f6e8edbb73e0eb0707e5f7399c7e62f4693bb3afda1d82c868b1059595"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die zeitlichen Grundlagen richten sich nach den §§ 40–44 bzw. den §§ 53–57 des Steuergesetzes."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "3329ece11b974e672c96d3419459db3704d9e994e751e44547bf92d5216bf42e"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Besteuerung der Grundstückgewinne richtet sich nach den §§ 102–110 des Steuergesetzes."
        },
        {
          "absatz": "2",
          "text": "Für die Bemessung der kommunalen Steuer ist die rechtskräftige Veranlagung der kantonalen Steuer massgebend."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "30daad22a6311b3898edb61935826ae9bb5006d77c289e1a2c7fb91fff0fca4c"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_12",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "12",
      "artikelLabel": "§ 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Steuerfuss der Grundstückgewinnsteuer bestimmt sich gemäss § 2 Abs. 2 des Steuergesetzes. Er beträgt 50%."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "c55e0cce9757c76c63119f0411d7b2c3461b7878dbdcd55fb16e4836e18a2d59"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_13",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "13",
      "artikelLabel": "§ 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gemeindeverwaltung ist für den Vollzug dieser Ordnung zuständig."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "e8df34870496a2fff079cfeab1ede08057230bb56069885e876c5f6e700b6c16"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_14",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "14",
      "artikelLabel": "§ 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Veranlagung der Steuer sind die §§ 137–148 des Steuergesetzes sinngemäss anwendbar."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "554e59bbf647cf712fbff458f9db3da081292b2603e3df1397c0dab01b758c72"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_15",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "15",
      "artikelLabel": "§ 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Über Einsprachen gegen die Steuerberechnung oder sonstige Verfügungen der Gemeindeverwaltung, die im Zusammenhang mit dem Vollzug dieser Ordnung erfolgen, entscheidet die Gemeindeverwaltung."
        },
        {
          "absatz": "2",
          "text": "Die Bemessungsgrundlage (§§ 7 und 11) ist im Rahmen des kantonalen Veranlagungsverfahrens anzufechten."
        },
        {
          "absatz": "3",
          "text": "Im Übrigen gelten für das Einspracheverfahren die §§ 160–163 des Steuergesetzes sinngemäss."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "bb464eecdbadfa87d6481ef42460762c61859e464ee54c2d99bf564d93fb7653"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_16",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "16",
      "artikelLabel": "§ 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gegen Einspracheentscheide der Gemeindeverwaltung kann Rekurs bei der kantonalen Steuerrekurskommission gemäss den §§ 164–170 des Steuergesetzes erhoben werden."
        },
        {
          "absatz": "2",
          "text": "Der weitere Rechtsweg richtet sich nach den §§ 171 und 172 des Steuergesetzes."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "faa23d3e62d3c55c581427260c1e17bf131a5f61442cbd98a8132e3d918bc5c5"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_17",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "17",
      "artikelLabel": "§ 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Änderungen rechtskräftiger Verfügungen und Entscheide richten sich nach den §§ 173–176 des Steuergesetzes."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "7ed1c05ab929b51b9dbbd436de31216bb07401c6d1711568b1149bbffd48573c"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_18",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "18",
      "artikelLabel": "§ 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Erhebung von Nachsteuern erfolgt in sinngemässer Anwendung der §§ 177–179 des Steuergesetzes."
        },
        {
          "absatz": "2",
          "text": "Ein für die Kantonssteuer eingeleitetes Nachsteuerverfahren gilt auch für die kommunalen Steuern als eingeleitet."
        },
        {
          "absatz": "3",
          "text": "Die Gemeindeverwaltung erhebt die Nachsteuern aufgrund der Ergebnisse des kantonalen Verfahrens."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "e6490282d09c0c0739edceba68c5bc354f889ce2706856140da69f49b8fbb972"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_19",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "19",
      "artikelLabel": "§ 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die kommunalen Steuern werden durch die Gemeindeverwaltung in Rechnung gestellt und bezogen."
        },
        {
          "absatz": "2",
          "text": "Bezug und Sicherung der kommunalen Steuern erfolgen gemäss den §§ 194 und 196–206 des Steuergesetzes."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "ac3993c0705006ee0c7e98f94fdba9f0819024d7fe0b0677b24a077a97451d14"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_20",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "20",
      "artikelLabel": "§ 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Gemeinderat bestimmt, wer gemäss § 139 des Steuergesetzes bei der kantonalen Steuerverwaltung Einsicht in die Daten der in Riehen steuerpflichtigen Personen nehmen kann."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "b11ae8848e50b389d704334c4fd6a52b666f7be2357da4a6215eeabfaeaa5a49"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_21",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "21",
      "artikelLabel": "§ 21",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Fälligkeiten der Gemeindesteuern richten sich nach § 194 des Steuergesetzes."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "66b52fe5b6c3804bc508a15de460a770522f4d05ace774ff982e233d3cbf9868"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_22",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "22",
      "artikelLabel": "§ 22",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Zinsausgleich richtet sich nach § 195 Abs. 1–3 des Steuergesetzes."
        },
        {
          "absatz": "2",
          "text": "Der Gemeinderat regelt die Einzelheiten."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "34a2ac43c019eba7f1409441e8d45b0f13edf68b4b56a6651cb4cb4a02e72cf6"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_23",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "23",
      "artikelLabel": "§ 23",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Gemeinderat legt den Vergütungs- und den Belastungszinssatz jeweils für ein Kalenderjahr fest."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "ca7cc233dc3b16f337533176c68d815dcc1509af6db4591834f7d11100df5d16"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_24",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "24",
      "artikelLabel": "§ 24",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gemeindeverwaltung lädt zu Vorauszahlungen an die Einkommenssteuer und die Vermögenssteuer ein."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "ebad263eed7fe06c7d6b55063ead90cf16c5ad71113b4f0fc55495d551e4a8e0"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_25",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "25",
      "artikelLabel": "§ 25",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Über Stundung und Erlass der kommunalen Steuern sowie der Belastungszinsen, Gebühren und Bussen entscheidet der Gemeinderat."
        },
        {
          "absatz": "2",
          "text": "Er kann diese Aufgaben an das für den Politikbereich Finanzen und Steuern zuständige Mitglied des Gemeinderats oder an die Gemeindeverwaltung delegieren."
        },
        {
          "absatz": "3",
          "text": "Im Übrigen gelten die §§ 200 und 201 des Steuergesetzes sinngemäss."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "79c528ac37f1a6d25bcde1a80cda986918faec8dcd564700e145035733a5bf3a"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_26",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "26",
      "artikelLabel": "§ 26",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Steuerrückerstattung richtet sich nach § 202 des Steuergesetzes."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "2c33689d4a2e5fb8fe9551e636bbc18f36c20c1375a7945db51b267f73444d3d"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_27",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "27",
      "artikelLabel": "§ 27",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die §§ 198 und 199 des Steuergesetzes betreffend die Zwangsvollstreckung und die Bezugsverjährung sowie die §§ 203–206 des Steuergesetzes betreffend die Steuersicherung, den Arrest, das Steuerpfandrecht und das Bezugsverfahren gelten auch für die kommunalen Steuern."
        },
        {
          "absatz": "2",
          "text": "Die Sicherungsmassnahmen werden durch die Gemeindeverwaltung, gegebenenfalls in Zusammenarbeit mit der Steuerverwaltung, vollzogen."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "ece593250ab72d81e2b253db010c6ad183f410a9c7f881099bd5cbd0783d2eed"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_28",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "28",
      "artikelLabel": "§ 28",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Verletzung von Verfahrenspflichten und die Steuerhinterziehung gelten die §§ 208–214 des Steuergesetzes."
        },
        {
          "absatz": "2",
          "text": "Das Strafmass richtet sich nach den im kantonalen Verfahren angewandten Kriterien."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "4caeed35adc144fbffd3566a7433b858b27170cdd0b54273d0cae855203f9fca"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_29",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "29",
      "artikelLabel": "§ 29",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für das Verfahren kommen die §§ 216–222 des Steuergesetzes sinngemäss zur Anwendung."
        },
        {
          "absatz": "2",
          "text": "Ein für die Kantonssteuer eingeleitetes Steuerstrafverfahren gilt auch für die kommunalen Steuern als eingeleitet."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "54cb90f3d1e313ae3fbe967108e18ae77e92fabae03115d4793d7f7f391e8272"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_30",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "30",
      "artikelLabel": "§ 30",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Gemeinderat kann, auch wenn es nicht ausdrücklich vorgesehen ist, die erforderlichen Ausführungsbestimmungen zu dieser Ordnung erlassen."
        },
        {
          "absatz": "2",
          "text": "Er kann Gebühren für Mahnungen, Bescheinigungen und andere Verfahrensmassnahmen der Gemeindeverwaltung festsetzen."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "d969961ba11cfac87bd8fac6ebb1aae08f921083fa4a9698e2820714c9c18415"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_31",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "31",
      "artikelLabel": "§ 31",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Ordnung ersetzt die Steuerordnung der Gemeinde Riehen vom 22. August 2001."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "187ec90268b149ae3ccb525a3d411d03eae8981a0193a0a96297ffe7ca250478"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_32",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "32",
      "artikelLabel": "§ 32",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das neue Recht findet erstmals Anwendung auf die Einkommenssteuern der Steuerperiode 2003 und für die Grundstückgewinnsteuer auf die steuerbaren Tatbestände, die sich im Kalenderjahr 2003 verwirklicht haben."
        },
        {
          "absatz": "2",
          "text": "Die Berechnung der Steuern für die Steuerperiode 2003 erfolgt unter Berücksichtigung von § 239a des Steuergesetzes."
        },
        {
          "absatz": "3",
          "text": "Einsprachen gegen Verfügungen der Gemeindeverwaltung im Zusammenhang mit der Berechnung der Steuern der Steuerperioden 2002 und früher sind unter Vorbehalt von § 15 Abs. 2 an die Gemeindeverwaltung zu richten."
        },
        {
          "absatz": "4",
          "text": "In Fällen, in denen altes Recht anzuwenden ist, werden die nach altem Recht formulierten, steuerrechtlich relevanten Aufgaben und Befugnisse der Steuerkommission durch die Gemeindeverwaltung wahrgenommen."
        },
        {
          "absatz": "5",
          "text": "Die Beurteilung von Steuerstraftaten, die vor Inkrafttreten dieser Ordnung begangen wurden, erfolgt nach altem Recht, sofern sich das neue Recht für die steuerpflichtige Person nicht als milder erweist."
        },
        {
          "absatz": "6",
          "text": "Der Bezug der Gemeindesteuern, insbesondere die Fälligkeiten und der Zinsausgleich, bis und mit Steuerperiode 2002 richtet sich nach altem Recht."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "eb4662a1558c2f378fcc950fea13d30c6ba5584308e66124401d605e0457681e"
    },
    {
      "id": "kanton/BS/RiE 640.100/art_33",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Steuerordnung der Gemeinde Riehen (RiE 640.100)",
      "artikel": "33",
      "artikelLabel": "§ 33",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Ordnung wird publiziert; sie unterliegt der Genehmigung durch den Regierungsrat und dem Referendum."
        },
        {
          "absatz": "2",
          "text": "Sie wird rückwirkend am 1. Januar 2003 wirksam."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 640.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e7e83f2c60c31879a86796074f1b157f",
      "sha": "c01dc53a9104756d4fa3499c2bbfe142fd117b7c9ef75b0cf932b5139c683cbd"
    }
  ]
}