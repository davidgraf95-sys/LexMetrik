{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/223.1/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über das Handelsregister (223.1)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Handelsregisteramt führt das Handelsregister für den ganzen Kanton nach den hiefür geltenden Gesetzen und Verordnungen sowie den Weisungen der kantonalen Aufsichtsbehörde und des Eidg. Amtes für das Handelsregister."
        },
        {
          "absatz": "2",
          "text": "Es beurkundet Handelsregistersachen öffentlich und stellt Beglaubigungen aus."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/223.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cceaf8ffda2d8ec814d28e63dc6762b2",
      "sha": "2e630900a8c8eb3306567d50f93bc280471a487bed26ea8b19180d1341718a17"
    },
    {
      "id": "kanton/AR/223.1/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über das Handelsregister (223.1)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Departement Bau und Volkswirtschaft ist kantonale Aufsichtsbehörde über das Handelsregister."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/223.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cceaf8ffda2d8ec814d28e63dc6762b2",
      "sha": "8f42032387a8ddb11cb8e29fb4cd2f020eef8f722c2e1702f96db690066842ac"
    },
    {
      "id": "kanton/AR/223.1/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über das Handelsregister (223.1)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Handelsregister ist öffentlich."
        },
        {
          "absatz": "2",
          "text": "Die Registerführerin bzw. der Registerführer regelt die Einzelheiten der Einsichtnahme und die Öffnungszeiten."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/223.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cceaf8ffda2d8ec814d28e63dc6762b2",
      "sha": "df4a2a962f8a38f507c86052f8ad113872069c836e510fb94ef07e69344517da"
    },
    {
      "id": "kanton/AR/223.1/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über das Handelsregister (223.1)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gerichte sowie die kantonalen und kommunalen Amtsstellen geben dem Handelsregisteramt von eintragungspflichtigen Tatsachen unverzüglich Kenntnis."
        },
        {
          "absatz": "2",
          "text": "Sie unterstützen das Amt bei der Ermittlung und Feststellung eintragungspflichtiger Tatsachen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/223.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cceaf8ffda2d8ec814d28e63dc6762b2",
      "sha": "426389e1709433da7c892f02698a8afff0dd75cb2e2a0e7e3d23093e96032e92"
    },
    {
      "id": "kanton/AR/223.1/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über das Handelsregister (223.1)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Eintragungen im Handelsregister werden im kantonalen Amtsblatt veröffentlicht."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/223.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cceaf8ffda2d8ec814d28e63dc6762b2",
      "sha": "3db5154e649686cef928e88d27719b7e3aa70ef0d916fe57b71f79f0c44b887c"
    },
    {
      "id": "kanton/AR/223.1/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über das Handelsregister (223.1)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Handelsregisteramt erhebt für seine Arbeiten Gebühren nach der Verordnung über die Gebühren für das Handelsregister."
        },
        {
          "absatz": "2",
          "text": "Für die Beurkundungen des Handelsregisteramtes werden Gebühren in derselben Höhe erhoben, wie sie die Gemeinden gemäss Art. 11 Ziff. 4 des Gebührentarifes für die Gemeinden erheben können."
        },
        {
          "absatz": "3",
          "text": "Die Registerführerin bzw. der Registerführer fällt gegen die Beteiligten, die ihrer Eintragungspflicht nicht nachkommen, die in Art. 943 OR vorgesehenen Ordnungsbussen aus."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/223.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cceaf8ffda2d8ec814d28e63dc6762b2",
      "sha": "dd805fdc2d61b0ce75c7c079000599f7df83d00b51646cb10ba2c77cea35572d"
    },
    {
      "id": "kanton/AR/223.1/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über das Handelsregister (223.1)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gegen Verfügungen des Handelsregisteramtes kann innert 30 Tagen beim Obergericht Beschwerde erhoben werden."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/223.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cceaf8ffda2d8ec814d28e63dc6762b2",
      "sha": "9392ba5714a09ec6766c0857a00273840deeb0ee778e7f875be0e35ceb866293"
    },
    {
      "id": "kanton/AR/223.1/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über das Handelsregister (223.1)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Handelsregisteramt bewahrt das Güterrechtsregister sowie die Beibehaltungs- und Unterstellungserklärungen auf."
        },
        {
          "absatz": "2",
          "text": "In das Güterrechtsregister und das Verzeichnis der Beibehaltungserklärungen kann jedermann Einsicht nehmen; weitergehende Einsichtnahmen werden nur den Beteiligten gewährt."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/223.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cceaf8ffda2d8ec814d28e63dc6762b2",
      "sha": "f78d8f0e4897d1cdc2963ee09c7098a9307a515777f1e62be339e4f117580be9"
    },
    {
      "id": "kanton/AR/223.1/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über das Handelsregister (223.1)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung tritt mit der Genehmigung des Bundes in Kraft; sie ersetzt die Verordnung vom 26. Januar 1912 über das Handels- und Güterrechtsregister."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/223.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cceaf8ffda2d8ec814d28e63dc6762b2",
      "sha": "a2854050aae2905c803d48696c15bff5a2c75e2b4f0f6e498a2e98b68ed9b2ec"
    }
  ]
}