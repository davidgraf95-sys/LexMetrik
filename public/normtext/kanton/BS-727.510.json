{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/727.510/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung zum Gesetz über Strassenreinigungsbeiträge (727.510)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Beitrag ist vom Eigentümer des Grundstückes geschuldet, der im Zeitpunkt der Zustellung der Beitragsforderung im Grundbuch eingetragen ist."
        },
        {
          "absatz": "2",
          "text": "Der Erwerber eines Gebäudes haftet für ausstehende Beitragsforderungen."
        },
        {
          "absatz": "3",
          "text": "Ausserdem sind die Beitragsforderungen gemäss § 188 Ziff. 2 des Einführungsgesetzes zum Zivilgesetzbuch durch eine öffentlich-rechtliche Grundlast gesichert."
        }
      ],
      "stand": "1994-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/727.510",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4802c849b7fbe93a9d585637a1c2077a",
      "sha": "2f6e86c952da2dc18e3532b183e0c50498fcf4295aa82324bd11575844d284de"
    },
    {
      "id": "kanton/BS/727.510/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung zum Gesetz über Strassenreinigungsbeiträge (727.510)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Beitragspflicht beginnt mit der Festlegung der Versicherungspflicht durch die Gebäudeversicherung."
        },
        {
          "absatz": "2",
          "text": "Besteht die Versicherung während eines Teils des Jahres, so ist der Beitrag nur für diese Zeit zu entrichten."
        },
        {
          "absatz": "3",
          "text": "Angebrochene Monate werden voll berechnet."
        }
      ],
      "stand": "1994-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/727.510",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4802c849b7fbe93a9d585637a1c2077a",
      "sha": "ba9bb73369f25fa5fd1d1e6042b188805b6fae3f8141634666cd11a4336c0d5c"
    },
    {
      "id": "kanton/BS/727.510/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung zum Gesetz über Strassenreinigungsbeiträge (727.510)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Beitrag wird von dem von der Gebäudeversicherung ermittelten Neuwert erhoben."
        },
        {
          "absatz": "2",
          "text": "Die Beitragsforderungen sind auf den nächsten ganzen Franken aufzurunden."
        }
      ],
      "stand": "1994-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/727.510",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4802c849b7fbe93a9d585637a1c2077a",
      "sha": "8c22de36a2e432b1295027fa79ca12ce0c0f59ccfa4b70c733883e6f87eda262"
    },
    {
      "id": "kanton/BS/727.510/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung zum Gesetz über Strassenreinigungsbeiträge (727.510)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebäudeversicherung erhebt zuhanden der Finanzverwaltung den Beitrag für das laufende Jahr zu Beginn eines jeden Kalenderjahres."
        },
        {
          "absatz": "2",
          "text": "Sie wird für die ihr hieraus erwachsenden Kosten entschädigt."
        }
      ],
      "stand": "1994-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/727.510",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4802c849b7fbe93a9d585637a1c2077a",
      "sha": "b197a003b0db48df9f3ec7f978d09cc6f1fe195774975906dea4c3558f387ea0"
    },
    {
      "id": "kanton/BS/727.510/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung zum Gesetz über Strassenreinigungsbeiträge (727.510)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Beitragsforderungen sind innert 30 Tagen seit Rechnungsstellung zu bezahlen."
        },
        {
          "absatz": "2",
          "text": "Nach dieser Frist sind die säumigen Eigentümer zu mahnen."
        },
        {
          "absatz": "3",
          "text": "Die Gebäudeversicherung verlangt einen Verzugszins von 5,4% seit Ablauf der Mahnfrist."
        }
      ],
      "stand": "1994-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/727.510",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4802c849b7fbe93a9d585637a1c2077a",
      "sha": "80341c2ea94611eab6c6e1d3219ca664aae10a8619a398039ce50a6e025d80ea"
    },
    {
      "id": "kanton/BS/727.510/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung zum Gesetz über Strassenreinigungsbeiträge (727.510)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gegen die Beitragsforderung kann innert 30 Tagen bei der Finanzverwaltung Einsprache erhoben werden."
        },
        {
          "absatz": "2",
          "text": "Für die Weiterziehung gelten die Vorschriften für das Verwaltungsverfahren und die Verwaltungsrechtspflege"
        }
      ],
      "stand": "1994-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/727.510",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4802c849b7fbe93a9d585637a1c2077a",
      "sha": "8be13896f78218ee797e88e0ab603bf8d6c1aa15520619b20d7096c406444c72"
    }
  ]
}