{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/415.700/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung für den Schulpsychologischen Dienst (415.700)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Schulpsychologische Dienst berät Lehrkräfte, Schulbehörden und Erziehungsberechtigte und empfiehlt Massnahmen zur Verbesserung der Schul- und Erziehungssituation. Zu seinen Aufgaben gehören insbesondere:",
          "items": [
            {
              "marke": "a",
              "text": "Untersuchung und Beratung: Schulreifeuntersuchungen, Berichte zum Übertritt in sonderschulische Spezialangebote und Sonderschulen, für integrative Sonderschulung, ambulante Heilpädagogik und Privatschulfinanzierungen sowie für Internats- und Heimplatzierungen,"
            },
            {
              "marke": "b",
              "text": "Begleitung im therapeutischen Prozess (Therapiesitzung),"
            },
            {
              "marke": "c",
              "text": "Sprechstunden in Schulen,"
            },
            {
              "marke": "d",
              "text": "Krisenintervention,"
            },
            {
              "marke": "e",
              "text": "Konfliktmanagement,"
            },
            {
              "marke": "f",
              "text": "Moderation,"
            },
            {
              "marke": "g",
              "text": "Mediation,"
            },
            {
              "marke": "h",
              "text": "Expertentätigkeit,"
            },
            {
              "marke": "i",
              "text": "Vermittlung von Fachwissen, Referate, Fort- und Weiterbildungsveranstaltungen."
            }
          ]
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/415.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "ac51eb1e345cdd645ae236536bb0a595",
      "sha": "1a286ab8ac0549dcc79b480d08335bef4eb1e27e00e81a937e71c42c0610b513"
    },
    {
      "id": "kanton/BS/415.700/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung für den Schulpsychologischen Dienst (415.700)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Klientinnen und Klienten oder externen Anfragerinnen und Anfrager von Leistungen des Schulpsychologischen Dienstes haben sich wie folgt an den Kosten zu beteiligen:",
          "items": [
            {
              "marke": "a",
              "text": "Für die Begleitung im therapeutischen Prozess (Therapiesitzung) CHF 25 pro Stunde,"
            },
            {
              "marke": "b",
              "text": "für Expertisen nach Stundenaufwand,"
            },
            {
              "marke": "c",
              "text": "für Vermittlung von Fachwissen, Referate, Fort- und Weiterbildungveranstaltungen nach Stundenaufwand,"
            },
            {
              "marke": "d",
              "text": "für forensische Gutachten und Berichte nach Stundenaufwand."
            }
          ]
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/415.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "ac51eb1e345cdd645ae236536bb0a595",
      "sha": "7a125e914e85e4cf7d501b95733cca2d925112359d266de7ff399d3ab12b9456"
    },
    {
      "id": "kanton/BS/415.700/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung für den Schulpsychologischen Dienst (415.700)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Leitung des Schulpsychologischen Dienstes steht das Recht zu, in Härtefällen für Dienstleistungen gemäss § 2 lit. a Kostenerlass zu gewähren."
        },
        {
          "absatz": "2",
          "text": "Entsprechende Gesuche sind zu begründen und müssen in der Regel vor Behandlungsbeginn eingereicht werden."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/415.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "ac51eb1e345cdd645ae236536bb0a595",
      "sha": "07ff2de9d2a687795e60d62c4571e8f44ec394c7e2325fcd28e4a11605a35e12"
    },
