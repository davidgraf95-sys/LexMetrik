{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/621.12/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "ABRG (621.12)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zur Förderung einer ausgeglichenen Konjunktur sowie zur Verhütung von Arbeitslosigkeit können die Unternehmen der privaten Wirtschaft durch jährliche Einlagen steuerbegünstigte Arbeitsbeschaffungsreserven bilden («Reserven »)."
        },
        {
          "absatz": "2",
          "text": "Kanton und Gemeinden gewähren den Unternehmen, die nach dem Bundesgesetz über die Bildung steuerbegünstigter Arbeitsbeschaffungsreserven Reserven ausscheiden, Steuervergünstigungen."
        },
        {
          "absatz": "3",
          "text": "Soweit dieses Gesetz nichts Abweichendes bestimmt, gelten die Bestimmungen des Bundesrechts."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/621.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "56529077820554e808d9dddc4249e076",
      "sha": "a1195129743ce998e927981ed9451d7bd266de59675c73b42913df71af74f019"
    },
    {
      "id": "kanton/AR/621.12/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "ABRG (621.12)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zur Bildung von Reserven sind Unternehmen mit mindestens zehn Arbeitnehmern berechtigt."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/621.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "56529077820554e808d9dddc4249e076",
      "sha": "798ecb09a9057532f223644b3b3799da71570defff97b6fad1e7898851927b53"
    },
    {
      "id": "kanton/AR/621.12/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "ABRG (621.12)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die jährlichen Einlagen gelten als geschäftsmässig begründet, soweit sie 15 Prozent der Berechnungsgrundlage nicht übersteigen und mindestens Fr. 10 000.– erreichen."
        },
        {
          "absatz": "2",
          "text": "Die Reserven dürfen 20 Prozent der massgebenden jährlichen Lohnsumme im Sinne der AHV-Gesetzgebung nicht übersteigen. Der Regierungsrat kann diesen Satz für besonders kapitalintensive Unternehmen auf 30 Prozent erhöhen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/621.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "56529077820554e808d9dddc4249e076",
      "sha": "1ba5f0b0e38b76f183236fe0eaec6f4df789e36dada036be74b251c3f1d9d579"
    },
    {
      "id": "kanton/AR/621.12/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "ABRG (621.12)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Soweit das Bundesgesetz für die Freigabe der Reservevermögen durch die Bundesbehörden die Mitwirkung der Kantone vorsieht, gilt das Departement Bau und Volkswirtschaft als zuständige Behörde."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/621.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "56529077820554e808d9dddc4249e076",
      "sha": "c43bba8042072b374c1817b7b909d22226a1ae45bbb3942669e5e4dfaa646ad1"
    },
    {
      "id": "kanton/AR/621.12/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "ABRG (621.12)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die jährlichen Einlagen in die Arbeitsbeschaffungsreserven gelten bei den direkten Steuern als geschäftsmässig begründete Aufwendungen."
        },
        {
          "absatz": "2",
          "text": "Die Arbeitsbeschaffungsreserven sind steuerrechtlich den offenen Reserven gleichgestellt, die aus versteuertem Einkommen oder Reinertrag gebildet werden."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/621.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "56529077820554e808d9dddc4249e076",
      "sha": "8e175b96ac13115c442425f971162eb204545ee2b156076cd3112db20cc6d630"
    },
    {
      "id": "kanton/AR/621.12/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "ABRG (621.12)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Kanton und Gemeinden besteuern den aufgelösten Reservenbetrag, wenn das Unternehmen:",
          "items": [
            {
              "marke": "a",
              "text": "den Verwendungsnachweis nicht ordnungsgemäss erbringt;"
            },
            {
              "marke": "b",
              "text": "die Betriebstätigkeit einstellt;"
            },
            {
              "marke": "c",
              "text": "den Sitz oder eine Betriebsstätte ins Ausland verlegt."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Auf dem aufgelösten Reservenbetrag ist getrennt vom übrigen Einkommen oder Ertrag eine volle Jahressteuer zum Höchstsatz geschuldet. Die Verrechnung mit Verlusten aus dem laufenden oder aus früheren Geschäftsjahren ist ausgeschlossen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/621.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "56529077820554e808d9dddc4249e076",
      "sha": "f255b338721d9ad99321b21ee5e292bd09c2b3bb7a1eac2dcee438c7731b5649"
    },
    {
      "id": "kanton/AR/621.12/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "ABRG (621.12)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Verfahren über die Festsetzung der Steuervergünstigung und die nachträgliche Besteuerung richtet sich nach den Bestimmungen des Steuergesetzes."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/621.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "56529077820554e808d9dddc4249e076",
      "sha": "ac2e3f28ddf764b1b3f02a8ab21dc5e84ba4dea7f93b520316fa40cc8c9255e2"
    },
    {
      "id": "kanton/AR/621.12/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "ABRG (621.12)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die unrechtmässige Erlangung einer Steuervergünstigung unterliegt den Strafbestimmungen des Steuergesetzes."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/621.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "56529077820554e808d9dddc4249e076",
      "sha": "09f77a6d175cfaf79b6156018dcc1b3717d8e797f0e042cc7d7fb37e8c3345ac"
    },
    {
      "id": "kanton/AR/621.12/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "ABRG (621.12)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kantonsrat erlässt die zum Vollzug dieses Gesetzes erforderlichen Vorschriften."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/621.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "56529077820554e808d9dddc4249e076",
      "sha": "98ad856f1e43a97c2cd86c41a0f4edc71d5014468888d9cdacd454183a8834b9"
    },
    {
      "id": "kanton/AR/621.12/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "ABRG (621.12)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieses Gesetz findet erstmals Anwendung für die Veranlagung des Steuerjahres 1989."
        },
        {
          "absatz": "2",
          "text": "Reserven nach diesem Gesetz können erstmals für die in das Jahr 1988 fallenden Geschäftsabschlüsse gebildet werden."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/621.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "56529077820554e808d9dddc4249e076",
      "sha": "76f020143e171ef233ee372df741b90610a50bdd318f143c92d8db0f13fc540b"
    }
  ]
}