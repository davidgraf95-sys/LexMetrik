      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "EG BG-KKE (212.850)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat bezeichnet die Vollstreckungsbehörde bei Kindesrückführungen."
        }
      ],
      "stand": "2009-12-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/212.850",
