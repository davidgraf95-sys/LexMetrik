    {
      "id": "kanton/BS/212.850/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "EG BG-KKE (212.850)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zuständig für die Beurteilung von Rückführungsgesuchen, einschliesslich der Massnahmen zum Schutz von Kindern, ist als einzige Instanz das Appellationsgericht des Kantons Basel-Stadt."
        },
        {
          "absatz": "2",
          "text": "Es kann das Verfahren an das obere Gericht eines anderen Kantons abtreten, wenn die Parteien und das ersuchte Gericht dem zustimmen."
        }
      ],
      "stand": "2009-12-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/212.850",
      "abgerufen": "2026-06-23",
      "fassungsToken": "81cdda5f642bc7cf85000f168d5ffeca",
      "sha": "ade10d7d29a9b3ba18052c4c0f26002eab800cd79fff9ae56778761a8b3c6016"
    },
    {
      "id": "kanton/BS/212.850/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "EG BG-KKE (212.850)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat bezeichnet die zuständige Zentrale Behörde für das Haager Kindesschutzübereinkommen und das Haager Erwachsenenschutzübereinkommen."
        }
      ],
      "stand": "2009-12-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/212.850",
      "abgerufen": "2026-06-23",
