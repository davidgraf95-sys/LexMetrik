{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/RiE 332.400/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für das Gesundheitszentrum Riehen (RiE 332.400)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Einwohnergemeinde Riehen sorgt für die Einrichtung und den Betrieb eines ambulanten Gesundheitszentrums in Riehen mit Notfallabdeckung und ergänzendem stationären Angebot im Bereich der Betagten- und Krankenpflege."
        }
      ],
      "stand": "2010-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 332.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "afbc9b6180e52602170c31a321a06ffe",
      "sha": "cebf151046add7484e1ea5fbd0155a2946f6ce832377094ee6b02786b799ff2f"
    },
    {
      "id": "kanton/BS/RiE 332.400/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für das Gesundheitszentrum Riehen (RiE 332.400)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Gesundheitszentrum bildet Teil eines gut vernetzten Angebots von vielfältigen medizinischen und pflegerischen Dienstleistungen sowie Aktivitäten zur Gesundheitsförderung."
        }
      ],
      "stand": "2010-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 332.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "afbc9b6180e52602170c31a321a06ffe",
      "sha": "5dd6b5b96c1998dadbd4b86606fb9e1ce03ff1253a0c3adcc4e133a80cf72016"
    },
    {
      "id": "kanton/BS/RiE 332.400/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für das Gesundheitszentrum Riehen (RiE 332.400)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Gemeinderat sorgt für die erforderliche Koordination mit dem Kanton, namentlich was die akutmedizinische Spitalversorgung der Riehener Bevölkerung betrifft."
        }
      ],
      "stand": "2010-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 332.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "afbc9b6180e52602170c31a321a06ffe",
      "sha": "364df578fac6fb981430808f499e77627e4d680e1666bf165a8fa801dd933c30"
    },
    {
      "id": "kanton/BS/RiE 332.400/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für das Gesundheitszentrum Riehen (RiE 332.400)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Einwohnergemeinde kann sich an der Trägerschaft des Gesundheitszentrums beteiligen."
        },
        {
          "absatz": "2",
          "text": "Sie kann ferner Deckungsbeiträge an gemeinwirtschaftliche Leistungen des Gesundheitszentrums, wie beispielsweise erweiterte Öffnungszeiten, Notfallabdeckung oder Hausbesuche, gewähren. Das Nähere wird in einem Leistungsauftrag geregelt."
        }
      ],
      "stand": "2010-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 332.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "afbc9b6180e52602170c31a321a06ffe",
      "sha": "d759a4e67ecb6403cf5d8b68898e72a780fc76e9b98eaef353fda729a235627d"
    },
    {
      "id": "kanton/BS/RiE 332.400/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für das Gesundheitszentrum Riehen (RiE 332.400)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Gemeinderat erlässt die nötigen Ausführungsbestimmungen in einem Reglement und bestimmt den Zeitpunkt der Wirksamkeit dieser Ordnung."
        },
        {
          "absatz": "2",
          "text": "Mit dem Wirksamwerden dieser Ordnung wird die Ordnung für das Spital Riehen vom 29. Oktober 2008 aufgehoben."
        }
      ],
      "stand": "2010-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 332.400",
      "abgerufen": "2026-06-23",
