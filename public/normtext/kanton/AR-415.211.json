{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/415.211/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ausbildungen privater und öffentlich-rechtlicher Anbieter sind beitragsberechtigt, wenn sie zu einem vom Bund, von der Schweizerischen Konferenz der kantonalen Erziehungsdirektorinnen und -direktoren oder von der Schweizerischen Konferenz der kantonalen Gesundheitsdirektorinnen und -direktoren anerkannten Ausbildungsabschluss führen."
        },
        {
          "absatz": "2",
          "text": "Beitragsberechtigt sind zudem Ausbildungen, an die der Kanton Schulgeldbeiträge leistet. Das Departement Bildung und Kultur kann weitere Ausbildungen als beitragsberechtigt anerkennen."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "29d683c52400ee4edd0b2c6012f213329c242d60d261314e6056f82846c1c00a"
    },
    {
      "id": "kanton/AR/415.211/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ausbildungen im Ausland sind beitragsberechtigt, wenn die gesuchstellende Person die Gleichwertigkeit mit entsprechenden Ausbildungen in der Schweiz nachweist. Die Gleichwertigkeit ist in der Regel durch die zuständige Anerkennungsstelle in der Schweiz bestätigen zu lassen."
        },
        {
          "absatz": "2",
          "text": "Die Gewährung von Ausbildungsbeiträgen setzt voraus, dass die gesuchstellende Person die Aufnahmebedingungen für eine entsprechende Ausbildung in der Schweiz erfüllt."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "5d0a8a4ee277f0e1b2687d8d107b7c5e8223640a54bc8efeda9820f92d85f20c"
    },
    {
      "id": "kanton/AR/415.211/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Erstausbildung umfasst den Erwerb einer ersten berufsbefähigenden Ausbildung bis zum Abschluss auf der Tertiärstufe."
        },
        {
          "absatz": "2",
          "text": "Mit einer Zweitausbildung beginnt, wer bereits eine berufsbefähigende Ausbildung erworben hat und eine neue Ausbildung aufnimmt, die nicht darauf aufbaut."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "40d19660aabe7d502ef537d9851a6da0999b197286ae9af747fcebb26122df8a"
    },
    {
      "id": "kanton/AR/415.211/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Erstausbildung auf der Sekundarstufe II werden über die gesetzliche Alterslimite hinaus Stipendien gewährt, sofern damit vor der Vollendung des 50. Lebensjahrs begonnen wird."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "2bfcfa2056089248eb984a4499052c5aca2bb4facee8e893d263d05f52a837cd"
    },
    {
      "id": "kanton/AR/415.211/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Stipendien für die Zweitausbildung werden gewährt, wenn der erlernte Beruf infolge technologischen Wandels nicht mehr ausgeübt werden kann."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "2551e2e416dfa8ca0b0a6c8df05efa604a9a550c35ecfae1d1559267727ffaef"
    },
    {
      "id": "kanton/AR/415.211/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Eine Ausbildung kann höchstens zwei Jahre unterbrochen werden. Wird sie innert Frist nicht wieder aufgenommen, gilt dies als Abbruch der Ausbildung."
        },
        {
          "absatz": "2",
          "text": "Während des Ausbildungsunterbruchs werden keine Ausbildungsbeiträge ausgerichtet."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "5868bd1138c78e14ff1c41eec302acfb2f9cbcab68779386401c7aaf7218a74a"
    },
    {
      "id": "kanton/AR/415.211/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zur Bestimmung des finanziellen Bedarfs werden die finanziellen Verhältnisse der gesuchstellenden Person und ihrer Eltern erhoben."
        },
        {
          "absatz": "2",
          "text": "Ist die gesuchstellende Person verheiratet oder lebt sie in eingetragener Partnerschaft, werden die finanziellen Verhältnisse des Partners mitberücksichtigt."
        },
        {
          "absatz": "3",
          "text": "Ein finanzieller Bedarf ist ausgewiesen, wenn die zumutbaren Eigen- und Fremdleistungen nicht ausreichen, um die anerkannten Ausbildungs- und Lebenshaltungskosten zu decken."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "66d0f9cdd3421e063050ca268f9dce0bbe7d6b62fa31f35dc18a622b1ae9ea47"
    },
    {
      "id": "kanton/AR/415.211/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Soweit keine besondere Regelung besteht, sind die tatsächlichen Verhältnisse zu Beginn der Ausbildungsperiode massgebend, für die Ausbildungsbeiträge beantragt werden. Als Stichtag gilt der erste Tag des Kalendermonats."
        },
        {
          "absatz": "2",
          "text": "Liegt keine rechtskräftige Steuerveranlagung nach schweizerischem Recht vor oder haben sich die tatsächlichen Verhältnisse erheblich geändert, werden Einkommen und Vermögen aufgrund der konkreten Umstände eingeschätzt."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "166cff82bf2282bcabd5b1f96cb40d009d02a04f325e842fb1becfdabdd6b14a"
    },
    {
      "id": "kanton/AR/415.211/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Als Ausbildungskosten gelten Schul- und Studiengebühren, Prüfungsgebühren, Diplomgebühren, Auslagen für Schulmaterial, obligatorische Lehrmittel und dergleichen."
        },
        {
          "absatz": "2",
          "text": "Die Ausbildungskosten umfassen ferner die Fahrkosten für die günstigste Verkehrsverbindung zwischen Wohn- und Ausbildungsort."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "1d51a18f3d914677880ab45a4b7a7b3c5a7cba89db88e0c96edf83fed98da7de"
    },
    {
      "id": "kanton/AR/415.211/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Pro Jahr und Ausbildungsstufe sind als Ausbildungskosten pauschal anrechenbar:",
          "items": [
            {
              "marke": "a",
              "text": "Brückenangebote 800 Franken"
            },
            {
              "marke": "b",
              "text": "Sekundarstufe II:"
            },
            {
              "marke": "1",
              "text": "Berufslehren 500 Franken"
            },
            {
              "marke": "2",
              "text": "Berufslehren mit begleitender Berufsmatura 1'100 Franken"
            },
            {
              "marke": "3",
              "text": "Teilzeitliche Schulangebote 1'000 Franken"
            },
            {
              "marke": "4",
              "text": "Vollschulische Angebote 2'000 Franken"
            },
            {
              "marke": "c",
              "text": "Tertiärstufe A 4'400 Franken"
            }
          ]
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "58c9e9c6cb6d13b1c7d611ffae883831c9c459fadc53859d83b18cc089f3c553"
    },
    {
      "id": "kanton/AR/415.211/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Auf der Tertiärstufe B sowie für Passerellen sind die tatsächlichen Ausbildungskosten anrechenbar, pro Jahr aber höchstens:",
          "items": [
            {
              "marke": "a",
              "text": "Tertiärstufe B 18'000 Franken"
            },
            {
              "marke": "b",
              "text": "Passarellen 5'000 Franken"
            }
          ]
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "dff51d7f898e39aa01d1e72e853e9bcc2b8bf3d827e1c83228a181634492addd"
    },
    {
      "id": "kanton/AR/415.211/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Als Fahrkosten für die günstigste Verkehrsverbindung werden maximal die Kosten für ein Generalabonnement zweiter Klasse der Schweizerischen Bundesbahnen anerkannt."
        },
        {
          "absatz": "2",
          "text": "Die Fahrkosten werden zusätzlich zu den Kosten nach Art. 10 oder 11 angerechnet."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "cd21ef0e55f6373a6cb44e3c9da47402f78bc01a530067d524949ec66a8ca24e"
    },
    {
      "id": "kanton/AR/415.211/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ausland- und Austauschsemester werden mit einer zusätzlichen Kostenpauschale von 150 Franken pro Monat berücksichtigt."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "be9d41c2edcb8fdc0f023df823459461ac4a12d33ff95b1ae7144cd7c02562d6"
    },
    {
      "id": "kanton/AR/415.211/art_14",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Als Lebenshaltungskosten der gesuchstellenden Person werden alternativ anerkannt:",
          "items": [
            {
              "marke": "a",
              "text": "die Kosten für den eigenen Haushalt;"
            },
            {
              "marke": "b",
              "text": "die Kosten für den Mehrpersonenhaushalt;"
            },
            {
              "marke": "c",
              "text": "die Kosten im elterlichen Haushalt."
            }
          ]
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "eeb7acd57a7b064471d9007596d351a04b3c1926525f3df06ebcc4dbca430e65"
    },
    {
      "id": "kanton/AR/415.211/art_15",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "15",
      "artikelLabel": "Art. 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kosten für den eigenen Haushalt werden anerkannt, wenn:",
          "items": [
            {
              "marke": "a",
              "text": "die gesuchstellende Person das 25. Altersjahr vollendet hat;"
            },
            {
              "marke": "b",
              "text": "die einfache Fahrt mit öffentlichen Verkehrsmitteln zwischen Elternhaus und Ausbildungsstätte mehr als eine Stunde beträgt;"
            },
            {
              "marke": "c",
              "text": "andere achtenswerte Gründe vorliegen, welche es der gesuchstellenden Person unzumutbar machen, bei den Eltern zu wohnen."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Für den eigenen Haushalt wird eine Kostenpauschale von 17'000 Franken pro Jahr angerechnet."
        },
        {
          "absatz": "3",
          "text": "Als Lebenshaltungskosten werden ferner die vom Eidgenössischen Departement des Innern festgelegten Durchschnittsprämien der obligatorischen Krankenpflegeversicherung (inkl. Unfalldeckung) für den Kanton Appenzell Ausserrhoden berücksichtigt."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "7f91f9078341ff6fd4a50c16cf271e737efd987d99acc96aea40ad5a025bafce"
    },
    {
      "id": "kanton/AR/415.211/art_16",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "16",
      "artikelLabel": "Art. 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kosten für einen Mehrpersonenhaushalt werden anerkannt, wenn die gesuchstellende Person mit ihrem ehelichen oder eingetragenen Partner oder mit eigenen Kindern in einem gemeinsamen Haushalt lebt."
        },
        {
          "absatz": "2",
          "text": "Für die Kosten im Mehrpersonenhaushalt werden die Ausgaben nach Art. 20 angerechnet."
        },
        {
          "absatz": "3",
          "text": "Sind beide Partner in Ausbildung, werden die Ausgaben bei jedem Partner anteilmässig berücksichtigt."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "f45b3f3d71bead93571e0e4445df82d73489615afed53113f701342cb9c42f33"
    },
    {
      "id": "kanton/AR/415.211/art_17",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "17",
      "artikelLabel": "Art. 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Als Lebenshaltungskosten im elterlichen Haushalt werden die ungedeckten Ausgaben nach Art. 22 anerkannt, pro Jahr aber höchstens:",
          "items": [
            {
              "marke": "a",
              "text": "wenn beide Eltern einen gemeinsamen Haushalt führen 6'000 Franken"
            },
            {
              "marke": "b",
              "text": "im Haushalt eines alleinstehenden Elternteils 12'000 Franken"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Als notwendige Mehrkosten können darüber hinaus im Jahr 600 Franken pro Wochentag für auswärtige Verpflegung angerechnet werden."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "3806d991862c5d711452e304d7020ccadf0ea9295df2c9c207c8c5404169a6db"
    },
    {
      "id": "kanton/AR/415.211/art_18",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im elterlichen Haushalt werden die finanziellen Verhältnisse der Eltern, Stiefeltern und ihrer im gleichen Haushalt lebenden Kinder erfasst. Wirtschaftlich selbständige Kinder werden nicht berücksichtigt."
        },
        {
          "absatz": "2",
          "text": "Leben die Eltern nicht im gleichen Haushalt, werden ihre finanziellen Verhältnisse getrennt erfasst."
        },
        {
          "absatz": "3",
          "text": "Leistet ein Elternteil gerichtlich oder behördlich festgelegte Unterhaltsbeiträge für die gesuchstellende Person, wird in der Regel auf die Erhebung seiner Einkommens- und Vermögensverhältnisse verzichtet."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "344528715a04efcff67bdb78590622c46899e26056b8f2c760b26b0410f8d4ed"
    },
    {
      "id": "kanton/AR/415.211/art_19",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "19",
      "artikelLabel": "Art. 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die finanziellen Mittel des elterlichen Haushalts bemessen sich nach der Veranlagung für die Staats- und Gemeindesteuern."
        },
        {
          "absatz": "2",
          "text": "Zum Reineinkommen werden hinzugerechnet:",
          "items": [
            {
              "marke": "a",
              "text": "Unterhalts- und Verwaltungskosten für Liegenschaften, soweit sie 20 Prozent des Liegenschaftenertrags übersteigen;"
            },
            {
              "marke": "b",
              "text": "Einkaufsbeiträge an Einrichtungen der beruflichen Vorsorge (2. Säule);"
            },
            {
              "marke": "c",
              "text": "Beiträge an die gebundene Vorsorge (Säule 3a); bei Personen ohne berufliche Vorsorge (2. Säule): soweit die Beiträge den Betrag von 10'000 Franken pro Jahr übersteigen;"
            },
            {
              "marke": "d",
              "text": "Ergänzungsleistungen;"
            },
            {
              "marke": "e",
              "text": "11 Prozent des Reinvermögens."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Vom Reineinkommen werden abgezogen:",
          "items": [
            {
              "marke": "a",
              "text": "Waisen- und Kinderrenten aus Sozialversicherungen;"
            },
            {
              "marke": "b",
              "text": "Unterhaltsbeiträge für minderjährige Kinder;"
            },
            {
              "marke": "c",
              "text": "die Einkünfte des Stiefelternteils, höchstens aber 20'000 Franken."
            }
          ]
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "da91e749ea88e3b090bdaa8fbedfecba040cb6553dbf494daf600fd568b87108"
    },
    {
      "id": "kanton/AR/415.211/art_20",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "20",
      "artikelLabel": "Art. 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für den Grundbedarf einschliesslich Wohnkosten wird im elterlichen Haushalt eine Pauschale nach Haushaltsgrösse gemäss Anhang angerechnet."
        },
        {
          "absatz": "2",
          "text": "Zusätzlich werden berücksichtigt:",
          "items": [
            {
              "marke": "a",
              "text": "die vom Eidgenössischen Departement des Innern festgelegten Durchschnittsprämien der obligatorischen Krankenpflegeversicherung (inkl. Unfalldeckung) für den Kanton Appenzell Ausserrhoden;"
            },
            {
              "marke": "b",
              "text": "ein Steueranteil gemäss Anhang."
            }
          ]
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "f609ae629ab9d3ab0419cb9ad72f46fab9efee6a35014cc04f6616389407d12a"
    },
    {
      "id": "kanton/AR/415.211/art_21",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "21",
      "artikelLabel": "Art. 21",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für weitere Ausgaben werden pro Jahr ein pauschaler Freibetrag von 12'800 Franken und ein Zuschlag von 3'000 Franken für jedes unterhaltsberechtigte Kind angerechnet."
        },
        {
          "absatz": "2",
          "text": "Werden die finanziellen Verhältnisse der Eltern getrennt erfasst, sind der pauschale Freibetrag und die Zuschläge für unterhaltsberechtigte Kinder in beiden Haushalten voll anzurechnen. Halb- und Stiefgeschwister werden nur beim entsprechenden Elternteil berücksichtigt."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "e74a20438eb1e9dd39df194ab4016491d727ab4ea781c8b4106d9bcc98ac39b0"
    },
    {
      "id": "kanton/AR/415.211/art_22",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "22",
      "artikelLabel": "Art. 22",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ergibt sich aus der Gegenüberstellung von finanziellen Mitteln und anrechenbaren Ausgaben ein Fehlbetrag, wird dieser durch die Zahl der im gleichen Haushalt lebenden Personen geteilt. Das Ergebnis wird im Rahmen von Art. 17 als Lebenshaltungskosten der gesuchstellenden Person berücksichtigt."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "05ed18ffb0c186d40bbb9a0e16ebda195740a9e62ab9b6a225af95232475d716"
    },
    {
      "id": "kanton/AR/415.211/art_23",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "23",
      "artikelLabel": "Art. 23",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ergibt sich aus der Gegenüberstellung von finanziellen Mitteln und anrechenbaren Ausgaben ein Überschuss, wird dieser durch die Zahl der in der nachobligatorischen Ausbildung stehenden und wirtschaftlich unselbständigen Kinder geteilt. Das Ergebnis entspricht der zumutbaren Elternleistung."
        },
        {
          "absatz": "2",
          "text": "Die zumutbare Elternleistung wird unter den Voraussetzungen von Art. 13 Abs. 2 des Stipendiengesetzes nur zur Hälfte angerechnet."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "f8bc3dd42a181f3c7b3161967e9565957da00ae44182e259487029eab0bdbf41"
    },
    {
      "id": "kanton/AR/415.211/art_24",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "24",
      "artikelLabel": "Art. 24",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die zumutbare Eigenleistung der gesuchstellenden Person bemisst sich nach den mutmasslichen Einkünften während der massgebenden Ausbildungsperiode und dem anrechenbaren Vermögen."
        },
        {
          "absatz": "2",
          "text": "Die finanziellen Verhältnisse des ehelichen oder eingetragenen Partners werden sinngemäss nach denselben Regeln mitberücksichtigt, sofern der Partner sich nicht selbst in Ausbildung befindet."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "4eefc8b72b2be3613fd315ec61d57d4f512aeecbd09cb855a402f37acffe5134"
    },
    {
      "id": "kanton/AR/415.211/art_25",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "25",
      "artikelLabel": "Art. 25",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Erwerbseinkommen wird mit 75 Prozent des mutmasslichen Bruttobetrages angerechnet."
        },
        {
          "absatz": "2",
          "text": "Bei Teilzeitausbildung kann ein hypothetisch erzielbares Erwerbseinkommen angerechnet werden, wenn es die gesuchstellende Person unterlässt, einer nach den Umständen zumutbaren Erwerbstätigkeit nachzugehen."
        },
        {
          "absatz": "3",
          "text": "Als minimale Eigenleistung aus Erwerb wird der gesuchstellenden Person pro Jahr in jedem Fall angerechnet:",
          "items": [
            {
              "marke": "a",
              "text": "Sekundarstufe II und Passerellen 600 Franken"
            },
            {
              "marke": "b",
              "text": "Hochschulen und höhere Berufsbildung 4'000 Franken"
            }
          ]
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "1bdfd4fd4299e7ddf5eda447d78c5629b7fda62405c4b3021e7cdd6ea8acc229"
    },
    {
      "id": "kanton/AR/415.211/art_26",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "26",
      "artikelLabel": "Art. 26",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Als weitere Einkünfte werden angerechnet:",
          "items": [
            {
              "marke": "a",
              "text": "zu 100 Prozent: Ersatzeinkommen, Taggelder, Renten zugunsten der gesuchstellenden Person und ihrer Kinder, Ergänzungsleistungen;"
            },
            {
              "marke": "b",
              "text": "zu 75 Prozent: Unterhaltsbeiträge zugunsten der gesuchstellenden Person und ihrer Kinder."
            }
          ]
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "f898cd6d0869adec9d8640f0d80d84c9bba736bd4dce68e4e1a1416069c8ca9c"
    },
    {
      "id": "kanton/AR/415.211/art_27",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "27",
      "artikelLabel": "Art. 27",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Von den angerechneten Einkünften werden die voraussichtlichen Unterhaltsbeiträge abgezogen, welche die gesuchstellende Person und ihr Partner während der massgebenden Ausbildungsperiode zu leisten haben."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "d83cd95fdf00a95db1fbb941d15e4e351af08a654ff9cfcf33c42c4ff332bee4"
    },
    {
      "id": "kanton/AR/415.211/art_28",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "28",
      "artikelLabel": "Art. 28",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Als zumutbare Eigenleistung werden 15 Prozent des Vermögens angerechnet, das folgende Freibeträge übersteigt:",
          "items": [
            {
              "marke": "a",
              "text": "5'000 Franken für Alleinstehende;"
            },
            {
              "marke": "b",
              "text": "10'000 Franken für Verheiratete und eingetragene Partner;"
            },
            {
              "marke": "c",
              "text": "5'000 Franken für jedes unterstützungsberechtigte Kind der gesuchstellenden Person oder ihres Partners."
            }
          ]
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "2bbf59ffaad252ab1a4fe2f13d4b40b0bccba36bc37f0b0dee4dc2c1088da5ee"
    },
    {
      "id": "kanton/AR/415.211/art_29",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "29",
      "artikelLabel": "Art. 29",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ausbildungsbeiträge werden gewährt, wenn die gesuchstellende Person einen finanziellen Bedarf von mindestens 500 Franken ausweist."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "a80cddd5d4ae7889f69bc69471fb1b2e2b074699687a7fb1e73890fbe987eba8"
    },
    {
      "id": "kanton/AR/415.211/art_30",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "30",
      "artikelLabel": "Art. 30",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Innerhalb des gesetzlichen Höchstrahmens entspricht die Höhe des Ausbildungsbeitrags dem ausgewiesenen und auf die nächsten hundert Franken auf- oder abgerundeten Bedarf."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "4026fbb34b9192406321df61626908543de061e5ad80f17be9b28cd0ab0c92f5"
    },
    {
      "id": "kanton/AR/415.211/art_31",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "31",
      "artikelLabel": "Art. 31",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ausbildungsbeiträge werden in der Regel für ein Ausbildungsjahr von zwölf Monaten gesprochen."
        },
        {
          "absatz": "2",
          "text": "Die Beitragsperiode beginnt mit dem Kalendermonat, in dem die Ausbildung aufgenommen wird. Sie dauert bis zum Ende des Kalendermonats, nach dem ein neues Ausbildungsjahr beginnt."
        },
        {
          "absatz": "3",
          "text": "Bei abweichender Ausbildungsperiode wird die Beitragsperiode entsprechend angepasst."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "6e4d08141732e1be44ee523b8b5b4ea2173805617edda5a33a72099aa8e8464a"
    },
    {
      "id": "kanton/AR/415.211/art_32",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "32",
      "artikelLabel": "Art. 32",
      "bloecke": [
        {
          "absatz": "1",
          "text": "In Härtefällen können auf begründetes Gesuch hin Darlehen in Abweichung von der Berechnung des finanziellen Bedarfs ausgerichtet werden."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "06586ccfbae1a3527fe1d6c24cc9d8a66693e0c818462a554f79bbe14c5f4665"
    },
    {
      "id": "kanton/AR/415.211/art_33",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "33",
      "artikelLabel": "Art. 33",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Stipendien werden in der Regel semesterweise gegen Vorlage einer Ausbildungsbestätigung ausbezahlt."
        },
        {
          "absatz": "2",
          "text": "Nicht abgerufene Stipendien verfallen mit Ablauf der Beitragsperiode."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "e2cb790450adca8a1698dcb79511c21e67f580e4900c5c60e965734d4f31d56f"
    },
    {
      "id": "kanton/AR/415.211/art_34",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "34",
      "artikelLabel": "Art. 34",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Darlehen werden auf Abruf ausbezahlt. Der Abruf von Teilbeträgen ist möglich."
        },
        {
          "absatz": "2",
          "text": "Nicht abgerufene Darlehen verfallen bei Ausbildungsende."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "b312474aa0516f1193062d6c6b1a7952ac53f0742997e183f52a08f4158b1b25"
    },
    {
      "id": "kanton/AR/415.211/art_35",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "35",
      "artikelLabel": "Art. 35",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Abteilung Ausbildungs- und Studienbeiträge kann für ausstehende Darlehen und Zinsen jederzeit Abzahlungspläne vorschlagen."
        },
        {
          "absatz": "2",
          "text": "Abzahlungspläne werden mit der gegenseitigen Unterzeichnung verbindlich."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "9e6115bf486e7f6f6c4541b05c97cc23498b446f7295cf4cf9b2978ae94b5441"
    },
    {
      "id": "kanton/AR/415.211/art_36",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "36",
      "artikelLabel": "Art. 36",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Zinspflicht für ausstehende Darlehen beginnt nach Ablauf der zinsfreien Frist mit dem ersten Tag des darauffolgenden Monats."
        },
        {
          "absatz": "2",
          "text": "Der Zinssatz entspricht dem aktuellen Mindestzinssatz in der beruflichen Vorsorge. Er beträgt höchstens aber 5 Prozent."
        },
        {
          "absatz": "3",
          "text": "Der Zins wird jährlich fällig und in Rechnung gestellt."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "039f4e552cbc266c9bec323cc996c1b154201c2c28318ac53efd3981e085ee78"
    },
    {
      "id": "kanton/AR/415.211/art_37",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "37",
      "artikelLabel": "Art. 37",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gesuche um Ausbildungsbeiträge sind mit dem amtlichen Formular und den erforderlichen Unterlagen spätestens drei Monate nach Beginn der massgebenden Ausbildungsperiode der Abteilung Ausbildungs- und Studienbeiträge einzureichen."
        },
        {
          "absatz": "2",
          "text": "Das Gesuch ist in der Regel für jedes Ausbildungsjahr zu erneuern."
        },
        {
          "absatz": "3",
          "text": "Auf verspätete oder unvollständige Gesuche wird nicht eingetreten."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "80b9a0f176e1559638a5022d803b99c8cc5b4e59116741dc1c550d68d2f333b5"
    },
    {
      "id": "kanton/AR/415.211/art_38",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "38",
      "artikelLabel": "Art. 38",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Über die Gewährung von Ausbildungsbeiträgen entscheidet das Amt für Mittel- und Hochschulen und Berufsbildung. Das Departement Bildung und Kultur kann die Befugnis ganz oder teilweise an die Abteilung Ausbildungs- und Studienbeiträge delegieren."
        },
        {
          "absatz": "2",
          "text": "Gegen die Beitragsverfügung steht der Rekurs an das Departement Bildung und Kultur offen."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2d991a084b000cb2f379daba662b42f7",
      "sha": "8f73e3e2f033144e52acc6cbf0b38661cb427454a558e081792b8067a8567bde"
    },
    {
      "id": "kanton/AR/415.211/art_39",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Stipendienverordnung (415.211)",
      "artikel": "39",
      "artikelLabel": "Art. 39",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Auszahlung von Ausbildungsbeiträgen erfolgt auf ein Bank- oder Postkonto in der Schweiz."
        }
      ],
      "stand": "2018-02-13",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/415.211",
      "abgerufen": "2026-06-23",
