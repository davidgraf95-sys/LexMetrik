{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/RiE 890.110/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfereglement (RiE 890.110)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Rekursverfahren gegen Verfügungen der zuständigen Sozialhilfestelle richtet sich unter Vorbehalt der Bestimmungen dieses Reglements nach den Vorschriften des kantonalen Organisationsgesetzes."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "020d11c15ad48d738ae943d891bb1132",
      "sha": "1ae9e001d6f1f73f5042f546e3189e4a5bbe98fff40b8ab2207f9c9982344083"
    },
    {
      "id": "kanton/BS/RiE 890.110/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfereglement (RiE 890.110)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Sozialhilfestelle kann eine angefochtene Verfügung in Wiedererwägung ziehen, so lange der Gemeinderat über einen Rekurs noch nicht entschieden hat."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "020d11c15ad48d738ae943d891bb1132",
      "sha": "4392b0cc5fbdbc5d7747147c0d74860f430974de7f779aa42733d8768030d114"
    },
    {
      "id": "kanton/BS/RiE 890.110/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfereglement (RiE 890.110)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Gemeinderat entscheidet über Rekurse gegen Verfügungen der zuständigen Sozialhilfestelle."
        },
        {
          "absatz": "2",
          "text": "Seinen Entscheid fällt er in Kenntnis der Stellungnahme und der Anträge des Sozialhilfebeirats."
        },
        {
          "absatz": "3",
          "text": "Der Gemeinderat ist nicht an die Anträge des Sozialhilfebeirats gebunden."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "020d11c15ad48d738ae943d891bb1132",
      "sha": "82e0f7526946f5800545a025982e073691e898c83c6afeeeb889b13d6d0adb12"
    },
    {
      "id": "kanton/BS/RiE 890.110/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfereglement (RiE 890.110)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "In der Regel zieht der Gemeinderat bei Rekursen gegen Verfügungen der zuständigen Sozialhilfestelle den Sozialhilfebeirat zur Entscheidvorbereitung bei."
        },
        {
          "absatz": "2",
          "text": "Bei einfachen Sachverhalten und offensichtlich aussichtslosen Rekursen kann der Gemeinderat Entscheidungen ohne den Beizug des Sozialhilfebeirats fällen."
        },
        {
          "absatz": "3",
          "text": "Der Gemeinderat stellt die an ihn gerichteten Rekurse mit Ausnahme der in Abs. 2 genannten Fälle unverzüglich dem Sozialhilfebeirat zur Stellungnahme und Antragstellung zu."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "020d11c15ad48d738ae943d891bb1132",
      "sha": "5bd0450ccfe2d464b77083a16c901292fe82f8fc5027261a678fa00e7a466d3a"
    },
    {
      "id": "kanton/BS/RiE 890.110/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfereglement (RiE 890.110)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Sozialhilfebeirat berät mindestens in Dreierbesetzung."
        },
        {
          "absatz": "2",
          "text": "Seine Beschlüsse fasst er mit einfacher Stimmenmehrheit. Bei Stimmengleichheit hat die Präsidentin oder der Präsident den Stichentscheid."
        },
        {
          "absatz": "3",
          "text": "Die Beschlüsse teilt er dem Gemeinderat in Form einer schriftlichen Stellungnahme mit. Die Stellungnahme enthält einen Antrag."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "020d11c15ad48d738ae943d891bb1132",
      "sha": "3fa0b97481987e68f5e7f5b03508aa30542573d992d8f7cb86096eff32509a38"
    },
    {
      "id": "kanton/BS/RiE 890.110/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfereglement (RiE 890.110)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Präsidium des Sozialhilfebeirats wird vom zuständigen Mitglied des Gemeinderats ausgeübt."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "020d11c15ad48d738ae943d891bb1132",
      "sha": "4ce0884ba1bf2f60ceccd500424897bc32e5746981eb8bff60809bc101ce1e0f"
    },
    {
      "id": "kanton/BS/RiE 890.110/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfereglement (RiE 890.110)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Gemeinderat bestimmt die Sekretärin oder den Sekretär des Sozialhilfebeirats."
        },
        {
          "absatz": "2",
          "text": "Sie oder er verfügt über einen juristischen Hochschulabschluss."
        },
        {
          "absatz": "3",
          "text": "Das Sekretariat unterstützt die Präsidentin oder den Präsidenten in fachlicher und administrativer Hinsicht."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "020d11c15ad48d738ae943d891bb1132",
      "sha": "f5f97acdc2ccb2c626cc17b5aaf39b2e6e1147b13e1988149264042a5eff53a1"
    },
    {
      "id": "kanton/BS/RiE 890.110/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfereglement (RiE 890.110)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Präsidentin oder der Präsident legt die Organisation des Sozialhilfebeirats fest, leitet dessen Sitzungen und trifft die für einen regulären Verfahrensablauf notwendigen Anordnungen und Entscheidungen."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "020d11c15ad48d738ae943d891bb1132",
      "sha": "093a222b9590f437f15e159d50e63dfb89c2756f1da66d41666a9d96aaab3627"
    },
    {
      "id": "kanton/BS/RiE 890.110/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfereglement (RiE 890.110)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Auf Antrag einer Partei oder eines Mitglieds des Sozialhilfebeirats ordnet die Präsidentin oder der Präsident die Durchführung einer mündlichen Anhörung der Rekurrentin oder des Rekurrenten vor dem Sozialhilfebeirat an."
        },
        {
          "absatz": "2",
          "text": "Das Recht der Rekurrentin oder des Rekurrenten, vom Gemeinderat oder Gemeindepräsidium angehört zu werden, wird durch die Anhörung vor dem Sozialhilfebeirat nicht tangiert."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "020d11c15ad48d738ae943d891bb1132",
      "sha": "b5bb8bf7fa41f998f78699f08720aa3c01e74125a2bc240932d6082ca06af754"
    },
    {
      "id": "kanton/BS/RiE 890.110/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfereglement (RiE 890.110)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Mitglieder des Sozialhilfebeirats wahren den Datenschutz."
        },
        {
          "absatz": "2",
          "text": "Sie übergeben im Zeitpunkt der Beendigung des Amts alle Dokumente und Akten, die sie im Zusammenhang mit ihrem Amt erhalten haben, dem Sekretariat."
        },
        {
          "absatz": "3",
          "text": "Nach Beendigung des Amts sind sie weiterhin zur Verschwiegenheit verpflichtet."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "020d11c15ad48d738ae943d891bb1132",
      "sha": "c17d681867529134e0cb3f248e686b31dee14c973da7baea8a16a605316ba541"
    },
    {
      "id": "kanton/BS/RiE 890.110/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfereglement (RiE 890.110)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Den Mitgliedern des Sozialhilfebeirats wird die zu ihrer Aufgabenerfüllung notwendige Akteneinsicht gewährt."
        },
        {
          "absatz": "2",
          "text": "Benötigen sie Auskünfte von Mitarbeitenden der Gemeindeverwaltung, kann die Präsidentin oder der Präsident deren Anhörung oder Stellungnahme anordnen."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "020d11c15ad48d738ae943d891bb1132",
      "sha": "f520438a5aa137d8d32987dff642963694a56e4393fb74b1c09e501a0533f574"
    },
    {
      "id": "kanton/BS/RiE 890.110/art_12",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfereglement (RiE 890.110)",
      "artikel": "12",
      "artikelLabel": "§ 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Mitglieder des Sozialhilfebeirats werden wie Mitglieder von gemeinderätlichen Kommissionen entschädigt."
        },
        {
          "absatz": "2",
          "text": "Die Sekretärin oder der Sekretär wird nach Aufwand entschädigt. Die Entschädigung richtet sich nach den Ansätzen der Besoldungsordnung für das Gemeindepersonal."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "020d11c15ad48d738ae943d891bb1132",
      "sha": "733d45926b3346a7ecf83a3a2f3ce73e044d24825385e2bd4e8f3f906f0fc2cd"
    },
    {
      "id": "kanton/BS/RiE 890.110/art_13",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfereglement (RiE 890.110)",
      "artikel": "13",
      "artikelLabel": "§ 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Gemeinderat kann einzelne Spezialaufgaben aus dem Bereich der Sozialhilfe an Dritte übertragen."
        },
        {
          "absatz": "2",
          "text": "Im Rahmen der festgelegten Finanzkompetenzen kann die Gemeindeverwaltung einzelne Aufträge direkt an Dritte vergeben."
        },
        {
          "absatz": "3",
          "text": "Die zu übertragenden einzelnen Spezialaufgaben und die Leistungsmodalitäten werden in einer schriftlichen Vereinbarung festgelegt. Die Übertragungen werden befristet."
        },
        {
          "absatz": "4",
          "text": "Als übertragbare Spezialaufgaben gelten insbesondere",
          "items": [
            {
              "marke": "a",
              "text": "die Refundationen sowie"
            },
            {
              "marke": "b",
              "text": "die allgemeinen Familien- und Einzelberatungen."
            }
          ]
        },
        {
          "absatz": "5",
          "text": "Die Gewährung der wirtschaftlichen Hilfe an bedürftige Einwohnerinnen und Einwohner sind nicht an Dritte zu übertragen."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "020d11c15ad48d738ae943d891bb1132",
      "sha": "242c948dd99da196a876e230d38f22515fbc334bea5eb1b8e8ffc5ac7796dca2"
    },
    {
      "id": "kanton/BS/RiE 890.110/art_14",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Sozialhilfereglement (RiE 890.110)",
      "artikel": "14",
      "artikelLabel": "§ 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieses Reglement wird publiziert."
        },
        {
          "absatz": "2",
          "text": "Es wird am 1. Januar 2005 wirksam."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 890.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "020d11c15ad48d738ae943d891bb1132",
      "sha": "1d8dc8ec004b0547f4e37f7e99f48520477f88498ab44b0bdc0558a12845e00c"
    }
  ]
}