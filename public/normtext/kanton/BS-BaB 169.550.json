{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/BaB 169.550/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die sozialpartnerschaftliche Begutachtungskommission (BaB 169.550)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Den Mitarbeitenden steht ein Mitspracherecht zu, welches für die Bürgergemeinde in ihrer Gesamtheit durch die Personalvertretung in der sozialpartnerschaftlichen Begutachtungskommission wahrgenommen wird."
        },
        {
          "absatz": "2",
          "text": "Die sozialpartnerschaftliche Begutachtungskommission beurteilt zuhanden des Bürgerrats Geschäfte betreffend die Ausgestaltung und Handhabung der Anstellungsordnung und der Lohnordnung sowie der jeweiligen Ausführungserlasse."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 169.550",
      "abgerufen": "2026-06-23",
      "fassungsToken": "be0ce71d2ee2354153ac1eb2161b212a",
      "sha": "0b8f97cea8728f4502ef1219f3df6a8cd5a2833c191a708b9f5e709e28ca5450"
    },
    {
      "id": "kanton/BS/BaB 169.550/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die sozialpartnerschaftliche Begutachtungskommission (BaB 169.550)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die sozialpartnerschaftliche Begutachtungskommission ist paritätisch zusammengesetzt und besteht aus vier Vertretenden der Mitarbeitenden und vier Vertretenden der Arbeitgebenden (Institutionen und Zentrale Dienste)."
        },
        {
          "absatz": "2",
          "text": "Die Leitung Zentrale Personaldienste nimmt von Amtes wegen an den Sitzungen mit beratender Stimme teil."
        },
        {
          "absatz": "3",
          "text": "Der Vorsitz wechselt jährlich zwischen Arbeitgeber- und Arbeitnehmervertretung. In der Herbst-Sitzung wird jeweils der Vorsitz für das kommende Jahr bestimmt."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 169.550",
      "abgerufen": "2026-06-23",
      "fassungsToken": "be0ce71d2ee2354153ac1eb2161b212a",
      "sha": "4140656c793f93c8a050a6fae70d23bffbeb9e8f228127827cb8391f92de9b31"
    },
    {
      "id": "kanton/BS/BaB 169.550/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die sozialpartnerschaftliche Begutachtungskommission (BaB 169.550)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Mitglieder der sozialpartnerschaftlichen Begutachtungskommission werden für die Dauer von sechs Jahren gewählt."
        },
        {
          "absatz": "2",
          "text": "Die Amtsdauer entspricht der Legislatur für die politischen Behörden und beginnt jeweils am 1. September nach deren Erneuerungswahlen."
        },
        {
          "absatz": "3",
          "text": "Eine Wiederwahl ist möglich."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 169.550",
      "abgerufen": "2026-06-23",
      "fassungsToken": "be0ce71d2ee2354153ac1eb2161b212a",
      "sha": "c0156f439bdb44a9b348b537a3aea5320ba8b854505a566c95aa9cd1a9f2e6bb"
    },
    {
      "id": "kanton/BS/BaB 169.550/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die sozialpartnerschaftliche Begutachtungskommission (BaB 169.550)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Leitung Zentrale Personaldienste ladet zur Sitzung ein und stellt die Unterlagen zur Verfügung."
        },
        {
          "absatz": "2",
          "text": "Es findet mindestens eine Sitzung zur Behandlung der Lohnrunde statt."
        },
        {
          "absatz": "3",
          "text": "Weitere Sitzungen werden nach Bedarf oder auf Wunsch der Mehrheit der Kommissionsmitglieder von der Leitung Zentrale Personaldienste einberufen."
        },
        {
          "absatz": "4",
          "text": "Die Leitung Zentrale Personaldienste erstellt das Sitzungsprotokoll."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 169.550",
      "abgerufen": "2026-06-23",
      "fassungsToken": "be0ce71d2ee2354153ac1eb2161b212a",
      "sha": "5fcaafcc02d6deccf3c1d18a298445427901121b71d636f0225f9f759252c243"
    },
    {
      "id": "kanton/BS/BaB 169.550/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die sozialpartnerschaftliche Begutachtungskommission (BaB 169.550)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Leitung Zentrale Personaldienste informiert den Bürgerrat über die Haltung der Kommission zu den ihr unterbreiteten Geschäften."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 169.550",
      "abgerufen": "2026-06-23",
      "fassungsToken": "be0ce71d2ee2354153ac1eb2161b212a",
      "sha": "cd13f47c3d5bd29f499cec1984f3d19821df8c19f9c1faf9038738ce254d290a"
    },
    {
      "id": "kanton/BS/BaB 169.550/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die sozialpartnerschaftliche Begutachtungskommission (BaB 169.550)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Institutionen und Zentralen Dienste gewähren den Kommissionsmitgliedern für die Sitzungsteilnahme und deren Vorbereitung die effektive zeitliche Beanspruchung als bezahlte Arbeitszeit."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 169.550",
      "abgerufen": "2026-06-23",
      "fassungsToken": "be0ce71d2ee2354153ac1eb2161b212a",
      "sha": "b7edba0ae5f75028287a5123f6769a41e91c7a5d3e13715c36da94728801e2bf"
    },
    {
      "id": "kanton/BS/BaB 169.550/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die sozialpartnerschaftliche Begutachtungskommission (BaB 169.550)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die der sozialpartnerschaftlichen Begutachtungskommission unterbreiteten Geschäfte und die Beratungen sind vertraulich zu behandeln. Informationen darüber dürfen nicht an Aussenstehende weitergegeben werden."
        },
        {
          "absatz": "2",
          "text": "Die Verletzung der Vertraulichkeit kann den Ausschluss aus der Kommission zur Folge haben."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 169.550",
      "abgerufen": "2026-06-23",
      "fassungsToken": "be0ce71d2ee2354153ac1eb2161b212a",
      "sha": "2ae63a33fe3d638a51776f65a0d10840219182b5fe4116d3b6ce23e8eaa1f546"
    },
    {
      "id": "kanton/BS/BaB 169.550/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die sozialpartnerschaftliche Begutachtungskommission (BaB 169.550)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Vertretenden der Arbeitgebenden werden vom Bürgerrat auf Antrag der Direktionen der Institutionen und der Zentralen Dienste gewählt."
        },
        {
          "absatz": "2",
          "text": "Die Vertretenden der Mitarbeitenden werden von den bei der Bürgergemeinde (Institutionen und Zentrale Dienste) öffentlich-rechtlich angestellten Mitarbeitenden gewählt."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 169.550",
      "abgerufen": "2026-06-23",
      "fassungsToken": "be0ce71d2ee2354153ac1eb2161b212a",
      "sha": "8c688223984786530e92b9b134f1cbb021151798720f6891f90bd2193c0dc0ac"
    },
    {
      "id": "kanton/BS/BaB 169.550/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die sozialpartnerschaftliche Begutachtungskommission (BaB 169.550)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wahlberechtigt und wählbar sind Mitarbeitende der Bürgergemeinde (Institutionen und Zentrale Dienste), die in einem unbefristeten öffentlich-rechtlichen Arbeitsverhältnis stehen und nicht mehr in der Probezeit sind."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 169.550",
      "abgerufen": "2026-06-23",
      "fassungsToken": "be0ce71d2ee2354153ac1eb2161b212a",
      "sha": "c08369aa6975316e2cadf985dd33bfc3a82e9973eb6e91591dbdab497fa70695"
    },
    {
      "id": "kanton/BS/BaB 169.550/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die sozialpartnerschaftliche Begutachtungskommission (BaB 169.550)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Leitung Zentrale Personaldienste ist als Wahlbüro für die Durchführung der Wahlen zuständig."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 169.550",
      "abgerufen": "2026-06-23",
      "fassungsToken": "be0ce71d2ee2354153ac1eb2161b212a",
      "sha": "53c4909df4203a711b8587901ff8bfcaf8dca6da84cab1f94cc80ecff5da0597"
    },
    {
      "id": "kanton/BS/BaB 169.550/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die sozialpartnerschaftliche Begutachtungskommission (BaB 169.550)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Wahlen sind bis spätestens sechs Wochen vor den Erneuerungswahlen abgeschlossen."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 169.550",
      "abgerufen": "2026-06-23",
      "fassungsToken": "be0ce71d2ee2354153ac1eb2161b212a",
      "sha": "3ae30f031bc367bc2745031b484c0d260e92195e0aa42a491a7a37e47102a70b"
    },
    {
      "id": "kanton/BS/BaB 169.550/art_12",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die sozialpartnerschaftliche Begutachtungskommission (BaB 169.550)",
      "artikel": "12",
      "artikelLabel": "§ 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Wahlberechtigten üben ihr Wahlrecht schriftlich aus."
        },
        {
          "absatz": "2",
          "text": "Die Wahlen erfolgen nach dem Grundsatz des relativen Mehrs."
        },
        {
          "absatz": "3",
          "text": "Gewählt sind die Kandidatinnen oder Kandidaten mit der höchsten Stimmenzahl. Bei Stimmengleichheit entscheidet das Los. Die Nächstfolgenden gelten als Nachrückende."
        },
        {
          "absatz": "4",
          "text": "Stille Wahlen sind möglich."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 169.550",
      "abgerufen": "2026-06-23",
      "fassungsToken": "be0ce71d2ee2354153ac1eb2161b212a",
      "sha": "b468e99ffb2f2c8cdb8116dc6dfb6367cd335aefe1f325dafc5e65ef48f7b951"
    },
    {
      "id": "kanton/BS/BaB 169.550/art_13",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die sozialpartnerschaftliche Begutachtungskommission (BaB 169.550)",
      "artikel": "13",
      "artikelLabel": "§ 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Wahlbüro stellt den Wahlberechtigten das Wahlvorschlagsformular zu."
        },
        {
          "absatz": "2",
          "text": "Eine Person muss von mindestens drei Wahlberechtigten vorgeschlagen werden und die Annahme einer allfälligen Wahl unterschriftlich bestätigen."
        },
        {
          "absatz": "3",
          "text": "Treffen innert der vom Wahlbüro gesetzten Frist weniger als vier Wahlvorschläge ein, so fordert das Wahlbüro die Institutionen und die Zentralen Dienste auf, Nachnominationen vorzunehmen."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 169.550",
      "abgerufen": "2026-06-23",
      "fassungsToken": "be0ce71d2ee2354153ac1eb2161b212a",
      "sha": "f79ea93d3eb71b045810d0b32e9b5d234d43f482b6b5998aa9e05e43abcfe15d"
    },
    {
      "id": "kanton/BS/BaB 169.550/art_14",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die sozialpartnerschaftliche Begutachtungskommission (BaB 169.550)",
      "artikel": "14",
      "artikelLabel": "§ 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Wahlbüro stellt den Wahlberechtigten die Wahlvorschläge mit dem Wahlcouvert und dem Wahlzettel zu."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 169.550",
      "abgerufen": "2026-06-23",
      "fassungsToken": "be0ce71d2ee2354153ac1eb2161b212a",
      "sha": "891832436e45fec4a97973d49b8ae7f124767c55d1267f2d3f4398ec6f6658eb"
    },
    {
      "id": "kanton/BS/BaB 169.550/art_15",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die sozialpartnerschaftliche Begutachtungskommission (BaB 169.550)",
      "artikel": "15",
      "artikelLabel": "§ 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Wahlzettel muss handschriftlich ausgefüllt sein und darf maximal vier vorgeschlagene Personen enthalten."
        },
        {
          "absatz": "2",
          "text": "Bei Mehrfachnennungen wird nur eine Stimme gezählt."
        },
        {
          "absatz": "3",
          "text": "Wahlzettel, die nicht den Namen mindestens einer wählbaren Person enthalten, sind ungültig."
        },
        {
          "absatz": "4",
          "text": "Wahlzettel ohne Nennung einer Person gelten als leer."
        },
        {
          "absatz": "5",
          "text": "Der Wahlzettel muss bis zum vom Wahlbüro vorgegebenen Termin im Wahlbüro eintreffen."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 169.550",
      "abgerufen": "2026-06-23",
      "fassungsToken": "be0ce71d2ee2354153ac1eb2161b212a",
      "sha": "b83c342de4cdb9a1293bce8d4c9d5cf3e7043c7817045a8fda3bed4370914144"
    },
    {
      "id": "kanton/BS/BaB 169.550/art_16",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die sozialpartnerschaftliche Begutachtungskommission (BaB 169.550)",
      "artikel": "16",
      "artikelLabel": "§ 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Stimmen werden vom Wahlbüro im Beisein der Leitung des Zentralen Rechtsdiensts ausgezählt."
        },
        {
          "absatz": "2",
          "text": "Die Wahl wird protokolliert. Das Protokoll enthält:",
          "items": [
            {
              "marke": "a",
              "text": "die Zahl der eingegangenen Wahlzettel;"
            },
            {
              "marke": "b",
              "text": "die Zahl der leeren Wahlzettel;"
            },
            {
              "marke": "c",
              "text": "die Zahl der ungültigen Wahlzettel;"
            },
            {
              "marke": "d",
              "text": "die Namen der gewählten Personen."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Die Wahlergebnisse werden mit Hinweis auf die Beschwerdemöglichkeit auf der Webseite und im Intranet der Bürgergemeinde publiziert."
        },
        {
          "absatz": "4",
          "text": "Beschwerden gegen Unregelmässigkeiten bei der Wahlvorbereitung oder -durchführung sind innert 10 Tagen beim Bürgerrat einzureichen."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 169.550",
      "abgerufen": "2026-06-23",
      "fassungsToken": "be0ce71d2ee2354153ac1eb2161b212a",
      "sha": "47207eba361143bc0a5d08d263658d018a62d2f728baab6760a052410ea297f8"
    },
    {
      "id": "kanton/BS/BaB 169.550/art_17",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die sozialpartnerschaftliche Begutachtungskommission (BaB 169.550)",
      "artikel": "17",
      "artikelLabel": "§ 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Über die Gültigkeit der Wahlen beschliesst der Bürgerrat auf Bericht und Antrag des Wahlbüros."
        },
        {
          "absatz": "2",
          "text": "Der Validierungsbeschluss wird von der Leitung Zentrale Personaldienste auf der Webseite und im Intranet der Bürgergemeinde publiziert."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 169.550",
      "abgerufen": "2026-06-23",
      "fassungsToken": "be0ce71d2ee2354153ac1eb2161b212a",
      "sha": "c917a479e520b9efe3ee14ab3bd841dfb57018e09b39bc150c403f7d08e8ba29"
    },
    {
      "id": "kanton/BS/BaB 169.550/art_18",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die sozialpartnerschaftliche Begutachtungskommission (BaB 169.550)",
      "artikel": "18",
      "artikelLabel": "§ 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Ausscheiden eines Mitglieds der Vertretung der Mitarbeitenden während der Amtsdauer rückt die nächste nicht gewählte Person mit der höchsten Stimmenzahl nach."
        },
        {
          "absatz": "2",
          "text": "Stehen keine Personen zur Verfügung erfolgt eine Ersatzwahl, sofern die Amtsdauer noch mindestens zwei Jahre beträgt."
        },
        {
          "absatz": "3",
          "text": "Das Wahlbüro fordert die Institutionen und die Zentralen Dienste auf, einen Wahlvorschlag einzureichen."
        },
        {
          "absatz": "4",
          "text": "Wird innert der vom Wahlbüro gesetzten Frist nur ein Wahlvorschlag eingereicht, so gilt diese Kandidatin oder dieser Kandidat als in stiller Wahl gewählt."
        },
        {
          "absatz": "5",
          "text": "Werden mehrere Wahlvorschläge eingereicht, werden vom Wahlbüro schriftliche Wahlen gemäss §§ 13 ff. durchgeführt."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 169.550",
      "abgerufen": "2026-06-23",
      "fassungsToken": "be0ce71d2ee2354153ac1eb2161b212a",
      "sha": "c71d82d091067cb2c71e16ae83da698283d4ccfc6f4a7ceba1eac8c0bdd7afa1"
    }
  ]
}