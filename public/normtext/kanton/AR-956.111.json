    },
    {
      "id": "kanton/AR/956.111/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Auslagentarif für Eicharbeiten (956.111)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Auslagenersatz für das Erstellen von Eich- und Prüfzertifikaten beträgt:",
          "items": [
            {
              "marke": "a",
              "text": "Einzel-Eichzertifikat/Einzel-Prüfzertifikat Fr. 15.--"
            },
            {
              "marke": "b",
              "text": "Mehrfach-Eichzertifikat/Mehrfach-Prüfzertifikat Fr. 45.--"
            }
          ]
        }
      ],
      "stand": "2008-12-02",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/956.111",
      "abgerufen": "2026-06-23",
