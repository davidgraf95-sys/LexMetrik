{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/956.111/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Auslagentarif für Eicharbeiten (956.111)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Auslagenersatz für Gewichte, Transport und Reisezeit zur Eichung und Prüfung von Waagen beträgt:",
          "items": [
            {
              "marke": "a",
              "text": "bis 20 kg Fr. 14.--"
            },
            {
              "marke": "b",
              "text": "über 20 kg bis 50 kg Fr. 22.--"
            },
            {
              "marke": "c",
              "text": "über 50 kg bis 100 kg Fr. 29.--"
            },
            {
              "marke": "d",
              "text": "über 100 kg bis 200 kg Fr. 40.--"
            },
            {
              "marke": "e",
              "text": "über 200 kg bis 500 kg Fr. 46.--"
            },
            {
              "marke": "f",
              "text": "über 500 kg bis 1000 kg Fr. 59.--"
            },
            {
              "marke": "g",
              "text": "über 1000 kg bis 1500 kg Fr. 72.--"
            },
            {
              "marke": "h",
              "text": "über 1500 kg bis 2000 kg Fr. 90.--"
            },
            {
              "marke": "i",
              "text": "über 2000 kg nach Zeitaufwand, mindestens Fr. 90.--"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Bei Betrieben mit mehreren Wiegegeräten richtet sich der Auslagenersatz nach dem Wiegegerät mit der grössten Wiegefähigkeit."
        },
        {
          "absatz": "3",
          "text": "Bei der Eichung von Grosswaagen sind die Auslagen für den Eichlastenzug zusätzlich zu ersetzen."
        }
      ],
      "stand": "2008-12-02",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/956.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "94b24ddae7db9e4664840120cec55028",
      "sha": "ee77b5acf08129c5cf7c1515adc7429f65bdde1949b619e604864cc6455df465"
    },
    {
      "id": "kanton/AR/956.111/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Auslagentarif für Eicharbeiten (956.111)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Auslagenersatz für Messmittel, Transport und Reisezeit zur Eichung von Tanksäulen beträgt:",
          "items": [
            {
              "marke": "a",
              "text": "Betrieb mit bis zu fünf Zapfhähnen Fr. 35.--"
            },
            {
              "marke": "b",
              "text": "Betrieb mit mehr als fünf Zapfhähnen Fr. 45.--"
            }
          ]
        }
      ],
      "stand": "2008-12-02",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/956.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "94b24ddae7db9e4664840120cec55028",
      "sha": "0dc768a1adcb7a89812757c0db0a29d0f4b67b1df470de1b577a8925551d30e1"
    },
    {
      "id": "kanton/AR/956.111/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Auslagentarif für Eicharbeiten (956.111)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Auslagenersatz für die Eichung von Durchlaufzählern und Milchmessanlagen, erfolgt nach Aufwand. Zusätzliche externe Prüfmittel werden mit den effektiven Kosten weiterverrechnet."
        }
      ],
      "stand": "2008-12-02",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/956.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "94b24ddae7db9e4664840120cec55028",
      "sha": "8066b4db87fc395e6862d41894609ea926759a988a5585eb1f0a6b26f33fc2f2"
    },
    {
      "id": "kanton/AR/956.111/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Auslagentarif für Eicharbeiten (956.111)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Auslagenersatz für die Eichung von Abgasmessgeräten beträgt pauschal Fr. 35.-- für Messmittel, Transport und Reisezeit. Zusätzliche externe Prüfmittel (Referenz- und Kalibriergas, Graufiltermessgeräte etc.) werden mit den effektiven Kosten weiterverrechnet."
        }
      ],
      "stand": "2008-12-02",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/956.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "94b24ddae7db9e4664840120cec55028",
      "sha": "7dc02ef7bd7b77cf1a31cfb22aac01e94b73a4622f6b281020f114a592901976"
    },
    {
      "id": "kanton/AR/956.111/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Auslagentarif für Eicharbeiten (956.111)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Auslagenersatz für Fahrspesen ohne Eichgerätschaften innerhalb des Kantons beträgt pauschal Fr. 35.--."
        }
      ],
      "stand": "2008-12-02",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/956.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "94b24ddae7db9e4664840120cec55028",
      "sha": "e533a8b2fca2b3021ac2e8894d3e6724accb1fe31340344093c8d30d1ad0cc74"
    },
    {
      "id": "kanton/AR/956.111/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Auslagentarif für Eicharbeiten (956.111)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Amt kann für temporäre Einsätze Hilfspersonal beauftragen. Der Stundenansatz beträgt Fr. 55.--."
        }
      ],
      "stand": "2008-12-02",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/956.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "94b24ddae7db9e4664840120cec55028",
