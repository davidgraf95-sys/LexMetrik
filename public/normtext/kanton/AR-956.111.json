    },
    {
      "id": "kanton/AR/956.111/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Auslagentarif für Eicharbeiten (956.111)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Kann eine Eichung, Kontrolle oder Nachschau aus Gründen, welche von der gebührenpflichtigen Person zu verantworten sind, nicht erfolgreich durchgeführt werden, richtet sich der Auslagenersatz nach dem Zeitaufwand."
        }
      ],
      "stand": "2008-12-02",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/956.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "94b24ddae7db9e4664840120cec55028",
      "sha": "a09192af209ea4ca71520c7d363be0422a6ec8a63642956e0f0b9bdd8f9c5893"
    },
    {
      "id": "kanton/AR/956.111/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Auslagentarif für Eicharbeiten (956.111)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für Justierarbeiten richtet sich der Auslagenersatz nach dem Zeitaufwand."
        }
      ],
      "stand": "2008-12-02",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/956.111",
      "abgerufen": "2026-06-23",
