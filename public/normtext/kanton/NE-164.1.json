{
  "erzeugt": "2026-06-16",
  "eintraege": [
    {
      "id": "kanton/NE/164.1/art_12",
      "ebene": "kanton",
      "quelle": "NE",
      "erlass": "Loi sur les tarifs des frais (LTFrais) (RSN 164.1)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dans les affaires soumises à la procédure ordinaire ou à la procédure simplifiée, l'émolument forfaitaire de décision est fixé selon le tarif suivant :",
          "items": [
            {
              "marke": "- jusqu’à 2'000.–",
              "text": "500.–"
            },
            {
              "marke": "- de 2'001.– à 5’000.–",
              "text": "900.–"
            },
            {
              "marke": "- de 5'001.– à 8’000.–",
              "text": "1'000.–"
            },
            {
              "marke": "- de 8'001.– à 10’000.–",
              "text": "1'200.–"
            },
            {
              "marke": "- de 10'001.– à 30’000.–",
              "text": "13% de la valeur litigieuse"
            },
            {
              "marke": "- de 30'001.– à 100’000.–",
              "text": "4'000.– + 3% de la valeur litigieuse supérieure à 30'000.–"
            },
            {
              "marke": "- de 100'001.– à 1'000’000.–",
              "text": "6'500.– + 3% de la valeur litigieuse supérieure à 100'000.–"
            },
            {
              "marke": "- en-dessus de 1'000'000.–",
              "text": "4% (jusqu’à 300'000.–)"
            }
          ]
        },
        {
          "absatz": null,
          "text": "L’émolument est arrondi à la dizaine inférieure."
        },
        {
          "absatz": "2",
          "text": "Sont réservées les exceptions découlant des dispositions suivantes."
        },
        {
          "absatz": "2bis",
          "text": "Si l’affaire est de nature non patrimoniale, l’émolument forfaitaire de décision est fixé entre 500 et 50'000 francs."
        },
        {
          "absatz": "3",
          "text": "L’autorité peut s’écarter de ce tarif lorsque sa mise à contribution ne justifie pas l’émolument calculé selon les alinéas 1 et 2bis."
        }
      ],
      "stand": "2023-04-01",
      "quelleUrl": "https://rsn.ne.ch/DATA/program/books/RSN2024/20245/htm/164.1.htm",
      "abgerufen": "2026-06-16",
      "fassungsToken": "a111a54c8c2fe1d038fea2869a5a7dfd95af2aabbe00a9e77e4f26a2ae7ed0d9",
      "sha": "d6995086818fb98a30d7aff9edaba952cf313fed1fd2cb062458a6d0ce995a68"
    },
    {
      "id": "kanton/NE/164.1/art_11",
      "ebene": "kanton",
      "quelle": "NE",
      "erlass": "Loi sur les tarifs des frais (LTFrais) (RSN 164.1)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "L'émolument forfaitaire de conciliation est fixé selon le tarif suivant :",
          "items": [
            {
              "marke": "- jusqu'à 2'000.-",
              "text": "300.-"
            },
            {
              "marke": "- de 2'001.- à 5'000.-",
              "text": "400.-"
            },
            {
              "marke": "- de 5'001.- à 8'000.-",
              "text": "500.-"
            },
            {
              "marke": "- de 8'001.- à 10'000.-",
              "text": "6 00.-"
            },
            {
              "marke": "- de 10'001.- à 30'000.-",
              "text": "1'000.-"
            },
            {
              "marke": "- de 30'001.- à 100'000.-",
              "text": "1'300.-"
            },
            {
              "marke": "- de 100'001.- à 500'000.-",
              "text": "1'900.-"
            },
            {
              "marke": "- en-dessus de 500'000.-",
              "text": "2'500.-"
            }
          ]
        },
        {
          "absatz": "1bis",
          "text": "Si l’affaire est de nature non patrimoniale, l’émolument forfaitaire de décision est fixé entre 300 et 2'500 francs."
        },
        {
          "absatz": "2",
          "text": "Si l’affaire a nécessité peu de travail, les frais peuvent être réduits jusqu’à 300 francs. En principe, les frais ne sont pas réduits si la conciliation aboutit."
        },
        {
          "absatz": "3",
          "text": "Cet émolument couvre l'ensemble des opérations menées par la Chambre de conciliation et notamment, le cas échéant, la tenue d'audiences supplémentaires (art. 203, al. 4 CPC), la proposition de jugement (art. 210 CPC) et la décision au fond (art. 212 CPC). Les frais d’administration des preuves sont réservés."
        }
      ],
      "stand": "2023-04-01",
      "quelleUrl": "https://rsn.ne.ch/DATA/program/books/RSN2024/20245/htm/164.1.htm",
      "abgerufen": "2026-06-16",
      "fassungsToken": "a111a54c8c2fe1d038fea2869a5a7dfd95af2aabbe00a9e77e4f26a2ae7ed0d9",
      "sha": "27b186634da0a9202e0fe4d35b0bcc12447743dd8b7faed0a205554d0c6ae66d"
    },
    {
      "id": "kanton/NE/164.1/art_58",
      "ebene": "kanton",
      "quelle": "NE",
      "erlass": "Loi sur les tarifs des frais (LTFrais) (RSN 164.1)",
      "artikel": "58",
      "artikelLabel": "Art. 58",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Les honoraires sont proportionnés à la valeur litigieuse."
        },
        {
          "absatz": "2",
          "text": "Ils sont fixés dans les limites prévues au présent tarif, en fonction du temps nécessaire à la cause, de sa nature, de son importance, de sa difficulté, du résultat obtenu ainsi que de la responsabilité encourue par le représentant."
        }
      ],
      "stand": "2023-04-01",
      "quelleUrl": "https://rsn.ne.ch/DATA/program/books/RSN2024/20245/htm/164.1.htm",
      "abgerufen": "2026-06-16",
      "fassungsToken": "a111a54c8c2fe1d038fea2869a5a7dfd95af2aabbe00a9e77e4f26a2ae7ed0d9",
      "sha": "16240ab965a0a3609d563231b28d71d5b1c9d57283f1e3b77d52afb042e6435a"
    },
    {
      "id": "kanton/NE/164.1/art_59",
      "ebene": "kanton",
      "quelle": "NE",
      "erlass": "Loi sur les tarifs des frais (LTFrais) (RSN 164.1)",
      "artikel": "59",
      "artikelLabel": "Art. 59",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Les honoraires, taxe sur la valeur ajoutée (TVA) non comprise, sont fixés selon le tarif suivant :",
          "items": [
            {
              "marke": "- jusqu’à 8'000.– jusqu'à",
              "text": "2'500.–"
            },
            {
              "marke": "- de 8'001.– à 20'000,– jusqu'à",
              "text": "5'000.–"
            },
            {
              "marke": "- de 20'001.– à 50'000.– jusqu'à",
              "text": "10'000.–"
            },
            {
              "marke": "- de 50'001.– à 100'000.– jusqu'à",
              "text": "15'000.–"
            },
            {
              "marke": "- de 100'001.– à 200'000.– jusqu'à",
              "text": "25'000.–"
            },
            {
              "marke": "- de 200'001.– à 500'000.– jusqu'à",
              "text": "35'000.–"
            },
            {
              "marke": "- de 500'001.– à 1'000'000.– jusqu'à",
              "text": "45'000.–"
            },
            {
              "marke": "- de 1'000'001.– à 2'000'000.– jusqu'à",
              "text": "55'000.–"
            },
            {
              "marke": "- en-dessus de 2'000'000.– jusqu'à",
              "text": "3%"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Sous réserve de dispositions contraires, si l’affaire est de nature non patrimoniale, ils sont fixés, en application de l’article 58, alinéa 2, à 60'000 francs au plus, taxe sur la valeur ajoutée (TVA) non comprise."
        }
      ],
      "stand": "2023-04-01",
      "quelleUrl": "https://rsn.ne.ch/DATA/program/books/RSN2024/20245/htm/164.1.htm",
      "abgerufen": "2026-06-16",
