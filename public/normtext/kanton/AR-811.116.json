{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/811.116/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Hebammen-Verordnung (811.116)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung regelt die selbständige Ausübung des Berufes der Hebamme."
        }
      ],
      "stand": "1994-03-08",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.116",
      "abgerufen": "2026-06-23",
      "fassungsToken": "a030d3baae0487689f0029be557d46d8",
      "sha": "14a891dbb6a97fad0e08343089948229d310868e4e8847e56ccc7666e70554db"
    },
    {
      "id": "kanton/AR/811.116/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Hebammen-Verordnung (811.116)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die selbständige Ausübung des Berufes der Hebamme bedarf einer Bewilligung der Sanitätskommission."
        }
      ],
      "stand": "1994-03-08",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.116",
      "abgerufen": "2026-06-23",
      "fassungsToken": "a030d3baae0487689f0029be557d46d8",
      "sha": "c422fe2b1557377226f2c39cea8528346220d3f0d2bf883ecf22eefc413a416c"
    },
    {
      "id": "kanton/AR/811.116/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Hebammen-Verordnung (811.116)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Hebamme",
          "items": [
            {
              "marke": "a",
              "text": "berät und überwacht Schwangere,"
            },
            {
              "marke": "b",
              "text": "bereitet Schwangere auf die Geburt vor,"
            },
            {
              "marke": "c",
              "text": "leitet Geburten,"
            },
            {
              "marke": "d",
              "text": "pflegt Wöchnerinnen und Neugeborene."
            }
          ]
        }
      ],
      "stand": "1994-03-08",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.116",
      "abgerufen": "2026-06-23",
      "fassungsToken": "a030d3baae0487689f0029be557d46d8",
      "sha": "1f7f3b74c0ba8422b21ca91a964e80e5e95b1b22ad7a32dcfe3d5e7add2add48"
    },
    {
      "id": "kanton/AR/811.116/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Hebammen-Verordnung (811.116)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Voraussetzung für die selbständige Tätigkeit ist ein vom Schweizerischen Roten Kreuz anerkanntes Diplom oder ein gleichwertiger Ausweis."
        }
      ],
      "stand": "1994-03-08",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.116",
      "abgerufen": "2026-06-23",
      "fassungsToken": "a030d3baae0487689f0029be557d46d8",
      "sha": "e28d33216eb0bf1e1bc256d52ce4f39114c18ffc1bad65fa1f046610393901b2"
    },
    {
      "id": "kanton/AR/811.116/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Hebammen-Verordnung (811.116)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Schwangerschaftskomplikationen ist rechtzeitig ein Arzt beizuziehen."
        },
        {
          "absatz": "2",
          "text": "In Notfällen ist die Schwangere unverzüglich in ein Spital einzuweisen."
        },
        {
          "absatz": "3",
          "text": "Aussergewöhnliche Befunde bei Mutter oder Kind sind sofort dem zuständigen Arzt zu melden."
        },
        {
          "absatz": "4",
          "text": "Die Hebamme ist verantwortlich für alle pflegerischen und medizinischen Massnahmen bei Mutter und Kind gemäss der Praxis in den kantonalen Spitälern."
        },
        {
          "absatz": "5",
          "text": "Bei Totgeburten ist der Kantonsarzt mündlich zu informieren."
        },
        {
          "absatz": "6",
          "text": "Die Hebamme bildet sich regelmässig weiter."
        }
      ],
      "stand": "1994-03-08",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.116",
      "abgerufen": "2026-06-23",
      "fassungsToken": "a030d3baae0487689f0029be557d46d8",
      "sha": "5192b15db0fbf101d3a449ca618682ea2b53011469d9d3b4848d19ed93523d6d"
    },
    {
      "id": "kanton/AR/811.116/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Hebammen-Verordnung (811.116)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Hebammen führen über ihre Tätigkeiten die notwendigen Aufzeichnungen."
        },
        {
          "absatz": "2",
          "text": "Die Aufzeichnungen sind während wenigstens 10 Jahren aufzubewahren und danach zu vernichten."
        }
      ],
      "stand": "1994-03-08",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.116",
      "abgerufen": "2026-06-23",
      "fassungsToken": "a030d3baae0487689f0029be557d46d8",
      "sha": "1d2784f42775aaaeefc2a56a83e960a7e1f04a663db7ae4864f01d579ca91bf9"
    },
    {
      "id": "kanton/AR/811.116/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Hebammen-Verordnung (811.116)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Sanitätskommission entzieht die Bewilligung, wenn die fachlichen, physischen oder psychischen Voraussetzungen für die selbständige Berufsausübung nicht mehr gegeben sind."
        }
      ],
      "stand": "1994-03-08",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.116",
      "abgerufen": "2026-06-23",
      "fassungsToken": "a030d3baae0487689f0029be557d46d8",
      "sha": "9d12ac468149d1442c5c0dcc12115e108ff75017aa33ca7f45b7579949087d0b"
    },
    {
      "id": "kanton/AR/811.116/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Hebammen-Verordnung (811.116)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung tritt sofort in Kraft."
        }
      ],
      "stand": "1994-03-08",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.116",
      "abgerufen": "2026-06-23",
      "fassungsToken": "a030d3baae0487689f0029be557d46d8",
      "sha": "238540f55f28868b111d71734072f7d9831aa34d15b94a0b4352742e7adbf933"
    },
    {
      "id": "kanton/AR/811.116/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Hebammen-Verordnung (811.116)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung ersetzt die Verordnung vom 28. Mai 1946 über das Hebammenwesen."
        },
        {
          "absatz": "2",
          "text": "Gleichzeitig wird die Verordnung vom 9. Juni 1967 über die Taxordnung für die Hebammen aufgehoben."
        }
      ],
      "stand": "1994-03-08",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.116",
      "abgerufen": "2026-06-23",
      "fassungsToken": "a030d3baae0487689f0029be557d46d8",
      "sha": "99fb0b91bd333bed99f5a7b0e07399e60df14cde9f26028b64d7ec4c4fb32f12"
    }
  ]
}