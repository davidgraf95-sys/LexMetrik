{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/RiB 111.100/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Bürgergemeinde Riehen ist eine öffentlich-rechtliche Körperschaft des Kantons Basel-Stadt gemäss § 1 des Gemeindegesetzes vom 17. Oktober 1984."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "ffe26720b58679506c017a60833ee961ddfb2514492e1c218840062212625d6a"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Auf dem Gebiet der Einwohnergemeinde Riehen besteht die Bürgergemeinde Riehen. Sie umfasst alle in Riehen wohnenden Gemeindebürgerinnen und Gemeindebürger."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "8f06b2f40ad6a0cd4d1b9eccae4e059ea6d2c0f0c2de957aac3511011763bff6"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Bürgergemeinde hat folgende Aufgaben und Befugnisse:",
          "items": [
            {
              "marke": "1",
              "text": "Sie erteilt das Gemeindebürgerrecht;"
            },
            {
              "marke": "2",
              "text": "Sie führt ihre Kanzlei und erledigt die damit zusammenhängenden Geschäfte;"
            },
            {
              "marke": "3",
              "text": "…"
            },
            {
              "marke": "4",
              "text": "Sie verwaltet ihr Vermögen und dasjenige ihrer Institutionen;"
            },
            {
              "marke": "5",
              "text": "Sie beaufsichtigt die ihr zugeordneten Stiftungen und Institutionen;"
            },
            {
              "marke": "6",
              "text": "Sie kann weitere, nicht in die ausschliessliche Zuständigkeit von Bund, Kanton oder Einwohnergemeinde fallende Aufgaben übernehmen."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Ihre Zuständigkeit für die auswärtswohnenden Bürger richtet sich nach Verfassung und Gesetz."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "d55042bb16a9e79ff1a7a5056ec109d82220c113f62324218c73bfdbba50b4ae"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Bürgergemeinde gilt die ordentliche Gemeindeorganisation."
        },
        {
          "absatz": "2",
          "text": "Organe der Bürgergemeinde bilden die Gesamtheit der in den Angelegenheiten der Bürgergemeinde Stimmberechtigten (Bürgerversammlung), Bürgerrat und Revisionsstelle."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "f82b11697e90a0ba8e26391a67e3a853786205b953fdee6e5bd53fc8cb62511d"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Stimmberechtigt sind die in der Gemeinde wohnenden über 18 Jahre alten Gemeindebürgerinnen und Gemeindebürger, welche das Aktivbürgerrecht besitzen."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "01048d0a31d1ddbcc4cf185e5920811139febdc2075cc54d09da5ad9119b9c93"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Stimmberechtigten üben ihr Wahl- und Stimmrecht in der Bürgerversammlung aus."
        },
        {
          "absatz": "2",
          "text": "Die Wahlen erfolgen nach dem Majorzsystem."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "4e44b24e6d01cc4118b505467cebd5a385ffde9735af71820310bda05e002366"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Sämtliche in den Angelegenheiten der Bürgergemeinde Stimmberechtigten haben das Recht, an der Bürgerversammlung teilzunehmen, wo sie ihr Stimm-, Wahl- und Antragsrecht wahrnehmen können."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "f0e56fe95181b25b1cdfe1607c0879aabfac8aebf885801529214b8d47d0cbe7"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gesamtheit der in den Angelegenheiten der Bürgergemeinde Stimmberechtigten bildet die Bürgerversammlung als oberstes Organ der Bürgergemeinde."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "2da28a384c68dace5db9005463e670cc39498138659fcdf42256b7e4d8abeb57"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Bürgerversammlung wird jährlich wenigstens einmal zur Behandlung der Jahresrechnung und des Geschäftsberichtes durch den Bürgerrat einberufen."
        },
        {
          "absatz": "2",
          "text": "Ausserdem wird sie einberufen:",
          "items": [
            {
              "marke": "1",
              "text": "Auf einen vorhergehenden Beschluss der Bürgerversammlung;"
            },
            {
              "marke": "2",
              "text": "Auf Beschluss des Bürgerrates;"
            },
            {
              "marke": "3",
              "text": "Wenn ein Zehntel der in der Bürgergemeinde Stimmberechtigten es unter Angabe des Verhandlungsgegenstandes schriftlich verlangt."
            }
          ]
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "fa97055522209a303be86e15ac27eea818170116eb699b10d6c831c808a17cd1"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Organisation und den Geschäftsgang erlässt die Bürgerversammlung eine Geschäftsordnung."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "4d2b45d71156559328b7a3ca28ef3740c8a2e32a3fccc1a63307310ab4c22a42"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "In die Zuständigkeit der Bürgerversammlung fallen folgende Geschäfte:",
          "items": [
            {
              "marke": "1",
              "text": "Beratung und Beschlussfassung über Erlass und Änderung der Gemeindeordnung;"
            },
            {
              "marke": "2",
              "text": "Erlass der eigenen Geschäftsordnung;"
            },
            {
              "marke": "3",
              "text": "Oberaufsicht über die Geschäftsführung der Bürgergemeinde;"
            },
            {
              "marke": "4",
              "text": "Prüfung und Genehmigung von Rechnung und Geschäftsbericht;"
            },
            {
              "marke": "5",
              "text": "Wahl der Mitglieder des Bürgerrates und des Präsidenten;"
            },
            {
              "marke": "6",
              "text": "Wahl der Revisionsstelle auf die Amtsdauer des Bürgerrates;"
            },
            {
              "marke": "7",
              "text": "…"
            },
            {
              "marke": "8",
              "text": "…"
            },
            {
              "marke": "9",
              "text": "Genehmigung der vom Bürgerrat abgeschlossenen wichtigen Verträge;"
            },
            {
              "marke": "10",
              "text": "Beschlussfassung über die Aufnahme von Darlehen;"
            },
            {
              "marke": "11",
              "text": "Bewilligung von Ausgaben, soweit sie die Summe von CHF 25'000 übersteigen;"
            },
            {
              "marke": "12",
              "text": "Beschlussfassung über Erwerb, Veräusserung oder Verpfändung von Grundstücken, soweit der Betrag von CHF 50'000 überschritten wird."
            }
          ]
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "cb8b6ad6b4451d06d6d282108966bf625d6277d50996518013dd1db85327713b"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_12",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "12",
      "artikelLabel": "§ 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Über die Verhandlungen der Bürgerversammlung ist Protokoll zu führen."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "add572260f69da1ea373e4453095fa5dab742c23e49001680a15fce8154d7f93"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_13",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "13",
      "artikelLabel": "§ 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Mit Ausnahme der Entscheidungen internen Charakters sind alle Beschlüsse der Bürgerversammlung zu publizieren. Ebenfalls zu publizieren sind die getroffenen Wahlen."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "db49c9c996f14fb56f705db5921cac5a3db1644712f378ea929f04f1c9bed3ab"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_14",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "14",
      "artikelLabel": "§ 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Bürgerrat ist ausführende Behörde und besorgt alle Geschäfte der Bürgergemeinde, die nicht der Bürgerversammlung vorbehalten sind."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "b3a0817c3a13329a94a708ca4d4f37ecaeb394d5c0f3cb5e724bad82844a2999"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_15",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "15",
      "artikelLabel": "§ 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Bürgerrat besteht aus der Bürgerratspräsidentin oder dem Bürgerratspräsidenten und weiteren vier Mitgliedern, die von der Bürgerversammlung aus den Stimmberechtigten der Bürgergemeinde auf eine Amtsdauer von vier Jahren gewählt werden."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "d43a08c304a4bfba51344ac2fbf3b8de82ed7b2b79d2b6f1ea1e61e429c2e198"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_16",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "16",
      "artikelLabel": "§ 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Während der Amtsdauer frei werdende Sitze sind umgehend wieder zu besetzen."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "b508b2846f0203667bd58c0ea97014719832352e156efb1eb9ed14deff3d3334"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_17",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "17",
      "artikelLabel": "§ 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dem Bürgerrat kommen namentlich folgende Aufgaben und Befugnisse zu:",
          "items": [
            {
              "marke": "1",
              "text": "Vertretung der Bürgergemeinde nach aussen;"
            },
            {
              "marke": "2",
              "text": "Leitung und Geschäftsführung der Bürgergemeinde;"
            },
            {
              "marke": "3",
              "text": "Einberufung der Bürgerversammlung;"
            },
            {
              "marke": "4",
              "text": "Behandlung der Bürgerrechtsbegehren;"
            },
            {
              "marke": "5",
              "text": "Erteilung des Bürgerrechts;"
            },
            {
              "marke": "6",
              "text": "…"
            },
            {
              "marke": "7",
              "text": "Wahl von Delegierten in die der Bürgergemeinde zugeordneten Stiftungen und der gemäss § 3 Abs. 1 Ziff. 5 übertragenen Aufgaben;"
            },
            {
              "marke": "8",
              "text": "Einstellung des erforderlichen Personals und Festlegung der Anstellungsbedingungen;"
            },
            {
              "marke": "9",
              "text": "Verwaltung des Bürgergutes;"
            },
            {
              "marke": "10",
              "text": "Vorbereitung und Vollzug der Beschlüsse der Bürgerversammlung;"
            },
            {
              "marke": "11",
              "text": "Erstellen von Rechnung und Geschäftsbericht;"
            },
            {
              "marke": "12",
              "text": "Erlass der zur Erfüllung der Aufgaben der Bürgergemeinde nötigen Reglemente mit Einschluss der Regelung der Gebühren;"
            },
            {
              "marke": "13",
              "text": "Oberaufsicht über die der Bürgergemeinde zugeordneten Stiftungen und der gemäss § 3 Abs. 1 Ziff. 5 übertragenen Aufgaben."
            }
          ]
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "1e67fb6d1ab6ea81ed7febbab2681c2f9f9f470c73199bdbe528f8c4b4099251"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_18",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "18",
      "artikelLabel": "§ 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Bürgerrat beschliesst grundsätzlich als Kollegialbehörde. Er ist beschlussfähig, wenn die Mehrheit der Mitglieder anwesend ist."
        },
        {
          "absatz": "2",
          "text": "Der Bürgerrat kann Aufgaben, die nicht zwingend vom Gesamtbürgerrat wahrgenommen werden müssen, einzelnen seiner Mitglieder oder einer Kommission zum Entscheid übertragen. Die Verantwortung bleibt aber in jedem Fall beim Gesamtbürgerrat."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "773d05f6cc83161b44b225ebe4e88b6a009c965c22a92a7dc79be1c431f670d6"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_19",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "19",
      "artikelLabel": "§ 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Mitglieder des Regierungsrates sowie das Personal der Bürgergemeinde sind in den Bürgerrat nicht wählbar."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "44c85344ce43a9e2ee9ea68a574c269f7a79227bf8cde0dab6ca3b2f7bfd5ed7"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_20",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "20",
      "artikelLabel": "§ 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Verhandlungen des Bürgerrates sind nicht öffentlich. Über die Verhandlungen ist Protokoll zu führen."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "77c4332d68c2054e419556717e8e70a8603c30a3206da18d2f79de3acf7a2960"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_21",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "21",
      "artikelLabel": "§ 21",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Mitglieder des Bürgerrates sind verpflichtet, Feststellungen, die sie bei ihrer amtlichen Tätigkeit gemacht haben, gegenüber Aussenstehenden geheimzuhalten, sofern es das öffentliche oder ein privates Interesse erfordert. Äusserungen und Stellungnahmen dürfen nicht an Aussenstehende bekanntgegeben werden."
        },
        {
          "absatz": "2",
          "text": "Mitglieder, die an einem Geschäft persönlich beteiligt sind oder zu einem Beteiligten in einem nahen Verwandtschaftsverhältnis stehen, haben in den Ausstand zu treten."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "18fe9c0d30f7d56cd8ca4c7d6b2d7b55d587c9fba6b441c2e503af5a36674fb8"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_22",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "22",
      "artikelLabel": "§ 22",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Präsidentin oder der Präsident hat folgende Aufgaben und Befugnisse:",
          "items": [
            {
              "marke": "1",
              "text": "Er leitet die Bürgerversammlung;"
            },
            {
              "marke": "2",
              "text": "Er bereitet die Bürgerratssitzungen vor und leitet sie;"
            },
            {
              "marke": "3",
              "text": "Er überwacht den Vollzug der Beschlüsse;"
            },
            {
              "marke": "4",
              "text": "Er erlässt in dringlichen Fällen die erforderlichen Anordnungen und erstattet darüber dem Bürgerrat an der nächsten Sitzung Bericht;"
            },
            {
              "marke": "5",
              "text": "…"
            }
          ]
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "57acdf2bb10475ddbb956ccedc3b0babec27277aec878e90ccfe2c8f9e9dc91a"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_23",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "23",
      "artikelLabel": "§ 23",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Bürgerrat kann über folgende Beträge verfügen:",
          "items": [
            {
              "marke": "1",
              "text": "CHF 25'000 für die einzelne Ausgabe"
            },
            {
              "marke": "2",
              "text": "CHF 50'000 für Ankauf, Verkauf und Verpfändung von Grundstücken pro Objekt."
            }
          ]
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "8252a4c5cc48a28febab4f24632217dfa007eb8430c80903201bb939fe91d8df"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_24",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "24",
      "artikelLabel": "§ 24",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Bürgerrat wählt jeweils auf seine Amtszeit eine Schreiberin oder einen Schreiber. Wählbar sind alle Bürgerinnen und Bürger sowie in Riehen stimmberechtigte Einwohnerinnen und Einwohner."
        },
        {
          "absatz": "2",
          "text": "Ihr oder ihm obliegt die Führung der Protokolle der Bürgerversammlung und des Bürgerrates, die Besorgung der Kanzleigeschäfte der Bürgergemeinde sowie die Besorgung des Archivs der Bürgergemeinde."
        },
        {
          "absatz": "3",
          "text": "Durch Beschluss des Bürgerrates können der Bürgerratskanzlei weitere Geschäfte übertragen werden."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "93010fe707803ce590d7f3ff756ea23c4e6be90082378b4eeeb696c08cb05d22"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_25",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "25",
      "artikelLabel": "§ 25",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Revision wird einer anerkannten Revisionsstelle übertragen."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "11656e76c81f7d15a90786c3d5cfa27630ef7982fee5a6bd79d73128968f7d1a"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_26",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "26",
      "artikelLabel": "§ 26",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Revisionsstelle prüft und revidiert die Rechnungen der Bürgergemeinde sowie den Geschäftsbericht des Bürgerrates und hat der Bürgerversammlung darüber zu berichten."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "ac81e8b052c2b7aea423dd09936d26a930e8792a2801782c2d02d53aa6f98d08"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_29",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "29",
      "artikelLabel": "§ 29",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Bürgergemeinde erhebt Kanzleigebühren für die Behandlung von Bürgerrechtsbegehren sowie Abgaben nach Massgabe des vom Bürgerrat erlassenen Reglementes."
        },
        {
          "absatz": "2",
          "text": "Für die Erhebung weiterer Gebühren für besondere Dienstleistungen kann der Bürgerrat entsprechende Reglemente erlassen."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "07721d04c3c64ab3c105b152ef99234e01bbd5bbdc7410514128d0fbd3776f18"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_30",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "30",
      "artikelLabel": "§ 30",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Mittel der Bürgergemeinde werden nach ihrer Zweckbestimmung für die Erfüllung der Aufgaben der Bürgergemeinde verwendet."
        },
        {
          "absatz": "2",
          "text": "Soweit die Mittel nicht unmittelbar zur Erfüllung von Aufgaben der Bürgergemeinde benötigt werden, sind sie sicher und ertragbringend anzulegen."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "2cf04a3b3a94c69e59127e1d752a7396bb3b0accfb439d46f3e9fdff3ef67b2a"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_31",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "31",
      "artikelLabel": "§ 31",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Rechnungsjahr entspricht dem Kalenderjahr. Nach Ablauf des Rechnungsjahres ist die Jahresrechnung zu erstellen."
        },
        {
          "absatz": "2",
          "text": "Nach der Prüfung durch den Bürgerrat und die Revisionsstelle ist die Jahresrechnung innerhalb von sechs Monaten nach Ablauf des Rechnungsjahres der Bürgerversammlung zur Genehmigung vorzulegen."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "e410e3a575b7e950c098afc764e49559511844c4a4e59226998b095dcd1ac794"
    },
    {
      "id": "kanton/BS/RiB 111.100/art_32",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gemeindeordnung der Bürgergemeinde Riehen (RiB 111.100)",
      "artikel": "32",
      "artikelLabel": "§ 32",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Gemeindeordnung ist nach erfolgter Genehmigung durch den Regierungsrat zu publizieren. Sie wird nach Eintritt der Rechtskraft am 1. Januar 1986 wirksam."
        }
      ],
      "stand": "2019-08-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiB 111.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62ae91524f6c3923fc7ef19701517a50",
      "sha": "6a8970c8d38276a7b2308a4df3b0fa7205aaaae9bf4d04d519a3f36e28192df6"
    }
  ]
}