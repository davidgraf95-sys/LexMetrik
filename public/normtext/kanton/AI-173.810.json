      "erlass": "GGV (GS 173.810)",
      "artikel": "19",
      "artikelLabel": "Art. 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zeitaufwand:",
          "items": [
            {
              "marke": "a",
              "text": "bis vier Stunden: bis 160.--"
            },
            {
              "marke": "b",
              "text": "über vier Stunden: bis 320.--"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die Entschädigung kann bis zur Höhe des Verdienstausfalls erhöht werden."
        },
        {
          "absatz": "3",
          "text": "Für ausgewiesene Spesen wird das Reglement über Spesen und weitere Vergütungen vom 21. November 2017 sachgemäss angewendet."
        }
