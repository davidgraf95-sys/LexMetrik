      "artikelLabel": "Art. 17",
      "bloecke": [
        {
          "absatz": null,
          "text": "",
          "items": [
            {
              "marke": "a",
              "text": "Leichtsinnige oder mutwillige Prozessführung: 100.-- bis 2'000.--"
            }
          ]
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/173.810",
      "abgerufen": "2026-06-17",
