      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kosten für mitwirkende Dritte werden entsprechend den nachfolgenden Bestimmungen tatsächlich ausgerichteten Entschädigungen belastet."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/173.810",
