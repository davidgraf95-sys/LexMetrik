{
  "erzeugt": "2026-06-17",
  "eintraege": [
    {
      "id": "kanton/AI/173.810/art_1",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "GGV (GS 173.810)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieser Tarif gilt für die amtlichen Kosten des Verfahrens vor Vermittler, Schlichtungsstellen und Gerichten."
        },
        {
          "absatz": "2",
          "text": "Er regelt die Entschädigung an Dritte."
        },
        {
          "absatz": "3",
          "text": "Durch die Bundesgesetzgebung festgesetzte Gebühren bleiben vorbehalten."
        },
        {
          "absatz": "4",
          "text": "Die in diesem Tarif genannten Beträge lauten auf Schweizer Franken."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/173.810",
      "abgerufen": "2026-06-17",
      "fassungsToken": "b447ca274ee70f25b6d91cb0952f4676",
      "sha": "9af77c4a7f68682d4731dde15fdcc56b1384ccbfcba1939a26db560e2d5a6ead"
    },
    {
      "id": "kanton/AI/173.810/art_2",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "GGV (GS 173.810)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Enthält dieser Tarif einen Mindest- und einen Höchstansatz, so werden bei der Bestimmung der Gebühr die Art des Falls, die finanziellen Interessen der Beteiligten, die Umtriebe, die Vermögensverhältnisse des Kostenpflichtigen und die Art der Prozessführung der Beteiligten berücksichtigt."
        },
        {
          "absatz": "2",
          "text": "Wenn der Aufwand mit der Bearbeitung oder die Schwierigkeiten des Falls aussergewöhnlich gross sind, kann die Gebühr innerhalb des Rahmens von Art. 45 des Gerichtsorganisationsgesetzes vom 25. April 2010 (GOG) bis auf das Vierfache erhöht werden."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/173.810",
      "abgerufen": "2026-06-17",
      "fassungsToken": "b447ca274ee70f25b6d91cb0952f4676",
      "sha": "3cdb0cef3f4f970c13a18b128f22037e6ebb3bcee6496d839ede4f7d0f838d1e"
    },
    {
      "id": "kanton/AI/173.810/art_3",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "GGV (GS 173.810)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die mutmasslichen amtlichen Kosten sind durch die Partei, welche eine Prozesshandlung anbegehrt, zu bevorschussen. Der Kostenvorschuss darf die Streitwertgrenze nicht überschreiten."
        },
        {
          "absatz": "2",
          "text": "Die Kosten eines allfälligen Beweisverfahrens hat der Beweisführer vorzuschiessen."
        },
        {
          "absatz": "3",
          "text": "Im erstinstanzlichen Strafprozess finden Abs. 1 und 2 grundsätzlich keine Anwendung."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/173.810",
      "abgerufen": "2026-06-17",
      "fassungsToken": "b447ca274ee70f25b6d91cb0952f4676",
      "sha": "dab9b071b6b6d78e80d93c7464342b4442a886771e655cafc57a6e717833fe87"
    },
    {
      "id": "kanton/AI/173.810/art_4",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "GGV (GS 173.810)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kostenspruch ist Bestandteil einer Verfügung oder eines Entscheids und umfasst die Entscheidgebühr und allfällige zusätzliche Gerichtskosten."
        },
        {
          "absatz": "2",
          "text": "Werden einem am Verfahren nicht beteiligten Dritten Kosten auferlegt oder eine beanspruchte Entschädigung verweigert, so ist ihm vor Erlass des Kostenspruchs Gelegenheit zur Stellungnahme zu geben."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/173.810",
      "abgerufen": "2026-06-17",
      "fassungsToken": "b447ca274ee70f25b6d91cb0952f4676",
      "sha": "be9dd0e718d02da799d4e4c8234979c7c7421d4b575c1d27b52246b97053e0d8"
    },
    {
      "id": "kanton/AI/173.810/art_5",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "GGV (GS 173.810)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kosten werden mit Rechtskraft des zugrundeliegenden Entscheids fällig."
        },
        {
          "absatz": "2",
          "text": "Ein allfälliger Überschuss aus dem geleisteten Kostenvorschuss wird nach Rechtskraft des zugrundeliegenden Entscheides zurückerstattet."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/173.810",
      "abgerufen": "2026-06-17",
      "fassungsToken": "b447ca274ee70f25b6d91cb0952f4676",
      "sha": "9af155d202006af3d3392d94c0f751c57d9b601ab559f2d62ca32bb08517f9a0"
    },
    {
      "id": "kanton/AI/173.810/art_6",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "GGV (GS 173.810)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für amtliche Kosten nach diesem Tarif, die aufgrund eines rechtskräftigen Entscheids geschuldet werden, wird im Betreibungsfall zusätzlich ein Verzugszins von 5% ab Fälligkeit berechnet."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/173.810",
      "abgerufen": "2026-06-17",
      "fassungsToken": "b447ca274ee70f25b6d91cb0952f4676",
      "sha": "8d261095fa92b002eb5c9e9a0df4221e21bc7f747fb018d2d4d34eaddb5b79b4"
    },
