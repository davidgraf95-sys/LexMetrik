    {
      "id": "kanton/AI/173.810/art_15",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "GGV (GS 173.810)",
      "artikel": "15",
      "artikelLabel": "Art. 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühren für Zwischen- und Endentscheide werden abhängig vom Streitwert innerhalb des Rahmens von Art. 45 GOG wie folgt erhöht:",
          "items": [
            {
              "marke": "a",
              "text": "bei einem Streitwert über 50'000.-- bis 100'000.-- auf höchstens 200%"
            },
            {
              "marke": "b",
              "text": "bei einem Streitwert über 100'000.-- bis 250'000.-- auf höchstens 300%"
            },
            {
              "marke": "c",
              "text": "bei einem Streitwert von je weiteren 250'000.-- je weitere 100%"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Eine weitere Erhöhung nach Art. 2 Abs. 2 bleibt vorbehalten."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/173.810",
      "abgerufen": "2026-06-17",
      "fassungsToken": "b447ca274ee70f25b6d91cb0952f4676",
      "sha": "a3b35e247446185d0c1fb6c33a7c51536d272e4fb4d32711c038001fc9c798d3"
    },
    {
      "id": "kanton/AI/173.810/art_16",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "GGV (GS 173.810)",
      "artikel": "16",
      "artikelLabel": "Art. 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die amtlichen Kosten werden grundsätzlich um einen Drittel ermässigt, wenn bei Entscheiden keine Begründung erfolgt. In Ausnahmefällen, namentlich dann, wenn die Begründung einen ausserordentlich grossen Aufwand verursachen würde, kann die Kostenermässigung über den Drittel hinaus erhöht werden."
        },
        {
          "absatz": "2",
          "text": "Wenn die Umstände es rechtfertigen, kann auf das Erheben von Kosten verzichtet werden."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/173.810",
      "abgerufen": "2026-06-17",
      "fassungsToken": "b447ca274ee70f25b6d91cb0952f4676",
      "sha": "8104819f4245055e0034f50cfce4c55e363c26628bb6d4eadc682f0d9747f6d6"
    },
