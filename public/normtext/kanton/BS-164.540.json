{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/164.540/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung betreffend Mischpensen (164.540)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "titel": "Definition",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ein Mischpensum besteht darin, dass eine Lehrkraft Unterricht in Bereichen erteilt, die verschiedenen Lohnklassen zugeordnet sind."
        },
        {
          "absatz": "2",
          "text": "Erfolgt der Unterricht an einer einzigen Schule oder Schulart und verfügt die Lehrkraft über die Ausbildung, die im höher eingereihten Bereich vorausgesetzt wird, so liegt beim Unterricht in verschiedenen Fächergruppen laut § 98a Abs. 2 des Schulgesetzes vom 4. April 1929 kein Mischpensum im Sinne dieser Verordnung vor."
        }
      ],
      "stand": "2010-08-09",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/164.540",
      "abgerufen": "2026-06-23",
      "fassungsToken": "96c1396f5e90e70b9a84c0a0ac2a5ee2",
      "sha": "369706ab0f2e434ce9166aa1968116837d26d68633e1aa755ef85b4c437fa6f1"
    },
    {
      "id": "kanton/BS/164.540/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung betreffend Mischpensen (164.540)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Grundsatz der proportionalen Entlöhnung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Lohn ist die Summe der aufgrund der Stundenzahlen auf die einzelnen Lohnklassen entfallenden Lohnanteile."
        },
        {
          "absatz": "2",
          "text": "Vorbehalten bleiben § 1 Abs. 2 sowie §§ 3 und 4."
        }
      ],
      "stand": "2010-08-09",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/164.540",
      "abgerufen": "2026-06-23",
      "fassungsToken": "96c1396f5e90e70b9a84c0a0ac2a5ee2",
      "sha": "da92a9a676dc8cf724ca1d79bf9e4d1f12288d40c843a26f698f2db11674581d"
    },
    {
      "id": "kanton/BS/164.540/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung betreffend Mischpensen (164.540)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Ausnahmeregelung: Vorrang des Anstellungsbeschlusses",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Lehrkräfte mit vollem Pensum, aus deren Anstellungsbeschluss sich eine bestimmte Lohnklasse ergibt, haben Anspruch auf diese Lohnklasse, auch wenn ihnen vorübergehend oder dauernd Stunden in niedrigeren Lohnklassen zugeteilt werden."
        }
      ],
      "stand": "2010-08-09",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/164.540",
      "abgerufen": "2026-06-23",
      "fassungsToken": "96c1396f5e90e70b9a84c0a0ac2a5ee2",
      "sha": "8a63a4039ece40f67c17930ea24b4358b60c61623b4f713a328d212ccadda3c7"
    },
    {
      "id": "kanton/BS/164.540/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung betreffend Mischpensen (164.540)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Übergangsregelung, Besitzstand",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Lehrkräften mit vollem Pensum, die in den Schuljahren 1995/96 und 1996/97 gemäss den §§ 1 und 3 der Vo betreffend Mischpensen vom 19. April 1971 den vollen Lohn der höheren Lohnklassen bezogen haben, erhalten diesen Lohn für die Schuljahre bis und mit 1999/2000."
        }
      ],
      "stand": "2010-08-09",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/164.540",
      "abgerufen": "2026-06-23",
      "fassungsToken": "96c1396f5e90e70b9a84c0a0ac2a5ee2",
      "sha": "3ce660dba9b59e7c127aeb86a4faa16a5449ef65d519ae90970692f6d514a61c"
    },
    {
      "id": "kanton/BS/164.540/art_4_a",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung betreffend Mischpensen (164.540)",
      "artikel": "4_a",
      "artikelLabel": "§ 4a",
      "titel": "Übergangsregelung für die Schuljahre 2011/12 bis 2020/21",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Unbefristet angestellte Lehrpersonen, die aufgrund der grundlegenden Strukturänderung des Bildungssystems (Aufhebung der Orientierungs- und Weiterbildungsschule) in einer Schulstufe mit tiefer eingereihten Stellen unterrichten, werden für die an dieser Stufe unterrichteten Lektionen während der Schuljahre 2011/12 bis und mit 2020/21 in der höheren Lohnklasse entlöhnt."
        }
      ],
      "stand": "2010-08-09",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/164.540",
      "abgerufen": "2026-06-23",
      "fassungsToken": "96c1396f5e90e70b9a84c0a0ac2a5ee2",
      "sha": "013a1ec77ab77c1085e106b9b112923b460600b7696b3ff822d0ed3c6bef53e7"
    },
    {
      "id": "kanton/BS/164.540/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung betreffend Mischpensen (164.540)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "titel": "Schlussbestimmungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Durch diese Verordnung wird die Verordnung betreffend Mischpensen vom 19. April 1971 aufgehoben."
        }
      ],
      "stand": "2010-08-09",
