{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/BeE 153.860/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Entschädigungsordnung Bettingen (BeE 153.860)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Mitglieder des Gemeinderates werden für ihre Amtstätigkeit entschädigt."
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 153.860",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8be9cdb6f7fd41cd05d8de434c652f8d",
      "sha": "80e19c923298f00b3b9259545d30b7d6b00b20862a27432869fe06049a8c9a24"
    },
    {
      "id": "kanton/BS/BeE 153.860/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Entschädigungsordnung Bettingen (BeE 153.860)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Jahresentschädigung der einzelnen Mitglieder des Gemeinderates wird wie folgt festgesetzt:",
          "items": [
            {
              "marke": "a",
              "text": "Gemeindepräsidentin oder Gemeindepräsident: Fr. 25'000;"
            },
            {
              "marke": "b",
              "text": "übrige Mitglieder des Gemeinderates: Fr. 19'000."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Mit der Jahresentschädigung werden die regulären Gemeinderatssitzungen sowie die Einwohnergemeindeversammlungen jeweils mit Vor- und Nachbereitung entschädigt. Mit der Entschädigung werden zudem alle Aufgaben, welche aus der ordentlichen Leitung eine Gemeinderatsbereichs anfallen, abgegolten. Insbesondere:",
          "items": [
            {
              "marke": "a",
              "text": "Aktenstudium, Besprechungen mit den zuständigen Mitarbeitenden der Verwaltung;"
            },
            {
              "marke": "b",
              "text": "Sitzungen, welche dem eigenen Gemeinderatsbereich zuzuordnen sind;"
            },
            {
              "marke": "c",
              "text": "Erledigung der reglementarischen Geschäfte;"
            },
            {
              "marke": "d",
              "text": "Kommunikations- und Repräsentationsaufgaben."
            }
          ]
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 153.860",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8be9cdb6f7fd41cd05d8de434c652f8d",
      "sha": "cdbc0c4c4f2f82939194e826d47152e30599a20b8706dc537bfe0caf97be582f"
    },
    {
      "id": "kanton/BS/BeE 153.860/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Entschädigungsordnung Bettingen (BeE 153.860)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im Rahmen der Zielsetzungs- und Planungsprozesse kann der Gemeinderat zusätzliche ausserordentliche, projektbezogene Sitzungen und Anlässe, welche in § 2 Abs. 2 nicht aufgeführt sind, genehmigen."
        },
        {
          "absatz": "2",
          "text": "Für genehmigte Sitzungen und Anlässe wird den Mitgliedern des Gemeinderates eine Entschädigung von Fr. 65 pro Stunde ausgerichtet."
        },
        {
          "absatz": "3",
          "text": "Die Entschädigung für Sitzungen von Kommissionen der Gemeinde Bettingen richtet sich nach den Bestimmungen, welche der Gemeinderat im Rahmen der jährlichen Lohn- und Entschädigungsberatung beschliesst."
        },
        {
          "absatz": "4",
          "text": "Die Gemeindeverwalterin oder der Gemeindeverwalter kontrolliert und visiert das Sitzungsgeld."
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 153.860",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8be9cdb6f7fd41cd05d8de434c652f8d",
      "sha": "f4c40c22c5be6ced74b0aabc9180ccfe2f06901dcebe7631cd56668c436b9a57"
    },
    {
      "id": "kanton/BS/BeE 153.860/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Entschädigungsordnung Bettingen (BeE 153.860)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für Klausuren, Weiterbildungen, umfangreiche Projekte und ausserordentliche Anlässe kann anstatt Sitzungsgeld eine oder mehrere Tagespauschalen (in der Höhe von Fr. 520) zugesprochen werden."
        },
        {
          "absatz": "2",
          "text": "Über den Zuspruch und die Anzahl Tagespauschalen entscheidet auf begründetes Gesuch der Gesamtgemeinderat. Für das betroffene Mitglied des Gemeinderates gilt die Ausstandspflicht gemäss Gemeindeordnung. Sind alle Mitglieder des Gemeinderates betroffen, entscheidet die Gemeindepräsidentin oder der Gemeindepräsident."
        },
        {
          "absatz": "3",
          "text": "Die Tagespauschalen pro Jahr und Mitglied des Gemeinderates betragen im Maximum die Hälfte der Jahresentschädigung gemäss § 2 Abs. 1 lit. b."
        },
        {
          "absatz": "4",
          "text": "Die Gemeindeverwalterin oder der Gemeindeverwalter kontrolliert und visiert die Tagespauschalen."
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 153.860",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8be9cdb6f7fd41cd05d8de434c652f8d",
      "sha": "3d7a97e59e7410dc202f497f1d1f10015a6d3ef2b61ae9688e54369e90b8929b"
    },
    {
      "id": "kanton/BS/BeE 153.860/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Entschädigungsordnung Bettingen (BeE 153.860)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zur Abgeltung der mit dem Amt verbundenen Unkosten wie private Büroinfrastruktur, Kommunikation (Telefonie, Internet), Fahr- und Reisespesen sowie Repräsentationskosten erhalten die Mitglieder des Gemeinderates eine jährliche Spesenpauschale wie folgt:",
          "items": [
            {
              "marke": "a",
              "text": "Gemeindepräsidentin oder Gemeindepräsident: Fr. 2'000;"
            },
            {
              "marke": "b",
              "text": "Übrige Mitglieder des Gemeinderates: Fr. 1'000."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Für Fahrten an geschäftliche Verpflichtungen, die ausserhalb der Region Basel und in der Schweiz stattfinden, steht die Gemeindetageskarte zur Verfügung."
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 153.860",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8be9cdb6f7fd41cd05d8de434c652f8d",
      "sha": "a0c118a9c07567953e6b6b42f33ed14cf6e24d440d5463a5f79ab36e2754111e"
    },
    {
      "id": "kanton/BS/BeE 153.860/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Entschädigungsordnung Bettingen (BeE 153.860)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Erhält ein Mitglied des Gemeinderates Entschädigungen für ein Mandat, welches ihm vom Gemeinderat erteilt worden ist, besteht eine Abgabepflicht zuhanden der Gemeindekasse."
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 153.860",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8be9cdb6f7fd41cd05d8de434c652f8d",
      "sha": "7b95a58d1dce9c69b5dd360be6e33b6bad72876136945374815eed26fcd8e790"
    },
    {
      "id": "kanton/BS/BeE 153.860/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Entschädigungsordnung Bettingen (BeE 153.860)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Jahresentschädigung wird in zwölf monatlichen Teilzahlungen vergütet."
        },
        {
          "absatz": "2",
          "text": "Sitzungsgeld und Pauschalen werden in der Regel pro Quartal ausbezahlt."
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 153.860",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8be9cdb6f7fd41cd05d8de434c652f8d",
      "sha": "becbba02fb034e202bc427d79e11f0f4d44655647a477fefb4f2c9dbbd3a8ddf"
    },
    {
      "id": "kanton/BS/BeE 153.860/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Entschädigungsordnung Bettingen (BeE 153.860)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Mitglieder des Gemeinderates haben bei Krankheit oder Unfall Anspruch auf die Jahresentschädigung."
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 153.860",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8be9cdb6f7fd41cd05d8de434c652f8d",
      "sha": "dedf561d54030dcb70b6707701898f78dd3186d57b242f2bc5dab3bd222543f7"
    },
    {
      "id": "kanton/BS/BeE 153.860/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Entschädigungsordnung Bettingen (BeE 153.860)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Mitglieder des Gemeinderates werden gemäss den gesetzlichen Grundlagen in der für die Gemeinde Bettingen zuständigen Pensionskasse versichert."
        },
        {
          "absatz": "2",
          "text": "Die Vorsorgekommission vertritt die Arbeitgeberin gegenüber der Vorsorgeeinrichtung."
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 153.860",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8be9cdb6f7fd41cd05d8de434c652f8d",
      "sha": "4f38b69b6f88a68933417213b5402bd2d17f14562fcd3db15c356a2b3c5c25b4"
    },
    {
      "id": "kanton/BS/BeE 153.860/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Entschädigungsordnung Bettingen (BeE 153.860)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Höhe der Jahresentschädigung, des Sitzungsgeldes und der Pauschalen ist alle vier Jahre einer Überprüfung zu unterziehen."
        }
      ],
      "stand": "2021-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 153.860",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8be9cdb6f7fd41cd05d8de434c652f8d",
      "sha": "e1adaef3e5791f4eb28fa4cd2a1471cf192aa087f91e94958aa71823f3b92b6c"
    }
  ]
}