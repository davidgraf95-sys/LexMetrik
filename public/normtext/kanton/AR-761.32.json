      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Lärm-, Rauch-, Abgasmessung wird eine Gebühr zwischen Fr. 30.- und Fr. 300.- erhoben."
        },
        {
          "absatz": "2",
          "text": "Für Prüfungen von technischen Änderungen wird eine Gebühr zwischen Fr. 15.- und Fr. 300.- erhoben."
        },
        {
          "absatz": "3",
          "text": "Für die Prüfung aller nicht aufgeführten Fahrzeuge werden Gebühren nach Aufwand in der Höhe von Fr. 120.- pro Stunde erhoben."
        }
