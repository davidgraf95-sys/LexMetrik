      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühren gemäss Art. 2 bis Art. 10 werden auch erhoben bei:",
          "items": [
            {
              "marke": "a",
              "text": "Nachprüfungen von Führern und Fahrzeugen infolge ungenügenden Prüfungsbefundes bis zu 100% der Gebühren"
            },
            {
              "marke": "b",
              "text": "Nichterscheinen oder Abmeldung später als 5 Arbeitstage vor der Führer- oder Fahrzeugprüfung"
            }
          ]
        }
      ],
