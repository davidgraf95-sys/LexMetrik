      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif zum EG SVG (761.32)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für amtliche Verrichtungen werden folgende Gebühren erhoben:",
          "items": [
            {
              "marke": "a",
              "text": "Deponierung von Kontrollschildern Fr. 20.-"
            },
            {
              "marke": "b",
              "text": "Wiederausgabe von deponierten Kontrollschildern (WIK) Fr. 20.-"
            },
            {
              "marke": "c",
              "text": "Verlängerung der Hinterlegungsdauer von Kontrollschildern Fr. 50.-"
            },
            {
              "marke": "d",
              "text": "Ausschreibungen im Ripol Fr. 50.-"
            },
            {
              "marke": "e",
              "text": "Verweigerung von Ausweisen oder Bewilligungen Fr. 40.- bis Fr. 100.-"
            },
            {
              "marke": "f",
              "text": "Bestätigung \"Bewilligte Änderung\" Fr. 40.-"
            },
            {
              "marke": "g",
              "text": "Bestätigung für Italienischen Zoll (Zulassung) Fr. 100.-"
            },
            {
              "marke": "h",
              "text": "Bestätigung über bestandene Führerprüfungen Fr. 35.-"
            },
            {
              "marke": "i",
              "text": "Verfügung über den Entzug von Fahrzeugausweisen und Kontrollschildern infolge Nichtbezahlens von Steuern oder Gebühren, fehlendem Versicherungsschutz oder Nichtvorführens von Fahrzeugen Fr. 150.-"
            },
            {
              "marke": "j",
              "text": "Verfügung / Auftrag über den Einzug von Ausweisen und Schildern Fr. 150.-"
            },
            {
              "marke": "k",
              "text": "Mahnung bei Nichterfüllen von Auflagen im Führerausweis Fr. 50.-"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Bei irrtümlicher oder unberechtigter Meldung über das Aufhören der Haftpflichtversicherung werden die entsprechenden Gebühren der Versicherungsgesellschaft belastet."
        },
        {
          "absatz": "3",
          "text": "Für besondere Amtshandlungen, Abklärungen, Nachforschungen und Bestätigungen, die noch nicht beschrieben wurden (z.B. technische Daten, Zahlungsverkehr etc.), wird ein Betrag von Fr. 60.- pro angebrochene halbe Stunde verrechnet."
        }
