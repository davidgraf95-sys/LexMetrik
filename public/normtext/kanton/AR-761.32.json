        {
          "absatz": "2",
          "text": "Nach einem Ausweisentzug wird die Gebühr der Führerprüfung der entsprechenden Kategorie erneut erhoben."
        },
        {
          "absatz": "3",
          "text": "Für die Kontrollfahrt wird die Gebühr der praktischen Führerprüfung der entsprechenden Kategorie erhoben."
        },
        {
          "absatz": "4",
          "text": "Bei besonderen Prüfungen wird eine Gebühr nach Aufwand von Fr. 120.- pro Stunde erhoben."
        }
      ],
      "stand": "2025-04-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/761.32",
