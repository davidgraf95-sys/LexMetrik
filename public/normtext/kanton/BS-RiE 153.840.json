{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/RiE 153.840/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenreglement Einwohnerdienste (RiE 153.840)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieses Reglement regelt die Erhebung von Gebühren für verschiedene Dienstleistungen der Einwohnerdienste der Gemeinde Riehen."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "177cbe883fbc1e4d249d0d7cffd8ba3d",
      "sha": "9a38c61ddc4bfc7559fff2914acdb49117b895dd8c3653849b6edad435aaadd0"
    },
    {
      "id": "kanton/BS/RiE 153.840/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenreglement Einwohnerdienste (RiE 153.840)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühren sind das Entgelt für Verwaltungshandlungen der Gemeinde und alle damit notwendig zusammenhängenden Tätigkeiten."
        },
        {
          "absatz": "2",
          "text": "Die Gebühren bemessen sich grundsätzlich nach dem gesamten mittelbaren und unmittelbaren Verwaltungsaufwand und sollen kostendeckend sein. Im Übrigen sind die Grundsätze des Gesetzes über die Verwaltungsgebühren massgeblich."
        },
        {
          "absatz": "3",
          "text": "Für ausserordentlichen Verwaltungsaufwand kann die Gebühr um das Doppelte erhöht werden."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "177cbe883fbc1e4d249d0d7cffd8ba3d",
      "sha": "d3e21748b2af362edc713282c60df1065e5553c712d80142d2ae672820cb2c12"
    },
    {
      "id": "kanton/BS/RiE 153.840/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenreglement Einwohnerdienste (RiE 153.840)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Es werden folgende Gebühren erhoben:",
          "items": [
            {
              "marke": "a",
              "text": "Für das Erstellen von Fotokopien / A4, pro Kopie CHF 0.50"
            },
            {
              "marke": "b",
              "text": "Für das Erstellen von Fotokopien / A3, pro Kopie CHF 1.00"
            },
            {
              "marke": "c",
              "text": "Für Porti gemäss Aufwand"
            }
          ]
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "177cbe883fbc1e4d249d0d7cffd8ba3d",
      "sha": "2b1fc621c43993a271672b517ffe708e002252228cd80abf4096dc6ccffbcaba"
    },
    {
      "id": "kanton/BS/RiE 153.840/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenreglement Einwohnerdienste (RiE 153.840)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Zahlungsfrist von Gebühren beträgt 30 Tage."
        },
        {
          "absatz": "2",
          "text": "Nach Ablauf der Zahlungsfrist kann ein Verzugszins von 5 % erhoben werden."
        },
        {
          "absatz": "3",
          "text": "Für nicht rechtzeitig bezahlte Gebühren können Mahn- und Umtriebsgebühren für Inkassomassnahmen erhoben werden. Diese betragen:",
          "items": [
            {
              "marke": "a",
              "text": "erste Mahnung kostenlos"
            },
            {
              "marke": "b",
              "text": "Mahngebühren ab zweiter Mahnung je CHF 40"
            },
            {
              "marke": "c",
              "text": "Umtriebsgebühr für Inkassomassnahmen CHF 50"
            }
          ]
        },
        {
          "absatz": "4",
          "text": "Vorbehalten bleibt die Einforderung weiterer Gebühren im Zusammenhang mit Betreibungsverfahren."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "177cbe883fbc1e4d249d0d7cffd8ba3d",
      "sha": "feae08961ccf763f4f4b7f445e9b3843500b0a739e787f92f1a23b75a26605c1"
    },
    {
      "id": "kanton/BS/RiE 153.840/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenreglement Einwohnerdienste (RiE 153.840)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gemeindeverwaltung erhebt für Beglaubigungen, Bescheinigungen und weitere Dienstleistungen der Einwohnerdienste Gebühren gemäss Anhang."
        },
        {
          "absatz": "2",
          "text": "Für die Ausstellung von Identitätskarten werden die Gebühren gemäss Vorgaben des Bundes erhoben."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "177cbe883fbc1e4d249d0d7cffd8ba3d",
      "sha": "236b86e397b79cb8e844ce09fae3d2adce2cf9258470e2f976546f18f8bc6c73"
    }
  ]
}