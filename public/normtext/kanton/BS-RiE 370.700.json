{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/RiE 370.700/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Naturbadreglement (RiE 370.700)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gemeinde Riehen betreibt ein Schwimmbad mit vollbiologischer Wasseraufbereitung (Naturbad)."
        },
        {
          "absatz": "2",
          "text": "Es steht der Bevölkerung und den Schulen nach Massgabe dieses Reglements zur Verfügung."
        }
      ],
      "stand": "2020-06-07",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 370.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "dba84131afdb7e69cc511189d68ae035",
      "sha": "9beb78767d13a62d5928d856e598315327519d95f1583ec7140c53fca678ec30"
    },
    {
      "id": "kanton/BS/RiE 370.700/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Naturbadreglement (RiE 370.700)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Leitung der zuständigen Verwaltungsabteilung legt gestützt auf das vom Gemeinderat genehmigte Betriebskonzept die Betriebs- und Öffnungszeiten fest."
        },
        {
          "absatz": "2",
          "text": "Die Betriebsleitung kann aufgrund der Wetterverhältnisse oder bei besonderen Anlässen und Vorkommnissen sowie für Reinigungs- und Unterhaltsarbeiten",
          "items": [
            {
              "marke": "a",
              "text": "die Öffnungszeiten einschränken bzw. verlängern oder den Betrieb einstellen,"
            },
            {
              "marke": "b",
              "text": "den Zutritt zu einzelnen Bereichen des Naturbads vorübergehend einschränken."
            }
          ]
        }
      ],
      "stand": "2020-06-07",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 370.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "dba84131afdb7e69cc511189d68ae035",
      "sha": "3f48a43fa71f94c9445a8c6cb89d2ad0d9a6680034f5578678abdba3c238a2b9"
    },
    {
      "id": "kanton/BS/RiE 370.700/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Naturbadreglement (RiE 370.700)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Leitung der zuständigen Verwaltungsabteilung erlässt die Haus- und Badeordnung."
        },
        {
          "absatz": "2",
          "text": "Die Mitarbeitenden des Naturbads üben die Zutrittskontrollen im Naturbad aus, sorgen für einen geordneten Badebetrieb und können die hierzu notwendigen Anweisungen erteilen."
        }
      ],
      "stand": "2020-06-07",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 370.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "dba84131afdb7e69cc511189d68ae035",
      "sha": "ff387c2174018d3033285ad1ce9fe14dcf81b7909fda2db45673791d28d14ed7"
    },
    {
      "id": "kanton/BS/RiE 370.700/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Naturbadreglement (RiE 370.700)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Gemeinderat legt die Gebühren für die Benützung des Naturbads und dessen Einrichtungen in einem Anhang zu diesem Reglement fest."
        }
      ],
      "stand": "2020-06-07",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 370.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "dba84131afdb7e69cc511189d68ae035",
      "sha": "bd06a5ed0680e7a1f7d6bf494134028f84b61876364fd41f24601b0161486474"
    },
    {
      "id": "kanton/BS/RiE 370.700/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Naturbadreglement (RiE 370.700)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Besuche des Naturbads im Klassenverband sind für die öffentlichen Schulen des Kantons Basel-Stadt kostenlos."
        }
      ],
      "stand": "2020-06-07",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 370.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "dba84131afdb7e69cc511189d68ae035",
      "sha": "922eab5d2c6a2bbd289f3b6e81df5d03cc8e89f9ae966da344cc25b63d5433b4"
    },
    {
      "id": "kanton/BS/RiE 370.700/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Naturbadreglement (RiE 370.700)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Leitung der zuständigen Verwaltungsabteilung legt die Preise für Mietobjekte wie Sonnenschirme, Liegestühle usw. fest."
        }
      ],
      "stand": "2020-06-07",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 370.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "dba84131afdb7e69cc511189d68ae035",
      "sha": "c17732298e12b49f4f8b27547f3d87e96406e2c172017a19358f6ace72704979"
    },
    {
      "id": "kanton/BS/RiE 370.700/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Naturbadreglement (RiE 370.700)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Betriebsleitung ist befugt, Personen zu verwarnen oder aus dem Naturbad wegzuweisen, die gegen die Haus- und Badeordnung oder gegen Weisungen des Aufsichtspersonals verstossen."
        },
        {
          "absatz": "2",
          "text": "Die vorgesetzte Stelle der Betriebsleitung kann ein zeitlich begrenztes Zutrittsverbot aussprechen. Sie entscheidet bei Inhaberinnen oder Inhabern von Saisonabonnementen, wie lange das Zutrittsverbot gilt."
        },
        {
          "absatz": "3",
          "text": "Die Leitung der zuständigen Verwaltungsabteilung kann ein definitives Zutrittsverbot erlassen."
        },
        {
          "absatz": "4",
          "text": "Bei Zutrittsverboten wird der Eintrittspreis nicht zurück erstattet."
        }
      ],
      "stand": "2020-06-07",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 370.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "dba84131afdb7e69cc511189d68ae035",
      "sha": "19b97575a8ba809fe529f3632077651e30ee46d0d17c92a4ba2372dc74b00d5d"
    },
    {
      "id": "kanton/BS/RiE 370.700/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Naturbadreglement (RiE 370.700)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Betriebsleitung kann bei Verdacht auf Verstösse gegen die Haus- und Badeordnung oder auf strafbare Handlungen mitgebrachte Gepäckstücke kontrollieren, insbesondere auf alkoholische Getränke, Betäubungsmittel oder Drogen."
        }
      ],
      "stand": "2020-06-07",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 370.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "dba84131afdb7e69cc511189d68ae035",
      "sha": "371a69f5f1be9353a292232790d93afe4f22dbe2a3dc4c18989e16d5e5d6b68e"
    },
    {
      "id": "kanton/BS/RiE 370.700/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Naturbadreglement (RiE 370.700)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gegen definitive Zutrittsverbote kann beim Gemeinderat innert 10 Tagen ein begründeter Rekurs eingereicht werden."
        },
        {
          "absatz": "2",
          "text": "Der Gemeinderat entscheidet endgültig."
        }
      ],
      "stand": "2020-06-07",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 370.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "dba84131afdb7e69cc511189d68ae035",
      "sha": "166dfbf0d3c335a491bdf30a688d9841b6dc12eb4edb45f9003fa1682f0c186c"
    }
  ]
}