{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/410.500/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für den Religionsunterricht (410.500)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "titel": "Verfahren für die Festsetzung der Religionsstunden",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die zuständigen Organe der Kirchen vereinbaren die Unterrichtszeiten der Religionsstunden im Rahmen des normalen Schulpensums jeweils spätestens vier Monate vor Beginn des neuen Schuljahres mit den Schulleitungen der Schulen."
        }
      ],
      "stand": "2012-08-13",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8e136fd42af33ed5b5557d3001a29f28",
      "sha": "e6ef9bfa50c0547a7823cf14b000c47debbcc205181ba51ca133e1dd4a46e89b"
    },
    {
      "id": "kanton/BS/410.500/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für den Religionsunterricht (410.500)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Richtlinien 9. bis 11. Schuljahr",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für das 9. Schuljahr sind vier Projekthalbtage, nach Absprache mit den Kirchen, freizuhalten."
        },
        {
          "absatz": "2",
          "text": "Für das 10. Schuljahr ist wöchentlich eine Doppelstunde am Donnerstag ab 16.00 Uhr freizuhalten."
        },
        {
          "absatz": "3",
          "text": "Für das 11. Schuljahr ist wöchentlich eine Doppelstunde am Dienstag ab 16 Uhr freizuhalten."
        }
      ],
      "stand": "2012-08-13",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8e136fd42af33ed5b5557d3001a29f28",
      "sha": "8e25e6e99ca5c81f40bac1aec18167a2070c7e2941a0c88ebffdec2fc00e0c3f"
    },
    {
      "id": "kanton/BS/410.500/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für den Religionsunterricht (410.500)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Sonderregelung für das 12. bis 14. Schuljahr",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für das 12. bis 14. Schuljahr ist die Konferenz der Rektorinnen und Rektoren oberer Schulen (KROS) ermächtigt, mit den Kirchen die Ansetzung einer Wochenstunde abzusprechen."
        }
      ],
      "stand": "2012-08-13",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8e136fd42af33ed5b5557d3001a29f28",
      "sha": "b0e56f516ff526722b7b8d2f6b6d5045f864f292b0659892937334537857c0d5"
    },
    {
      "id": "kanton/BS/410.500/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für den Religionsunterricht (410.500)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Anmeldung für den Religionsunterricht",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Schülerinnen und Schüler unter 16 Jahren, die den Kirchen angehören, gelten für den Religionsunterricht der Kirchen als angemeldet. Abmeldungen sind von den Erziehungsberechtigten an die Religionslehrerin bzw. den Religionslehrer zu richten."
        },
        {
          "absatz": "2",
          "text": "Schülerinnen und Schüler über 16 Jahre können sich selbständig an- und abmelden."
        }
      ],
      "stand": "2012-08-13",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8e136fd42af33ed5b5557d3001a29f28",
      "sha": "6adffb407e1fcff54900a1aa4d0f8e728699f4af91b2645d9fbff1179e4a2635"
    },
    {
      "id": "kanton/BS/410.500/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für den Religionsunterricht (410.500)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "titel": "Zuteilung der Religionslehrerinnen und -lehrer",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kirchen teilen den Schulleitungen rechtzeitig vor Beginn des Schuljahres die Namen der Religionslehrerinnen und -lehrer sowie allfälliger Inspektorinnen und Inspektoren mit."
        }
      ],
      "stand": "2012-08-13",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8e136fd42af33ed5b5557d3001a29f28",
      "sha": "7412dc6f44ed753fb70820c815279e4e663dc59ef6e560b38cef60a139ff0c84"
    },
    {
      "id": "kanton/BS/410.500/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für den Religionsunterricht (410.500)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "titel": "Pflichten der Religionslehrerinnen und -lehrer",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Religionslehrerinnen und -lehrer gelten sinngemäss die Pflichten, die in den Bestimmungen über die Arbeit der Lehrpersonen festgelegt sind."
        }
      ],
      "stand": "2012-08-13",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8e136fd42af33ed5b5557d3001a29f28",
      "sha": "16f332dd0c76638b9e203d359aeb78f15902d982bf14e0efd263e7ea40fe3659"
    },
    {
      "id": "kanton/BS/410.500/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für den Religionsunterricht (410.500)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "titel": "Pflichten und Rechte der Schulleitungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Schulleitungen sorgen für die Information der Schülerinnen und Schüler über Ort und Zeit des Religionsunterrichtes, soweit dieser in der Schule stattfindet."
        },
        {
          "absatz": "2",
          "text": "Sie halten die Schülerinnen- und Schülerlisten den Religionslehrerinnen und -lehrern zur Einsicht offen."
        },
        {
          "absatz": "3",
          "text": "Sie gewährleisten die unbehinderte Benützung der zugewiesenen Unterrichtsräume und Lehrpersonenzimmer."
        },
        {
          "absatz": "4",
          "text": "Bei Störungen des Unterrichtsbetriebes ergreift die Schulleitung die erforderlichen Massnahmen und orientiert die zuständige Leiterin oder den zuständigen Leiter des Religionsunterrichtes."
        }
      ],
      "stand": "2012-08-13",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8e136fd42af33ed5b5557d3001a29f28",
      "sha": "2ef1f979d5c20cb1684fa9940e4909cbeaa16299ccc47fb7b68c1e8839a48b18"
    },
    {
      "id": "kanton/BS/410.500/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für den Religionsunterricht (410.500)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "titel": "Lehrpersonen staatlicher Schulen als Religionslehrerinnen und -lehrer",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Schulleitungen können den ihnen unterstellten Lehrpersonen die Erteilung von Religionsunterricht im Auftrag der Kirchen innerhalb ihrer Pflichtstundenzahl erlauben. Im Übrigen gilt § 77 Abs. 4 des Schulgesetzes."
        }
      ],
      "stand": "2012-08-13",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8e136fd42af33ed5b5557d3001a29f28",
      "sha": "86933c32b00e0a9fb08c37a5571295654b4b75bcf72fa0f7bdc6ea480a91371a"
    },
    {
      "id": "kanton/BS/410.500/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für den Religionsunterricht (410.500)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "titel": "Übergangsbestimmung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Schuljahre 2009/10 und 2010/11 sind für die Kindergärten der Stadt Basel für die Aufgaben der Schulleitungen das Rektorat der Kindergärten Basel, für die Primarschulen der Stadt Basel für die Aufgaben der Schulleitungen gemäss §§ 1 und 7 die Schulhausleitungen der Primarschule Basel sowie für die Aufgaben der Schulleitungen gemäss § 5 das Rektorat der Primarschule Basel zuständig."
        }
      ],
      "stand": "2012-08-13",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8e136fd42af33ed5b5557d3001a29f28",
      "sha": "ccc7ed20b3d63f46783de1a056d695fbb47e4c582d7967caaeb86b86a044ab4e"
    },
    {
      "id": "kanton/BS/410.500/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für den Religionsunterricht (410.500)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "titel": "Schlussbestimmung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Ordnung ist zu publizieren; sie wird rückwirkend auf Beginn des Schuljahres 2009/10 am 10. August 2009 wirksam."
        },
        {
          "absatz": "2",
          "text": "Auf den gleichen Zeitpunkt wird die Ordnung für den Religionsunterricht vom 16. Mai 1973 aufgehoben."
        }
      ],
      "stand": "2012-08-13",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.500",
      "abgerufen": "2026-06-23",
