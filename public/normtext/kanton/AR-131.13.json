      "sha": "68f8cc6c100ddc7b39c6f4a80b850773573a4f623317d2c7d50f5c5aa7901a04"
    },
    {
      "id": "kanton/AR/131.13/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die eidpflichtigen Behördenmitglieder der Gemeinden (131.13)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Eidpflichtig ist, wer in ein eidpflichtiges Amt gewählt worden ist. Ausgenommen ist die unmittelbare Wiederwahl in dasselbe Amt."
        }
      ],
