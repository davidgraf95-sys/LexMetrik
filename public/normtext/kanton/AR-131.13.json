{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/131.13/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die eidpflichtigen Behördenmitglieder der Gemeinden (131.13)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Eidpflichtig sind folgende Behördenmitglieder der Gemeinden:",
          "items": [
            {
              "marke": "a",
              "text": "die Gemeindepräsidentin oder der Gemeindepräsident;"
            },
            {
              "marke": "b",
              "text": "die Mitglieder des Gemeinderates;"
            },
            {
              "marke": "c",
              "text": "die Mitglieder der Geschäftsprüfungskommission, einschliesslich der Präsidentin oder des Präsidenten;"
            },
            {
              "marke": "d",
              "text": "die Mitglieder des Gemeindeparlaments."
            }
          ]
        }
      ],
      "stand": "2019-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/131.13",
      "abgerufen": "2026-06-23",
