{
  "erzeugt": "2026-06-22",
  "eintraege": [
    {
      "id": "kanton/ZH/211.11/art_1",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": null,
          "text": "Diese Verordnung regelt folgende Kosten eines Zivil- oder Strafverfahrens:",
          "items": [
            {
              "marke": "a",
              "text": "Gebühren für das Schlichtungsverfahren (Art. 95 Abs. 2 lit. a ZPO),"
            },
            {
              "marke": "b",
              "text": "Entscheidgebühren der Zivilgerichte (Art. 95 Abs. 2 lit. b ZPO),"
            },
            {
              "marke": "c",
              "text": "Entscheidgebühren der Strafgerichte (Art. 422 Abs. 1 St PO)."
            }
          ]
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "8493aa1cc1693b5602f3188e6d033a4ab658464fcfb55761a0692e8148f109d8"
    },
    {
      "id": "kanton/ZH/211.11/art_2",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Grundlage für die Festsetzung der Gebühren bilden:",
          "items": [
            {
              "marke": "a",
              "text": "im Zivilprozess: Streitwert bzw. tatsächliches Streitinteresse,"
            },
            {
              "marke": "b",
              "text": "im Strafprozess: Bedeutung des Falls,"
            },
            {
              "marke": "c",
              "text": "Zeitaufwand des Gerichts,"
            },
            {
              "marke": "d",
              "text": "Schwierigkeit des Falls."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die Kosten für Vorladungen, die Telekommunikation sowie die Ausfertigung und die Zustellung von Entscheiden sind in den Gebühren enthalten."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "ef29e379bf43c0c910c4687bd0d93e002633c6d65043c119a02269c43dcbb99a"
    },
    {
      "id": "kanton/ZH/211.11/art_3",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "",
          "mehrspaltig": {
            "kopf": [
              "Streitwert",
              "Gebühr"
            ],
            "zeilen": [
              [
                "bis 1 000",
                "65– 250"
              ],
              [
                "über 1 000 bis 10 000",
                "250– 420"
              ],
              [
                "über 10 000 bis 100 000",
                "420– 615"
              ],
              [
                "über 100 000",
                "615–1240"
              ]
            ]
          }
        },
        {
          "absatz": "2",
          "text": "Bei nicht vermögensrechtlichen Streitigkeiten beträgt die Gebühr Fr. 100 bis Fr. 850."
        },
        {
          "absatz": "3",
          "text": "Entscheidet die Schlichtungsbehörde die Streitigkeit oder unterbreitet sie den Parteien einen Urteilsvorschlag, kann sie die Gebühr bis um die Hälfte erhöhen."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "a09d74ac10b0a59fd3244ca2f0d348e886082f9dcee0de111cecdd357b38d6c6"
    },
    {
      "id": "kanton/ZH/211.11/art_4",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "",
          "mehrspaltig": {
            "kopf": [
              "Streitwert",
              "Grundgebühr",
              "Zuschlag"
            ],
            "zeilen": [
              [
                "bis 1 000 25% des Streitwertes, mind. Fr. 150",
                "",
                ""
              ],
              [
                "über 1 000 bis 5 000",
                "250",
                "zuzügl. 20% des Fr. 1 000 übersteigenden Streitwertes"
              ],
              [
                "über 5 000 bis 20 000",
                "1 050",
                "zuzügl. 14% des Fr. 5 000 übersteigenden Streitwertes"
              ],
              [
                "über 20 000 bis 80 000",
                "3 150",
                "zuzügl. 8% des Fr. 20 000 übersteigenden Streitwertes"
              ],
              [
                "über 80 000 bis 300 000",
                "7 950",
                "zuzügl. 4% des Fr. 80 000 übersteigenden Streitwertes"
              ],
              [
                "über 300 000 bis 1 Mio.",
                "16 750",
                "zuzügl. 2% des Fr. 300 000 übersteigenden Streitwertes"
              ],
              [
                "über 1 Mio. bis 10 Mio.",
                "30 750",
                "zuzügl. 1% des Fr. 1 Mio. übersteigenden Streitwertes"
              ],
              [
                "über 10 Mio.",
                "120 750",
                "zuzügl. 0,5% des Fr. 10 Mio. übersteigenden Streitwertes"
              ]
            ]
          }
        },
        {
          "absatz": "2",
          "text": "Die Grundgebühr kann unter Berücksichtigung des Zeitaufwandes des Gerichts und der Schwierigkeit des Falls ermässigt oder um bis zu einem Drittel, in Ausnahmefällen bis auf das Doppelte, erhöht werden."
        },
        {
          "absatz": "3",
          "text": "Bei Streitigkeiten über wiederkehrende Nutzungen oder Leistungen gemäss Art. 92 ZPO wird die Grundgebühr in der Regel ermässigt."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "54a7085663d959d3b8838ea793d2bb77ce0fc99e9283cbf4ee30d02c3343b66d"
    },
    {
      "id": "kanton/ZH/211.11/art_5",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei nicht vermögensrechtlichen Streitigkeiten wird die Gebühr nach dem tatsächlichen Streitinteresse, dem Zeitaufwand des Gerichts und der Schwierigkeit des Falles bemessen. Sie beträgt in der Regel Fr. 300 bis Fr. 13 000."
        },
        {
          "absatz": "2",
          "text": "Ist im Rahmen von nicht vermögensrechtlichen Streitigkeiten auch über vermögensrechtliche Rechtsbegehren zu entscheiden, die das Verfahren aufwendig gestalten, kann die Gebühr bis zum Betrag erhöht werden, der für den Entscheid über die vermögensrechtlichen Rechtsbegehren allein zu erheben wäre."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "1c97561f86827b7e07f98e977fd18e17439e170e712cd32362151c94af0c94c1"
    },
    {
      "id": "kanton/ZH/211.11/art_6",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "In Scheidungsverfahren nach Art.274–294 ZPO wird die Gebühr gemäss §5 festgesetzt."
        },
        {
          "absatz": "2",
          "text": "Die Gebühr kann bis zur Hälfte der ordentlichen Gebühr ermässigt werden:",
          "items": [
            {
              "marke": "a",
              "text": "bei einer Ehescheidung oder -trennung auf gemeinsames Begehren, wenn sich die Parteien umfassend geeinigt haben,"
            },
            {
              "marke": "b",
              "text": "in Eheschutzsachen."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Abs.1 und 2 gelten sinngemäss für Prozesse über eingetragene Partnerschaften."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "8334a67dbba1deb5f655dd0848670cc5a93016604c74913670a3c26b9990ea2e"
    },
    {
      "id": "kanton/ZH/211.11/art_7",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": null,
          "text": "Die Gebühr kann bis auf zwei Drittel der ordentlichen Gebühr ermässigt werden",
          "items": [
            {
              "marke": "a",
              "text": "in Verfahren über die Anfechtung der Kündigung und über die Erstreckung von Miet- und Pachtverhältnissen für Wohn- und Geschäftsräume,"
            },
            {
              "marke": "b",
              "text": "bei Streitigkeiten aus landwirtschaftlicher Pacht."
            }
          ]
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "cf068600666cef102edefefcda12665de33189e8c847367b61cf9802d4976008"
    },
    {
      "id": "kanton/ZH/211.11/art_8",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im summarischen Verfahren beträgt die Gebühr die Hälfte bis drei Viertel der ordentlichen Gebühr."
        },
        {
          "absatz": "2",
          "text": "Für die Entgegennahme einer Schutzschrift beträgt die Gebühr Fr. 500 bis Fr. 2000."
        },
        {
          "absatz": "3",
          "text": "Bei nicht streitigen Erbschaftsangelegenheiten bemisst sich die Gebühr nach dem Interessewert und dem Zeitaufwand des Gerichts. Sie beträgt in der Regel Fr. 100 bis Fr. 7000."
        },
        {
          "absatz": "4",
          "text": "Bei anderen Angelegenheiten der freiwilligen Gerichtsbarkeit beträgt die Gebühr Fr. 100 bis Fr. 7000."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "676557044c23179100a3b6da7aa3381e9def6bda003bca8c1fe8c6b9901bd704"
    },
    {
      "id": "kanton/ZH/211.11/art_9",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für Entscheide über Ausstandsgesuche nach Art.50 ZPO und für prozessleitende Verfügungen mit Kostenauflage beträgt die Gebühr Fr. 100 bis Fr. 7000."
        },
        {
          "absatz": "2",
          "text": "Für Zwischenentscheide nach Art.237 ZPO beträgt die Gebühr die Hälfte bis drei Viertel der ordentlichen Gebühr."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "6d4ffe880b4d5a12294a27958a733905a768b9cb2c36e95d70bd1ee513ddb0d5"
    },
    {
      "id": "kanton/ZH/211.11/art_10",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wird das Verfahren ohne Anspruchsprüfung oder nach Säumnis erledigt, kann die gemäss §§4–8 bestimmte Gebühr bis auf die Hälfte herabgesetzt werden."
        },
        {
          "absatz": "2",
          "text": "Verzichten die Parteien auf die Begründung des Entscheids, wird die Gebühr auf zwei Drittel ermässigt."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "383e7a58a581c05d62c1dc0f1f76476f3bab519864846ecdd9f2810b3851dd9b"
    },
    {
      "id": "kanton/ZH/211.11/art_11",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "bloecke": [
        {
          "absatz": null,
          "text": "Die Gebühr kann bis auf das Doppelte erhöht werden, wenn keine der Parteien Sitz oder Wohnsitz in der Schweiz hat und es sich beim Streitgegenstand nicht um ein in der Schweiz gelegenes Grundstück handelt."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "eb4b1b8e274c760e70f7cbaf812ee1029be8c456b47116b2dbbfa46953d8845b"
    },
    {
      "id": "kanton/ZH/211.11/art_12",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "12",
      "artikelLabel": "§ 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im Berufungs- und Beschwerdeverfahren wird die Gebühr grundsätzlich nach den für die Vorinstanz geltenden Bestimmungen bemessen."
        },
        {
          "absatz": "2",
          "text": "Die Gebühr bemisst sich dabei nach Massgabe dessen, was vor der Rechtsmittelinstanz noch im Streit liegt."
        },
        {
          "absatz": "3",
          "text": "Entscheidet die Revisionsinstanz in der Sache neu, gelten die Ansätze des ursprünglichen Verfahrens."
        },
        {
          "absatz": "4",
          "text": "Wird ein Revisionsbegehren abgewiesen, kann die Gebühr bis auf einen Drittel reduziert werden."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "5d42afc6f6e582134b0940abc82b6cf53b11fceff96d9d7a0450862003953de0"
    },
    {
      "id": "kanton/ZH/211.11/art_13",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "13",
      "artikelLabel": "§ 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für Vorkehrungen und Entscheidungen staatlicher Gerichte im Bereich der Schiedsgerichtsbarkeit betragen die Gebühren in der Regel Fr. 1000 bis Fr. 20 000."
        },
        {
          "absatz": "2",
          "text": "§8 Abs. 1 gilt sinngemäss",
          "items": [
            {
              "marke": "a",
              "text": "bei vorsorglichen und sichernden Massnahmen nach Art. 374 ZPO und Art.183 Abs.2 des Bundesgesetzes vom 17.September 1987 über das Internationale Privatrecht,"
            },
            {
              "marke": "b",
              "text": "für Anerkennungs- und Vollstreckungsverfahren nach dem Übereinkommen vom 10.Juni 1958 über die Anerkennung und Vollstreckung ausländischer Schiedssprüche (New Yorker Abkommen)."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "In Rechtsmittelverfahren gegen Schiedsurteile vor staatlichen"
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "c4533b25135863f955638637208a930708c857bb0a62a800ef4d6da4d31a3cf9"
    },
    {
      "id": "kanton/ZH/211.11/art_14",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "14",
      "artikelLabel": "§ 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Entscheidet das Gericht materiell über die Anklage, beträgt die Gebühr",
          "items": [
            {
              "marke": "a",
              "text": "vor den Einzelgerichten:Fr. 150 bis Fr. 12 000,"
            },
            {
              "marke": "b",
              "text": "vor den Bezirksgerichten: Fr. 750 bis Fr. 45 000."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "In Ausnahmefällen kann die Gebühr um bis zu einem Drittel erhöht oder ermässigt werden."
        },
        {
          "absatz": "3",
          "text": "Wird das Verfahren ohne materielle Prüfung der Anklage erledigt, kann die Gebühr bis auf zwei Drittel der Ansätze gemäss Abs.1 ermässigt werden. Die Minimalgebühr nach Abs. 1 ist einzuhalten."
        },
        {
          "absatz": "4",
          "text": "Wird über eine Zivilklage erst anschliessend an die Beurteilung von Schuld und Strafpunkt entschieden (Art. 126 Abs. 4 St PO), bemisst sich die Gebühr nach Abs. 1 und 2."
        },
        {
          "absatz": "5",
          "text": "Muss ein Entscheid nicht schriftlich begründet werden, ermässigt sich die Gebühr auf zwei Drittel der Ansätze gemäss Abs. 1. Die Minimalgebühr nach Abs. 1 ist einzuhalten."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "9e13b369fa4f9d98a03e68e722d1a4daf931f1849dd867f7439bec2efe09edf9"
    },
    {
      "id": "kanton/ZH/211.11/art_15",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "15",
      "artikelLabel": "§ 15",
      "bloecke": [
        {
          "absatz": null,
          "text": "Die Gebühr beträgt Fr. 150 bis Fr. 4500",
          "items": [
            {
              "marke": "a",
              "text": "bei selbstständigen nachträglichen Entscheiden nach Art. 363–365 St PO,"
            },
            {
              "marke": "b",
              "text": "bei der Anordnung einer Friedensbürgschaft in einem selbständigen Verfahren nach Art. 372 und 373 St PO,"
            },
            {
              "marke": "c",
              "text": "in selbstständigen Einziehungsverfahren nach Art. 376–378 St PO,"
            },
            {
              "marke": "d",
              "text": "in Ausstandsverfahren (Art. 56–59 St PO)."
            }
          ]
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "b37a1b346f390e2477ccd91d4a952bacd5b31bd7d542f6d898fccaa2130f8245"
    },
    {
      "id": "kanton/ZH/211.11/art_16",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "16",
      "artikelLabel": "§ 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im Berufungsverfahren wird die Gebühr grundsätzlich nach den für die Vorinstanz geltenden Regeln bemessen. Dabei wird auch berücksichtigt, ob das Urteil vollumfänglich oder nur teilweise angefochten worden ist."
        },
        {
          "absatz": "2",
          "text": "Erklärt einzig die geschädigte Person Berufung und beschränkt sich diese auf die Zivilansprüche, richtet sich die Gebühr nach §12 Abs. 1 und 2."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "cbe0bb2f7c791275cf8cecac4531097a692c9af93356aa6ddafcea9c18276b8e"
    },
    {
      "id": "kanton/ZH/211.11/art_17",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "17",
      "artikelLabel": "§ 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im Beschwerdeverfahren beträgt die Gebühr Fr. 300 bis Fr. 12 000. In Ausnahmefällen kann sie um bis zu einem Drittel erhöht werden."
        },
        {
          "absatz": "2",
          "text": "Sind Kostenauflage, Entschädigungsansprüche oder die Einziehung verwertbarer Sach- oder Barwerte Gegenstand der Beschwerde,"
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "589dfbc1e1a1822c0d57d7d787c118cd3bf075d3f91a6e7cc64cfef55794a36a"
    },
    {
      "id": "kanton/ZH/211.11/art_18",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "18",
      "artikelLabel": "§ 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wird ein Revisionsbegehren abgewiesen, beträgt die Gebühr Fr. 300 bis Fr. 3000."
        },
        {
          "absatz": "2",
          "text": "Entscheidet die Revisionsinstanz in der Sache neu, wird die Gebühr nach den Bestimmungen festgelegt, die im Verfahren des revidierten Entscheids massgeblich waren."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "4f8592de6888e90356def39bbdf924a7f2d6dfb98be75d9303c2a92bdab1f672"
    },
    {
      "id": "kanton/ZH/211.11/art_19",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "19",
      "artikelLabel": "§ 19",
      "bloecke": [
        {
          "absatz": null,
          "text": "Für kostenpflichtige Entscheide ausserhalb des Beschwerdeverfahrens erhebt die Beschwerdeinstanz eine Gebühr von Fr. 150 bis Fr. 4500."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "0b0ff2385f5922ef65f5508f0bad4ae59d9d9166059e43eae22ca0ee39d203d9"
    },
    {
      "id": "kanton/ZH/211.11/art_20",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "20",
      "artikelLabel": "§ 20",
      "bloecke": [
        {
          "absatz": null,
          "text": "Die Gebühren für weitere Amtshandlungen der Gerichte, insbesondere solche im Bereich der Justizverwaltung, betragen zwischen Fr. 500 bis Fr. 12 000. In Ausnahmefällen kann die Gebühr um bis zu einem Drittel erhöht werden."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "31f2b0b448f0772cfb6fe2478727c07587eb29b9c254dfc9a8e432dbc981fe7e"
    },
    {
      "id": "kanton/ZH/211.11/art_21",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "21",
      "artikelLabel": "§ 21",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Erstellung von Kopien oder die Zustellung von Akten an Verfahrensbeteiligte gelten die Tarife gemäss §35 der Verordnung über die Information und den Datenschutz vom 28. Mai 2008 sinngemäss. Abweichend von Abs. 3 Satz 2 dieser Bestimmung werden auch Kosten unter Fr. 50 in Rechnung gestellt."
        },
        {
          "absatz": "2",
          "text": "Die Erstellung von Kopien, Vorlegung oder Zustellung von Akten an Amtsstellen erfolgt kostenlos."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "486e6bf1b417cf02c41006715fd25a3c62d765fd5510b8afe6e58eacb99f297f"
    },
    {
      "id": "kanton/ZH/211.11/art_22",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "22",
      "artikelLabel": "§ 22",
      "bloecke": [
        {
          "absatz": null,
          "text": "Die Verordnung des Obergerichts über die Gerichtsgebühren vom 4. April 2007 wird unter Vorbehalt von §23 aufgehoben."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "63b075cd55ff6c782858bc3811b1c96992f6aa4a3d17c3b4f9b23c6def6b72fe"
    },
    {
      "id": "kanton/ZH/211.11/art_23",
      "ebene": "kanton",
      "quelle": "ZH",
      "erlass": "Gebührenverordnung des Obergerichts (GebV OG) (LS 211.11)",
      "artikel": "23",
      "artikelLabel": "§ 23",
      "bloecke": [
        {
          "absatz": null,
          "text": "Finden auf ein Verfahren weiterhin die Bestimmungen des kantonalen Prozessrechts Anwendung, gilt die bisherige Gebührenverordnung."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://www.zh.ch/de/politik-staat/gesetze-beschluesse/gesetzessammlung/zhlex-ls/erlass-211_11-2010_09_08-2011_01_01-087.html",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1ad6aaac74c84a1b5604abb54bf7b2f67dd9656cd4311ec75976da7d8cef4c2c",
      "sha": "883ae0fdd3d374c5fe3ea66034e214ddbe339d8afe352d760b856fe0a347ae7d"
    }
  ]
}