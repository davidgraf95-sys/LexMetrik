{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/415.150/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kinder- und Jugendkommissionsverordnung , KJKV (415.150)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung regelt die Aufgaben, Zusammensetzung und Wahl der Kommission für Kinder- und Jugendfragen."
        }
      ],
      "stand": "2015-03-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/415.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "18405b08e485ce7672c0daa9885c4498",
      "sha": "49308d8555ae0f6da0c81fd5add55908531fa309f6fbf2bff680e36e6b6af952"
    },
    {
      "id": "kanton/BS/415.150/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kinder- und Jugendkommissionsverordnung , KJKV (415.150)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kommission für Kinder- und Jugendfragen hat insbesondere folgende Aufgaben:",
          "items": [
            {
              "marke": "a",
              "text": "Sie berät private und öffentliche Stellen bei der Weiterentwicklung von Förderung und Schutz von Kindern und Jugendlichen,"
            },
            {
              "marke": "b",
              "text": "sie fördert die Zusammenarbeit zwischen privaten Leistungserbringern und kantonalen und kommunalen Stellen, und"
            },
            {
              "marke": "c",
              "text": "sie engagiert sich für die Mitwirkung von Kindern und Jugendlichen und bezieht diese in geeigneter Weise in ihre Meinungs- und Willensbildung ein."
            }
          ]
        }
      ],
      "stand": "2015-03-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/415.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "18405b08e485ce7672c0daa9885c4498",
      "sha": "bf52a27e1bf3825624b999e8ce5f30e2d4f8ee4c69afa67d46369f33c4043756"
    },
    {
      "id": "kanton/BS/415.150/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kinder- und Jugendkommissionsverordnung , KJKV (415.150)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kinder- und Jugendkommission besteht aus mindestens neun Mitgliedern."
        },
        {
          "absatz": "2",
          "text": "Die Vorsteherin oder der Vorsteher des Erziehungsdepartements präsidiert die Kommission für Kinder- und Jugendfragen."
        },
        {
          "absatz": "3",
          "text": "Der Regierungsrat wählt die übrigen Mitglieder auf Antrag des Erziehungsdepartements."
        },
        {
          "absatz": "4",
          "text": "Er berücksichtigt in angemessener Weise Vertretungen der privaten Leistungserbringer, der Gemeinden und der zuständigen kantonalen und kommunalen Fachstellen."
        },
        {
          "absatz": "5",
          "text": "Es gilt die Amtsdauer der regierungsrätlichen Kommissionen."
        },
        {
          "absatz": "6",
          "text": "Der Junge Rat kann zwei seiner Mitglieder mit beratender Stimme in die Kommission für Kinder- und Jugendfragen delegieren."
        }
      ],
      "stand": "2015-03-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/415.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "18405b08e485ce7672c0daa9885c4498",
      "sha": "640b812095c5befb276c5fa02660cd25c8a403a2b0779a2fdbef9a0675dc7794"
    },
    {
      "id": "kanton/BS/415.150/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kinder- und Jugendkommissionsverordnung , KJKV (415.150)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Sekretariat der Kommission für Kinder- und Jugendfragen wird vom Erziehungsdepartement geführt."
        }
      ],
      "stand": "2015-03-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/415.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "18405b08e485ce7672c0daa9885c4498",
      "sha": "445387ba35456629b8628bb4ffd39c1cdb919f5f49ec1497241ef157381b5b75"
    },
    {
      "id": "kanton/BS/415.150/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kinder- und Jugendkommissionsverordnung , KJKV (415.150)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die bisherige Kommission für Jugendfragen übernimmt in bestehender Zusammensetzung die Aufgaben der Kinder- und Jugendkommission bis zum Ablauf der Amtsperiode 2013 bis 2017."
        }
      ],
      "stand": "2015-03-08",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/415.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "18405b08e485ce7672c0daa9885c4498",
      "sha": "b2d557a2698efe591c6c3bded200ec2df0fb42b7bf4cbbcaf11cc11a284de67b"
    }
  ]
}