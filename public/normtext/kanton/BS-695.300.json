{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/695.300/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schatzungs- und Abgrenzungsbestimmungen zum Gebäudeversicherungsgesetz (695.300)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Neubauten sowie wertvermehrende Investitionen am Gebäude sind der Gebäudeversicherung unmittelbar nach Erteilung der Baubewilligung, spätestens bei Beginn der Bauarbeiten anzumelden."
        },
        {
          "absatz": "2",
          "text": "Die Versicherung beginnt mit dem Eintreffen der Anmeldung bei der Gebäudeversicherung."
        },
        {
          "absatz": "3",
          "text": "Der Versicherte erhält einen Versicherungsausweis über den Umfang der Deckung."
        },
        {
          "absatz": "4",
          "text": "Der Bezug der Prämie erfolgt nach Vollendung der Bauarbeiten und wird rückwirkend auf den Beginn der Bauarbeiten erhoben."
        }
      ],
      "stand": "2006-12-14",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f2db6c437dc0069aabc455d9b6b915bf",
      "sha": "16bf377262ad8ab97f236a0e06e06af5d800deb552844ceefb30b5414b6eaaa2"
    },
    {
      "id": "kanton/BS/695.300/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schatzungs- und Abgrenzungsbestimmungen zum Gebäudeversicherungsgesetz (695.300)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Anmeldung zur Bauversicherung ist das Antrags-Formular mit den erforderlichen Beilagen einzureichen."
        }
      ],
      "stand": "2006-12-14",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f2db6c437dc0069aabc455d9b6b915bf",
      "sha": "326560fd87a2f5f54584e4deed85a448f5df511eb71dd4b2a69411e3bfecddd4"
    },
    {
      "id": "kanton/BS/695.300/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schatzungs- und Abgrenzungsbestimmungen zum Gebäudeversicherungsgesetz (695.300)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Versichert ist der steigende Wert des Bauwerkes bis zur Höhe der bestätigten Deckungssumme. § 8 des Gesetzes gilt sinngemäss."
        },
        {
          "absatz": "2",
          "text": "Von der Versicherung ausgeschlossen sind insbesondere:",
          "items": [
            {
              "marke": "a",
              "text": "Aushub, Aufschüttungen, Fundament- und Leitungsgräben;"
            },
            {
              "marke": "b",
              "text": "Bauplatzinstallationen (Spriessungen, Gerüste, Bauhütten);"
            },
            {
              "marke": "c",
              "text": "Werkzeuge, Baugeräte und Maschinen aller Art;"
            },
            {
              "marke": "d",
              "text": "durch den Bau bedingte Provisorien."
            }
          ]
        }
      ],
      "stand": "2006-12-14",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f2db6c437dc0069aabc455d9b6b915bf",
      "sha": "6363f4de0e56bc6c04638d970d901e01761fcd24313a94beba3f670bac23af7b"
    },
    {
      "id": "kanton/BS/695.300/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schatzungs- und Abgrenzungsbestimmungen zum Gebäudeversicherungsgesetz (695.300)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Vollendung der Bauarbeiten ist der Gebäudeversicherung zu melden."
        },
        {
          "absatz": "2",
          "text": "Die Bauversicherung wird durch die definitive Versicherung abgelöst, wenn der vollendete Neu- oder Ausbau durch das Bauinspektorat abgenommen ist, spätestens jedoch ein Jahr nach Bezug bzw. Inbetriebnahme des Gebäudes."
        }
      ],
      "stand": "2006-12-14",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f2db6c437dc0069aabc455d9b6b915bf",
      "sha": "68d13f8529af6e85c8f483165c277e3d7ab600eefe91354752353c7d13a63d9e"
    },
    {
      "id": "kanton/BS/695.300/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schatzungs- und Abgrenzungsbestimmungen zum Gebäudeversicherungsgesetz (695.300)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Schatzung von Gebäuden wird in der Regel durch zwei Schatzungsexperten vorgenommen. Ein Schatzungsexperte kann durch einen Vertreter der Gebäudeversicherung ersetzt werden."
        },
        {
          "absatz": "2",
          "text": "Auf eine Schatzung kann verzichtet werden, wenn der Aufwand für die Bauarbeiten genügend belegt ist."
        }
      ],
      "stand": "2006-12-14",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f2db6c437dc0069aabc455d9b6b915bf",
      "sha": "58b254cd36d2a69d5f57eefc1df49f561f644f9ff0949cb6d19500134ac753a7"
    },
    {
      "id": "kanton/BS/695.300/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schatzungs- und Abgrenzungsbestimmungen zum Gebäudeversicherungsgesetz (695.300)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Gebäudeeigentümer oder sein Vertreter sind zur Schatzung eingeladen."
        },
        {
          "absatz": "2",
          "text": "Der Schatzungstermin wird dem Eigentümer schriftlich, mindestens 14 Tage vorher, mitgeteilt."
        },
        {
          "absatz": "3",
          "text": "Muss ein weiterer Schatzungstermin angesetzt werden, weil die Schatzung nicht oder nicht vollständig durchgeführt werden konnte, wegen Abwesenheit des Eigentümers oder seines Vertreters oder Fehlens anderer Voraussetzungen für die Schatzung, so hat der Eigentümer eine Gebühr von CHF 100 bis 250 zu entrichten"
        }
      ],
      "stand": "2006-12-14",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f2db6c437dc0069aabc455d9b6b915bf",
      "sha": "1d1b433fb2fc9d17e99b52aefc634e2deb854bb5af7b8ab0863f781c0fdd54a8"
    },
    {
      "id": "kanton/BS/695.300/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schatzungs- und Abgrenzungsbestimmungen zum Gebäudeversicherungsgesetz (695.300)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die definitive Schatzung wird aufgrund folgender Unterlagen vorgenommen:",
          "items": [
            {
              "marke": "a",
              "text": "der Bauabrechnung;"
            },
            {
              "marke": "b",
              "text": "der nachgeführten Ausführungspläne;"
            },
            {
              "marke": "c",
              "text": "…"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die Kubatur der Gebäude wird nach den Normalien für kubische Berechnungen von Hochbauten, SIA-Norm Nr. 116, festgelegt."
        }
      ],
      "stand": "2006-12-14",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f2db6c437dc0069aabc455d9b6b915bf",
      "sha": "75a1501fd187060a09007ef0e5bef07d472c007134e0573f1de30d269edc15bf"
    },
    {
      "id": "kanton/BS/695.300/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schatzungs- und Abgrenzungsbestimmungen zum Gebäudeversicherungsgesetz (695.300)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Wertverminderung eines Gebäudes ist vom Alter, von der mutmasslichen Lebensdauer und vom Zustand des Gebäudes abhängig."
        },
        {
          "absatz": "2",
          "text": "Mittlere Werte liefert die Hägi-Kurve (siehe Anhang)."
        }
      ],
      "stand": "2006-12-14",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f2db6c437dc0069aabc455d9b6b915bf",
      "sha": "48886c7e74d97d6d949d90ed4d7ae0c9f643774f9749a115f18cbabb1e7c8dda"
    },
    {
      "id": "kanton/BS/695.300/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schatzungs- und Abgrenzungsbestimmungen zum Gebäudeversicherungsgesetz (695.300)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Schatzungsergebnis und die Risikoklassenzuteilung werden dem Eigentümer mit dem neuen Versicherungsausweis mitgeteilt."
        }
      ],
      "stand": "2006-12-14",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f2db6c437dc0069aabc455d9b6b915bf",
      "sha": "6f5873c5322b0e93eec095ae1b1cf91e2e0b686c536c669ad6f6a9ead2ea11c3"
    },
    {
      "id": "kanton/BS/695.300/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schatzungs- und Abgrenzungsbestimmungen zum Gebäudeversicherungsgesetz (695.300)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei teilweisem Abbruch eines Gebäudes ist der verbleibende Versicherungswert festzusetzen."
        }
      ],
      "stand": "2006-12-14",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f2db6c437dc0069aabc455d9b6b915bf",
      "sha": "dcf903fbcbebbadeb59488b3bc4f42d25ff0796147325a0a369bea474fa59444"
    },
    {
      "id": "kanton/BS/695.300/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schatzungs- und Abgrenzungsbestimmungen zum Gebäudeversicherungsgesetz (695.300)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Mit dem Gebäude sind versichert, sofern ortsgebunden und dem Gebäudeeigentümer gehörend:",
          "items": [
            {
              "marke": "a",
              "text": "alle Einrichtungen, die dem umbauten Raum dazu verhelfen benützbar zu sein;"
            },
            {
              "marke": "b",
              "text": "die der Beheizung, Belüftung und Klimatisierung des Raumes dienenden Einrichtungen;"
            },
            {
              "marke": "c",
              "text": "die elektrischen und sanitären Installationen, die hauswirtschaftlichen oder hygienischen Zwecken dienen;"
            },
            {
              "marke": "d",
              "text": "alle anderen Einrichtungen, die in das Gebäude fest eingebaut oder so eingepasst sind, dass sie ohne Beschädigung des Gebäudes nicht entfernt werden können;"
            },
            {
              "marke": "e",
              "text": "bis maximal CHF 10'000 pro Schadenfall – Aussenbeleuchtungen – Gartenmauern und -tore – Einfriedungen (ohne Lebhag) – Im Boden fest eingebaute Schwimmbassins samt Abdeckungen – Stützmauern Diese Aufzählung ist abschliessend."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die unter Abs. 1 lit. b–e genannten Einrichtungen sind auch dann versichert, wenn sie dem Mieter gehören. Ausgenommen sind Spannteppiche."
        },
        {
          "absatz": "3",
          "text": "Ferner sind diejenigen Bauteile versichert, die nicht allseitig umwandet sind, wie Vordächer, Veranden, Terrassen, Pergolen usw."
        },
        {
          "absatz": "4",
          "text": "Kleinbauten unter CHF 15'000 können auf Antrag hin versichert werden."
        }
      ],
      "stand": "2006-12-14",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f2db6c437dc0069aabc455d9b6b915bf",
      "sha": "17441f1494e02555040e0343cab58278b42b48768b3abbd7b1f0a0b7f8665b35"
    },
    {
      "id": "kanton/BS/695.300/art_12",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schatzungs- und Abgrenzungsbestimmungen zum Gebäudeversicherungsgesetz (695.300)",
      "artikel": "12",
      "artikelLabel": "§ 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Von der Versicherung ausgeschlossen sind:",
          "items": [
            {
              "marke": "a",
              "text": "Fahrnis;"
            },
            {
              "marke": "b",
              "text": "alle betriebstechnischen Einrichtungen gewerblicher und industrieller Anlagen mit den zugehörigen Installationen, auch wenn sie in das Gebäude fest eingebaut oder eingepasst sind;"
            },
            {
              "marke": "c",
              "text": "Gartenanlagen und Bepflanzungen."
            }
          ]
        }
      ],
      "stand": "2006-12-14",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f2db6c437dc0069aabc455d9b6b915bf",
      "sha": "51f0ec7fb58c59756853fc53a59e884c9bbb625ae1a3f56ed8efeaaa8f151ea0"
    },
    {
      "id": "kanton/BS/695.300/art_13",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schatzungs- und Abgrenzungsbestimmungen zum Gebäudeversicherungsgesetz (695.300)",
      "artikel": "13",
      "artikelLabel": "§ 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Bestimmungen sind zu publizieren und treten mit dem Gesetz am 1. Januar 1974 in Wirksamkeit."
        }
      ],
      "stand": "2006-12-14",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f2db6c437dc0069aabc455d9b6b915bf",
      "sha": "592df8ea4574413342846be3eabe716752d623974bbdbc7487eb0d8d01e322e8"
    }
  ]
}