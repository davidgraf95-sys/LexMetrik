{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/424.510/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kursgeldverordnung für den Passerellen-Lehrgang (424.510)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Kursgeld wird semesterweise erhoben."
        },
        {
          "absatz": "2",
          "text": "Massgebend für die Erhebung des Kursgeldes ist der stipendienrechtliche Wohnsitz."
        },
        {
          "absatz": "3",
          "text": "Das Kursgeld beträgt CHF 1'500 pro Semester."
        },
        {
          "absatz": "4",
          "text": "Für auswärtige (ausserkantonale und ausländische) Auszubildende wird zusätzlich zum Kursgeld ein Schulgeld erhoben, wenn der zuständige Kanton das Schulgeld nicht übernimmt. Die Höhe des Schulgeldes ist im Regionalen Schulabkommen (RSA) geregelt."
        }
      ],
      "stand": "2005-08-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/424.510",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4c8df54a7f46c79a416b1d63614ee6fd",
      "sha": "f7b032b30b5c77d7c15cb965c86f94094391a99c2f58ededa21118f4cd60de27"
    },
    {
      "id": "kanton/BS/424.510/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kursgeldverordnung für den Passerellen-Lehrgang (424.510)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Es wird eine Einschreibgebühr von CHF 200 erhoben."
        },
        {
          "absatz": "2",
          "text": "Die Einschreibgebühr wird an die 1. Rate des Kursgeldes angerechnet."
        },
        {
          "absatz": "3",
          "text": "Die Einschreibgebühr wird bei Abmeldung nicht rückerstattet."
        }
      ],
      "stand": "2005-08-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/424.510",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4c8df54a7f46c79a416b1d63614ee6fd",
      "sha": "a062ca0fd0bda2c4cbd7f8eaef84a2f1b8d703ddd47b27194e1b7618b6ecb30f"
    },
    {
      "id": "kanton/BS/424.510/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kursgeldverordnung für den Passerellen-Lehrgang (424.510)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Als Stichtage für die Rechnungstellung gelten der 31. August und der 31. Januar. Das Kursgeld ist innert der in der Rechnung festgelegten Zahlungsfrist zu begleichen."
        },
        {
          "absatz": "2",
          "text": "Das Kursgeld kann in fünf Raten oder semesterweise beglichen werden."
        }
      ],
      "stand": "2005-08-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/424.510",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4c8df54a7f46c79a416b1d63614ee6fd",
      "sha": "bea62ae9dd936dbf31916969a3bf407f5a5bfc7e35cb38b6e535b99d7bfdb286"
    },
    {
      "id": "kanton/BS/424.510/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kursgeldverordnung für den Passerellen-Lehrgang (424.510)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "In Härtefällen kann das Kursgeld auf schriftliches Gesuch hin vom Erziehungsdepartement reduziert werden."
        },
        {
          "absatz": "2",
          "text": "Bezahltes Kursgeld wird nicht rückerstattet."
        }
      ],
      "stand": "2005-08-15",
