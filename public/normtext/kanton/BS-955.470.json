  "eintraege": [
    {
      "id": "kanton/BS/955.470/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührentarif der Schweizerischen Rheinhäfen (955.470)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieser Gebührentarif regelt die Inanspruchnahme von Dienstleistungen in der Rheinschifffahrt sowie dem Energiebezug und der Entsorgung von Schiffsbetriebsabfällen durch die Schweizerischen Rheinhäfen."
        },
        {
          "absatz": "2",
          "text": "Für die Gebühren kann eine Vorauszahlung oder deren Sicherstellung verlangt werden. Die Tarife verstehen sich in Schweizer Franken. Bei Tarifpositionen mit anfallender MwSt. wird diese zusätzlich in Rechnung gestellt."
        },
        {
          "absatz": "3",
          "text": "Für die Personaleinsätze nach § 9 Abs. 5 und § 11 gilt ein Samstagszuschlag von 25% sowie ein Zuschlag von 50% an Sonntagen, Feiertagen oder während der Nachtzeit."
        }
      ],
      "stand": "2017-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/955.470",
