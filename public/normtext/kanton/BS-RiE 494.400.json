{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/RiE 494.400/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Kulturpreises (RiE 494.400)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "titel": "Zweck",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zur Förderung kultureller Tätigkeiten und zur Anerkennung bedeutender kultureller Leistungen wird ein Kulturpreis ausgerichtet."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 494.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9e85f48031eed88c1931086d500f874d",
      "sha": "316b505b463198b54e1c462524e61da242c947230d7026bf32f8398ea9c0c46d"
    },
    {
      "id": "kanton/BS/RiE 494.400/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Kulturpreises (RiE 494.400)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Jury",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Ausrichtung des Kulturpreises ist eine Jury, bestehend aus sieben Mitgliedern, zuständig. Sie wird vom Gemeinderat gewählt."
        },
        {
          "absatz": "2",
          "text": "Ihre Entscheide trifft sie nach geheimer Beratung mit einfacher Stimmenmehrheit."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 494.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9e85f48031eed88c1931086d500f874d",
      "sha": "0c4fce08ecdacbdbdc5d6c87b887ea34d1c245ef73032d35fa21a1d07e6415c8"
    },
    {
      "id": "kanton/BS/RiE 494.400/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Kulturpreises (RiE 494.400)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Amtsdauer",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Amtsdauer der Jury entspricht derjenigen des Gemeinderats."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 494.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9e85f48031eed88c1931086d500f874d",
      "sha": "2b5622434e65127c12374b0c36fe22c0badb7c0c0600186fdf5976eafbb9eb7f"
    },
    {
      "id": "kanton/BS/RiE 494.400/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Kulturpreises (RiE 494.400)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Organisation",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Jury wählt aus ihren Mitgliedern das Präsidium und Vizepräsidium für eine Amtsdauer von zwei Jahren."
        },
        {
          "absatz": "1bis",
          "text": "Das Sekretariat wird von der zuständigen Verwaltungsabteilung sichergestellt. Die Protokolle werden nur den Mitgliedern zugestellt und sind nicht öffentlich zugänglich."
        },
        {
          "absatz": "2",
          "text": "Die Organisation der Vergabe des Kulturpreises erfolgt durch die zuständige Verwaltungsabteilung."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 494.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9e85f48031eed88c1931086d500f874d",
      "sha": "3ce1d0fe612990990a7fd4b1148d6c980d8a7140f5975bec69e3a7e06d437999"
    },
    {
      "id": "kanton/BS/RiE 494.400/art_5.",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Kulturpreises (RiE 494.400)",
      "artikel": "5.",
      "artikelLabel": "§ 5.",
      "titel": "Anerkennungs- oder Förderpreis",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kulturpreis wird als Anerkennung für bedeutende kulturelle Leistungen oder als Förderpreis an fähige junge Kulturschaffende vergeben."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 494.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9e85f48031eed88c1931086d500f874d",
      "sha": "3f9c86aa169a44386983f3cc2f662b1b3f55e986a3405b89075d99500321da36"
    },
    {
      "id": "kanton/BS/RiE 494.400/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Kulturpreises (RiE 494.400)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "titel": "Bezug zu Riehen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Preisempfängerin oder der Preisempfänger muss in Riehen einen festen Wohnsitz haben oder zur Gemeinde in einer besonderen Beziehung stehen."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 494.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9e85f48031eed88c1931086d500f874d",
      "sha": "da20a4891c7187e6097734ea804a9a38ebaa99a4713c8dd2e263ce1cba0d150f"
    },
    {
      "id": "kanton/BS/RiE 494.400/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Kulturpreises (RiE 494.400)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "titel": "Ausrichtung des Kulturpreises",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kulturpreis wird in der Regel alle zwei Jahre ausgerichtet."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 494.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9e85f48031eed88c1931086d500f874d",
      "sha": "89bcefd91a7ae2108047a981ef286273ae7709f5c14cb741fa3cb6af86eb44b8"
    },
    {
      "id": "kanton/BS/RiE 494.400/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Kulturpreises (RiE 494.400)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "titel": "Preissumme",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Ausrichtung des Kulturpreises steht jeweils eine Preissumme von CHF 10'000 zur Verfügung."
        },
        {
          "absatz": "2",
          "text": "Im Einzelfall dürfen in der Regel nicht mehr als CHF 10'000 ausgerichtet werden. Es können auch mehrere Auszeichnungen verliehen werden."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 494.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9e85f48031eed88c1931086d500f874d",
      "sha": "f7bc2f6c1f476815f775edcff4c386eee28323581ae2c59cf444173259e8d761"
    },
    {
      "id": "kanton/BS/RiE 494.400/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Kulturpreises (RiE 494.400)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "titel": "Verzicht auf die Vergabe",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Jury kann in begründeten Fällen auf die Vergabe eines Kulturpreises verzichten."
        },
        {
          "absatz": "2",
          "text": "…"
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 494.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9e85f48031eed88c1931086d500f874d",
      "sha": "5c2b80e5c95fc7886039918278ed904535f5e235ed77089c12dda28ddb05ad5f"
    },
    {
      "id": "kanton/BS/RiE 494.400/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Kulturpreises (RiE 494.400)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "titel": "Vorschlag",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Jury unterbreitet dem Gemeinderat alle zwei Jahre einen Vorschlag für die Vergabe des Kulturpreises zur Genehmigung."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 494.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9e85f48031eed88c1931086d500f874d",
      "sha": "e86ab2d697f1402329f0c8a0ea3345f9c114a8a3facd58e5b7b387aad26f27a7"
    },
    {
      "id": "kanton/BS/RiE 494.400/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Kulturpreises (RiE 494.400)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "titel": "Entscheid",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Entscheid betreffend Kulturpreis wird in der Regel spätestens im März getroffen."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 494.400",
