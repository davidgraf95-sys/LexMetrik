{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/519.400/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "GVo (519.400)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung gilt für die Erhebung von Gebühren auf dem Gebiet der Beglaubigungen, der Einwohnerkontrolle, des Namensrechts, des Ausländerrechts und des amtlichen Schriftenrechts, soweit sie nicht in anderen Erlassen des Bundes oder des Kantons geregelt ist."
        }
      ],
      "stand": "2024-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/519.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "986f34c9df79c7a196267e8014069421",
      "sha": "d2a482cd7daef3f73613dd2a67941be7a179a66b77b6f8487e03fbb4c4d7907c"
    },
    {
      "id": "kanton/BS/519.400/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "GVo (519.400)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühr beträgt:",
          "items": [
            {
              "marke": "a",
              "text": "für das Erstellen von Fotokopien, pro Kopie Fr. 2"
            },
            {
              "marke": "b",
              "text": "für Kommunikations- und Übermittlungsleistungen die effektiven Kosten"
            }
          ]
        }
      ],
      "stand": "2024-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/519.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "986f34c9df79c7a196267e8014069421",
      "sha": "1f51dd18be0938e201b2f570f4b08734debb364db3fb1ed0c895546a529cd9f4"
    },
    {
      "id": "kanton/BS/519.400/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "GVo (519.400)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühr beträgt für die Beglaubigung:",
          "items": [
            {
              "marke": "a",
              "text": "einer Einzelunterschrift (persönliche oder Firmenunterschrift) Fr. 15"
            },
            {
              "marke": "b",
              "text": "einer Kollektivunterschrift (Firmenunterschrift) Fr. 20"
            },
            {
              "marke": "c",
              "text": "einer notariellen oder amtlichen Unterschrift Fr. 15"
            },
            {
              "marke": "d",
              "text": "der Echtheit einer öffentlichen Urkunde (Apostille) Fr. 20"
            },
            {
              "marke": "e",
              "text": "der Übereinstimmung von Bücher- und Protokollauszügen, Fotokopien usw. mit dem Original:"
            },
            {
              "marke": "1",
              "text": "für die erste Seite Fr. 12"
            },
            {
              "marke": "2",
              "text": "für jede weitere Seite Fr. 4"
            }
          ]
        }
      ],
      "stand": "2024-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/519.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "986f34c9df79c7a196267e8014069421",
      "sha": "da5c7912211aa30ebca0d473a4e0814077d5481a47949678abb3e10a88675256"
    },
    {
      "id": "kanton/BS/519.400/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "GVo (519.400)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühr beträgt:",
          "items": [
            {
              "marke": "a",
              "text": "für amtliche Bescheinigungen Fr. 20"
            },
            {
              "marke": "b",
              "text": "für Lebensbescheinigungen am Schalter Fr. 10"
            },
            {
              "marke": "c",
              "text": "für Schriftenbesorgung und Schriftennachsendungen Fr. 20"
            },
            {
              "marke": "d",
              "text": "für Adressauskünfte,"
            },
            {
              "marke": "1",
              "text": "pro Adresse Fr. 10"
            },
            {
              "marke": "2",
              "text": "bei Listenauskünften pro Adresse Fr. 5"
            },
            {
              "marke": "e",
              "text": "für Archivauskünfte, pro Anfrage Fr. 30"
            },
            {
              "marke": "f",
              "text": "für die Anmeldung, pro Person Fr. 25"
            },
            {
              "marke": "g",
              "text": "für die Abmeldung,"
            },
            {
              "marke": "1",
              "text": "pro Person Fr. 20"
            },
            {
              "marke": "2",
              "text": "pro Haushalt Fr. 40"
            },
            {
              "marke": "h",
              "text": "für die schuldhafte amtliche Streichung Fr. 40"
            },
            {
              "marke": "i",
              "text": "für die Ausstellung eines Heimatausweises,"
            },
            {
              "marke": "1",
              "text": "pro Person Fr. 25"
            },
            {
              "marke": "2",
              "text": "Verlängerung Fr. 15"
            },
            {
              "marke": "j",
              "text": "für die Registrierung oder Änderung eines Geschäftseintrages Fr. 25"
            }
          ]
        }
      ],
      "stand": "2024-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/519.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "986f34c9df79c7a196267e8014069421",
      "sha": "bff5d260176da185aed871b4865f566b55fa71a2aa15fc0bb4ae6c6b3772568d"
    },
    {
      "id": "kanton/BS/519.400/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "GVo (519.400)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühr beträgt:",
          "items": [
            {
              "marke": "a",
              "text": "für Vornamensänderungen Fr. 200"
            },
            {
              "marke": "b",
              "text": "für Familiennamensänderungen Fr. 400"
            },
            {
              "marke": "c",
              "text": "für gleichzeitige Vor- und Familiennamensänderungen Fr. 500"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Stellen mehrere Familienmitglieder ein Namensänderungsgesuch, so kann die Gebühr reduziert werden."
        }
      ],
      "stand": "2024-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/519.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "986f34c9df79c7a196267e8014069421",
      "sha": "cfeb7af5bab3c0b7eab612b020705e4e963a00c81e1115c93afdb857128e69b5"
    },
    {
      "id": "kanton/BS/519.400/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "GVo (519.400)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die in Art. 8 und 12 der GebV-AIG aufgeführten Höchstgebühren gelten als kantonale Gebühren."
        },
        {
          "absatz": "2",
          "text": "Es werden zudem die folgenden Gebühren erhoben:",
          "items": [
            {
              "marke": "a",
              "text": "für ausländerrechtliche Verfügungen, insbesondere die Verweigerung einer Bewilligung, den Widerruf einer Bewilligung bis Fr. 500"
            },
            {
              "marke": "b",
              "text": "für die Verwarnung bis Fr. 200"
            },
            {
              "marke": "c",
              "text": "für die Aufhebung einer Verfügung nach § 6 Abs. 2 lit. a, sofern die Verfügung aufgrund mangelhafter Mitwirkung der Verfügungsadressatin oder des Verfügungsadressaten im Verfahren ergangen ist bis Fr. 500"
            },
            {
              "marke": "d",
              "text": "für die Abschreibung des Verfahrens bis Fr. 100"
            },
            {
              "marke": "e",
              "text": "für die Ausstellung der Anwesenheitsbestätigung Fr. 20"
            },
            {
              "marke": "f",
              "text": "für die Bearbeitung einer Verpflichtungserklärung Fr. 50"
            },
            {
              "marke": "g",
              "text": "für die Bescheinigung betreffend Wegfall der Grenzgängereigenschaft Fr. 20"
            }
          ]
        }
      ],
      "stand": "2024-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/519.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "986f34c9df79c7a196267e8014069421",
      "sha": "15bedfeda4104de7573e6a0a17ebc946bd3411e9eaaf4aee0d1c4939d81a595e"
    },
    {
      "id": "kanton/BS/519.400/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "GVo (519.400)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für amtliche Ausweise für Schweizer Staatsangehörige und weitere Dienstleistungen werden die in der Ausweisverordnung festgelegten Gebühren erhoben."
        },
        {
          "absatz": "2",
          "text": "Es werden zudem die folgenden Gebühren erhoben:",
          "items": [
            {
              "marke": "a",
              "text": "Bearbeitungsgebühr für den Verlust gültiger Ausweise Fr. 20"
            },
            {
              "marke": "b",
              "text": "Verwaltung/Depot von Zweitpässen, Gebühr pro Kalenderjahr Fr. 20"
            }
          ]
        }
      ],
      "stand": "2024-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/519.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "986f34c9df79c7a196267e8014069421",
      "sha": "b5cb56eb2337e910436687cad06c9b641f7f64ca8223a989fdbf521065175de4"
    },
    {
      "id": "kanton/BS/519.400/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "GVo (519.400)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für Verfügungen und Dienstleistungen ohne festen Gebührensatz werden die Gebühren nach Zeitaufwand bemessen."
        },
        {
          "absatz": "2",
          "text": "Der Stundenansatz beträgt je nach erforderlicher Sachkenntnis Fr. 100 bis Fr. 250."
        }
      ],
      "stand": "2024-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/519.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "986f34c9df79c7a196267e8014069421",
      "sha": "054c988faba232917444cc9269029ac917713910303f25df9690425f63ebdc55"
    },
    {
      "id": "kanton/BS/519.400/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "GVo (519.400)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Es können folgende Zuschläge erhoben werden:",
          "items": [
            {
              "marke": "a",
              "text": "für Verfügungen und Dienstleistungen, die auf Ersuchen hin dringlich erlassen oder erbracht werden bis zu 50 % der ordentlichen Gebühr"
            },
            {
              "marke": "b",
              "text": "für Verfahren und Dienstleistungen von aussergewöhnlichem Umfang oder besonderer Schwierigkeit bis zu Fr. 250"
            },
            {
              "marke": "c",
              "text": "für Übersetzungen die effektiven Kosten"
            },
            {
              "marke": "d",
              "text": "für Leistungen anderer Behörden oder Dritter die effektiven Kosten"
            },
            {
              "marke": "e",
              "text": "für das unentschuldigte Nichterscheinen zu Terminen bei Behörden bis zu Fr. 50"
            },
            {
              "marke": "f",
              "text": "ab der zweiten Mahnung für die Nichteinreichung von Dokumenten Fr. 20"
            },
            {
              "marke": "g",
              "text": "für schriftliche Vorladungen, die wegen Versäumnissen zu erlassen sind Fr. 40"
            }
          ]
        }
      ],
      "stand": "2024-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/519.400",
      "abgerufen": "2026-06-23",
      "fassungsToken": "986f34c9df79c7a196267e8014069421",
      "sha": "9c13f369eb88e1c275baedc9078df776925643cf417bb7b96be4ae4fcd61d457"
    }
  ]
}