{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/133.1/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Informationsgesetz (133.1)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieses Gesetz regelt die Grundsätze der Information der Bevölkerung über die Tätigkeit der Behörden sowie das Recht auf Einsicht in amtliche Akten."
        },
        {
          "absatz": "2",
          "text": "Es gilt für alle Behörden und Organe des Kantons, der Gemeinden und von Gemeindeverbindungen sowie der öffentlich-rechtlichen Körperschaften und Anstalten i.S. von Art. 108 der Kantonsverfassung."
        },
        {
          "absatz": "3",
          "text": "Vorbehalten bleiben besondere Bestimmungen des Bundes oder anderer kantonaler Gesetze."
        }
      ],
      "stand": "2019-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/133.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "df7f3b284f0807b674784ee53425489a",
      "sha": "b3096315252cfafaf9f143b0db4f623c2a1945608160e970a087f8ffa1f7210e"
    },
    {
      "id": "kanton/AR/133.1/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Informationsgesetz (133.1)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Sitzungen des Regierungsrates und der von ihm eingesetzten Kommissionen sind nicht öffentlich."
        },
        {
          "absatz": "2",
          "text": "Über Ausnahmen befindet der Regierungsrat."
        }
      ],
      "stand": "2019-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/133.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "df7f3b284f0807b674784ee53425489a",
      "sha": "8ab23fc12faa6b0b827418a7e31826ec75a7790629502d5c8a2bfe198c0881cc"
    },
    {
      "id": "kanton/AR/133.1/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Informationsgesetz (133.1)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Sitzungen der Gerichte sind vorbehältlich der im Gesetz vorgesehenen Ausnahmen öffentlich."
        }
      ],
      "stand": "2019-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/133.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "df7f3b284f0807b674784ee53425489a",
      "sha": "9552e95232db20915303bad4dbb31cd19e2db4ef53c3ca20d5cb55ed3c3efad8"
    },
    {
      "id": "kanton/AR/133.1/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Informationsgesetz (133.1)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Sitzungen der Gemeindeparlamente sind öffentlich. Art. 2 Abs. 3 und Art. 4 gelten sinngemäss."
        },
        {
          "absatz": "2",
          "text": "Die Sitzungen der Gemeinderäte und der gemeinderätlichen Kommissionen sind nicht öffentlich; über Ausnahmen befindet der Gemeinderat."
        }
      ],
      "stand": "2019-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/133.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "df7f3b284f0807b674784ee53425489a",
      "sha": "ca0292a55ab523a9490d04dc0394c30d0123156f00d12cb6aa40d7aab5b10226"
    },
    {
      "id": "kanton/AR/133.1/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Informationsgesetz (133.1)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Behörden des Kantons und der Gemeinden informieren die Öffentlichkeit frühzeitig und ausreichend über ihre Tätigkeit, soweit nicht überwiegende öffentliche oder private Interessen entgegenstehen."
        }
      ],
      "stand": "2019-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/133.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "df7f3b284f0807b674784ee53425489a",
      "sha": "ff276162dc98c5466db1dcd049f12791df63798e381ec52f4e40fc5d46fe7377"
    },
    {
      "id": "kanton/AR/133.1/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Informationsgesetz (133.1)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Jede Person, die ein berechtigtes Interesse nachweisen kann, hat im Rahmen dieses Gesetzes das Recht auf Einsicht in amtliche Akten, soweit keine überwiegenden öffentlichen oder privaten Interessen entgegenstehen (Art. 12 Abs. 3 der Kantonsverfassung)."
        }
      ],
      "stand": "2019-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/133.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "df7f3b284f0807b674784ee53425489a",
      "sha": "c9fdd2ef4b50913c67d5b26bebd1bd0e270fac183ee4feec675e6cb71c023920"
    },
    {
      "id": "kanton/AR/133.1/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Informationsgesetz (133.1)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Berichte, Studien und Gutachten werden der Öffentlichkeit zugänglich gemacht, soweit keine überwiegenden öffentlichen oder privaten Interessen entgegenstehen."
        }
      ],
      "stand": "2019-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/133.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "df7f3b284f0807b674784ee53425489a",
      "sha": "70175d21c3f1c402fc5ed182657af5dcbeccad08401f644ce571b2574cce7c19"
    },
    {
      "id": "kanton/AR/133.1/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Informationsgesetz (133.1)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Einsichtnahme in Protokolle von nicht öffentlichen Verhandlungen bedarf einer Bewilligung der betreffenden Behörde."
        }
      ],
      "stand": "2019-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/133.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "df7f3b284f0807b674784ee53425489a",
      "sha": "02ee578cb6327a536d62b3d00997be3f0d6d22a1bc1c91f1fd0b4adce3de4929"
    },
    {
      "id": "kanton/AR/133.1/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Informationsgesetz (133.1)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Überwiegende öffentliche Interessen liegen insbesondere vor, wenn",
          "items": [
            {
              "marke": "a",
              "text": "durch die vorzeitige Bekanntgabe von internen Arbeitspapieren, Anträgen und Entwürfen die Entscheidfindung wesentlich beeinträchtigt würde;"
            },
            {
              "marke": "b",
              "text": "der Bevölkerung auf andere Weise Schaden zugefügt würde, namentlich durch die Gefährdung der öffentlichen Sicherheit;"
            },
            {
              "marke": "c",
              "text": "bei der Behörde ein unverhältnismässiger Aufwand entstehen würde."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Ein unverhäItnismässiger Aufwand im Sinne von Abs. 1 lit. c liegt vor, wenn die Behörde mit ihren ordentlichen personellen Mitteln und ihrer Infrastruktur nicht in der Lage ist, das Gesuch innert nützlicher Frist zu erledigen, ohne andere Aufgaben zu vernachlässigen."
        }
      ],
      "stand": "2019-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/133.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "df7f3b284f0807b674784ee53425489a",
      "sha": "0c4b8cb9c38d77f51973a899936bf1a937828305f52065dc5b7ef3728d10fb69"
    },
    {
      "id": "kanton/AR/133.1/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Informationsgesetz (133.1)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Als überwiegende private Interessen gelten insbesondere",
          "items": [
            {
              "marke": "a",
              "text": "der Schutz besonders schützenswerter Personendaten;"
            },
            {
              "marke": "b",
              "text": "der Persönlichkeitsschutz in nicht rechtskräftig abgeschlossenen Verwaltungs- und Gerichtsverfahren;"
            },
            {
              "marke": "c",
              "text": "das Geschäftsgeheimnis oder das Berufsgeheimnis."
            }
          ]
        }
      ],
      "stand": "2019-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/133.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "df7f3b284f0807b674784ee53425489a",
      "sha": "959801fabe3c3f7591f07f953d3bf867844add899ad0b51919b0cdc52586ce67"
    },
    {
      "id": "kanton/AR/133.1/art_14",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Informationsgesetz (133.1)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Ausnahmebestimmungen gemäss den Art. 11 bis 13 beziehen sich nur auf den schutzwürdigen Teil der Akten oder einer Auskunft und gelten nur solange, als das überwiegende Interesse an der Geheimhaltung besteht."
        }
      ],
      "stand": "2019-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/133.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "df7f3b284f0807b674784ee53425489a",
      "sha": "afb546353bda8bacbac4f75f902d0e33c4cec5f6b4db452fe6043aae137aa53a"
    },
    {
      "id": "kanton/AR/133.1/art_15",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Informationsgesetz (133.1)",
      "artikel": "15",
      "artikelLabel": "Art. 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gesuche um Akteneinsicht sind in der Regel schriftlich einzureichen. Sie haben den Nachweis zu enthalten, worin das berechtige Interesse liegt. Die interessierenden Daten sind möglichst genau zu bezeichnen."
        },
        {
          "absatz": "2",
          "text": "Zuständig zur Beantwortung ist die mit der Sache befasste Behörde oder, wenn das Verfahren abgeschlossen ist, die Behörde, welche die Akten verwaltet."
        },
        {
          "absatz": "3",
          "text": "Gesuche, die an eine unzuständige Stelle gerichtet sind, werden ohne Verzug an die für die Behandlung zuständige Behörde weitergeleitet."
        }
      ],
      "stand": "2019-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/133.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "df7f3b284f0807b674784ee53425489a",
      "sha": "e383e032b4c810c13191dd30a78cf285ecb407029e30d98c7e5a433fdd699d35"
    },
    {
      "id": "kanton/AR/133.1/art_16",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Informationsgesetz (133.1)",
      "artikel": "16",
      "artikelLabel": "Art. 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für besonderen Aufwand kann eine Gebühr erhoben werden."
        }
      ],
      "stand": "2019-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/133.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "df7f3b284f0807b674784ee53425489a",
      "sha": "b6c1d18a3d695b644a518677faf260e667402c84b1e5d7311a758b82a3612865"
    },
    {
      "id": "kanton/AR/133.1/art_17",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Informationsgesetz (133.1)",
      "artikel": "17",
      "artikelLabel": "Art. 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ist die Akteneinsicht strittig, erlässt die Behörde eine Verfügung."
        },
        {
          "absatz": "2",
          "text": "Verfügungen von Organen des Kantonsrates können innert 20 Tagen an den Kantonsrat weitergezogen werden."
        }
      ],
      "stand": "2019-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/133.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "df7f3b284f0807b674784ee53425489a",
      "sha": "d9ee4d45aac8a3a8e22dcf1a56d3ac226be1047dea5aa3eb41a7837099c23cc7"
    },
    {
      "id": "kanton/AR/133.1/art_18",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Informationsgesetz (133.1)",
      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat bezeichnet die für die Information zuständigen Stellen des Kantons; er kann weitere Ausführungsbestimmungen erlassen."
        },
        {
          "absatz": "2",
          "text": "Das Obergericht regelt die Information durch die Gerichte sowie die Schuldbetreibungs- und Konkursbehörden. Sie können die Akkreditierung von Medienschaffenden regeln."
        }
      ],
      "stand": "2019-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/133.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "df7f3b284f0807b674784ee53425489a",
      "sha": "e51836ebae21de8bcb6de9acaa2fa4a7b35488787ba513b89f3854b97ddbec7d"
    },
    {
      "id": "kanton/AR/133.1/art_19",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Informationsgesetz (133.1)",
      "artikel": "19",
      "artikelLabel": "Art. 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieses Gesetz tritt am 1. Mai 1996 in Kraft."
        }
      ],
      "stand": "2019-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/133.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "df7f3b284f0807b674784ee53425489a",
      "sha": "717dd7be848dfb116baa1b972a6f492aa3ab3bb9de364816af796b419b82da47"
    }
  ]
}