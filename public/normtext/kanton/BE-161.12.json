      "erlass": "Verfahrenskostendekret, VKD (BSG 161.12)",
      "artikel": "36",
      "artikelLabel": "Art. 36 (Art. 38 vereinfacht)",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im ordentlichen Verfahren beträgt die Gebühr in vermögensrechtlichen Streitigkeiten bei einem Streitwert von",
          "items": [
            {
              "marke": "a",
              "text": "30'000 bis 100'000 Franken: 1'000 bis 20'000 Taxpunkte"
            },
            {
              "marke": "b",
              "text": "100'000 bis 500'000 Franken: 4'000 bis 36'000 Taxpunkte"
            },
            {
              "marke": "c",
              "text": "500'000 bis eine Million Franken: 8'000 bis 60'000 Taxpunkte"
            },
            {
              "marke": "d",
              "text": "eine Million bis zwei Millionen Franken: 12'000 bis 120'000 Taxpunkte"
            },
            {
              "marke": "e",
              "text": "zwei Millionen Franken und mehr: 0,5 bis 7 Prozent des Streitwerts"
            },
            {
              "marke": "f",
              "text": "bei einem nicht schätzbaren Streitwert: 1'000 bis 40'000 Taxpunkte"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "In miet- und in arbeitsrechtlichen Streitigkeiten kann die Mindestgebühr unterschritten werden, wenn der Streitwert nach Artikel 92 Absatz 2 ZPO ermittelt wurde."
        }
      ],
      "stand": "2026-05-01",
