    },
    {
      "id": "kanton/BS/RiE 328.610/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend die Zahnpflege bei Kindern, Zahnpflegereglement (RiE 328.610)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Anwendbares Recht",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Soweit dieses Reglement nichts Abweichendes festlegt, gelten die Bestimmungen der Verordnung betreffend die soziale Zahnpflege (Zahnpflegeverordnung) vom 6. Dezember 2011 sinngemäss auch für die Durchführung der Schulzahnpflege für Kinder mit Wohnsitz in Riehen."
        }
      ],
      "stand": "2013-10-31",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 328.610",
      "abgerufen": "2026-06-23",
      "fassungsToken": "aa4a2fbc25af99340243f191cd7ead4e",
      "sha": "c593faa5f76da453bab9f2b654a54a07d57c83600a18b303d85ccd1e43032261"
    },
    {
      "id": "kanton/BS/RiE 328.610/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend die Zahnpflege bei Kindern, Zahnpflegereglement (RiE 328.610)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Behandlungstarif",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Als Basistarife für die zahnärztlichen und zahntechnischen Leistungen der Schulzahnpflege gelten die Tarife gemäss dem eidgenössischen Unfallversicherungsgesetz (UVG), soweit in Verträgen mit Drittzahlern nicht andere Taxen vereinbart sind."
        },
        {
          "absatz": "2",
          "text": "Die Rechnungsstellung erfolgt für Kinder und Jugendliche, deren Eltern oder Erziehungsberechtigte Wohnsitz in Riehen haben, zum jeweiligen UVG-Taxpunktwert."
        }
      ],
      "stand": "2013-10-31",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 328.610",
      "abgerufen": "2026-06-23",
      "fassungsToken": "aa4a2fbc25af99340243f191cd7ead4e",
      "sha": "6c0781197684a905e75ebf8dce0ea361f992a12bfb928e99db5c032bba95d480"
    },
    {
      "id": "kanton/BS/RiE 328.610/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend die Zahnpflege bei Kindern, Zahnpflegereglement (RiE 328.610)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Reduktionsansprüche",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Auf den gemäss Behandlungstarif ermittelten Rechnungsbetrag für Leistungen der Schulzahnpflege werden je nach tatsächlichem Einkommen und Vermögen der Eltern oder erziehungsberechtigten Personen Tarifreduktionen gewährt."
        },
        {
          "absatz": "2",
          "text": "Die Höhe der Reduktionen richtet sich nach § 8 der kantonalen Zahnpflegeverordnung."
        }
      ],
      "stand": "2013-10-31",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 328.610",
      "abgerufen": "2026-06-23",
      "fassungsToken": "aa4a2fbc25af99340243f191cd7ead4e",
      "sha": "82aea679f392e35a2b725e5f55faabf137605fb4b2c0bfc15f6003678eb131a1"
    },
    {
      "id": "kanton/BS/RiE 328.610/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend die Zahnpflege bei Kindern, Zahnpflegereglement (RiE 328.610)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "titel": "Unentgeltliche Leistungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Folgende Leistungen der Schulzahnklinik werden nicht in Rechnung gestellt:",
          "items": [
            {
              "marke": "a",
              "text": "gruppenprophylaktische Massnahmen;"
            },
            {
              "marke": "b",
              "text": "jährliche Gebisskontrollen;"
            },
            {
              "marke": "c",
              "text": "ein Übersichtsröntgenbild zur Erfassung von Nichtanlagen der Zähne bis zur Schulentlassung;"
            },
            {
              "marke": "d",
              "text": "Instruktionen über die Zahnreinigung und über die Kariesprophylaxe in den Kindergärten;"
            },
            {
              "marke": "e",
              "text": "zwei Bissflügelaufnahmen bis zur Schulentlassung."
            }
          ]
        }
      ],
      "stand": "2013-10-31",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 328.610",
      "abgerufen": "2026-06-23",
      "fassungsToken": "aa4a2fbc25af99340243f191cd7ead4e",
