      "sha": "772bbd1a0fa3e0e1b48209b4fde5c80ae27b6606c5f22d110badf62c9f89d95e"
    },
    {
      "id": "kanton/AR/766.1/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schiffsführerausweisverordnung; SFAV (766.1)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühren für theoretische und praktische Prüfungen richten sich nach dem anwendbaren Tarif der Durchführungsstelle."
        },
        {
          "absatz": "2",
          "text": "Für die Abnahme von Prüfungen durch das Strassenverkehrsamt werden folgende Gebühren erhoben:",
          "items": [
            {
              "marke": "a",
              "text": "Theorieprüfung Fr. 30.–"
            },
            {
              "marke": "b",
              "text": "besondere Prüfungen, nach Aufwand Fr. 120.– pro Stunde"
            }
          ]
        }
      ],
      "stand": "2026-02-13",
