{
  "erzeugt": "2026-06-16",
  "eintraege": [
    {
      "id": "kanton/AG/725.100/art_8",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "8",
      "artikelLabel": "§ 8 Abs. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Handänderungen an Grundstücken beträgt die Abgabe 4 &permil; der Kauf- oder Übernahmesumme, mindestens jedoch Fr. 100.–."
        },
        {
          "absatz": "2",
          "text": "Wird in der Vertragsurkunde kein Preis genannt oder liegt dieser unterhalb des Steuerwertes, ist letzterer massgebend. Fehlt ein Steuerwert, haben die Parteien auf Verlangen des Grundbuchamtes auf ihre Kosten eine nach anerkannten Regeln erstellte Verkehrswertschätzung vorzulegen. Weicht der Wert dieser Schätzung gegenüber der Kauf- oder Übernahmesumme um mehr als 10 % nach oben ab, ist die Abgabe vom Schätzungswert zu erheben."
        },
        {
          "absatz": "3",
          "text": "Bei Enteignungen oder bei Vorgängen, auf die das Enteignungsrecht anwendbar wäre, wird 1 &permil; der Enteignungsentschädigung pro Enteignungsvertrag berechnet, mindestens aber Fr. 50.–."
        }
      ],
      "stand": "1981-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-16",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "e92d27da6047c33e46f83c290fad5c864c52edab9e05265195bdcf72084ae5a5"
    },
    {
      "id": "kanton/AG/725.100/art_15",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "15",
      "artikelLabel": "§ 15 GBAG (SAR 725.100)",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Eintragung des Erbganges beträgt die Abgabe 2 &permil; des Steuerwertes, mindestens jedoch Fr. 50.–."
        }
      ],
      "stand": "1981-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-16",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "f811a370fb22f26b84ed30adca13e7240e50ea47209b7bd20113e1b613d8acd4"
    },
    {
      "id": "kanton/AG/725.100/art_23",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "23",
      "artikelLabel": "§ 23 Abs. 1 lit. a GBAG (SAR 725.100)",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Eintragung von Grundpfändern werden von der jeweiligen Pfandsumme folgende Abgaben, mindestens jedoch Fr. 100.–, erhoben: a) vertragliche Grundpfandrechte: 1,5 &permil;; b) gesetzliche Grundpfandrechte 1. zu Gunsten des Verkäufers, der Miterben, des Kantons, der Gemeinde, des Pfrundnehmers oder des Bauhandwerkers: &frac12; &permil;, 2. bei gleichzeitiger Abtretung an Dritte oder bei Ausstellung eines Schuldbriefes: 1&frac12; &permil;; c) leere Pfandstelle: &frac12; &permil;; d) Aufteilung oder Zusammenlegung von Pfandstellen: &frac12; &permil;; e) &hellip;"
        }
      ],
      "stand": "1981-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-16",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "e31e02c347c65c3521a2f3a0e9b4347ab3d8666ec8f385ff0c82b810f7d4b6da"
    },
    {
      "id": "kanton/AG/725.100/art_29",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "29",
      "artikelLabel": "§ 29 GBAG (SAR 725.100)",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Eintragung von Dienstbarkeiten und Grundlasten beträgt die Abgabe 1 &permil; des Wertes pro herrschendes Grundstück oder pro berechtigte Person, mindestens jedoch Fr. 50.–."
        },
        {
          "absatz": "2",
          "text": "Wird eine Entschädigung vereinbart, so gilt diese als Wert des Rechtes."
        }
      ],
      "stand": "1981-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-16",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "29345258691ab163cf9674aad50038e299cc1feca1fd169caa8680bde110ba3a"
    },
    {
      "id": "kanton/AG/725.100/art_18",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "18",
      "artikelLabel": "§ 18 GBAG (SAR 725.100)",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Aufnahme selbstständiger und dauernder Rechte und für die Verlängerung ihrer Geltung beträgt die Abgabe 2&frac12; &permil; des Verkehrswertes der belasteten Bodenfläche, mindestens jedoch Fr. 100.–."
        },
        {
          "absatz": "2",
          "text": "Bei gleichzeitiger Eintragung der selbstständigen und dauernden Rechte als Grundstück entfällt die Abgabe nach § 29."
        }
      ],
      "stand": "1981-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-16",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "ccca97aceaaceebef4d8e6557bdb21d540b4e269a0fda0d464cab8198ad53a9f"
    },
    {
      "id": "kanton/AG/725.100/art_27",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "27",
      "artikelLabel": "§ 27 GBAG (SAR 725.100) für Kaufsrecht; abweichend § 26 (½ ‰, min 50, max 500) und § 28 (½ ‰ Jahreszins, min 50)",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Vormerkung eines Kaufsrechtes beträgt die Abgabe 1 &permil; des Kaufpreises, mindestens jedoch Fr. 50.–."
        }
      ],
      "stand": "1981-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-16",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "b1ca14c5ae714d838a1eaac3f8405d5695be54d944cb739bd9b5a9751d45aa72"
    },
    {
      "id": "kanton/AG/725.100/art_20",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "20",
      "artikelLabel": "§ 20 GBAG (SAR 725.100)",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Aufnahme einer Stockwerkeinheit beträgt die Abgabe 2 &permil; des Verkehrswertes und für die Änderung von Miteigentumsquoten oder Aufhebung von Stockwerkeinheiten auf dem Stammgrundstück Fr. 20.– pro beteiligte Stockwerkeinheit."
        }
      ],
      "stand": "1981-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-16",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "f7f14ba1dbb865ed514b1c6aeea80ca5ceb4c31a1aaecd473401ca6c4c1ffef4"
    },
    {
      "id": "kanton/AG/725.100/art_21",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "21",
      "artikelLabel": "§ 21 GBAG (SAR 725.100)",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Parzellierungen beträgt die Abgabe 1 &permil; des Verkehrswertes des Bodens der abgetrennten Teilstücke, mindestens jedoch Fr. 50.– pro neue Parzelle."
        }
      ],
      "stand": "1981-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-16",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "563f84b0c5f1a30c91ce29478b9de2543a6fe1598018c7dd4c48e89c7989755b"
    },
    {
      "id": "kanton/AG/725.100/art_13",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "13",
      "artikelLabel": "§ 13 Dekret über die Grundbuchgebühren (SAR 725.110)",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Berichtigungen, die auf die Parteien selbst zurückzuführen sind, beträgt die Abgabe &frac12; &permil; der ursprünglichen Bemessungsgrundlage, mindestens jedoch Fr. 50.–."
        }
      ],
      "stand": "1981-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-16",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "68bec0f25480dc145ba0b20d81deaa8be022e55f3c3fd7f8e6349d4426a8f2f0"
    },
    {
      "id": "kanton/AG/725.100/art_3",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "3",
      "artikelLabel": "§ 3 Abs. 1 / § 23 Abs. 1 lit. a",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat kann gemeinnützigen Institutionen auf Gesuch hin die Abgaben ganz oder teilweise erlassen."
        }
      ],
      "stand": "1981-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-16",
