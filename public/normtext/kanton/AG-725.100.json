{
  "erzeugt": "2026-06-22",
  "eintraege": [
    {
      "id": "kanton/AG/725.100/art_1",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton erhebt auf allen grundbuchlichen Vorgängen neben den Kanzleigebühren eine Abgabe nach Massgabe dieses Gesetzes. Ausserdem sind die Auslagen (Porti, Telefon usw.) zu ersetzen."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "758aa5b54c70a88336b611e45f4b248d1d2847e4a8a9923df32e08f88988b77f"
    },
    {
      "id": "kanton/AG/725.100/art_1_a",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "1_a",
      "artikelLabel": "§ 1a",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die in diesem Gesetz verwendeten Personenbezeichnungen beziehen sich auf beide Geschlechter."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "ac37174bc922a06c0aabb009e996f36783b3be48b48130de0eb4db32e24433d2"
    },
    {
      "id": "kanton/AG/725.100/art_2",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Keine Abgaben werden erhoben auf grundbuchlichen Vorgängen, die mit Bodenverbesserungen (Art. 954 Abs. 2 und Art. 703 des Schweizerischen Zivilgesetzbuches) oder Entschuldungsmassnahmen (Art. 100 des Bundesgesetzes über die Entschuldung landwirtschaftlicher Heimwesen) im Zusammenhang stehen, oder die einen Bodenaustausch zur Abrundung landwirtschaftlicher Betriebe zum Gegenstand haben, sofern dabei eine volle Arrondierung erreicht wird."
        },
        {
          "absatz": "2",
          "text": "Der Regierungsrat kann die Abgaben angemessen herabsetzen, wenn der Landabtausch zur teilweisen Abrundung landwirtschaftlicher Betriebe führt oder wenn nur ein Teil des abgetauschten Landes zu einer Parzelle vereinigt wird."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "177346ae7b49dfe267a8aa21309e392f166f36512e0c3ef31ded91c319f6ece7"
    },
    {
      "id": "kanton/AG/725.100/art_3",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat kann gemeinnützigen Institutionen auf Gesuch hin die Abgaben ganz oder teilweise erlassen."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "bd27cb281e98df81c08a55f09f2a1fdb736fea10f199581d25f118daa630fa3e"
    },
    {
      "id": "kanton/AG/725.100/art_4",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Summen, von denen die Abgaben berechnet werden, sind auf jeweils Fr. 1'000.– auf- oder abzurunden."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "99e198192e7eea91e7174a333fc01ff319e2bd495e64df108c2d4326ff8fb3b2"
    },
    {
      "id": "kanton/AG/725.100/art_5",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Abgaben sind im Voraus zu bezahlen oder angemessen sicherzustellen."
        },
        {
          "absatz": "2",
          "text": "Die Parteien haften solidarisch."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "181ca741a93ad91cce82b54e7c19fc5ed6a37bc93d9a9d67a6092362919d3292"
    },
    {
      "id": "kanton/AG/725.100/art_6",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Behandeln mehrere Ämter einen grundbuchlichen Vorgang, so bezieht jenes Amt die Abgaben, bei dem das Geschäft angemeldet worden ist."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "6e9a3491a9e140fd6b5e6105bf11334b0cb7020e53a9217d0c7a6f0dd2b7a46f"
    },
    {
      "id": "kanton/AG/725.100/art_7",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Parteien, die Urkundspersonen sowie die Gemeinde- und Steuerbehörden haben dem Grundbuchamt die für die Berechnung der Abgaben erforderlichen Auskünfte zu erteilen."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "2d065bfacf555b253938d5b06c1a6540234a4533e14635d35f2cd166281c9c81"
    },
    {
      "id": "kanton/AG/725.100/art_8",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Handänderungen an Grundstücken beträgt die Abgabe 4 ‰ der Kauf- oder Übernahmesumme, mindestens jedoch Fr. 100.–."
        },
        {
          "absatz": "2",
          "text": "Wird in der Vertragsurkunde kein Preis genannt oder liegt dieser unterhalb des Steuerwertes, ist letzterer massgebend. Fehlt ein Steuerwert, haben die Parteien auf Verlangen des Grundbuchamtes auf ihre Kosten eine nach anerkannten Regeln erstellte Verkehrswertschätzung vorzulegen. Weicht der Wert dieser Schätzung gegenüber der Kauf- oder Übernahmesumme um mehr als 10 % nach oben ab, ist die Abgabe vom Schätzungswert zu erheben."
        },
        {
          "absatz": "3",
          "text": "Bei Enteignungen oder bei Vorgängen, auf die das Enteignungsrecht anwendbar wäre, wird 1 ‰ der Enteignungsentschädigung pro Enteignungsvertrag berechnet, mindestens aber Fr. 50.–."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "ef917941a4f7fcd00ddf17694e170d7b3af409928746b35bb433f5f0c73f90f4"
    },
    {
      "id": "kanton/AG/725.100/art_10",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Abgabepflicht erstreckt sich auf alle vertraglichen Leistungen, welche die Parteien zu erbringen haben, auch wenn sie im beurkundeten Kaufpreis nicht inbegriffen sind, aber den Wert der Liegenschaft erhöhen."
        },
        {
          "absatz": "2",
          "text": "Die im Grundbuch angemerkte Zugehör wird, soweit sie nicht im Kaufpreis inbegriffen ist, zum Wert der Liegenschaft hinzugerechnet."
        },
        {
          "absatz": "3",
          "text": "Bei Tauschverträgen werden die Werte sämtlicher Grundstücke zusammengezählt; die Abgabe wird von der Gesamtsumme berechnet."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "b64a0ffdb5b769b2aad7f3303580afaa4cd9f21bd61914877bb15e36f3f99bc8"
    },
    {
      "id": "kanton/AG/725.100/art_11",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei vertraglicher Begründung sowie bei ganzer oder teilweiser Auflösung von Gesamthandsverhältnissen wie Erbengemeinschaft, Gütergemeinschaft oder einfacher Gesellschaft ist die Abgabe vom Wert der Gesamteigentumsanteile, welche auf die Übernehmer übergehen, zu entrichten."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "16169b49b49a6f45e6e366613331d77ffae8813477d233824f22891e896eda57"
    },
    {
      "id": "kanton/AG/725.100/art_12",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "12",
      "artikelLabel": "§ 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Baulandumlegungen beträgt die Abgabe 1 ‰ des Verkehrswertes der Gesamtfläche, mindestens jedoch Fr. 100.–."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "5abbd05278f72d1aef4c7f3582859bff468ec0ef3ec98e2b2975349df4496bfb"
    },
    {
      "id": "kanton/AG/725.100/art_13",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "13",
      "artikelLabel": "§ 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Berichtigungen, die auf die Parteien selbst zurückzuführen sind, beträgt die Abgabe ½ ‰ der ursprünglichen Bemessungsgrundlage, mindestens jedoch Fr. 50.–."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "f19675b9e75c6431bbb0b2caf20636050b2f2992d06d8b9aa21f438669f629d2"
    },
    {
      "id": "kanton/AG/725.100/art_14",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "14",
      "artikelLabel": "§ 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "In Fällen, da der stipulierte Kaufpreis weniger beträgt als der tatsächlich vereinbarte, ist der dreifache Betrag der Abgabendifferenz nachzuzahlen."
        },
        {
          "absatz": "2",
          "text": "Die strafrechtliche Verfolgung bleibt vorbehalten."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "64fbc130d1ae9fc21782ae07cb6f4cad290183d5fdd5337680b41ac776090965"
    },
    {
      "id": "kanton/AG/725.100/art_15",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "15",
      "artikelLabel": "§ 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Eintragung des Erbganges beträgt die Abgabe 2 ‰ des Steuerwertes, mindestens jedoch Fr. 50.–."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "74d17305c99bd2e498a70a9b1526de32ff01255b84e0ed9aed8c927f247fdfba"
    },
    {
      "id": "kanton/AG/725.100/art_16",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "16",
      "artikelLabel": "§ 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Umwandlung von Gesamteigentum in Miteigentum und umgekehrt beträgt die Abgabe 2 ‰ des Steuerwertes, mindestens jedoch Fr. 50.–."
        },
        {
          "absatz": "2",
          "text": "Bei gleichzeitiger Anmeldung mit dem Erbgang entfällt die Erbgangsabgabe."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "6873ce42a1e40e1a23b0279ddb232ee800ff5ea5feb8db8f966a5bc20e6c470a"
    },
    {
      "id": "kanton/AG/725.100/art_17",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "17",
      "artikelLabel": "§ 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für Eintragungen auf Grund von Vermächtnissen beträgt die Abgabe – neben der Erbgangsabgabe – 3½ ‰ des Steuerwertes, mindestens jedoch Fr. 50.–."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "313febb21059cbd7d893c15fa3ec7851c796dbca3d583998148aa8f41abf6cc4"
    },
    {
      "id": "kanton/AG/725.100/art_18",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "18",
      "artikelLabel": "§ 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Aufnahme selbstständiger und dauernder Rechte und für die Verlängerung ihrer Geltung beträgt die Abgabe 2½ ‰ des Verkehrswertes der belasteten Bodenfläche, mindestens jedoch Fr. 100.–."
        },
        {
          "absatz": "2",
          "text": "Bei gleichzeitiger Eintragung der selbstständigen und dauernden Rechte als Grundstück entfällt die Abgabe nach § 29."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "0819510c951a713f13c0d8f06ffc9fc13b34e51721def3b124956eda1721daa4"
    },
    {
      "id": "kanton/AG/725.100/art_19",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "19",
      "artikelLabel": "§ 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Eintragung von Wasserrechtsverleihungen beträgt die Abgabe 2½ ‰ des Steuerwertes des Werkes und der dazu gehörenden Anlagen, mindestens jedoch Fr. 100.–."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "ab52ec35947bc480a082a2d4f1aa6699bda52b1efa153346b1421c90f5d7ac07"
    },
    {
      "id": "kanton/AG/725.100/art_20",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "20",
      "artikelLabel": "§ 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Aufnahme einer Stockwerkeinheit beträgt die Abgabe 2 ‰ des Verkehrswertes und für die Änderung von Miteigentumsquoten oder Aufhebung von Stockwerkeinheiten auf dem Stammgrundstück Fr. 20.– pro beteiligte Stockwerkeinheit."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "1bda23c294585a07f158aaf4b6c2eeb042cbff70e4911e4ad5eef9d4c6cc33a2"
    },
    {
      "id": "kanton/AG/725.100/art_21",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "21",
      "artikelLabel": "§ 21",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Parzellierungen beträgt die Abgabe 1 ‰ des Verkehrswertes des Bodens der abgetrennten Teilstücke, mindestens jedoch Fr. 50.– pro neue Parzelle."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "ba3af303ecfe6c7aa5aa7fc5b98b5a43b693cba6bee1f60566f06f7416ecedf9"
    },
    {
      "id": "kanton/AG/725.100/art_23",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "23",
      "artikelLabel": "§ 23",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Eintragung von Grundpfändern werden von der jeweiligen Pfandsumme folgende Abgaben, mindestens jedoch Fr. 100.–, erhoben:",
          "items": [
            {
              "marke": "a",
              "text": "vertragliche Grundpfandrechte: 1,5 ‰;"
            },
            {
              "marke": "b",
              "text": "gesetzliche Grundpfandrechte"
            },
            {
              "marke": "1",
              "text": "zu Gunsten des Verkäufers, der Miterben, des Kantons, der Gemeinde, des Pfrundnehmers oder des Bauhandwerkers: ½ ‰,"
            },
            {
              "marke": "2",
              "text": "bei gleichzeitiger Abtretung an Dritte oder bei Ausstellung eines Schuldbriefes: 1½ ‰;"
            },
            {
              "marke": "c",
              "text": "leere Pfandstelle: ½ ‰;"
            },
            {
              "marke": "d",
              "text": "Aufteilung oder Zusammenlegung von Pfandstellen: ½ ‰;"
            },
            {
              "marke": "e",
              "text": "…"
            }
          ]
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "0d0f49d7b18c99f11922dde88867a09ebf16f843e6483f5ac83915c687942ad9"
    },
    {
      "id": "kanton/AG/725.100/art_24",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "24",
      "artikelLabel": "§ 24",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Eintragung von Pfandvermehrungen beträgt die Abgabe ½ ‰ des Versicherungswertes der Gebäude (ordentliche Versicherung, Zusatzversicherung und Teuerungszusatzversicherung) und des Verkehrswertes bei nichtlandwirtschaftlichen bzw. des Ertragswertes bei landwirtschaftlichen Grundstücken, mindestens jedoch Fr. 50.– pro Pfandrecht oder maximal die Abgabe der Neuerrichtung des Pfandrechtes."
        },
        {
          "absatz": "2",
          "text": "Bei gleichzeitiger Erhöhung des Pfandrechtes ist nur die höhere Abgabe zu entrichten."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "bc3378745ce4521d64b9d5a8035412f4be5b6ee7fc9e2960cac45ddfdb9d410f"
    },
    {
      "id": "kanton/AG/725.100/art_25",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "25",
      "artikelLabel": "§ 25",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Anmerkung neuer oder weiterer Zugehör beträgt die Abgabe ½ ‰ des Wertes der Zugehör bzw. der Vermehrung, mindestens jedoch Fr. 50.– und höchstens Fr. 500.–."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "3cce7adea9a4965755d08654d8ebc78bdf47eb0f47670895519319881644df69"
    },
    {
      "id": "kanton/AG/725.100/art_26",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "26",
      "artikelLabel": "§ 26",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Vormerkung von Vor- und Rückkaufsrechten, Nacherbschaften und Schenkungsrückfall beträgt die Abgabe ½ ‰ des Kaufpreises, beim Fehlen eines solchen ½ ‰ des Steuerwertes."
        },
        {
          "absatz": "2",
          "text": "Die Abgabe hat mindestens Fr. 50.– und höchstens Fr. 500.– zu betragen."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "1d15bf073233a76b489c09cf48c35a65bfca3241ad157278f5c702e5dd54a628"
    },
    {
      "id": "kanton/AG/725.100/art_27",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "27",
      "artikelLabel": "§ 27",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Vormerkung eines Kaufsrechtes beträgt die Abgabe 1 ‰ des Kaufpreises, mindestens jedoch Fr. 50.–."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "da0fe9868527e9c0c77c48db8e5af71d6f36d5e01231a810c9fbc1260adc2dc9"
    },
    {
      "id": "kanton/AG/725.100/art_28",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "28",
      "artikelLabel": "§ 28",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Vormerkung von Miete und Pacht beträgt die Abgabe ½ ‰ eines Jahreszinses, mindestens jedoch Fr. 50.–."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "9d9d9b4212d03f80aa8a0ce17d6c9c9f7e1782da2c1e35011c69b3997d980569"
    },
    {
      "id": "kanton/AG/725.100/art_29",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "29",
      "artikelLabel": "§ 29",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Eintragung von Dienstbarkeiten und Grundlasten beträgt die Abgabe 1 ‰ des Wertes pro herrschendes Grundstück oder pro berechtigte Person, mindestens jedoch Fr. 50.–."
        },
        {
          "absatz": "2",
          "text": "Wird eine Entschädigung vereinbart, so gilt diese als Wert des Rechtes."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "74df27ed6233d2994c936a899e2459957f830d55b4637cacfa1179f664b3b3ed"
    },
    {
      "id": "kanton/AG/725.100/art_30",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "30",
      "artikelLabel": "§ 30",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gegen Abgaberechnungen kann innert 30 Tagen seit Zustellung beim Regierungsrat Beschwerde geführt werden. Hiezu sind sowohl die Parteien als auch die Urkundsperson, die das Geschäft angemeldet hat, legitimiert."
        },
        {
          "absatz": "2",
          "text": "Der Entscheid des Regierungsrates kann innert 30 Tagen seit Zustellung an das Verwaltungsgericht weitergezogen werden."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "e9f8e6592102baa9155c9a23e3dfdd710d839b76a66a15d36113772ce2369587"
    },
    {
      "id": "kanton/AG/725.100/art_31",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "31",
      "artikelLabel": "§ 31",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Rechtskräftige Verfügungen betreffend Grundbuchabgaben bilden definitive Rechtsöffnungstitel im Sinne von Art. 80 Abs. 2 des Bundesgesetzes über Schuldbetreibung und Konkurs."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "6c477e31f92655a2ebe34807babc741dabdfd5f242a5e3864f97036fbad0dc17"
    },
    {
      "id": "kanton/AG/725.100/art_32",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "32",
      "artikelLabel": "§ 32",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Dekret über den Grundbuchtarif vom 15. Dezember 1970 ist aufgehoben."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "a18026f117aa9d2347d11996eb3e88b19dfa4a5bb4477358b40561be0aca928c"
    },
    {
      "id": "kanton/AG/725.100/art_33",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "33",
      "artikelLabel": "§ 33",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieses Gesetz wird nach der Annahme durch das Volk, zusammen mit einem vom Grossen Rat zu erlassenden Dekret über die Grundbuchgebühren, vom Regierungsrat in Kraft gesetzt und ist in der Gesetzessammlung zu publizieren."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "c9a73e4ba8e985bd04e5a79214263a53917292de1024c09f7e826b972ebf0021"
    },
    {
      "id": "kanton/AG/725.100/art_34",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Gesetz über die Grundbuchabgaben (GBAG) (SAR 725.100)",
      "artikel": "34",
      "artikelLabel": "§ 34",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die mit dem Gesetz über Massnahmen des Finanzpakets 1998 geänderten Bestimmungen sind anwendbar auf alle im Zeitpunkt ihres Inkrafttretens hängigen Rechtsgeschäfte, sofern sie für den Abgabenpflichtigen zu einem günstigeren Resultat führen."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/725.100",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c8fd03927f498fe939c30dd5e6ea7d0",
      "sha": "08eb2ad26f58d3d95ce71029c2af8ef633a456e6831d6ce26614c6184e6d5b20"
    }
  ]
}