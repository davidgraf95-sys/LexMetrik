{
  "erzeugt": "2026-06-17",
  "eintraege": [
    {
      "id": "kanton/SH/221.101/art_1",
      "ebene": "kanton",
      "quelle": "SH",
      "erlass": "Notariatsgebührenverordnung (221.101 (ergänzend 211.433))",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die öffentliche Beurkundung der nachstehend genannten Geschäfte werden folgende Gebühren erhoben:",
          "items": [
            {
              "marke": "1",
              "text": "Errichtung einer Stiftung: 2‰ des Stiftungsvermögens, mindestens Fr. 500.00, höchstens Fr. 10'000.00"
            },
            {
              "marke": "2",
              "text": "Aktiengesellschaften und Gesellschaften mit beschränkter Haftung:"
            },
            {
              "marke": "3",
              "text": "Bürgschaften: 2‰ des Haftungsbetrages, mindestens Fr. 100.00, höchstens Fr. 500.00"
            },
            {
              "marke": "4",
              "text": "Wechselproteste: 2‰ der Wechselsumme, mindestens Fr. 100.00, höchstens Fr. 500.00"
            },
            {
              "marke": "5",
              "text": "Übrige Beurkundungsgebühren: Fr. 100.00 bis Fr. 10'000.00"
            }
          ]
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://rechtsbuch.sh.ch/app/de/texts_of_law/221.101",
      "abgerufen": "2026-06-17",
      "fassungsToken": "5c227273dbe6c659359f9f2f61feb954",
      "sha": "d99a7504d7783a54b5bd0b7bdbea669590652d53c13ffba8c0675e66d2cddef3"
    },
    {
      "id": "kanton/SH/221.101/art_3",
      "ebene": "kanton",
      "quelle": "SH",
      "erlass": "Notariatsgebührenverordnung (221.101 (ergänzend 211.433))",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Urkundsperson berechnet die Gebühren innerhalb des Rahmens nach dem Arbeits- und Zeitaufwand, der Bedeutung, dem Schwierigkeitsgrad und dem Vermögenswert des zu beurkundenden Geschäfts."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://rechtsbuch.sh.ch/app/de/texts_of_law/221.101",
      "abgerufen": "2026-06-17",
      "fassungsToken": "5c227273dbe6c659359f9f2f61feb954",
      "sha": "d90ef40b877c5f3ed0c1e007bc6e8258dfbf3a66ca81e5d48c624e7f14efa997"
    },
    {
      "id": "kanton/SH/221.101/art_4",
      "ebene": "kanton",
      "quelle": "SH",
      "erlass": "Notariatsgebührenverordnung (221.101 (ergänzend 211.433))",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühren können angemessen, höchstens aber um das Doppelte der ordentlichen Gebühr, erhöht werden:",
          "items": [
            {
              "marke": "a",
              "text": "aussergewöhnlichem Arbeits- oder Zeitaufwand"
            },
            {
              "marke": "b",
              "text": "Beurkundungen ausserhalb der Geschäftsräumlichkeiten oder ausserhalb der Bürozeiten"
            },
            {
              "marke": "c",
              "text": "wiederholten Verhandlungen"
            },
            {
              "marke": "d",
              "text": "Gründungen mit Sacheinlagen oder Vermögensübernahmen"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Besondere Barauslagen können zusätzlich in Rechnung gestellt werden."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://rechtsbuch.sh.ch/app/de/texts_of_law/221.101",
      "abgerufen": "2026-06-17",
      "fassungsToken": "5c227273dbe6c659359f9f2f61feb954",
      "sha": "8a97ac6d3c0d9ae5b689720198803db944f448c03b588ad89cc6c04f81534ae9"
    },
    {
      "id": "kanton/SH/221.101/art_5",
      "ebene": "kanton",
      "quelle": "SH",
      "erlass": "Notariatsgebührenverordnung (221.101 (ergänzend 211.433))",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühren können angemessen, höchstens aber um einen Drittel, ermässigt werden, wenn:",
          "items": [
            {
              "marke": "a",
              "text": "das ganz oder teilweise vorbereitete Beurkundungsgeschäft nicht zum Abschluss gelangt"
            },
            {
              "marke": "b",
              "text": "im gleichen Sachzusammenhang mehrere gleichartige Rechtsgeschäfte zu beurkunden sind"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Über Stundung und Erlass entscheidet die zuständige Dienststelle. § 11 der Verwaltungsgebührenverordnung ist sinngemäss anwendbar."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://rechtsbuch.sh.ch/app/de/texts_of_law/221.101",
      "abgerufen": "2026-06-17",
      "fassungsToken": "5c227273dbe6c659359f9f2f61feb954",
      "sha": "6c51bbd46f1f3385a7023c46fcb77808be0f5fcb203f6476c3c3d9fd9386448c"
    },
    {
      "id": "kanton/SH/221.101/art_6",
      "ebene": "kanton",
      "quelle": "SH",
      "erlass": "Notariatsgebührenverordnung (221.101 (ergänzend 211.433))",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Amtshandlung kann von der Leistung eines Kostenvorschusses abhängig gemacht werden."
        },
        {
          "absatz": "2",
          "text": "Wer um eine Beurkundung ersucht oder darum ersuchen müsste, haftet persönlich für die Bezahlung der Gebühren; mehrere Personen haften solidarisch. Ebenso haftet solidarisch die Rechtseinheit, für die um die Beurkundung berechtigterweise nachgesucht oder die Beurkundung von Amtes wegen angeordnet worden ist."
        },
        {
          "absatz": "3",
          "text": "Die Kosten für die Abweisung einer Beurkundung tragen die Gesuchsteller; mit ihnen haftet solidarisch die Rechtseinheit, die das Gesuch veranlasst hat."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://rechtsbuch.sh.ch/app/de/texts_of_law/221.101",
      "abgerufen": "2026-06-17",
      "fassungsToken": "5c227273dbe6c659359f9f2f61feb954",
      "sha": "e1e464f92a66d7416a1da5c5e2ab3cfaf18205beec2974058398c92b7aec57c9"
    },
    {
      "id": "kanton/SH/221.101/art_7",
      "ebene": "kanton",
      "quelle": "SH",
      "erlass": "Notariatsgebührenverordnung (221.101 (ergänzend 211.433))",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Bezug erfolgt durch die zuständige Dienststelle."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://rechtsbuch.sh.ch/app/de/texts_of_law/221.101",
      "abgerufen": "2026-06-17",
      "fassungsToken": "5c227273dbe6c659359f9f2f61feb954",
      "sha": "78f3902b7204e4db7181872cdfafb252d1e1f40771c6ff89d1c7b1a6b8befc30"
    },
    {
      "id": "kanton/SH/221.101/art_8",
      "ebene": "kanton",
      "quelle": "SH",
      "erlass": "Notariatsgebührenverordnung (221.101 (ergänzend 211.433))",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung tritt am 1. Januar 2011 in Kraft."
        },
        {
          "absatz": "2",
          "text": "Sie ersetzt die Verordnung über die Gebühren für öffentliche Beurkundungen durch die Einzelrichter des Kantonsgerichts vom 12. März 1974. Für Verfahrensschritte, welche bis zum 31. Dezember 2010 erfolgen, werden die Gebühren nach der bisherigen Verordnung erhoben."
        },
        {
          "absatz": "3",
          "text": "Diese Verordnung ist im Amtsblatt zu veröffentlichen und in die kantonale Gesetzessammlung aufzunehmen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://rechtsbuch.sh.ch/app/de/texts_of_law/221.101",
      "abgerufen": "2026-06-17",
      "fassungsToken": "5c227273dbe6c659359f9f2f61feb954",
      "sha": "5f2d530446fb7c1b84bd9462a089a53d500297a69e061af19f039fb15f0d934d"
    }
  ]
}