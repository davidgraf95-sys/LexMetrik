{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/811.11.1/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Prüfungsreglement für Heilpraktikerinnen und Heilpraktiker (811.11.1)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Prüfungskommission besteht aus:",
          "items": [
            {
              "marke": "a",
              "text": "der Leiterin oder dem Leiter der Fachstelle Gesundheitsfachpersonen und Heilmittelkontrolle (Vorsitz);"
            },
            {
              "marke": "b",
              "text": "einer Ärztin oder einem Arzt (Vorsitz-Stellvertretung);"
            },
            {
              "marke": "c",
              "text": "einer Pflegefachperson mit Ausbildung Tertiärstufe;"
            },
            {
              "marke": "d",
              "text": "einer Heilpraktikerin oder einem Heilpraktiker;"
            },
            {
              "marke": "e",
              "text": "einer Apothekerin oder einem Apotheker beziehungsweise einer Drogistin oder einem Drogisten."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Das Departement Gesundheit und Soziales wählt auf eine Amtsdauer von vier Jahren die in Abs. 1 lit. b–e bezeichneten Mitglieder sowie Ersatzmitglieder."
        },
        {
          "absatz": "3",
          "text": "Das Ersatzmitglied handelt, wenn das Mitglied verhindert ist."
        },
        {
          "absatz": "4",
          "text": "…"
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.11.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd34dc0d6b04cc9e83410bd6e0d8f7d4",
      "sha": "bbbd3a5ae52273ef4bff65e447bf8cf2779b4d288d4d64bf621881dad110f85c"
    },
    {
      "id": "kanton/AR/811.11.1/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Prüfungsreglement für Heilpraktikerinnen und Heilpraktiker (811.11.1)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Prüfungskommission",
          "items": [
            {
              "marke": "a",
              "text": "sorgt für Organisation und Durchführung der Prüfung;"
            },
            {
              "marke": "b",
              "text": "formuliert die Prüfungsfragen und legt die Kriterien für die Bewertung der Antworten fest;"
            },
            {
              "marke": "c",
              "text": "nimmt die mündliche Prüfung ab und führt darüber ein Protokoll;"
            },
            {
              "marke": "d",
              "text": "bewertet die Antworten und stellt das Prüfungsergebnis fest;"
            },
            {
              "marke": "e",
              "text": "teilt das Prüfungsergebnis den Prüfungsteilnehmenden spätestens innert vierzehn Tagen nach der Prüfung mit."
            }
          ]
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.11.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd34dc0d6b04cc9e83410bd6e0d8f7d4",
      "sha": "74feccdb66be5fc00469328b715093c23cdef7daa5fc3054431d204e2d768dd2"
    },
    {
      "id": "kanton/AR/811.11.1/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Prüfungsreglement für Heilpraktikerinnen und Heilpraktiker (811.11.1)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Prüfungskommission nimmt mündliche Prüfungen ab und fasst ihre Beschlüsse vollzählig."
        },
        {
          "absatz": "2",
          "text": "Sie beschliesst mit einfachem Mehr. Stimmenthaltung ist nicht zulässig."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.11.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd34dc0d6b04cc9e83410bd6e0d8f7d4",
      "sha": "3e6b281d1a992f68caa0dfaad86693eeed9e0b5c6aa3b27ea6bf0d6357d68e23"
    },
    {
      "id": "kanton/AR/811.11.1/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Prüfungsreglement für Heilpraktikerinnen und Heilpraktiker (811.11.1)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Prüfungsfächer sind:",
          "items": [
            {
              "marke": "a",
              "text": "Aufbau und Funktion der menschlichen Organe;"
            },
            {
              "marke": "b",
              "text": "allgemeine Hygiene;"
            },
            {
              "marke": "c",
              "text": "Heilmittelkunde;"
            },
            {
              "marke": "d",
              "text": "Herstellung und Prüfung von Arzneimitteln;"
            },
            {
              "marke": "e",
              "text": "Bedeutung meldepflichtiger Krankheiten;"
            },
            {
              "marke": "f",
              "text": "Therapiemöglichkeiten im Rahmen der heilpraktischen Verfahren;"
            },
            {
              "marke": "g",
              "text": "eidgenössisches und kantonales Gesundheitsrecht."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die Prüfung besteht, wer über ausreichende Grundkenntnisse in den Prüfungsfächern verfügt."
        },
        {
          "absatz": "3",
          "text": "Die Prüfungskommission legt die für die einzelnen Prüfungsfächer geltenden Anforderungen fest."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.11.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd34dc0d6b04cc9e83410bd6e0d8f7d4",
      "sha": "6aa06293b0aaa56727cb087a780e7fd1c6c5c9f87f007789da0ab701db88929e"
    },
    {
      "id": "kanton/AR/811.11.1/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Prüfungsreglement für Heilpraktikerinnen und Heilpraktiker (811.11.1)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Von der Prüfung befreit wird:",
          "items": [
            {
              "marke": "a",
              "text": "wer über ein abgeschlossenes Universitätsstudium als Humanmedizinerin oder -mediziner mit eidgenössischem oder gleichwertigem Diplom verfügt;"
            },
            {
              "marke": "b",
              "text": "wer den Nachweis einer abgeschlossenen Aus-, Fort- oder Weiterbildung erbringt, die den Anforderungen nach Art. 4 Abs. 3 genügt. Der oder die Vorsitzende der Prüfungskommission entscheidet für die Prüfungskommission über Gesuche um vollständige oder teilweise Befreiung von der Prüfung."
            }
          ]
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.11.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd34dc0d6b04cc9e83410bd6e0d8f7d4",
      "sha": "7c70bd21be151dede37900758710a0c36d015c19f5948b967fb0ce4adffa47cd"
    },
    {
      "id": "kanton/AR/811.11.1/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Prüfungsreglement für Heilpraktikerinnen und Heilpraktiker (811.11.1)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Prüfung findet in der Regel einmal jährlich statt."
        },
        {
          "absatz": "2",
          "text": "Die Prüfungskommission",
          "items": [
            {
              "marke": "a",
              "text": "bestimmt Termin und Ort;"
            },
            {
              "marke": "b",
              "text": "gibt den nächsten Prüfungstermin spätestens drei Monate vorher im Amtsblatt bekannt und weist auf das Anmeldeverfahren hin."
            }
          ]
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.11.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd34dc0d6b04cc9e83410bd6e0d8f7d4",
      "sha": "517e850bd87d2810b62b59163a195368de9adadf5b694fc1382502751f9f8925"
    },
    {
      "id": "kanton/AR/811.11.1/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Prüfungsreglement für Heilpraktikerinnen und Heilpraktiker (811.11.1)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer an der Prüfung teilnehmen will, meldet sich mit dem von der Fachstelle Gesundheitsfachpersonen und Heilmittelkontrolle herausgegebenen Formular spätestens vier Wochen vor dem Termin bei der Fachstelle Gesundheitsfachpersonen und Heilmittelkontrolle an."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.11.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd34dc0d6b04cc9e83410bd6e0d8f7d4",
      "sha": "7f6763655b099230590b7182dd71d5c4e818021090e06195d3ccc923d579cf71"
    },
    {
      "id": "kanton/AR/811.11.1/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Prüfungsreglement für Heilpraktikerinnen und Heilpraktiker (811.11.1)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Prüfung dauert einen Tag."
        },
        {
          "absatz": "2",
          "text": "Sie umfasst einen schriftlichen und einen mündlichen Teil."
        },
        {
          "absatz": "3",
          "text": "Die Prüfungsteile werden nach Massgabe der in Art. 4 Abs. 1 festgelegten Prüfungsfächer modular aufgebaut."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.11.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd34dc0d6b04cc9e83410bd6e0d8f7d4",
      "sha": "3b247e1e3cfbf630c76a140a31389ca3cc665412c541cccfe1640b1c561c81fc"
    },
    {
      "id": "kanton/AR/811.11.1/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Prüfungsreglement für Heilpraktikerinnen und Heilpraktiker (811.11.1)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Prüfungskommission bewertet das Ergebnis von schriftlicher und mündlicher Prüfung je mit «bestanden» oder «nicht bestanden»."
        },
        {
          "absatz": "2",
          "text": "Die Prüfung ist bestanden, wenn beide Teile mit «bestanden» bewertet worden sind."
        },
        {
          "absatz": "3",
          "text": "Die Prüfungskommission bescheinigt das Bestehen der Prüfung in einem Diplom."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.11.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd34dc0d6b04cc9e83410bd6e0d8f7d4",
      "sha": "b343362fd6e6095561c8eabb96d388816e597198c03353660002bc43c0cead6b"
    },
    {
      "id": "kanton/AR/811.11.1/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Prüfungsreglement für Heilpraktikerinnen und Heilpraktiker (811.11.1)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer die Prüfung nicht besteht, kann diese höchstens einmal wiederholen."
        },
        {
          "absatz": "2",
          "text": "Die Wiederholung umfasst die nicht bestandenen Prüfungsteile."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.11.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd34dc0d6b04cc9e83410bd6e0d8f7d4",
      "sha": "c0bfbf267b3e1a38e146951fa8ecc7099bc180e3ee9d692ed26f1cf46c7fa666"
    },
    {
      "id": "kanton/AR/811.11.1/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Prüfungsreglement für Heilpraktikerinnen und Heilpraktiker (811.11.1)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer sich zur Prüfung oder zur Wiederholung der Prüfung anmeldet, bezahlt eine Gebühr von Fr. 500.–."
        },
        {
          "absatz": "2",
          "text": "Die Gebühr wird zurückerstattet:",
          "items": [
            {
              "marke": "a",
              "text": "vollständig, wenn sich die Kandidatin oder der Kandidat bis spätestens zwei Wochen vor dem Prüfungstermin aus entschuldbaren Gründen abmeldet;"
            },
            {
              "marke": "b",
              "text": "zur Hälfte, wenn die Kandidatin oder der Kandidat nicht zur Prüfung erscheint."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Die Gesuchstellerin oder der Gesuchsteller bezahlt für den Entscheid über die vollständige oder teilweise Befreiung von der Prüfung nach Art. 5 lit. b eine Gebühr von Fr. 300.–. Diese Gebühr wird an die Prüfungsgebühr nach Abs. 1 dieser Bestimmung angerechnet."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.11.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd34dc0d6b04cc9e83410bd6e0d8f7d4",
      "sha": "f295f64db5fe5bcdf5fba28a4d57b49d429ec7ad4a0c0865ef5eeb8f753d7794"
    },
    {
      "id": "kanton/AR/811.11.1/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Prüfungsreglement für Heilpraktikerinnen und Heilpraktiker (811.11.1)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Entscheide der Prüfungskommission können innert zwanzig Tagen seit Eröffnung mit Rekurs beim Departement Gesundheit und Soziales angefochten werden."
        },
        {
          "absatz": "2",
          "text": "Das Verfahren richtet sich nach dem Gesetz über die Verwaltungsrechtspflege."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.11.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd34dc0d6b04cc9e83410bd6e0d8f7d4",
      "sha": "3b57a7a338044b0a0ce3017baf45b0a30a5db959ef5bdf8a7b9ec5d34c831a64"
    },
    {
      "id": "kanton/AR/811.11.1/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Prüfungsreglement für Heilpraktikerinnen und Heilpraktiker (811.11.1)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Prüfungsreglement für Heilpraktiker vom 7. April 1987 wird aufgehoben."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.11.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd34dc0d6b04cc9e83410bd6e0d8f7d4",
      "sha": "ab0ecfca03b5ee8401c6223050d56a219a52fcf90ae3259a8eb3d44bc0c7418a"
    },
    {
      "id": "kanton/AR/811.11.1/art_14",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Prüfungsreglement für Heilpraktikerinnen und Heilpraktiker (811.11.1)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieses Reglement tritt sofort in Kraft."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/811.11.1",
      "abgerufen": "2026-06-23",
