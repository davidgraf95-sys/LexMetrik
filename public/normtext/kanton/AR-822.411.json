{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/822.411/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Departement Gesundheit und Soziales ist zuständiges Departement im Sinne des EG zum FamZG."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "d88d0867a4f3a562f05449c67a2fd05ae10af98c7eafd5f72206955d9b4d5bc3"
    },
    {
      "id": "kanton/AR/822.411/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Anerkennungen von Familienausgleichskassen werden per 1. Januar ausgesprochen. Gesuche um Anerkennung sind bis zum 31. August des Vorjahres einzureichen. Die Gesuche haben vollständige Angaben über Organisation, Organe und Finanzen der gesuchstellenden Kasse sowie deren Reglement zu enthalten."
        },
        {
          "absatz": "2",
          "text": "Sämtliche nach der Anerkennung eingetretenen Änderungen in Belangen, welche eine Grundlage bildeten für die Anerkennung, sind dem Departement mitzuteilen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "17b4b1ba5a9265cea3b2b421ab6ad64bc560fda1ea0a247faa572f81fd3eae9e"
    },
    {
      "id": "kanton/AR/822.411/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Erhält das Departement Kenntnis von Tatsachen, welche einen Widerruf der Anerkennung zur Folge haben, setzt es der Familienausgleichskasse eine angemessene Frist, um den gesetzmässigen Zustand wieder herzustellen."
        },
        {
          "absatz": "2",
          "text": "Verstreicht die Frist ungenutzt, verfügt das Departement den Widerruf."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "0beb71f38664672c61892f7e98a1fda24c4cfe749a11fddde7a4069c4fef5836"
    },
    {
      "id": "kanton/AR/822.411/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Anspruchsberechtigte Arbeitnehmende machen ihren Anspruch auf Familienzulagen beim Arbeitgebenden geltend."
        },
        {
          "absatz": "2",
          "text": "Macht die anspruchsberechtigte Person die Familienzulage nicht selber geltend, kann der Anspruch vom andern Elternteil sowie von der Person, Sozialhilfestelle oder Einrichtung, welche für das Kind sorgt, geltend gemacht werden."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "4b49a68bf7120719b9c0a3e75bb27ced681f3ada0340d6fad2e8139ffbc14462"
    },
    {
      "id": "kanton/AR/822.411/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Selbständigerwerbende machen ihren Anspruch mit einer Anmeldung bei der Familienausgleichskasse geltend."
        },
        {
          "absatz": "2",
          "text": "Arbeitgebenden melden die anspruchsberechtigten Arbeitnehmenden der Familienausgleichskasse."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "16630529f98e6a3d2fd4ae256a06bea557f45cb89642732ca4d78ce161552a38"
    },
    {
      "id": "kanton/AR/822.411/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Familienausgleichskasse entscheidet über den Anspruch in Form einer Verfügung."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "94cb8f59bf53178f3542e734c58dca5317a48fb5cc115389347dc32e5b1fbc39"
    },
    {
      "id": "kanton/AR/822.411/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Zulagen für Arbeitnehmende werden jeweils auf Ende des Monats fällig. Sie werden durch den Arbeitgebenden ausgerichtet und auf der Lohnabrechnung separat aufgeführt."
        },
        {
          "absatz": "2",
          "text": "Die Arbeitgebenden haben periodisch mit der Familienausgleichskasse abzurechnen."
        },
        {
          "absatz": "3",
          "text": "Die Zulagen für Selbständigerwerbende werden durch die Familienausgleichskasse in der Regel vierteljährlich ausgerichtet. Die Verrechnung mit geschuldeten Beiträgen ist zulässig."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "f15fa216a09cc7311d737c667d68ee9d0a2b0655e6edf9c92240fcfa1ef97bbf"
    },
    {
      "id": "kanton/AR/822.411/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Nichterwerbstätige melden ihren Anspruch bei der Familienausgleichskasse Appenzell Ausserrhoden an."
        },
        {
          "absatz": "2",
          "text": "Dem Gesuch legen sie die für die Prüfung notwendigen Unterlagen bei, insbesondere die in den letzten zwölf Monaten zuletzt eingereichte Steuererklärung."
        },
        {
          "absatz": "3",
          "text": "Hat die antragstellende Person keine Steuererklärung eingereicht oder macht sie geltend, dass die tatsächlichen Verhältnisse massgeblich von der eingereichten Steuererklärung abweichen, hat sie die anspruchsbegründenden Tatsachen nachzuweisen."
        },
        {
          "absatz": "4",
          "text": "Die Zulagen für Nichterwerbstätige werden durch die Familienausgleichskasse Appenzell Ausserrhoden ausgerichtet."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "a3c49fd0d584c228a80f4009b53f6e4acabb752e5b3c64931f80f56b7aa3c53d"
    },
    {
      "id": "kanton/AR/822.411/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Familienausgleichskassen regeln die Details des Verfahrens. Sie stellen die notwendigen Formulare zur Verfügung."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "dd0a49b773d977201481ab64c63e7c8b01f82140cb86f9cb07083b0b34cc5ba0"
    },
    {
      "id": "kanton/AR/822.411/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Familienausgleichskassen stellen dem Departement innert drei Monaten unentgeltlich die geprüfte Jahresrechnung, den Revisionsbericht sowie die notwendigen statistischen Angaben zu."
        },
        {
          "absatz": "2",
          "text": "Die Bestimmungen des Bundesgesetzes über die Alters- und Hinterlassenversicherung über die Kassenrevisionen und Arbeitgeberkontrollen gelten sinngemäss."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "3806fec5e051ad4262bff2f92867c45b1a1db3e23624a29a6d08739d01131ab3"
    },
    {
      "id": "kanton/AR/822.411/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Familienausgleichskassen führen ein Verzeichnis der ihnen angeschlossenen Arbeitgebenden, der Nichterwerbstätigen, der Selbständigerwerbenden sowie der Arbeitnehmenden ohne beitragspflichtige Arbeitgebende."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "09bc2a9159d8d237064a94bf1a14be44d2b6a99b324bd0560afdc04b4f004e0d"
    },
    {
      "id": "kanton/AR/822.411/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Verordnung über die Organisation der Ausgleichskasse findet sinngemäss Anwendung."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "3e805f9d0f87ee27ebfe4bd2903ea790a6217127ed6434be7785f0accedfc105"
    },
    {
      "id": "kanton/AR/822.411/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Familienausgleichskasse Appenzell Ausserrhoden kann Verbandsausgleichskassen im Sinne der Art. 53 ff. des Bundesgesetzes über die Alters- und Hinterlassenenversicherung, denen im Kanton Appenzell Ausserrhoden domizilierte Arbeitgebende und bzw. oder Selbständigerwerbende angeschlossen sind, die Erhebung der Beiträge und die Ausrichtung der Zulagen übertragen. Die Einzelheiten sind jeweils in einer Vereinbarung zu regeln."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "7243cd2898ab55b86a60d5d43b0ef2481e5357b2e8971a8d77a41df79ecb8e2c"
    },
    {
      "id": "kanton/AR/822.411/art_14",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Beitragssatz beträgt für Arbeitgebende und für Selbständigerwerbende je 1.6 Prozent."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "cff4fecd6e0293621230a894800dc262a649412ccd24fe9f451008d32ec97cb3"
    },
    {
      "id": "kanton/AR/822.411/art_15",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "15",
      "artikelLabel": "Art. 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Ausgleichskasse stellt dem Kanton bis zum 15. Dezember Rechnung für:",
          "items": [
            {
              "marke": "a",
              "text": "die im laufenden Jahr an die Nichterwerbstätigen ausgerichteten Zulagen abzüglich der Beiträge der Nichterwerbstätigen;"
            },
            {
              "marke": "b",
              "text": "die Durchführungskosten."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Der Anteil, den Nichterwerbstätige gemäss Art. 8 Abs. 1 EG zum FamZG zu leisten haben, beträgt 20 Prozent."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "eb850f8818f1942e2ae38091877ae9dea4746d639a24082fbf01ff6209019463"
    },
    {
      "id": "kanton/AR/822.411/art_16",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "16",
      "artikelLabel": "Art. 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Familienausgleichskasse ist jährlich durch das Revisionsorgan der kantonalen Ausgleichskasse zu prüfen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "0f936a1032c884aecf23289c3ff915650e5baf87944189a639a59eaafc47fb74"
    },
    {
      "id": "kanton/AR/822.411/art_17",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "17",
      "artikelLabel": "Art. 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Familienausgleichskasse informiert die möglichen Anspruchsberechtigten angemessen über ihre Ansprüche."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "3c28fd30cb969730ac25ffbd6f79db2fe39aedf84766e604bb2b3b6458775047"
    },
    {
      "id": "kanton/AR/822.411/art_18",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ein Wechsel der Familienausgleichskasse kann jeweils nur auf den Jahresanfang erfolgen."
        },
        {
          "absatz": "2",
          "text": "Wer zu einer anderen Familienausgleichskasse wechselt, meldet der bisherigen Familienausgleichskasse den Austritt bis zum 31. August des dem Wechsel vorangehenden Jahres."
        },
        {
          "absatz": "3",
          "text": "Die bisherige Familienausgleichskasse meldet der neuen Familienausgleichskasse sowie dem Departement den Austritt."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "164f5f1bf37fde4d9c34014350b556a0c82fca33d91785df9a509486fb99a23a"
    },
    {
      "id": "kanton/AR/822.411/art_19",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "19",
      "artikelLabel": "Art. 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Departement sorgt für die Datenerhebung nach den Bestimmungen des Bundesrechts."
        },
        {
          "absatz": "2",
          "text": "Das Departement kann diese Aufgabe ganz oder teilweise der Familienausgleichskasse Appenzell Ausserrhoden übertragen. Diese wird dafür durch den Kanton entschädigt."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "ba9513637008e97d7a7dcfb9b6bbf252ec4fc19352b598a39315dd1a38b696e2"
    },
    {
      "id": "kanton/AR/822.411/art_20",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "20",
      "artikelLabel": "Art. 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Verordnung vom 29. Oktober 1984 zum Gesetz über die Kinderzulagen wird aufgehoben."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "4e76b214515898abac677777e91b8c173f443e2a0c04a78676bbe9d764d71107"
    },
    {
      "id": "kanton/AR/822.411/art_21",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum FamZG (822.411)",
      "artikel": "21",
      "artikelLabel": "Art. 21",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung tritt unter Vorbehalt des unbenützten Ablaufs der Referendumsfrist zum EG zum FamZG am 1. Januar 2009 in Kraft."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/822.411",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd2b908cfe7f11ac2a1bab1ef84de4ed",
      "sha": "a0d43a285b08ffa69d1bdf46e061f4b63c6a776bfae8847cd01ac2c201e3e830"
    }
  ]
}