{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/862.11/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Verwaltungsrat genehmigt den Geschäftsbericht und die Jahresrechnung der Assekuranz zuhanden des Regierungsrates und des Kantonsrates."
        },
        {
          "absatz": "2",
          "text": "Er erlässt Richtlinien über das Versicherungsverhältnis, über die Ermittlung der Versicherungswerte und der Schäden sowie einen Prämientarif."
        },
        {
          "absatz": "3",
          "text": "Er wählt die Schätzerinnen und Schätzer und die leitenden Angestellten der Assekuranz."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "f300a454ce39a615df32031e42cfed413d14d60698e8bfe4203466e56aee29d0"
    },
    {
      "id": "kanton/AR/862.11/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Direktion führt die Geschäfte nach den Weisungen des Verwaltungsrates und vertritt die Assekuranz nach aussen, soweit Gesetz und Verordnungen nichts anderes bestimmen."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "701c35aa186d6a0074f5b13227e4cd33c25721f57549d84a42e957710cfabf41"
    },
    {
      "id": "kanton/AR/862.11/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die von der kantonalen Verwaltung und von den Organen der Assekuranz unabhängige Revisionsstelle erstattet dem Verwaltungsrat zuhanden des Regierungsrates und des Kantonsrates einen schriftlichen Bericht über ihre Prüfung und über die Jahresrechnung."
        },
        {
          "absatz": "2",
          "text": "Der Regierungsrat, der Verwaltungsrat und die Direktion können die Revisionsstelle beauftragen, Zwischenberichte zu erstatten."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "a85553bba7fbb5bb72d8fce39b59d0e22d9407bc07d1f6e849418d76ca23490a"
    },
    {
      "id": "kanton/AR/862.11/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Keine Elementarschäden im Sinne des Gesetzes sind insbesondere Schäden, die auf schlechten Baugrund, ungenügende Fundamente, fehlerhafte Arbeit oder Konstruktion, mangelhaften Unterhalt, künstlich vorgenommene Bodenveränderungen oder Grundwasserabsenkungen, Bodensenkungen, Feuchtigkeit, Frost, Grundwasser oder ähnliche Einwirkungen zurückzuführen sind."
        },
        {
          "absatz": "2",
          "text": "Nicht als Hochwasser- oder Überschwemmungsschäden gelten insbesondere Schäden, die durch Wasser aus Stauseen, durch Rückstau aus Abwasserkanalisationen oder von Grundwasser verursacht werden."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "e205b39be3e1d3376d2c224a6af3a3c3837138eca3fc0e4ac38313eeb42cbe56"
    },
    {
      "id": "kanton/AR/862.11/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die jeweils massgebende Haftungsgrenze wird im Geschäftsbericht bekanntgegeben."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "a2f9f376a8a382a982e9622f20d5efb5952b463c7509101002d8febb4f4c3518"
    },
    {
      "id": "kanton/AR/862.11/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Mit dem Gebäude versichert sind seine Bestandteile sowie die baulichen Einrichtungen, die so eingebaut sind, dass sie ohne Beschädigung des Gebäudes oder der Einrichtung nicht entfernt werden können."
        },
        {
          "absatz": "2",
          "text": "Der Verwaltungsrat regelt die Abgrenzung zwischen Gebäude- und Fahrhabeversicherung im Einzelnen und befolgt dabei die branchenüblichen Grundsätze."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "7e4cf529ae8f9989e91f1cc4f3f46044350859f03c9cf22e66ad4168e1c788ff"
    },
    {
      "id": "kanton/AR/862.11/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Nicht obligatorisch versichert werden Gebäude, deren Neuwert zwei Prozent des durchschnittlichen Wertes aller im Kanton versicherten Gebäude nicht erreicht. Dieser Wert wird im Geschäftsbericht veröffentlicht."
        },
        {
          "absatz": "2",
          "text": "Gebäude, deren Wert zehn Prozent des durchschnittlichen Wertes aller im Kanton versicherten Gebäude nicht erreicht, können auf Verlangen des Eigentümers oder der Eigentümerin von der Versicherung ausgenommen werden, wenn allfällige Grundpfandgläubiger damit einverstanden sind."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "4af408a0ab9412200f0726902cecd26e32b925cdf963e55e4a8c3c060572d46a"
    },
    {
      "id": "kanton/AR/862.11/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gebäude bis zu einem Wert von zwei Prozent des durchschnittlichen Wertes aller im Kanton versicherten Gebäude und gebäudeähnliche Objekte können freiwillig versichert werden."
        },
        {
          "absatz": "2",
          "text": "Als gebäudeähnliche Objekte gelten selbständige bauliche Anlagen, die aus dauerhaftem Material erstellt sind, wie Wasserzisternen, Brunnen, Treppen, Schwimmbassins, Stützmauern und dergleichen, soweit sie nicht Gegenstand der Grundstückversicherung sind; sie müssen nach den anerkannten Regeln der Baukunde erstellt sein."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "b481081f7e769200ed7474cca0da78f109c237cb1b67e993352863eb13966576"
    },
    {
      "id": "kanton/AR/862.11/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Ausschluss aus der Versicherung bezieht sich auf die Feuergefahr oder auf einzelne Elementargefahren."
        },
        {
          "absatz": "2",
          "text": "Wird ein Gebäude nur für einzelne Gefahren von der Versicherungsdeckung ausgeschlossen, ist die ganze Prämie zu entrichten."
        },
        {
          "absatz": "3",
          "text": "Bei vollständigem Ausschluss ist die Prämie während zwei Jahren zu entrichten."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "864cc9f82adfc645c8f24be0d13f174b1aa4e85c513c4f57c5804dbaf8d36226"
    },
    {
      "id": "kanton/AR/862.11/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Versicherten melden der Assekuranz den Baubeginn vor der Bauausführung zur Versicherung an. Wird die Anmeldung unterlassen, sind der Baubeginn und der Umfang der ausgeführten Arbeiten nachzuweisen."
        },
        {
          "absatz": "2",
          "text": "Wesentliche Erneuerungen sind wertvermehrende Bauarbeiten im Wert von fünf Prozent des durchschnittlichen Wertes aller im Kanton versicherten Gebäude."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "c4adedbfcd5216c433ddc8ccbb25b06931e844e101218254ee785d11d05c55f2"
    },
    {
      "id": "kanton/AR/862.11/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Versicherung während der Bauzeit gilt der Kostenvoranschlag für die wertvermehrenden Aufwendungen. Fehlt ein Kostenvoranschlag, ist die Schätzung nach Vollendung der Bauarbeiten massgebend."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "e50284a0b6b34f4e5b37fecdab0b8daea5ec5f6681068ce6b41c79d9e8c3a5da"
    },
    {
      "id": "kanton/AR/862.11/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Grundsätzlich sind alle Gebäude zum Neuwert versichert. Der Neuwert ist der Kostenaufwand, der für die Erstellung eines gleichartigen Gebäudes zur Zeit der Schätzung erforderlich wäre."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "5dbdac3ba031a1e10e5a62d260a9f7d1f4baaa1bb765f67459be7de47c4fba3b"
    },
    {
      "id": "kanton/AR/862.11/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wenn sich der Wert eines Gebäudes infolge mangelnden Unterhalts oder Abnützung um mehr als die Hälfte des Neuwertes vermindert hat, wird es zum Zeitwert versichert."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "9694a9d1cce7550fa9736d05fccd8cae2cefab33ff2639c36f3b9857a8772260"
    },
    {
      "id": "kanton/AR/862.11/art_14",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zu einer festen Versicherungssumme können Gebäude versichert werden, die der Eigentümer oder die Eigentümerin nach einem Schadenfall nur mit unverhältnismässigem Aufwand in gleicher Ausführung wiederaufbauen könnte."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "4189dffcf17088643570fbc2672ccbe15bf020d75db52326f2ed184d1c1a6d9b"
    },
    {
      "id": "kanton/AR/862.11/art_15",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "15",
      "artikelLabel": "Art. 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Assekuranz kann den Versicherungswert von Abbruchobjekten auf den Abbruchwert herabsetzen."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "09dc15d10cc3cf20cc512a634b2cbb2d0d660e483b830c4aa0dbbba41ae816b8"
    },
    {
      "id": "kanton/AR/862.11/art_16",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "16",
      "artikelLabel": "Art. 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Assekuranz ermittelt den Neuwert und den Zeitwert der Gebäude, die Bauweise, die Nutzung, die besondere Gefährdung und die entsprechenden Schutzmassnahmen."
        },
        {
          "absatz": "2",
          "text": "Die Versicherten und die Assekuranz können jederzeit eine Neuschätzung verlangen."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "ca36bb1beea6af3996a41195e4ff20b68f0e986dbf0b1124892aa67bec8f51d5"
    },
    {
      "id": "kanton/AR/862.11/art_17",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "17",
      "artikelLabel": "Art. 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Neubauten kann die Assekuranz den Wert des Gebäudes aufgrund der Baukostenabrechnung und der Pläne ermitteln. Sie kontrolliert die übrigen für die Versicherung massgebenden Angaben."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "36605e26823968eb883747590a23c92ca23e460a7c26f75f36e0b9f3ef672455"
    },
    {
      "id": "kanton/AR/862.11/art_18",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Versicherten haben der Assekuranz alle für die Versicherung massgebenden Auskünfte zu erteilen. Verweigern sie die Mitwirkung, werden die Schätzungsdaten aufgrund von Erfahrungswerten von der Assekuranz festgelegt."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "f799a61515d8d4b71031ab1b0cc685d02eb68ee4b89b19c22e431ee0856df3e3"
    },
    {
      "id": "kanton/AR/862.11/art_19",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "19",
      "artikelLabel": "Art. 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Assekuranz schätzt jedes Gebäude in der Regel nach zehn Jahren neu."
        },
        {
          "absatz": "2",
          "text": "Der Verwaltungsrat passt die Neuwertversicherung auf den Beginn eines Kalenderjahres an, wenn sich die Baukosten wesentlich ändern."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "ab48b70ef19c3cbcd1b2ce2086e3eb4a302b9da73284b67c4e6a4b684514721d"
    },
    {
      "id": "kanton/AR/862.11/art_20",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "20",
      "artikelLabel": "Art. 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Verwaltungsrat erlässt einen Tarif über die Schätzungsgebühren."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "bd516b662977de09432c8836072912ece19faab15c5ad4185e1cb9fac6c1318c"
    },
    {
      "id": "kanton/AR/862.11/art_21",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "21",
      "artikelLabel": "Art. 21",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Versicherten können verlangen, dass Schäden bis höchstens zwei Prozent des Versicherungswertes des Gebäudes nicht versichert sind. Die Prämienreduktion richtet sich nach einem besonderen Tarif, die übrigen Modalitäten werden nach Richtlinien des Verwaltungsrates vertraglich geregelt."
        },
        {
          "absatz": "2",
          "text": "Dem Grundpfandgläubiger haftet die Assekuranz auch für den Selbstbehalt, wenn ein Pfandausfall entsteht."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "75dddcb3d32528610cfe1499778350f5a317945eb39f19ce04bb986c45206b49"
    },
    {
      "id": "kanton/AR/862.11/art_22",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "22",
      "artikelLabel": "Art. 22",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Verwaltungsrat erlässt einen Prämientarif, der folgende Grundsätze berücksichtigt:",
          "items": [
            {
              "marke": "a",
              "text": "Massgebend für die Prämien sind die Bauart des Gebäudes, die Zweckbestimmung sowie die Gefährlichkeit infolge der Nutzung oder der Lage;"
            },
            {
              "marke": "b",
              "text": "ist ein Gebäude einer erhöhten Feuer- oder Elementargefahr ausgesetzt, werden Zuschläge auf den Prämien erhoben;"
            },
            {
              "marke": "c",
              "text": "wirkt sich die Gefahrerhöhung auf Nachbargebäude aus, ist der Zuschlag auch für diese zu entrichten;"
            },
            {
              "marke": "d",
              "text": "die Prämie oder Prämienzuschläge werden reduziert, wenn die Sicherheit des Gebäudes freiwillig verbessert wird;"
            },
            {
              "marke": "e",
              "text": "Selbstbehalte bewirken eine Prämienermässigung nach einem besonderen Tarif. Die Prämie ist in dem Umfang zu ermässigen, als die Haftung der Assekuranz versicherungstechnisch vermindert wird."
            }
          ]
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "67f1763c08fe636a9011f63b469c32a14f96d950f01cb5bc9184ece7bdb4fcde"
    },
    {
      "id": "kanton/AR/862.11/art_23",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "23",
      "artikelLabel": "Art. 23",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Besteht die Versicherung nur während eines Teils des Jahres, ist die Prämie anteilmässig und nach vollen Monaten gerechnet zu entrichten."
        },
        {
          "absatz": "2",
          "text": "Nach einem Schadenfall ist die Prämie für das ganze laufende Jahr geschuldet."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "30dbfc524e3e01d8cb71ffc206083f61552fa67df9347ea50d2850f05c893b19"
    },
    {
      "id": "kanton/AR/862.11/art_24",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "24",
      "artikelLabel": "Art. 24",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Handänderungen haften die Vertragsparteien der Assekuranz für die ausstehenden Prämien solidarisch."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "6f8c86215fa917f5437cc53aa60fcde602005d2f25fed2e107c3317f7295d7cc"
    },
    {
      "id": "kanton/AR/862.11/art_25",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "25",
      "artikelLabel": "Art. 25",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Prämienrechnungen sind einem vollstreckbaren Urteil im Sinne des Schuldbetreibungs- und Konkursrechtes gleichgestellt."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "a03e75b396bbd6e36ea02a277158994f798f328686d625ca960ce69aa3e8c506"
    },
    {
      "id": "kanton/AR/862.11/art_26",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "26",
      "artikelLabel": "Art. 26",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Assekuranz entgangene oder von ihr zu Unrecht bezogene Prämien können höchstens für das laufende Jahr und für die vergangenen fünf Jahre nach- oder zurückgefordert werden."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "919ef43d0185ae1c912e3308ab3c9a5d45e16c2239d19751a7997f01fe75808c"
    },
    {
      "id": "kanton/AR/862.11/art_27",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "27",
      "artikelLabel": "Art. 27",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zum Beitrag berechtigen bauliche Präventionsmassnahmen am Gebäude oder dessen unmittelbarer Umgebung."
        },
        {
          "absatz": "2",
          "text": "Der Beitrag beträgt 30 bis 50 Prozent im Rahmen der verfügbaren Mittel."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "e733d7e04317acd78da5cdc5ae801f693123840724d2b0fb08ecf2e79e243af4"
    },
    {
      "id": "kanton/AR/862.11/art_28",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "28",
      "artikelLabel": "Art. 28",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Assekuranz achtet darauf, dass die Prämieneinnahmen, die Reserven und die Rückversicherung in einem ausgewogenen Verhältnis zueinander stehen, damit die Leistungsfähigkeit der Assekuranz ständig gewährleistet bleibt. Sie lässt ihre Finanzierung periodisch von Fachleuten begutachten und gibt im Geschäftsbericht das Ergebnis der Prüfung bekannt."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "6f72cf343ab32481e6d283ceaca06a28411d11bcb365b848fa3ca5e1a203f2e6"
    },
    {
      "id": "kanton/AR/862.11/art_29",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "29",
      "artikelLabel": "Art. 29",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Sicherheitsvorkehren wie der Abbruch des Gebäudes oder einzelner Gebäudeteile oder der Aufbau eines Notdaches werden von der Direktion angeordnet."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "ceae84250abf1b4521bc3f5288f089566e84ac2a9c976d5c1616b05c4b08c9cf"
    },
    {
      "id": "kanton/AR/862.11/art_30",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "30",
      "artikelLabel": "Art. 30",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Assekuranz ermittelt unverzüglich und auf ihre Kosten den Schaden."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "a9f7e986f012f48af4b38376845cebd24510e25934885f76cad1da7b434834a0"
    },
    {
      "id": "kanton/AR/862.11/art_31",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "31",
      "artikelLabel": "Art. 31",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wenn das Gebäude vollständig beschädigt ist, bezahlt die Assekuranz nach Abschluss der Untersuchung den Verkehrswert aus. Der Verkehrswert entspricht dem Marktwert des Gebäudes ohne den Wert des Bodens und der dinglichen Rechte."
        },
        {
          "absatz": "2",
          "text": "Die Restzahlungen werden nach Massgabe des Fortschritts beim Wiederaufbau ausgerichtet."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "eb9d892de2a7772da676142cdc60a282e0b72f940d3b180265735d13af34bdc5"
    },
    {
      "id": "kanton/AR/862.11/art_32",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "32",
      "artikelLabel": "Art. 32",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Behebung von Teilschäden wird aufgrund der Bauabrechnungen vergütet. Es können Pauschalvergütungen vereinbart werden."
        },
        {
          "absatz": "2",
          "text": "Wenn die Reparaturkosten in einem offensichtlichen Missverhältnis zur Beschädigung stehen, werden für Schäden, welche die Gebrauchstauglichkeit eines Gebäudeteiles nicht vermindern, Pauschalen vergütet."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "c1b966fccaf6e230133e5e9cd54fbb97663ebbc60e6c5905ef900ffab35c7136"
    },
    {
      "id": "kanton/AR/862.11/art_33",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "33",
      "artikelLabel": "Art. 33",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für Schäden an unvollendeten Gebäuden werden die zur Zeit des Schadenereignisses eingebauten und mit dem Gebäude zu versichernden Teile und Einrichtungen vergütet."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "8f1bc6fc41692ba259485c916f159b57e9e770ea2b905306a6c32e936c6a903d"
    },
    {
      "id": "kanton/AR/862.11/art_34",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "34",
      "artikelLabel": "Art. 34",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wird ein Gebäude beschädigt, das für die Eigentümerin oder für den Eigentümer wirtschaftlich wertlos geworden, zum Abbruch vorgesehen oder nicht mehr benutzbar ist, wird der Abbruchwert vergütet, auch wenn das Gebäude wiederhergestellt wird."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "509176308faf94d15a47cca9909ab8418224ef7a96e13b7490e69d3001e3554d"
    },
    {
      "id": "kanton/AR/862.11/art_35",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "35",
      "artikelLabel": "Art. 35",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die vom Verwaltungsrat festgelegte Höchstgrenze für die Abbruch- und Entsorgungskosten für das Gebäude wird im Geschäftsbericht der Assekuranz veröffentlicht."
        },
        {
          "absatz": "2",
          "text": "Sie kann auf Verlangen der Versicherten und gegen einen angemessenen Prämienzuschlag höhere Deckung gewähren."
        },
        {
          "absatz": "3",
          "text": "Für besondere Hilfeleistungen in Schadenfällen kann die Assekuranz eine Belohnung ausrichten."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "51c8ff846562287c71e91752ac7db5397459ac53a1e7bf5fab786fbe8fc2de33"
    },
    {
      "id": "kanton/AR/862.11/art_36",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "36",
      "artikelLabel": "Art. 36",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Assekuranz zahlt ihre Versicherungsleistung dem Grundbuchamt zuhanden der Grundpfandgläubiger und der Versicherten aus."
        },
        {
          "absatz": "2",
          "text": "Versicherungsleistungen, die höher als ein Fünftel des durchschnittlichen Versicherungswertes aller im Kanton versicherten Gebäude sind, werden vom Zeitpunkt der rechtskräftigen Schadenschätzung an verzinst. Der Verwaltungsrat legt den Zinssatz fest."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "b6efdafeb7c79c69360b06f014159b7978a016d1e74b82c4b54ec327e230ffd8"
    },
    {
      "id": "kanton/AR/862.11/art_37",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "37",
      "artikelLabel": "Art. 37",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Von der Grundstückversicherung sind ausgeschlossen:",
          "items": [
            {
              "marke": "a",
              "text": "Tiefbauten, die zu mehr als zwei Dritteln von einer Gemeinde oder vom Kanton unterhalten werden;"
            },
            {
              "marke": "b",
              "text": "Tiefbauten, die vom Bund unterhalten werden;"
            },
            {
              "marke": "c",
              "text": "technischen Zwecken dienende Grundstücke, auf denen sich Anlagen wie Eisenbahn- und Seilbahnanlagen, Stark- und Schwachstromanlagen befinden;"
            },
            {
              "marke": "d",
              "text": "Anlagen wie Tunnels, Stützmauern, Wehre, Talsperren, Stauvorrichtungen, Sohlen- und Uferverbauungen fliessender Gewässer, Kanalisationen und Wasserleitungen."
            }
          ]
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "6e36e12ca5ad138b183ff756a36f77768771181c7e0f1a5fb9499f5ea7b8ab06"
    },
    {
      "id": "kanton/AR/862.11/art_38",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "38",
      "artikelLabel": "Art. 38",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Verwaltungsrat erlässt den Prämientarif nach folgenden Finanzierungsgrundsätzen:",
          "items": [
            {
              "marke": "a",
              "text": "Der Aufwand der Grundstückversicherung soll langfristig je hälftig aus Prämien und aus einem jährlichen Beitrag der Gebäudeversicherung finanziert werden;"
            },
            {
              "marke": "b",
              "text": "der Grundbeitrag bemisst sich nach der Schadenbelastung und soll mindestens die Hälfte des Prämienertrages ausmachen;"
            },
            {
              "marke": "c",
              "text": "der Flächenbeitrag soll höchstens die Hälfte des Prämienertrages ausmachen."
            }
          ]
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "ac6a4a010d0a7de0aec35f94ad0e7284c25947fd33f3e3fbac94c9d8944506bf"
    },
    {
      "id": "kanton/AR/862.11/art_39",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "39",
      "artikelLabel": "Art. 39",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Grundstückversicherung wird eine eigene Rechnung geführt, und es werden gesonderte Reserven ausgewiesen."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "dc7f94a5aca6957c9b515fb0ed2a1956fc89479fdcc582ab545aa5ea97a8050b"
    },
    {
      "id": "kanton/AR/862.11/art_40",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "40",
      "artikelLabel": "Art. 40",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Grundstückschäden sind der Assekuranz unverzüglich zu melden. Es dürfen nur Schäden vergütet werden, die von der Assekuranz noch feststellbar sind."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "69dadf975a54168323d7da2ba49fa3271c96623473b9c6808f75919bea0f65c2"
    },
    {
      "id": "kanton/AR/862.11/art_41",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "41",
      "artikelLabel": "Art. 41",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Schadenschätzung wird von Fachleuten durchgeführt, die von der Assekuranz bezeichnet werden. Im Übrigen gelten dieselben Grundsätze wie für die Gebäudeversicherung."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "9a1d980b0ae42cae75bc8f1345888b32b12291d5e550fba3bad60bba00fe5809"
    },
    {
      "id": "kanton/AR/862.11/art_42",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "42",
      "artikelLabel": "Art. 42",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wenn die Wiederherstellungskosten sich im Verhältnis zum Wert des beschädigten Grundstückes nicht rechtfertigen, wird der entstandene Minderwert vergütet."
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "7cd453c1aefc74159ecb94913aba401917948cc3e7da041cd72777a68a7f31e6"
    },
    {
      "id": "kanton/AR/862.11/art_43",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Assekuranzverordnung (862.11)",
      "artikel": "43",
      "artikelLabel": "Art. 43",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Keine Leistungen werden erbracht bei",
          "items": [
            {
              "marke": "a",
              "text": "periodisch wiederkehrendem Abschwemmen von Humus an Hängen und beim Abschwemmen von Kies an Strassen und Plätzen;"
            },
            {
              "marke": "b",
              "text": "mangelhaftem Unterhalt an Tiefbauten und Anlagen."
            }
          ]
        }
      ],
      "stand": "2020-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/862.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "549ff80276cd8fc9c5cba400de77aab0",
      "sha": "3fcfa3dbc7c75460cf1fd7141626785a43abd4e96a9ec827f6a8a76ab7af44fd"
    }
  ]
}