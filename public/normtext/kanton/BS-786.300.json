{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/786.300/art_1.1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "1.1",
      "artikelLabel": "Art. 1.1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kantone arbeiten in allen Belangen der Abfallbewirtschaftung zusammen und stimmen insbesondere Planung, Bau und Betrieb der erforderlichen Anlagen eng aufeinander ab. Den Kantonen steht das Recht zu, die Kehrichtverwertungsanlage Basel (KVA) und die Deponie Elbisgraben gemäss den jeweiligen Zulassungsbestimmungen zu benutzen."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "7fc5706e1bc0b80ea6e2a254343aea67be815c9937453e813f09c7e112d016ee"
    },
    {
      "id": "kanton/BS/786.300/art_1.2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "1.2",
      "artikelLabel": "Art. 1.2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kantone legen in einem Umsetzungsvertrag die Lieferbedingungen, Liefermengen, Heizwert, Tarifgestaltung und Garantieleistungen gemeinsam fest."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "5524ece69f2f562b126b203bb272659e0f140adc2efe41852bba0e29cecc731f"
    },
    {
      "id": "kanton/BS/786.300/art_1.3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "1.3",
      "artikelLabel": "Art. 1.3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kantone sorgen dafür, dass die wesentlichen Belange der beiden Abfallanlagen transparent dargestellt werden. Sie hören sich gegenseitig dazu an."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "27cae2d06b52a29e81427828c14e7c7443a356296fa1f95a8da601d66d027e71"
    },
    {
      "id": "kanton/BS/786.300/art_1.4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "1.4",
      "artikelLabel": "Art. 1.4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Anlieferungen der Abfälle und der Verbrennungsrückstände aus den Kantonen sollen soweit ökologisch sinnvoll, technisch machbar und wirtschaftlich tragbar per Bahn erfolgen."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "cc3594fe44d5ccd60d28b68814cea92e9d212921dce37a0e903a3aa6d0f63364"
    },
    {
      "id": "kanton/BS/786.300/art_1.5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "1.5",
      "artikelLabel": "Art. 1.5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kantone vermeiden jegliche Konkurrenzierung bei der Abfallentsorgung und wirken innerhalb der ganzen Region darauf hin, dass die anstehenden Aufgaben koordiniert, wirtschaftlich und unter bestmöglicher Schonung der Umwelt gelöst werden."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "7b56ff12ac0b9b2aa75bdb3476c64174ade91c56f44dfc5e09161f2024ece136"
    },
    {
      "id": "kanton/BS/786.300/art_1.6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "1.6",
      "artikelLabel": "Art. 1.6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kantone stimmen ihre Abfallplanung aufeinander ab und sind bemüht, gegenüber Dritten eine gemeinsame Haltung zu vertreten."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "24545d0b485241663a2e477e6347f2db1cc2afcf7e05ef1ee17b8b0d2bbd8182"
    },
    {
      "id": "kanton/BS/786.300/art_2.1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "2.1",
      "artikelLabel": "Art. 2.1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton Basel-Stadt sorgt für den Bau und Betrieb der KVA. Er kann die Aufgabe an Dritte übertragen."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "855f98e15d4b3cbbc8add2a35f8d095618d79338e418755677d94c8ac591bb75"
    },
    {
      "id": "kanton/BS/786.300/art_2.2.1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "2.2.1",
      "artikelLabel": "Art. 2.2.1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton Basel-Stadt verpflichtet sich, brennbare Siedlungsabfälle aus Haushaltungen sowie Abfälle vergleichbarer Zusammensetzung aus Industrie und Gewerbe aus dem Kanton Basel-Landschaft zur Verwertung anzunehmen."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "b358fdf27296b508d926a9e3220ce7384ae0e5d5ef809e188457867b9a57e8c8"
    },
    {
      "id": "kanton/BS/786.300/art_2.2.2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "2.2.2",
      "artikelLabel": "Art. 2.2.2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton Basel-Landschaft verpflichtet sich, die im Umsetzungsvertrag festgelegten Liefermengen von brennbaren Siedlungsabfällen aus Haushaltungen sowie von Abfällen vergleichbarer Zusammensetzung aus Industrie und Gewerbe an die KVA zu liefern."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "1a371f7631a5418c233ff3ad22ef0de4239f47bda94951cb82cbfc051ec1d8ed"
    },
    {
      "id": "kanton/BS/786.300/art_3.1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "3.1",
      "artikelLabel": "Art. 3.1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton Basel-Landschaft sorgt für den Bau und Betrieb der Deponie Elbisgraben. Er kann die Aufgabe an Dritte übertragen."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "7e5a3c052cdd649ec7326dc2ef840e1043bd120246fe9b3187c81b99c016b7ed"
    },
    {
      "id": "kanton/BS/786.300/art_3.2.1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "3.2.1",
      "artikelLabel": "Art. 3.2.1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton Basel-Landschaft verpflichtet sich, die im Umsetzungsvertrag festgelegten Mengen an Verbrennungsrückständen aus der KVA sowie weitere, gesetzlich zulässige Abfälle aus dem Kanton Basel-Stadt auf der Deponie Elbisgraben abzulagern."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "5d5db67c65257222d2ccdcad008744f429b213bdf80c61bca18471bc886fa047"
    },
    {
      "id": "kanton/BS/786.300/art_3.2.2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "3.2.2",
      "artikelLabel": "Art. 3.2.2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton Basel-Stadt verpflichtet sich, die im Umsetzungsvertrag festgelegten Mengen an Verbrennungsrückständen aus der KVA in die Deponie Elbisgraben zu liefern."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "4409f3bdb98c9f0250d72a4166a1279f1d8c9d7a3693550f5aaa76c3976706ba"
    },
    {
      "id": "kanton/BS/786.300/art_4.1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "4.1",
      "artikelLabel": "Art. 4.1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Betriebsrechnungen der KVA und des Schlackenkompartiments der Deponie Elbisgraben erfolgen nach der Methodik zur Ermittlung von Deckungsdifferenzen."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "45fceb16827a1e11e2c2e57bb4c3d732148b5f885a6b33abe7b6bc287b841cfe"
    },
    {
      "id": "kanton/BS/786.300/art_4.2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "4.2",
      "artikelLabel": "Art. 4.2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Berechnung der Tarife erfolgt nach dem Prinzip der Deckungsdifferenz und einem kalkulatorischen Zins. Der Zinssatz wird im Umsetzungsvertrag festgelegt."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "63a29f8893c218de77e1c563bbd1051d3185fd36110d98d20c7208ed0f0938bd"
    },
    {
      "id": "kanton/BS/786.300/art_4.3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "4.3",
      "artikelLabel": "Art. 4.3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Tarife für die Annahme von brennbaren Abfällen in der KVA werden vom Verwaltungsrat der Industriellen Werke Basel (IWB) festgesetzt und vom Regierungsrat Basel-Stadt genehmigt. Die Tarife für die Annahme der Verbrennungsrückstände und weiterer, gesetzlich zulässiger Abfälle in der Deponie Elbisgraben werden vom Regierungsrat Basel-Landschaft festgelegt."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "95fb6e88e29c347a414a76c02bbf2cb93c2eeff782d6bba6c1f01c50e97d8d14"
    },
    {
      "id": "kanton/BS/786.300/art_4.4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "4.4",
      "artikelLabel": "Art. 4.4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Betriebsrechnungen der KVA und der Deponie Elbisgraben werden von unabhängigen Revisionsstellen geprüft."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "58360d140547030b2e43ba1d7091829b42bb1ee8c987f4b7044b17471dccfc80"
    },
    {
      "id": "kanton/BS/786.300/art_5.1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "5.1",
      "artikelLabel": "Art. 5.1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die zuständigen Departemente der Kantone Basel-Stadt und Basel-Landschaft vollziehen diese Vereinbarung."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "e11cd6cea86d997d898f037f94cb8d1f15387565f0d0b6aef3ea399119bdf1a7"
    },
    {
      "id": "kanton/BS/786.300/art_5.2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "5.2",
      "artikelLabel": "Art. 5.2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Umsetzungsvertrag bedarf der Genehmigung durch die Regierungen der Kantone Basel-Stadt und Basel-Landschaft."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "edff1ac102c2a6a20429c74d8f234098e0fdb75abfceb55a8d523444f16beae2"
    },
    {
      "id": "kanton/BS/786.300/art_5.3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "5.3",
      "artikelLabel": "Art. 5.3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die beiden Kantone Basel-Stadt und Basel-Landschaft schaffen eine Plattform mit den Betreibern der KVA und der Deponie Elbisgraben. Weitere öffentlich-rechtliche Abfalllieferanten können sich der Plattform anschliessen."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "cbda385525652db557a6117cb39d95e247b969b603c70a8565e751514d811d67"
    },
    {
      "id": "kanton/BS/786.300/art_5.4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "5.4",
      "artikelLabel": "Art. 5.4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Mitglieder der Plattform treffen sich regelmässig und informieren sich gegenseitig über alle Tatsachen und Vorgänge, welche die Erfüllung dieser Vereinbarung beeinflussen können."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "2c5aa3432196c35dd5c4b0010380032151d614b015ba092aa6ee75ab25bf4bfd"
    },
    {
      "id": "kanton/BS/786.300/art_5.5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "5.5",
      "artikelLabel": "Art. 5.5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der jeweilige Kanton sorgt dafür, dass Dritte, soweit ihnen Bau und Betrieb der KVA oder der Deponie Elbisgraben übertragen wurde, diese Vereinbarung und den Umsetzungsvertrag ebenfalls einhalten."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "f05b626e532154e5a13693b0987b0ec8ae78653c098e9fc06924416b00433b01"
    },
    {
      "id": "kanton/BS/786.300/art_6.1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "6.1",
      "artikelLabel": "Art. 6.1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Vereinbarung wird auf die Dauer von 15 Jahren ab Inkrafttreten abgeschlossen. Ohne Kündigung gilt die Vereinbarung als stillschweigend auf unbestimmte Zeit verlängert. Sie kann nach Ablauf von zwölf Jahren jeweils mit einer Kündigungsfrist von drei Jahren auf ein Jahresende gekündigt werden."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "83024d8f699eeea565bcb98a90d51740d770745c2dbfffa343e391b364e9ef4b"
    },
    {
      "id": "kanton/BS/786.300/art_6.2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "6.2",
      "artikelLabel": "Art. 6.2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Vereinbarung ist zu publizieren."
        }
      ],
      "stand": "2019-10-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/786.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "410a1c7d49eee13c83136eb27639d5ae",
      "sha": "c8c0450457afa255ebf1adfd8fbdaab5d0ec1fd2f11be88c9811f5a32e052700"
    },
    {
      "id": "kanton/BS/786.300/art_6.3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Abfallvereinbarung BS - BL (786.300)",
      "artikel": "6.3",
      "artikelLabel": "Art. 6.3",
      "bloecke": [
        {
