{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/590.110/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Feuerwehrverordnung, FWV (590.110)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Über Einsätze im Sinne von § 1 Abs. 3 des Gesetzes entscheidet die piketthabende Offiziersperson des Bereichs Rettung."
        }
      ],
      "stand": "2017-12-21",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "74da4154daac28af3859d661c6757ed0",
      "sha": "f9a9a0ebc7654e31c5c03bd5eb2df6e999186bcc5557a0560281889d8f007ba7"
    },
    {
      "id": "kanton/BS/590.110/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Feuerwehrverordnung, FWV (590.110)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Bereich Rettung des Justiz- und Sicherheitsdepartements ist die für die Belange des Feuerwehr-Inspektorats zuständige Stelle."
        },
        {
          "absatz": "2",
          "text": "…"
        },
        {
          "absatz": "3",
          "text": "…"
        },
        {
          "absatz": "4",
          "text": "…"
        }
      ],
      "stand": "2017-12-21",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "74da4154daac28af3859d661c6757ed0",
      "sha": "f333afe4cfe53b82ca3f31362e8668e072136a038d0b6b7b39b6205f1d2cf9fa"
    },
    {
      "id": "kanton/BS/590.110/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Feuerwehrverordnung, FWV (590.110)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Angehörigen der Feuerwehr sind verpflichtet, die vom Feuerwehr-Inspektorat vorgeschriebenen Ausbildungen zu absolvieren. Die Kurskosten für die kantonale Ausbildung gehen zu Lasten des Bereichs Rettung. Allfällige Entschädigungen (Sold/Vergütungen) gehen zu Lasten der entsendenden Organisation."
        },
        {
          "absatz": "2",
          "text": "Für Angehörige von Berufsfeuerwehren gelten zudem die vom Bundesamt für Berufsbildung und Technologie BBT genehmigten einschlägigen Vorschriften."
        },
        {
          "absatz": "3",
          "text": "Die Angehörigen der Feuerwehr dürfen grundsätzlich nur Funktionen ausüben, für die sie ausgebildet sind. Das Feuerwehr-Inspektorat kann Ausnahmen bewilligen."
        }
      ],
      "stand": "2017-12-21",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "74da4154daac28af3859d661c6757ed0",
      "sha": "30994444e0aa2ae42a1db151d0a26b05dbac86a8e1d9046a65d7200ec2e1da99"
    },
    {
      "id": "kanton/BS/590.110/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Feuerwehrverordnung, FWV (590.110)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Richtigkeit der Angaben betreffend das versicherte Kapital ist durch die zuständige Revisionsstelle der Feuerversicherungsgesellschaften auf eigene Kosten zu bestätigen."
        }
      ],
      "stand": "2017-12-21",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "74da4154daac28af3859d661c6757ed0",
      "sha": "3b22a8f265b8262efc2966a4cda6e390ced8d7ee530027a5772d58d8eb6ae9bc"
    },
    {
      "id": "kanton/BS/590.110/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Feuerwehrverordnung, FWV (590.110)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Berufsfeuerwehr ist in der Organisationsstruktur des Bereichs Rettung des Justiz- und Sicherheitsdepartements eingegliedert."
        }
      ],
      "stand": "2017-12-21",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "74da4154daac28af3859d661c6757ed0",
      "sha": "449bc60f92405807e5f96d60928fdb2975a8eb2a856a42bd5e149d83594f08b6"
    },
    {
      "id": "kanton/BS/590.110/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Feuerwehrverordnung, FWV (590.110)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Milizfeuerwehr ist der Abteilung Feuerwehr des Bereichs Rettung unterstellt und besteht aus den Einsatzkompanien."
        },
        {
          "absatz": "2",
          "text": "Ein Reglement legt die Organisation und die Aufgaben fest."
        }
      ],
      "stand": "2017-12-21",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "74da4154daac28af3859d661c6757ed0",
      "sha": "b95db6995d858ea79d19ceca52a2b2fb08b27ad92f6e169e32c90ea6ad5e4d96"
    },
    {
      "id": "kanton/BS/590.110/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Feuerwehrverordnung, FWV (590.110)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Über die Aufnahme einer Bewerberin oder eines Bewerbers in die Milizfeuerwehr entscheidet die Leiterin oder der Leiter der Abteilung Feuerwehr des Bereichs Rettung."
        }
      ],
      "stand": "2017-12-21",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "74da4154daac28af3859d661c6757ed0",
      "sha": "0618fb423f5609939136de9cdea0ca38dcfff94116e08ecda31f956942d89e60"
    },
    {
      "id": "kanton/BS/590.110/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Feuerwehrverordnung, FWV (590.110)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Angehörigen der Milizfeuerwehr werden für ihre Dienstleistungen gemäss nachstehenden Ansätzen besoldet:",
          "items": [
            {
              "marke": "a",
              "text": "bei Übungen, bei geplanten Einsätzen, bei Sitzungen sowie für Fourierdienstleistungen, pro Stunde CHF 30"
            },
            {
              "marke": "b",
              "text": "bei Ernstfalleinsätzen, pro Stunde CHF 45"
            },
            {
              "marke": "c",
              "text": "als Kursteilnehmerin oder Kursteilnehmer an kantonalen Kursen, pro Tag CHF 240"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Im Ernstfall wird pro Einsatz mindestens ein Sold von einer Stundeausbezahlt; angebrochene Stunden sind auf eine ganze Stunde aufzurunden."
        }
      ],
      "stand": "2017-12-21",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "74da4154daac28af3859d661c6757ed0",
      "sha": "0457cd498a75d46016023ef802eeddc53aaae98eef1ac4cc16239bd1da960297"
    },
    {
      "id": "kanton/BS/590.110/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Feuerwehrverordnung, FWV (590.110)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Pro Jahr werden folgende Funktionsvergütungen ausbezahlt:",
          "items": [
            {
              "marke": "a",
              "text": "Kommandantin oder Kommandant Milizfeuerwehr CHF 3'000"
            },
            {
              "marke": "b",
              "text": "Stabsoffizierinnen oder Stabsoffiziere CHF 2'500"
            },
            {
              "marke": "c",
              "text": "Kompaniekommandantin oder Kompaniekommandant CHF 2'500"
            },
            {
              "marke": "d",
              "text": "Kompaniekommandantin oder Kompaniekommandant Stellvertretung CHF 1'500"
            },
            {
              "marke": "e",
              "text": "Offizierin oder Offizier CHF 700"
            },
            {
              "marke": "f",
              "text": "Feldweibelin oder Feldweibel CHF 700"
            },
            {
              "marke": "g",
              "text": "Gruppenführerin oder Gruppenführer CHF 400"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Mit den Funktionsvergütungen werden sämtliche administrative Arbeiten inklusive Übungsvorbereitungen entschädigt."
        }
      ],
      "stand": "2017-12-21",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "74da4154daac28af3859d661c6757ed0",
      "sha": "c5355c5e3408bffba09fc7a3e5d7ce6bba1d9842a54fa8d617b0a51c14a90fb0"
    },
    {
      "id": "kanton/BS/590.110/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Feuerwehrverordnung, FWV (590.110)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Beförderungen ist auf die Eignung der oder des Angehörigen der Milizfeuerwehr zu achten. Für die Beförderung wird die erfolgreiche Absolvierung der durch das Feuerwehr-Inspektorat vorgeschriebenen Ausbildungskurse vorausgesetzt."
        },
        {
          "absatz": "2",
          "text": "Beförderungen bis zum Grade eines höheren Unteroffiziers werden durch die Leiterin oder den Leiter der Abteilung Feuerwehr des Bereichs Rettung vorgenommen."
        },
        {
          "absatz": "3",
          "text": "Die Offiziere oder die Offizierinnen werden durch den Departementsvorsteher oder die Departementsvorsteherin ernannt oder befördert."
        },
        {
          "absatz": "4",
          "text": "Der Kommandant oder die Kommandantin der Kompanie Bettingen/Riehen wird im Einvernehmen mit den Einwohnergemeinden ernannt."
        }
      ],
      "stand": "2017-12-21",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "74da4154daac28af3859d661c6757ed0",
      "sha": "074756949558b59f941f17bdf10f764151d310bf7adf7b34da22c4517d3b341f"
    },
    {
      "id": "kanton/BS/590.110/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Feuerwehrverordnung, FWV (590.110)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zuständig für Entscheide nach § 7 des Gesetzes betreffend Aufnahme und Verbleiben in der Milizfeuerwehr ist die Leiterin oder der Leiter der Abteilung Feuerwehr des Bereichs Rettung."
        }
      ],
      "stand": "2017-12-21",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "74da4154daac28af3859d661c6757ed0",
      "sha": "12c1660cad4cb37aafdd201951b48a576defc13b5f9779f704152341aad61940"
    },
    {
      "id": "kanton/BS/590.110/art_12",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Feuerwehrverordnung, FWV (590.110)",
      "artikel": "12",
      "artikelLabel": "§ 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Angehörigen der Milizfeuerwehr sind bei der Hilfskasse des Schweizerischen Feuerwehrverbandes gegen die Folgen von Unfall und Krankheit gemäss geltenden Statuten und der geltenden Leistungsübersicht versichert."
        }
      ],
      "stand": "2017-12-21",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "74da4154daac28af3859d661c6757ed0",
      "sha": "499a110540c3260c8bbc2d20b59e309971b9230e26d5c0c2dbb55c9551a42d3d"
    },
    {
      "id": "kanton/BS/590.110/art_13",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Feuerwehrverordnung, FWV (590.110)",
      "artikel": "13",
      "artikelLabel": "§ 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Verweise werden von der Leiterin oder dem Leiter der Abteilung Feuerwehr des Bereichs Rettung erteilt."
        },
        {
          "absatz": "2",
          "text": "Der Ausschluss von Milizangehörigen mit Ausnahme der Offizierinnen und Offiziere wird von der Leiterin oder dem Leiter der Abteilung Feuerwehr des Bereichs Rettung ausgesprochen."
        },
        {
          "absatz": "3",
          "text": "Der Ausschluss von Offizierinnen und Offizieren wird von der Departementsvorsteherin oder dem Departementsvorsteher ausgesprochen."
        },
        {
          "absatz": "4",
          "text": "Vor Erlass einer Disziplinarmassnahme ist der oder dem Angehörigen der Milizfeuerwehr Gelegenheit zu geben, sich zu der ihr oder ihm zur Last gelegten Verfehlung mündlich oder schriftlich zu äussern. Im Falle einer mündlichen Äusserung ist ein Protokoll zu führen."
        }
      ],
      "stand": "2017-12-21",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "74da4154daac28af3859d661c6757ed0",
      "sha": "1d63d767fe53c47cab317d0ad7ad5355a8aac48273efe770ee2ac13d5add8714"
    },
    {
      "id": "kanton/BS/590.110/art_14",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Feuerwehrverordnung, FWV (590.110)",
      "artikel": "14",
      "artikelLabel": "§ 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Justiz- und Sicherheitsdepartement ist das zuständige Departement gemäss § 9 des Gesetzes."
        },
        {
          "absatz": "2",
          "text": "Die Rekrutierung, die Besoldung, die Versicherung der Angehörigen der Betriebsfeuerwehren sowie das Disziplinarwesen ist Sache der Betriebe."
        }
      ],
      "stand": "2017-12-21",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "74da4154daac28af3859d661c6757ed0",
      "sha": "4061d7922ccdbd5d53bc48fde38da0b1a908cfe5ddd946a0f2e87e9476bb96c0"
    },
    {
      "id": "kanton/BS/590.110/art_15",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Feuerwehrverordnung, FWV (590.110)",
      "artikel": "15",
      "artikelLabel": "§ 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Organisation und die Einsatzstruktur der Betriebsfeuerwehren haben den Vorgaben des Feuerwehr-Inspektorats zu entsprechen und sind in einem von den Betrieben zu erstellenden Reglement festzuhalten, das durch das Feuerwehr-Inspektorat zu genehmigen ist."
        }
      ],
      "stand": "2017-12-21",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "74da4154daac28af3859d661c6757ed0",
      "sha": "bab294795706a672a0d995b1a5bd6aa07fadae8dc58e00c56b14c65d8503bfaf"
    },
    {
      "id": "kanton/BS/590.110/art_16",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Feuerwehrverordnung, FWV (590.110)",
      "artikel": "16",
      "artikelLabel": "§ 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Beförderungen ist auf die Eignung der oder des Angehörigen der Betriebsfeuerwehr zu achten. Für die Beförderung wird die erfolgreiche Absolvierung der durch das Feuerwehr-Inspektorat vorgeschriebenen Ausbildungskurse vorausgesetzt."
        },
        {
          "absatz": "2",
          "text": "Beförderungen bis zum Grade einer höheren Unteroffizierin oder eines höheren Unteroffiziers werden durch die Bereichsleiterin oder den Bereichsleiter Rettung bestätigt."
        },
        {
          "absatz": "3",
          "text": "Die Offizierinnen oder die Offiziere werden durch die Departementsvorsteherin oder den Departementsvorsteher bestätigt."
        }
      ],
      "stand": "2017-12-21",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "74da4154daac28af3859d661c6757ed0",
      "sha": "4c34160e9a79a5a8707ec58247ee191203c133b720189d6d35cdb1f8dca9f10d"
    },
    {
      "id": "kanton/BS/590.110/art_17",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Feuerwehrverordnung, FWV (590.110)",
      "artikel": "17",
      "artikelLabel": "§ 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Unterstützende sowie selbständige Einsätze der Betriebsfeuerwehren ausserhalb des eigenen Betriebsareals können gemäss der kantonalen Verordnung über die von der Feuerwehr zu erhebenden Gebühren in Rechnung gestellt werden."
        },
        {
          "absatz": "2",
          "text": "Die Rechnung ist dem Feuerwehr-Inspektorat innerhalb von 30 Tagen nach dem Einsatz zuzustellen."
        }
      ],
      "stand": "2017-12-21",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/590.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "74da4154daac28af3859d661c6757ed0",
      "sha": "7f192de5f2c84f67b96d64a1ff77fb073a8d3b2171ce884ce5b8893db3681e63"
    }
  ]
}