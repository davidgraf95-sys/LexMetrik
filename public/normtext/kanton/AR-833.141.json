{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/833.141/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum KVG (833.141)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die externe Revisionsstelle des Krankenversicherers ist Revisionsstelle nach Art. 64a Abs. 3 des Bundesgesetzes über die Krankenversicherung."
        }
      ],
      "stand": "2017-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.141",
      "abgerufen": "2026-06-23",
      "fassungsToken": "637a22881be23ddd05a466437345fb9e",
      "sha": "0b8ee843e28ae3d80d4536fbb8fa4e2d63633682ee44180bae1507598b288ad1"
    },
    {
      "id": "kanton/AR/833.141/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum KVG (833.141)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "…"
        },
        {
          "absatz": "2",
          "text": "Die Ausgleichskasse Appenzell Ausserrhoden entrichtet zulasten des Kantons die Vergütung für die nach der Bundesgesetzgebung über die Krankenversicherung ausstehenden Forderungen aus der obligatorischen Krankenversicherung aus den Mitteln der Prämienverbilligung."
        },
        {
          "absatz": "3",
          "text": "Sie erhält vom Versicherer die Rückzahlungen aus der Bewirtschaftung der Verlustscheine zugunsten der Mittel der Prämienverbilligung."
        },
        {
          "absatz": "4",
          "text": "Verfügungen über die Ausrichtung von wirtschaftlicher Sozialhilfe sind einem Verlustschein gleichzusetzende Rechtstitel."
        }
      ],
      "stand": "2017-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.141",
      "abgerufen": "2026-06-23",
      "fassungsToken": "637a22881be23ddd05a466437345fb9e",
      "sha": "7677ed846afbdfa2f2325b117830652cc8c6788abc29a369dbaf9ec4863943b9"
    },
    {
      "id": "kanton/AR/833.141/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum KVG (833.141)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Versicherer meldet der Ausgleichskasse Appenzell Ausserrhoden die Schuldnerinnen und Schuldner, die betrieben werden, sobald die Voraussetzungen für das Fortsetzungsbegehren erfüllt sind und bevor der Versicherer das Fortsetzungsbegehren stellt."
        },
        {
          "absatz": "2",
          "text": "…"
        }
      ],
      "stand": "2017-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.141",
      "abgerufen": "2026-06-23",
      "fassungsToken": "637a22881be23ddd05a466437345fb9e",
      "sha": "ed3e58e040d28bf317b6f738f8fedefe862b3873ab316c9fe5696e9ab2d9228c"
    },
    {
      "id": "kanton/AR/833.141/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum KVG (833.141)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Leistungserbringer meldet seinen Ausstand nach Art. 44 Abs. 2 des Bundesgesetzes über die Krankenversicherung dem Departement Gesundheit und Soziales."
        }
      ],
      "stand": "2017-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.141",
      "abgerufen": "2026-06-23",
      "fassungsToken": "637a22881be23ddd05a466437345fb9e",
      "sha": "3b3f47290d51e4c1c3301995c0c1fbfb1f375fb638d33903032f6ddd6d741b24"
    },
    {
      "id": "kanton/AR/833.141/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum KVG (833.141)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zum steuerbaren Einkommen werden hinzugezählt:",
          "items": [
            {
              "marke": "a",
              "text": "der Betrag an die Säule 3a von Personen, die keiner Vorsorgeeinrichtung nach Art. 80 des Bundesgesetzes über die berufliche Alters-, Hinterlassenen- und Invalidenvorsorge angehören, der 10 000 Franken übersteigt;"
            },
            {
              "marke": "b",
              "text": "…"
            },
            {
              "marke": "d",
              "text": "15 Prozent des steuerbaren Vermögens."
            }
          ]
        }
      ],
      "stand": "2017-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.141",
      "abgerufen": "2026-06-23",
      "fassungsToken": "637a22881be23ddd05a466437345fb9e",
      "sha": "66bc08e627c5082e4dca5f00bf2abf7a3861bcdd4e675762df4ead140008e3f2"
    },
    {
      "id": "kanton/AR/833.141/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum KVG (833.141)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Anspruch auf Prämienverbilligung beginnt:",
          "items": [
            {
              "marke": "a",
              "text": "mit dem der Geburt folgenden Monat;"
            },
            {
              "marke": "b",
              "text": "bei Zuzug aus dem Ausland mit dem Monat der Antragstellung."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Er endet bei Wegzug ins Ausland und bei Tod ab dem darauffolgenden Monat."
        }
      ],
      "stand": "2017-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.141",
      "abgerufen": "2026-06-23",
      "fassungsToken": "637a22881be23ddd05a466437345fb9e",
      "sha": "e21ee38681628aa63d0d80ccb7ffeca559eceef58a2defa3b91d1f532c553700"
    },
    {
      "id": "kanton/AR/833.141/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum KVG (833.141)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Prämienverbilligung übersteigt die Höhe der Prämie für die obligatorische Krankenversicherung mit der ordentlichen Franchise und mit Unfalldeckung nicht."
        }
      ],
      "stand": "2017-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.141",
      "abgerufen": "2026-06-23",
      "fassungsToken": "637a22881be23ddd05a466437345fb9e",
      "sha": "8c72fef0be84d65ad88c70afe38bbe4b56a146a2308ce6b52c1d4d769d24e753"
    },
    {
      "id": "kanton/AR/833.141/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum KVG (833.141)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Ausgleichskasse Appenzell Ausserrhoden informiert die Bevölkerung regelmässig über die Möglichkeit der Prämienverbilligung und das Antragsverfahren."
        }
      ],
      "stand": "2017-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.141",
      "abgerufen": "2026-06-23",
      "fassungsToken": "637a22881be23ddd05a466437345fb9e",
      "sha": "05eca49f70f6427083d3a75c6006d1233f51ab8159a7f15b883fd91a7ada85bf"
    },
    {
      "id": "kanton/AR/833.141/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum KVG (833.141)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Personen, die Anspruch auf Prämienverbilligung erheben, sowie die Versicherer erteilen den zuständigen Organen die nötigen Auskünfte wahrheitsgetreu."
        }
      ],
      "stand": "2017-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.141",
      "abgerufen": "2026-06-23",
      "fassungsToken": "637a22881be23ddd05a466437345fb9e",
      "sha": "2f2399cf42090d1ef3d83408da412369a63d50df1eaa7cd0e6ffa573177b11cb"
    },
    {
      "id": "kanton/AR/833.141/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum KVG (833.141)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Personen, die Anspruch auf Prämienverbilligung erheben, reichen ihren Antrag bis spätestens 31. März bei der AHV-Gemeindezweigstelle der Gemeinde ein, in welcher sie am 1. Januar des Jahres Wohnsitz hatten."
        },
        {
          "absatz": "2",
          "text": "Die Ausgleichskasse Appenzell Ausserrhoden kann in Härtefällen die Frist für die Einreichung des Antrags bis spätestens 30. April verlängern."
        }
      ],
      "stand": "2017-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.141",
      "abgerufen": "2026-06-23",
      "fassungsToken": "637a22881be23ddd05a466437345fb9e",
      "sha": "0c355dd6b34c8b46a4eae915d89f814f3d73dbc03bc689dd78eed380c1ba54cb"
    },
    {
      "id": "kanton/AR/833.141/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum KVG (833.141)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die zuständige AHV-Gemeindezweigstelle:",
          "items": [
            {
              "marke": "a",
              "text": "prüft den eingereichten Antrag auf Vollständigkeit;"
            },
            {
              "marke": "b",
              "text": "kontrolliert die Richtigkeit der Personalien;"
            },
            {
              "marke": "c",
              "text": "veranlasst die notwendigen Ergänzungen und Abklärungen."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Sie leitet die Anträge mit den nötigen Hinweisen an die Ausgleichskasse Appenzell Ausserrhoden weiter."
        }
      ],
      "stand": "2017-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.141",
      "abgerufen": "2026-06-23",
      "fassungsToken": "637a22881be23ddd05a466437345fb9e",
      "sha": "cdfac6a2e0546a14b1671fd0e4e968a0c4fe24a10fdec60c19ac424edb2930df"
    },
    {
      "id": "kanton/AR/833.141/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum KVG (833.141)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Ausgleichskasse Appenzell Ausserrhoden trifft die erforderlichen zusätzlichen Abklärungen."
        },
        {
          "absatz": "2",
          "text": "Personen, die einen Antrag auf Prämienverbilligung stellen, übermitteln der Ausgleichskasse Appenzell Ausserrhoden innert der von ihr gesetzten Frist die erforderlichen Angaben."
        },
        {
          "absatz": "3",
          "text": "Die Ausgleichskasse Appenzell Ausserrhoden kann eine Nachfrist ansetzen."
        }
      ],
      "stand": "2017-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.141",
      "abgerufen": "2026-06-23",
      "fassungsToken": "637a22881be23ddd05a466437345fb9e",
      "sha": "3e30ea9566db9efbca4a06f48a27131f83973692b1610261df10d5d00fbd72b8"
    },
    {
      "id": "kanton/AR/833.141/art_12_a",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum KVG (833.141)",
      "artikel": "12_a",
      "artikelLabel": "Art. 12a",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Ausgleichskasse Appenzell Ausserrhoden gibt den Versicherern die nach der Bundesgesetzgebung über die Krankenversicherung erforderlichen Daten für die Durchführung der Prämienverbilligung bekannt."
        }
      ],
      "stand": "2017-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.141",
      "abgerufen": "2026-06-23",
      "fassungsToken": "637a22881be23ddd05a466437345fb9e",
      "sha": "36e4a9b9ebd8c2135acd76ee53e13f8c01d921f2bcac24c55ebbe02b822e9090"
    },
    {
      "id": "kanton/AR/833.141/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum KVG (833.141)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Beträge unter 20 Franken werden nicht ausbezahlt."
        },
        {
          "absatz": "2",
          "text": "Die Ausgleichskasse Appenzell Ausserrhoden richtet weder Vergütungs- noch Verzugszinsen aus."
        }
      ],
      "stand": "2017-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.141",
      "abgerufen": "2026-06-23",
      "fassungsToken": "637a22881be23ddd05a466437345fb9e",
      "sha": "642b27d9d0e9b53072b60ba11d37062919586e8922f4bb427ddba308e4aad892"
    },
    {
      "id": "kanton/AR/833.141/art_14",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum KVG (833.141)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton vergütet der Ausgleichskasse Appenzell Ausserrhoden auf der Basis einer Leistungsvereinbarung die Verwaltungskosten für den Vollzug der Prämienverbilligung."
        }
      ],
      "stand": "2017-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.141",
      "abgerufen": "2026-06-23",
      "fassungsToken": "637a22881be23ddd05a466437345fb9e",
      "sha": "2e84d5f58f527e02c8404c2d55ece7534385ac4a087085e7a4aac23dd3f55349"
    },
    {
      "id": "kanton/AR/833.141/art_15",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "V zum KVG (833.141)",
      "artikel": "15",
      "artikelLabel": "Art. 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung tritt am 1. Januar 2010 in Kraft."
        }
      ],
      "stand": "2017-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.141",
      "abgerufen": "2026-06-23",
      "fassungsToken": "637a22881be23ddd05a466437345fb9e",
      "sha": "d8e20f3b1a4a4da08d426e0735dd86ac46a990106cd0df2448220d5ffc35c75b"
    }
  ]
}