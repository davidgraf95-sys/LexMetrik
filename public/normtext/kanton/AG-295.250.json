{
  "erzeugt": "2026-06-19",
  "eintraege": [
    {
      "id": "kanton/AG/295.250/art_1",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Dekret über den Notariatstarif (SAR 295.250)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Stundenansatz der Urkundsperson beträgt höchstens Fr. 300.–."
        },
        {
          "absatz": "2",
          "text": "Liegt keine Vereinbarung über die Höhe des Stundenansatzes vor und können sich die Parteien nicht auf die Höhe der Gebühr einigen, wird diese gestützt auf den Antrag der Urkundsperson oder der Partei gemäss den §§ 73 und 74 des BeurG nach der Bedeutung und Schwierigkeit des betroffenen Geschäfts festgesetzt."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/295.250",
      "abgerufen": "2026-06-19",
      "fassungsToken": "e9af969caffc225cb771fae37617c1a2",
      "sha": "e991a4f6cc3c7be4dabbc164bc478e2586894df8dbb844900bc56b28bf34c277"
    },
    {
      "id": "kanton/AG/295.250/art_2",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Dekret über den Notariatstarif (SAR 295.250)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühr für die Beurkundung von Verträgen zur Eigentumsübertragung von Grundstücken sowie zur Begründung von selbstständigen und dauernden Baurechten richtet sich nach dem Vertragswert und beträgt:",
          "items": [
            {
              "marke": "1",
              "text": "4 ‰ bis Fr. 600'000.–, mindestens Fr. 300.–,"
            },
            {
              "marke": "2",
              "text": "plus 2 ‰ von Fr. 600'001.– bis Fr. 3'000'000.–,"
            },
            {
              "marke": "3",
              "text": "plus 1‰ ab Fr. 3'000'001.–, höchstens Fr. 20'000.–."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Wird kein Vertragswert genannt oder liegt dieser wesentlich unter dem Wert der Sache, ist der massgebliche Wert gemäss § 8 Abs. 2 des Gesetzes über die Grundbuchabgaben vom 7. Mai 1980 zu berechnen."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/295.250",
      "abgerufen": "2026-06-19",
      "fassungsToken": "e9af969caffc225cb771fae37617c1a2",
      "sha": "3eb12ac1961e9596824aef380042b3552aa21432391c6ebba2ab9e1ac8036e39"
    },
    {
      "id": "kanton/AG/295.250/art_3",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Dekret über den Notariatstarif (SAR 295.250)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühr für die Errichtung und Erhöhung von Grundpfandrechten richtet sich nach der Pfandsumme und beträgt zwei Drittel der Ansätze von § 2, aber höchstens Fr. 7'500.–."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/295.250",
      "abgerufen": "2026-06-19",
      "fassungsToken": "e9af969caffc225cb771fae37617c1a2",
      "sha": "84994c53ac743dfe557e9e5477fa215998c57596232c14e0684bf6859d837e25"
    },
    {
      "id": "kanton/AG/295.250/art_4",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Dekret über den Notariatstarif (SAR 295.250)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Mit dem Promilletarif sind der eigentliche Beurkundungsakt sowie die üblicherweise mit dem betroffenen Geschäft verbundenen Vor- und Nachbereitungen abgegolten."
        },
        {
          "absatz": "2",
          "text": "Zusätzliche Vor- und Nachbereitungen werden nach Aufwandtarif abgerechnet."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/295.250",
      "abgerufen": "2026-06-19",
      "fassungsToken": "e9af969caffc225cb771fae37617c1a2",
      "sha": "1a374438c0cb14dc4a7bc55832b9e70267b156c2ae4a6dcd4207567e12f7b685"
    },
    {
      "id": "kanton/AG/295.250/art_5",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Dekret über den Notariatstarif (SAR 295.250)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Kommt ein Geschäft nicht zum Abschluss, wird es nach Aufwand abgerechnet. Die Gebühr darf die Vergütung gemäss Promilletarif für ein zum Abschluss gebrachtes Geschäft nicht überschreiten."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/295.250",
      "abgerufen": "2026-06-19",
      "fassungsToken": "e9af969caffc225cb771fae37617c1a2",
      "sha": "4434a5e9bf8aa56d1663229311ddfa59a6c2fff6ee7ad9497b06d56ecb690d64"
    },
    {
      "id": "kanton/AG/295.250/art_6",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Dekret über den Notariatstarif (SAR 295.250)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühr für Beglaubigungen beträgt:",
          "items": [
            {
              "marke": "a",
              "text": "Beglaubigung einer Unterschrift oder einer Übersetzung: Fr. 20.–,"
            },
            {
              "marke": "b",
              "text": "Beglaubigung von Kopien, welche der Urkundsperson vorgelegt werden: Fr. 10.– für die erste und Fr. 5.– für jede weitere Seite,"
            },
            {
              "marke": "c",
              "text": "Beglaubigungen von Kopien, welche die Urkundsperson selbst hergestellt hat: Fr. 10.– für die erste und Fr. 1.– für jede weitere Seite."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die Urkundsperson darf beglaubigte Kopien von selbst hergestellten Urkunden, welche sie anlässlich einer Beurkundung für Parteien oder sich erstellt, nicht zusätzlich in Rechnung stellen."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/295.250",
      "abgerufen": "2026-06-19",
      "fassungsToken": "e9af969caffc225cb771fae37617c1a2",
      "sha": "67f224fea4c9f9fc986a1de7c3bf6f7ab1211951a18c923adcaf2d7a0234455d"
    },
    {
      "id": "kanton/AG/295.250/art_7",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Dekret über den Notariatstarif (SAR 295.250)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Beteiligung mehrerer Parteien an demselben Beurkundungsgegenstand darf der Tarif auf diese nicht unterschiedlich angewendet werden."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/295.250",
      "abgerufen": "2026-06-19",
      "fassungsToken": "e9af969caffc225cb771fae37617c1a2",
      "sha": "e5c043452a721bc34a525a8757fbdfa84e99a78c7f0e197031e3e06d52924c52"
    },
    {
      "id": "kanton/AG/295.250/art_8",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Dekret über den Notariatstarif (SAR 295.250)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Mit der Gebühr ist sämtlicher Aufwand für Personal (Kanzleiangestellte, Lernende usw.) und Infrastruktur (Miete Räumlichkeiten, Büromaterial usw.) abgegolten."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/295.250",
      "abgerufen": "2026-06-19",
      "fassungsToken": "e9af969caffc225cb771fae37617c1a2",
      "sha": "407202744d3b63c36b5d14cc64db5a62afd7ce2ae9fee26fb2a93f0896e3925b"
    },
    {
      "id": "kanton/AG/295.250/art_9",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Dekret über den Notariatstarif (SAR 295.250)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Urkundsperson hat Anspruch auf Ersatz der notwendigen Auslagen (Porti, Kommunikationsspesen, Kopien, Reisespesen und dergleichen) sowie auf die von ihr zu entrichtende Mehrwertsteuer."
        },
        {
          "absatz": "2",
          "text": "Die Entschädigung für eine kopierte Seite beträgt Fr. –.50."
        },
        {
          "absatz": "3",
          "text": "Die Entschädigung für jeden gefahrenen Kilometer wird gemäss Verordnung über Spesen, Sitzungsgelder und übrige Entschädigungen vom 31. Januar 2001 verrechnet."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/295.250",
      "abgerufen": "2026-06-19",
      "fassungsToken": "e9af969caffc225cb771fae37617c1a2",
      "sha": "b3271272ecac509edcc740853edaba668222383136af379ee0551c8fe1365232"
    },
    {
      "id": "kanton/AG/295.250/art_10",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Dekret über den Notariatstarif (SAR 295.250)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Urkundsperson erstellt eine detaillierte Abrechnung."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/295.250",
      "abgerufen": "2026-06-19",
      "fassungsToken": "e9af969caffc225cb771fae37617c1a2",
      "sha": "f6329ab8b0e961bb8f1b9573e05b18fd68255fc0ce4a9377349874d6a01202f4"
    },
    {
      "id": "kanton/AG/295.250/art_11",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Dekret über den Notariatstarif (SAR 295.250)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat kann alle frankenmässig festgesetzten Beträge einschliesslich der Promillesätze durch Verordnung um rund 10 % anpassen, sobald die Teuerung gegenüber der letzten Anpassung 10 % ausmacht. Massgebend ist der Landesindex der Konsumentenpreise gemäss Bundesamt für Statistik. Ausgangspunkt ist der Indexstand bei Inkrafttreten der letzten Änderung."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/295.250",
      "abgerufen": "2026-06-19",
      "fassungsToken": "e9af969caffc225cb771fae37617c1a2",
      "sha": "e1ea71cbda78f5766e33f8057ba6091b11697c37589ae47e725420e1f5302198"
    },
    {
      "id": "kanton/AG/295.250/art_12",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Dekret über den Notariatstarif (SAR 295.250)",
      "artikel": "12",
      "artikelLabel": "§ 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Es ist dasjenige Recht anwendbar, welches im Zeitpunkt des Beurkundungs- und Beglaubigungsakts in Kraft ist."
        },
        {
          "absatz": "2",
          "text": "Kommt der Aufwandtarif gemäss diesem Dekret zur Anwendung, werden die einzelnen notariellen Tätigkeiten, welche vor Inkrafttreten dieses Dekrets erbracht wurden, gemäss bisherigem Aufwandtarif abgerechnet."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/295.250",
      "abgerufen": "2026-06-19",
      "fassungsToken": "e9af969caffc225cb771fae37617c1a2",
      "sha": "f031f483ac39f7288ca6ba292a6c3ec066d0ee98b7486c783e8ac1500917415c"
    },
    {
      "id": "kanton/AG/295.250/art_13",
      "ebene": "kanton",
      "quelle": "AG",
      "erlass": "Dekret über den Notariatstarif (SAR 295.250)",
      "artikel": "13",
      "artikelLabel": "§ 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieses Dekret ist in der Gesetzessammlung zu publizieren. Es tritt zusammen mit dem Beurkundungs- und Beglaubigungsgesetz (BeurG) in Kraft."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://gesetzessammlungen.ag.ch/app/de/texts_of_law/295.250",
      "abgerufen": "2026-06-19",
      "fassungsToken": "e9af969caffc225cb771fae37617c1a2",
      "sha": "d3b785904fdadb19f2adcb8b3c89646dc04fb99ad89da788a73ff7698defa008"
    }
  ]
}