{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/BaB 153.840/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenreglement der Zentralen Dienste (BaB 153.840)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "titel": "Ordentliche Einbürgerung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im Verfahren der ordentlichen Einbürgerung erheben die Zentralen Dienste folgende Gebühren:",
          "items": [
            {
              "marke": "a",
              "text": "von ausländischen Bürgerrechtsbewerbenden ab 25 Jahren"
            },
            {
              "marke": "a",
              "text": "Einzelpersonen CHF 800"
            },
            {
              "marke": "a",
              "text": "Ehepaare, eingetragene Paare, Familien, Einzelperson mit Kind oder Kindern CHF 950"
            },
            {
              "marke": "b",
              "text": "von ausländischen Bürgerrechtsbewerbenden unter 25 Jahren CHF 700"
            },
            {
              "marke": "c",
              "text": "von Schweizer Bürgerrechtsbewerbenden CHF 150"
            },
            {
              "marke": "d",
              "text": "…"
            }
          ]
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4c6df624755c26b748f580646b1ab62e",
      "sha": "1ebc3b615ded2f36e26b6c979202239cff1dcd0a02efee8e5e04fe9963a4c924"
    },
    {
      "id": "kanton/BS/BaB 153.840/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenreglement der Zentralen Dienste (BaB 153.840)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Entlassung aus dem Bürgerrecht",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Zentralen Dienste erheben folgende Gebühren:",
          "items": [
            {
              "marke": "a",
              "text": "für die Entlassung aus dem Gemeindebürgerrecht CHF 50"
            },
            {
              "marke": "b",
              "text": "bei gleichzeitiger Entlassung aus dem Schweizer Bürgerrecht CHF 100"
            }
          ]
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4c6df624755c26b748f580646b1ab62e",
      "sha": "c6746e11b3bbe6c3d88ccca209b2f6bd35f0cdbc1bc40160650183d28520dd12"
    },
    {
      "id": "kanton/BS/BaB 153.840/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenreglement der Zentralen Dienste (BaB 153.840)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "fide-Test",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Zentralen Dienste führen den fide-Test durch. Für diesen Sprachnachweis werden folgende Teilnahmegebühren erhoben:",
          "items": [
            {
              "marke": "a",
              "text": "Teilnahmegebühr beide Teile CHF 250"
            },
            {
              "marke": "b",
              "text": "Teilnahmegebühr Sprechen und Verstehen CHF 170"
            },
            {
              "marke": "c",
              "text": "Teilnahmegebühr Lesen und Schreiben CHF 120"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Bei Rückzug der Anmeldung bis 20 Tage vor dem Durchführungstermin wird eine Bearbeitungsgebühr von CHF 100 erhoben. Bei späterem Rückzug der Anmeldung oder bei Nichterscheinen zum Durchführungstermin erfolgt keine Rückerstattung der Teilnahmegebühren. Die Anmeldung ist verbindlich und muss sofort bei Erhalt der Rechnung bezahlt werden."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4c6df624755c26b748f580646b1ab62e",
      "sha": "cbe522b1326dc60e7ef48850b412a971c42c0d9f98b657622a57d39e13a54f3b"
    },
    {
      "id": "kanton/BS/BaB 153.840/art_3_a",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenreglement der Zentralen Dienste (BaB 153.840)",
      "artikel": "3_a",
      "artikelLabel": "§ 3a",
      "titel": "Kurse",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Zentralen Dienste erheben folgende Gebühren:",
          "items": [
            {
              "marke": "a",
              "text": "Kompaktkurs"
            },
            {
              "marke": "1",
              "text": "Einzelperson CHF 120"
            },
            {
              "marke": "2",
              "text": "Ehepaar/Familie CHF 180"
            },
            {
              "marke": "b",
              "text": "Fit für Basel"
            },
            {
              "marke": "1",
              "text": "Einzelperson CHF 200"
            },
            {
              "marke": "2",
              "text": "Ehepaar/Familie CHF 300"
            },
            {
              "marke": "c",
              "text": "Politische Rechte"
            },
            {
              "marke": "1",
              "text": "Einzelperson CHF 80"
            },
            {
              "marke": "2",
              "text": "Ehepaar/Familie CHF 120"
            }
          ]
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4c6df624755c26b748f580646b1ab62e",
      "sha": "6fd49ba5040854728952f76c49033a602dcd61307f1ddfc25042ebbcca7191a8"
    },
    {
      "id": "kanton/BS/BaB 153.840/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenreglement der Zentralen Dienste (BaB 153.840)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Vorauszahlungspflicht",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die in diesem Reglement genannten Gebühren für die ordentliche Einbürgerung und den fide-Test sind im Voraus zu bezahlen."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4c6df624755c26b748f580646b1ab62e",
      "sha": "77a4a2f36bfcc1f1c3cab8a6e4e9259352c58a441f986e4dc8953e043b78e724"
    },
    {
      "id": "kanton/BS/BaB 153.840/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenreglement der Zentralen Dienste (BaB 153.840)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "titel": "Weitere Gebühren",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Es werden folgende weitere Gebühren erhoben für:",
          "items": [
            {
              "marke": "a",
              "text": "jede zusätzliche Vorladung vor die Einbürgerungskommission"
            },
            {
              "marke": "1",
              "text": "infolge Rückstellung von Gesuchen ausländischer Bürgerrechtsbewerbenden ab 25 Jahren CHF 300"
            },
            {
              "marke": "2",
              "text": "infolge Rückstellung von Gesuchen ausländischer Bürgerrechtsbewerbenden unter 25 Jahren CHF 300"
            },
            {
              "marke": "3",
              "text": "infolge Fernbleiben ohne triftigen Grund oder ohne vorherige Abmeldung CHF 300"
            },
            {
              "marke": "b",
              "text": "die zusätzliche Schulung durch Organe der Bürgergemeinde CHF 100"
            },
            {
              "marke": "c",
              "text": "die Beschaffung der von Bewerbenden mit Schweizer Bürgerrecht im Hinblick auf das Einbürgerungsverfahren neu beizubringender Dokumente in deren Auftrag (und auf deren Kosten) durch die Bürgergemeinde (fakultativ) CHF 100"
            },
            {
              "marke": "d",
              "text": "weiteren, über das ordentliche Verfahren hinausgehenden Aufwand CHF 100"
            },
            {
              "marke": "e",
              "text": "die Ausfertigung einer Bürgerrechtsbescheinigung CHF 30"
            }
          ]
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4c6df624755c26b748f580646b1ab62e",
      "sha": "fe54e7190709efbd5756c802498205fd6df8b3488de9e25644e54951fce3ab84"
    },
    {
      "id": "kanton/BS/BaB 153.840/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenreglement der Zentralen Dienste (BaB 153.840)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "titel": "Gebühren für Ehepaare und Elternteile mit/ohne Kinder",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühren werden bei Gesuchen um gemeinsame Einbürgerung oder Entlassung für Ehepaare bzw. für Eltern(-teile) mit ihren einbezogenen Kindern einmal pro Gesuch erhoben."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4c6df624755c26b748f580646b1ab62e",
      "sha": "ac3ac0697afd25066bb6653532102815670349a9a8b03aa523c3a444172578b2"
    },
    {
      "id": "kanton/BS/BaB 153.840/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenreglement der Zentralen Dienste (BaB 153.840)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "titel": "Gebührenrückerstattung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wird das Einbürgerungsgesuch von der oder dem Gesuchstellenden zurückgezogen, wird folgender Betrag zurückerstattet:",
          "items": [
            {
              "marke": "a",
              "text": "bei ausländischen Bürgerrechtsbewerbenden ab 25 Jahren"
            },
            {
              "marke": "1",
              "text": "Einzelperson CHF 300"
            },
            {
              "marke": "2",
              "text": "Ehepaare, eingetragene Paare, Familien, Einzelperson mit Kind/ern CHF 350"
            },
            {
              "marke": "b",
              "text": "bei ausländischen Bürgerrechtsbewerbenden unter 25 Jahren CHF 250"
            },
            {
              "marke": "c",
              "text": "bei Schweizer Bürgerrechtsbewerbenden CHF 100"
            }
          ]
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4c6df624755c26b748f580646b1ab62e",
      "sha": "3644e38986c4bb80d1331f41223365d18d1e90f1f600e52cf5cd34ddff146876"
    },
    {
      "id": "kanton/BS/BaB 153.840/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenreglement der Zentralen Dienste (BaB 153.840)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "titel": "Übergangsbestimmung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Bearbeitung von Gesuchen für die vollständige/teilweise Befreiung vom Sprachtest, die vor der Wirksamkeit dieses Reglements eingereicht worden sind, gilt noch das Gebührenreglement der Zentralen Dienste vom 26. Juni 2012."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4c6df624755c26b748f580646b1ab62e",
      "sha": "50bf67dafa50f5d73681d11848e3cd8e8408b1ad47b37c94eddb177ea8e0f884"
    },
    {
      "id": "kanton/BS/BaB 153.840/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenreglement der Zentralen Dienste (BaB 153.840)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "titel": "Übergangsbestimmung zur Änderung vom 12. November 2019",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühren für die ordentliche Einbürgerung gemäss § 1 gelten für alle Gesuche, die ab dem 1. Januar 2020 bei der Bürgergemeinde eingehen."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4c6df624755c26b748f580646b1ab62e",
      "sha": "b9101e5119ba650b6343d661a8742d365fe3854e80bd1ade1cf3d1781883ee7d"
    },
    {
      "id": "kanton/BS/BaB 153.840/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenreglement der Zentralen Dienste (BaB 153.840)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "titel": "Übergangsbestimmung zur Änderung vom 31. Oktober 2023",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühren gelten für alle Gesuche und Anmeldungen zum fide-Test, die ab dem 1. Januar 2024 bei der Bürgergemeinde eingehen."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.840",
      "abgerufen": "2026-06-23",
