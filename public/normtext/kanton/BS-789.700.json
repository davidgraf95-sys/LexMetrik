    },
    {
      "id": "kanton/BS/789.700/art_23",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "23",
      "artikelLabel": "§ 23",
      "titel": "Strafbestimmung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer den Vorschriften dieses Gesetzes und seiner Ausführungsbestimmungen zuwiderhandelt, namentlich wer einen geschützten Baum ohne Bewilligung beseitigt oder beschädigt, wird mit Busse bestraft."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "8b64aa0d6c33f12c84e4528464577538acf3b0425c4a92857157a635a3b88d10"
    },
    {
      "id": "kanton/BS/789.700/art_24",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "24",
      "artikelLabel": "§ 24",
      "titel": "Ausführungsbestimmungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungrat erlässt alle zur Durchführung dieses Gesetzes erforderlichen Ausführungsbestimmungen."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "6ea8447c1a3d8212cae48daddad2a2b1a5499ca04f66304ea349a36b5e87d6e2"
    },
    {
      "id": "kanton/BS/789.700/art_25",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "25",
      "artikelLabel": "§ 25",
      "titel": "Rekursrecht",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gegen Verfügungen, die aufgrund diese Gesetzes ergehen, kann grundsätzlich nach den allgemeinen Bestimmungen an den zuständigen Departementsvorsteher, den Regierungsrat und an das Verwaltungsgericht rekurriert werden."
        },
        {
          "absatz": "2",
          "text": "Stehen Verfügungen, die aufgrund dieses Gesetzes ergehen, mit Bauvorhaben im Zusammenhang, so kann nach den für das Baurekursverfahren geltenden Bestimmungen an die Baurekurskommission rekurriert werden."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "a7874fb25771c521bc19a565f7bb3ed6e222296166cd6ff9ed00bb53d8c7ae2a"
    },
