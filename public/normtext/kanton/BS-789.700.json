      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "22",
      "artikelLabel": "§ 22",
      "titel": "Öffentlich-rechtliche Grundlast",
      "bloecke": [
        {
          "absatz": null,
          "text": ""
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
