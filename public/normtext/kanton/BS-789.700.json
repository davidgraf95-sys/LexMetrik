{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/789.700/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "titel": "Grundsatz",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Baumbestand im Kanton Basel-Stadt ist im Interesse der Qualität des Lebensraumes, insbesondere der Wohnlichkeit, zu erhalten und möglichst zu vermehren."
        },
        {
          "absatz": "2",
          "text": "Für den Wald gelten die Bestimmungen der Waldgesetzgebung."
        },
        {
          "absatz": "3",
          "text": "Obstbäume im Landwirtschaftsgebiet und in Familiengartenarealen sowie Spalier- und Niederstammobstbäume fallen nicht unter dieses Gesetz."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "d2e1e8c2ecd33adaaf4b4f90255ab90e31c06e93b22e66ce4e1f52e01831bc46"
    },
    {
      "id": "kanton/BS/789.700/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Landgemeinden",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Landgemeinden sind nur diejenigen Bestimmungen dieses Gesetzes anwendbar, die sich auf Baumschutzgebiete beziehen."
        },
        {
          "absatz": "2",
          "text": "Die zuständigen Behörden der Landgemeinden können weitere Bestimmungen zum Schutze des Baumbestandes erlassen."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "5e37ec9622b1eb727a8a7f185f21d94ac9d5b8477e2854b3c135cc3442d47b39"
    },
    {
      "id": "kanton/BS/789.700/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Baumschutzgebiete",
      "bloecke": [
        {
          "absatz": "1",
          "text": "In den im Zonenplan mit grüner Schraffur gekennzeichneten Gebieten sind Bäume geschützt, deren Stamm einen Meter über dem Boden einen Umfang von über 50 cm (rund 16 cm Durchmesser) aufweisen."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "09d51b05a8ccfb636e7c7653f09d9847a182341e057b1288fcbba7451e133b8b"
    },
    {
      "id": "kanton/BS/789.700/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Übrige Gebiete",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ausserhalb der im Zonenplan mit grüner Schraffur gekennzeichneten Gebiete sind Bäume geschützt, deren Stamm einen Meter über dem Boden einen Umfang von über 90 cm (rund 30 cm Durchmesser) aufweisen."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "4c87bd40102d47c92311265e151be9ff0678f4efd6c7a9f7df6543c022928b28"
    },
    {
      "id": "kanton/BS/789.700/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "titel": "Einzelschutz",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Durch besondere Verfügung, die im Grundbuch anzumerken ist, kann der zuständige Departementsvorsteher besonders wertvolle Bäume oder Baumgruppen, die nicht schon aufgrund ihrer Grösse geschützt sind, unter Schutz stellen."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "8242b8b7f9cfab329f37825ff7fc6703d65f73daeb0c85c04ddeb19e23100c37"
    },
    {
      "id": "kanton/BS/789.700/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "titel": "Fällbewilligung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ein geschützter Baum darf nur gefällt werden, wenn eine besondere Bewilligung hiezu vorliegt."
        },
        {
          "absatz": "2",
          "text": "Eine solche ist zu erteilen, wenn",
          "items": [
            {
              "marke": "a",
              "text": "mit dem Fortbestand eines Baumes eine Gefahr verbunden ist,"
            },
            {
              "marke": "b",
              "text": "eine Fällung als Pflegemassnahme für den übrigen Baumbestand oder"
            },
            {
              "marke": "c",
              "text": "aus Gründen der Wohnhygiene geboten erscheint,"
            },
            {
              "marke": "d",
              "text": "in Würdigung des Interesses des Gesuchstellers das Festhalten am öffentlichen Interesse der Erhaltung des Baumes unverhältnismässig erscheint."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Soll eine Fällbewilligung gemäss lit. c oder d des vorstehenden Absatzes erteilt werden, ist zuvor die Baumschutzkommission anzuhören."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "b95f9efa1e7e466061ec7e7720e46f96e6cce2dae816055bf949da9998ec6b1e"
    },
    {
      "id": "kanton/BS/789.700/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "titel": "Generelle Fällbewilligung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für Fällungen, die im Rahmen des ordentlichen Unterhalts eines grösseren Baumbestandes notwendig werden, ist eine generelle Bewilligung zu erteilen, sofern Gewähr für eine einwandfreie Ausübung dieser Befugnis besteht."
        },
        {
          "absatz": "2",
          "text": "Eine solche Bewilligung kann mit sichernden Auflagen versehen werden und ist jederzeit widerruflich."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "ef7050b4f96d98c289c26d7562e99c443c154b6aa81860b7b976698550ffad4e"
    },
    {
      "id": "kanton/BS/789.700/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "titel": "Bauvorhaben",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bauvorhaben, welche die Erhaltung geschützter Bäume in Frage stellen, dürfen erst bewilligt werden, wenn eine Fällbewilligung erteilt ist."
        },
        {
          "absatz": "2",
          "text": "Die Abstände zwischen Bauten und Bäumen sind in Berücksichtigung der Baumentwicklung, der Wohnhygiene und des Bauvorganges festzusetzen."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "dc0ee6b3a3cf8a94267ca6b55c70dc37de820cc9d9a3fb42a76f1ebf60a4739a"
    },
    {
      "id": "kanton/BS/789.700/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "titel": "Ersatz für erlaubterweise gefällte Bäume",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für geschützte Bäume, die gefällt werden, kann eine geeignete Ersatzpflanzung angeordnet werden."
        },
        {
          "absatz": "2",
          "text": "In Ausnahmefällen kann eine Ersatzabgabe eingefordert werden."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "187fcef76b62c096a2145780c020794eb66b10916a9ab4eb7bafdfa8819590c9"
    },
    {
      "id": "kanton/BS/789.700/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "titel": "Ersatz für unerlaubterweise gefällte Bäume",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Werden geschützte Bäume ohne Fällbewilligung beseitigt, so wird eine Ersatzpflanzung oder – falls dies unzweckmässig wäre – eine Abgabe verfügt, welche dem Aufwand für eine Ersatzpflanzung entspricht."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "d5b3e36bc88e272470b419dba41876f4eebef4f166f9e584ae16dffb86cf8e95"
    },
    {
      "id": "kanton/BS/789.700/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "titel": "Förderung von Neupflanzungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "In einem Gebiet mit geringem Baumbestand soll eine unbebaute Fläche, die sich für eine Neupflanzung eignet, im Einvernehmen mit dem Landeigentümer nach Möglichkeit mit Bäumen bepflanzt werden."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "addce5032fb03ae1ea54cb3fe432bec6a7e71d6cacaa0e4758604b8ee3e114ae"
    },
    {
      "id": "kanton/BS/789.700/art_12",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "12",
      "artikelLabel": "§ 12",
      "titel": "Schutz von Ersatzpflanzungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die aufgrund behördlicher Verfügungen gepflanzten Bäume unterstehen unabhängig von ihrer Grösse den Bestimmungen dieses Gesetzes."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "5d31313f344f430912921f95a6ce488396ddf57e3c32db23deaa26a2c117f934"
    },
    {
      "id": "kanton/BS/789.700/art_13",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "13",
      "artikelLabel": "§ 13",
      "titel": "Öffentliche Bauvorhaben",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Müssen im Zusammenhang mit öffentlichen Bauvorhaben Bäume beseitigt werden, so sind deren Anzahl und Art sowie die vorgesehenen Ersatzpflanzungen in den entsprechenden Vorlagen darzulegen."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "3ecf8e79cd4687f98d243d6cc0a8f142ed942ed69e54836e7678748a722a27bc"
    },
    {
      "id": "kanton/BS/789.700/art_14",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "14",
      "artikelLabel": "§ 14",
      "titel": "Erhaltung der Lebensfähigkeit geschützter Bäume",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Bewässerung und Belüftung ist über dem unmittelbaren Wurzelbereich geschützter Bäume eine ausreichende Erdfläche freizuhalten, die, wo nötig, durch geeignete bauliche Massnahmen vor dem Einsickern von Schadstoffen zu schützen ist."
        },
        {
          "absatz": "2",
          "text": "Geschützte Bäume dürfen nur nach baumpflegerischen Grundsätzen geschnitten werden."
        },
        {
          "absatz": "3",
          "text": "Gefährdet eine Kappung voraussichtlich die Lebensfähigkeit eines geschützten Baumes oder wird dadurch sein Kronengleichgewicht empfindlich gestört, so ist die Einholung einer Bewilligung erforderlich, und diese wird aus den gleichen Gründen erteilt wie eine Fällbewilligung."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "dbb4868bf986c822333a28090dd15ecff4b525369cf5f9272d96db6620d6e474"
    },
    {
      "id": "kanton/BS/789.700/art_15",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "15",
      "artikelLabel": "§ 15",
      "titel": "Beiträge",
      "bloecke": [
        {
          "absatz": "1",
          "text": "An die Kosten für eine fachgerechte Pflege alter, ökologisch wertvoller Bäume und für Neupflanzungen, die nicht als Ersatzpflanzungen verfügt worden sind, können staatliche Beiträge bis zu höchstens sechs Zehnteln der Kosten geleistet werden."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "24b792f27cb5213ed19bd2bb59819f3092c6e1cb2a7c2bc9a145d14b00b90f67"
    },
    {
      "id": "kanton/BS/789.700/art_16",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "16",
      "artikelLabel": "§ 16",
      "bloecke": [
        {
          "absatz": null,
          "text": ""
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
    },
    {
      "id": "kanton/BS/789.700/art_17",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "17",
      "artikelLabel": "§ 17",
      "titel": "Vollzugsbehörden",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die zum Vollzug dieses Gesetzes zuständigen Behörden werden durch den Regierungsrat bezeichnet."
        },
        {
          "absatz": "2",
          "text": "Erlässt eine Landgemeinde Vorschriften, die über diejenigen für die Baumschutzgebiete hinausgehen, bezeichnet der Gemeinderat die für den Vollzug zuständigen Behörden."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "a7dc9feb1459da62affdab1da8ff31e60fa28b88a19211f6d9a9aaa3618cd65f"
    },
    {
      "id": "kanton/BS/789.700/art_18",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "18",
      "artikelLabel": "§ 18",
      "titel": "Aufnahme des Baumbestandes",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Baumbestand ist in geeigneter Weise festzuhalten."
        },
        {
          "absatz": "2",
          "text": "Die Bestandesaufnahme ist periodisch zu wiederholen. Die Grundstückeigentümer haben bei der Bestandesaufnahme mitzuwirken."
        },
        {
          "absatz": "3",
          "text": "Bei allen Bauvorhaben im Bereiche geschützter Bäume ist ein Baumbestandesplan für die Bauparzelle und nötigenfalls für die unmittelbar angrenzenden Flächen der Nachbarparzellen zu erstellen und dem Baubegehren beizulegen."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "daaf761cfa992c9980b371a776a4435eb188e43d9a315d9d29123290d6bae443"
    },
    {
      "id": "kanton/BS/789.700/art_19",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "19",
      "artikelLabel": "§ 19",
      "titel": "Kontrollen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die zuständigen Behörden führen die erforderlichen Kontrollen des Baumbestandes durch. Sie sind berechtigt, sämtliche Liegenschaften nach vorheriger Anzeige zu betreten, soweit dies zur Erfüllung ihrer Aufgabe notwendig ist."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "4053d0d88a7dcb1797044a8fdb9870e9febdc72b2ee0de48e2026b6e46013910"
    },
    {
      "id": "kanton/BS/789.700/art_20",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "20",
      "artikelLabel": "§ 20",
      "titel": "Baumschutzkommission",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat bestellt aus mehrheitlich verwaltungsunabhängigen Sachverständigen eine Baumschutzkommission, die die zuständigen Behörden in allen Fragen des Baumschutzes berät. Die Präsidentin oder der Präsident der Baumschutzkommission ist verwaltungsunabhängig."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f9ff30405df38551bbd1893aada4c410",
      "sha": "b82f809505270e380cfd9a7264b9eea90c3281f3c8ffcdc4c6107dc4eadf8869"
    },
    {
      "id": "kanton/BS/789.700/art_21",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "21",
      "artikelLabel": "§ 21",
      "titel": "Ersatzvornahme",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wird eine Verfügung innert der festgesetzten Frist nicht befolgt, so ordnet die zuständige Behörde an, dass die erforderliche Arbeit auf Kosten des Pflichtigen ausgeführt wird."
        }
      ],
      "stand": "2020-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/789.700",
      "abgerufen": "2026-06-23",
