    {
      "id": "kanton/BS/789.700/art_28",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Baumschutzgesetz, BSchG (789.700)",
      "artikel": "28",
      "artikelLabel": "§ 28",
      "titel": "Inkrafttreten",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat bestimmt den Zeitpunkt, auf den dieses Gesetz oder Teile davon in Kraft treten."
        },
        {
          "absatz": "2",
          "text": "Dieses Gesetz ist zu publizieren und der Gesamtheit der Stimmberechtigten vorzulegen, sofern die «Baumschutzinitiative» nicht innert sechs Wochen zurückgezogen wird. Für den Fall des Rückzuges des Initiativbegehrens unterliegt das Gesetz dem fakultativen Referendum."
        }
      ],
      "stand": "2020-07-01",
