{
  "erzeugt": "2026-06-17",
  "eintraege": [
    {
      "id": "kanton/VD/vd-105540/art_1",
      "ebene": "kanton",
      "quelle": "VD",
      "erlass": "Tarif des dépens (TDC) (RSV 270.11.6)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": null,
          "text": "Il Consiglio di Stato è autorizzato a partecipare alla costituzione della “Fondazione per l’Orchestra della Svizzera Italiana” con sede a Lugano."
        }
      ],
      "stand": "",
      "quelleUrl": "https://www.lexfind.ch/tolv/105540/fr",
      "abgerufen": "2026-06-17",
      "fassungsToken": "c0035f3d91a95c4e17b21f21d4414e048794f07299405640390293a95ff29357",
      "sha": "8c2766c886ebc8e23b9eae9c760d001ec405e70f8ff7412c0bcab93c67d9ecef"
    },
    {
      "id": "kanton/VD/vd-105540/art_2",
      "ebene": "kanton",
      "quelle": "VD",
      "erlass": "Tarif des dépens (TDC) (RSV 270.11.6)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": null,
          "text": "È stanziato un credito di fr. 75'000.-- da iscrivere nel conto degli investimenti del Dipartimento dell’educazione, della cultura e dello sport (in seguito Dipartimento), per la partecipazione del Cantone al capitale in dotazione della Fondazione."
        }
      ],
      "stand": "",
      "quelleUrl": "https://www.lexfind.ch/tolv/105540/fr",
      "abgerufen": "2026-06-17",
      "fassungsToken": "c0035f3d91a95c4e17b21f21d4414e048794f07299405640390293a95ff29357",
      "sha": "6f082f1452e2783c123487125470bf76bc6315d363374df44185b717439cae93"
    },
    {
      "id": "kanton/VD/vd-105540/art_3",
      "ebene": "kanton",
      "quelle": "VD",
      "erlass": "Tarif des dépens (TDC) (RSV 270.11.6)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": null,
          "text": "Il Cantone versa alla Fondazione un sussidio forfetario annuo, quale contributo agli oneri dell’orchestra. Il sussidio forfetario è stabilito annualmente dal Consiglio di Stato."
        }
      ],
      "stand": "",
      "quelleUrl": "https://www.lexfind.ch/tolv/105540/fr",
      "abgerufen": "2026-06-17",
      "fassungsToken": "c0035f3d91a95c4e17b21f21d4414e048794f07299405640390293a95ff29357",
      "sha": "56c94c252c16b9b3011406d665ee84f7310a2a1613da8cb8604a5d02b36ddfdb"
    },
    {
      "id": "kanton/VD/vd-105540/art_4",
      "ebene": "kanton",
      "quelle": "VD",
      "erlass": "Tarif des dépens (TDC) (RSV 270.11.6)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": null,
          "text": "Il Cantone può inoltre garantire un ulteriore sussidio in caso di sviluppo dell’attività o di eventuali deficit."
        }
      ],
      "stand": "",
      "quelleUrl": "https://www.lexfind.ch/tolv/105540/fr",
      "abgerufen": "2026-06-17",
      "fassungsToken": "c0035f3d91a95c4e17b21f21d4414e048794f07299405640390293a95ff29357",
      "sha": "22817a45bb7a875270080040dc326daca034120e42fdbc9c2e8fe3314113483b"
    },
    {
      "id": "kanton/VD/vd-105540/art_5",
      "ebene": "kanton",
      "quelle": "VD",
      "erlass": "Tarif des dépens (TDC) (RSV 270.11.6)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": null,
          "text": "Il Cantone garantisce inoltre un ulteriore margine di fr. 400’000.- nel caso di sviluppo dell’attività o di eventuali deficit."
        }
      ],
      "stand": "",
      "quelleUrl": "https://www.lexfind.ch/tolv/105540/fr",
      "abgerufen": "2026-06-17",
      "fassungsToken": "c0035f3d91a95c4e17b21f21d4414e048794f07299405640390293a95ff29357",
      "sha": "e91aa4015d9f438555b09801c7296513d13b61d8534ce86991c2f044e5b89d22"
    },
    {
      "id": "kanton/VD/vd-105540/art_6",
      "ebene": "kanton",
      "quelle": "VD",
      "erlass": "Tarif des dépens (TDC) (RSV 270.11.6)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": null,
          "text": "La spesa è da iscrivere nella gestione corrente del Dipartimento dell’educazione, della cultura e dello sport."
        }
      ],
      "stand": "",
      "quelleUrl": "https://www.lexfind.ch/tolv/105540/fr",
      "abgerufen": "2026-06-17",
      "fassungsToken": "c0035f3d91a95c4e17b21f21d4414e048794f07299405640390293a95ff29357",
      "sha": "fa88ca47e9b155890cbd14a91a65efbfbaaa34e318a80c34142b909754e79688"
    },
    {
      "id": "kanton/VD/vd-105540/art_7",
      "ebene": "kanton",
      "quelle": "VD",
      "erlass": "Tarif des dépens (TDC) (RSV 270.11.6)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": null,
          "text": "La “Fondazione per l’Orchestra della Svizzera Italiana” è esente da qualsiasi imposta cantonale e comunale."
        }
      ],
      "stand": "",
      "quelleUrl": "https://www.lexfind.ch/tolv/105540/fr",
