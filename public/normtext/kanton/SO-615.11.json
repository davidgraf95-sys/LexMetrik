{
  "erzeugt": "2026-06-16",
  "eintraege": [
    {
      "id": "kanton/SO/615.11/art_145",
      "ebene": "kanton",
      "quelle": "SO",
      "erlass": "GT (BGS 615.11)",
      "artikel": "145",
      "artikelLabel": "§ 145",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Entscheidgebühr beträgt bei einem Streitwert von",
          "items": [
            {
              "marke": "a",
              "text": "bis 30'000 Franken 200-4'000"
            },
            {
              "marke": "b",
              "text": "30'001-50'000 Franken 600-5'500"
            },
            {
              "marke": "c",
              "text": "50'001-100'000 Franken 800-8'000"
            },
            {
              "marke": "d",
              "text": "100'001-200'000 Franken 1'200-13'000"
            },
            {
              "marke": "e",
              "text": "200'001-500'000 Franken 1'800-25'000"
            },
            {
              "marke": "f",
              "text": "500'001-1'000'000 Franken 2'500-50'000"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Übersteigt der Streitwert 1 Million Franken, so kann die Maximalgebühr nach Absatz 1 um bis 1 Prozent des Streitwerts erhöht werden."
        },
        {
          "absatz": "3",
          "text": "Kann der Streitwert nicht beziffert werden, beträgt die Entscheidgebühr 200-20'000 Franken."
        },
        {
          "absatz": "4",
          "text": "Endet das Verfahren ohne Sachurteil oder ist keine schriftliche Urteilsbegründung erforderlich, so kann die Gebühr reduziert werden bis auf das Mass, das dem Aufwand entspricht, der bei Verfahrensbeendigung aufgelaufen ist. Die in Absatz 1 genannten Minimalgebühren dürfen in der Regel nicht unterschritten werden."
        }
      ],
      "stand": "2026-03-01",
      "quelleUrl": "https://bgs.so.ch/app/de/texts_of_law/615.11",
      "abgerufen": "2026-06-16",
      "fassungsToken": "0a1d469935a59317fd8ce1a93a7f4e22",
      "sha": "0ebf52805279bf01074f37db49e06de12a482873fcbb38c11880c45b4deead56"
    },
    {
      "id": "kanton/SO/615.11/art_144",
      "ebene": "kanton",
      "quelle": "SO",
      "erlass": "GT (BGS 615.11)",
      "artikel": "144",
      "artikelLabel": "§ 144",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für das Schlichtungsverfahren vor den Schlichtungsbehörden ist eine Pauschalgebühr von 200-1'500 Franken geschuldet."
        }
      ],
      "stand": "2026-03-01",
      "quelleUrl": "https://bgs.so.ch/app/de/texts_of_law/615.11",
      "abgerufen": "2026-06-16",
      "fassungsToken": "0a1d469935a59317fd8ce1a93a7f4e22",
      "sha": "391fa0ae1b16d74d4ef203a27e3647c409a695967453e0b88220a48b47722180"
    },
    {
      "id": "kanton/SO/615.11/art_160",
      "ebene": "kanton",
      "quelle": "SO",
      "erlass": "GT (BGS 615.11)",
      "artikel": "160",
      "artikelLabel": "§ 160",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Richter setzt die Kosten der berufsmässigen Vertretung und die Entschädigung der unentgeltlichen Rechtsbeistände nach dem Aufwand fest, welcher für eine sorgfältige und pflichtgemässe Vertretung erforderlich ist. Er gibt den Parteien vor dem Entscheid Gelegenheit zur Einreichung einer Honorarnote. Wird keine detaillierte Honorarnote eingereicht, schätzt er den Aufwand nach pflichtgemässem Ermessen."
        },
        {
          "absatz": "2",
          "text": "Der Stundenansatz für die Bestimmung der Kosten der berufsmässigen Vertretung beträgt 230-330 Franken zuzüglich Mehrwertsteuer, soweit sie durch Anwälte wahrgenommen wird. § 3 ist analog anwendbar."
        },
        {
          "absatz": "3",
          "text": "Der Stundenansatz für die Bestimmung der Entschädigung der unentgeltlichen Rechtsbeistände sowie für die Ausfallhaftung des Staates beträgt 180 Franken zuzüglich Mehrwertsteuer."
        },
        {
          "absatz": "4",
          "text": "Die Stundenansätze beruhen auf dem Teuerungsstand vom 30. September 2006. Sie werden jeweils der Teuerung angepasst, wenn diese im Vergleich zur aktuellen Festsetzung 5 Prozent beträgt. Die Gerichtsverwaltungskommission legt die neuen Stundenansätze durch Weisung fest."
        },
        {
          "absatz": "5",
          "text": "Die Vergütung für Fotokopien beträgt 50 Rappen pro Stück. Für die Reiseauslagen gilt § 157 Absatz 3."
        }
      ],
      "stand": "2026-03-01",
      "quelleUrl": "https://bgs.so.ch/app/de/texts_of_law/615.11",
      "abgerufen": "2026-06-16",
      "fassungsToken": "0a1d469935a59317fd8ce1a93a7f4e22",
      "sha": "8c91cd2810907e9d3f73ab9d9916c34a80d8a336b1e10b354f1a7d3b72545701"
    },
    {
      "id": "kanton/SO/615.11/art_25",
      "ebene": "kanton",
      "quelle": "SO",
      "erlass": "GT (BGS 615.11)",
      "artikel": "25",
      "artikelLabel": "§ 25 Abs. 1 lit. a",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Folgende Gebühren sind für Dienstleistungen im Sachenrecht geschuldet:",
          "items": [
            {
              "marke": "a",
              "text": "Kauf-, Tausch- und Schenkungsvertrag 100-10'000"
            },
            {
              "marke": "b",
              "text": "Aufhebung von Mit- und Gesamteigentum, sofern keine Gebühr nach § 24 Absatz 1 Buchstaben h und i geschuldet ist 200-1'000"
            },
            {
              "marke": "c",
              "text": "Übertragung eines selbständigen und dauernden Rechtes 200-10'000"
            },
            {
              "marke": "d",
              "text": "Begründung von Stockwerkeigentum 1'000-15'000"
            },
            {
              "marke": "e",
              "text": "Ausübung eines Vorkaufsrechtes 100-1'000"
            },
            {
              "marke": "f",
              "text": "Ausübung eines Kaufs- oder Rückkaufsrechtes 300-10'000"
            },
            {
              "marke": "g",
              "text": "Begründung eines selbständigen und dauernden Rechtes 200-10'000"
            },
            {
              "marke": "h",
              "text": "Begründung einer andern Dienstbarkeit, einer Grundlast oder eines vormerkbaren Rechtes 100-10'000"
            },
            {
              "marke": "i",
              "text": "Kontrolle, Prüfung oder Errichtung eines Eintragungsausweises für Grundbuchanmeldungen 80-1'500"
            },
            {
              "marke": "j",
              "text": "Arbeiten im Zusammenhang mit Baulandumlegungen 1'000-35'000"
            },
            {
              "marke": "k",
              "text": "Parzellierung und Vereinigung 100-10'000"
            },
            {
              "marke": "l",
              "text": "Vorvertrag 100-10'000"
            },
            {
              "marke": "m",
              "text": "in separater Urkunde begründete Errichtung oder Abänderung eines Grundpfandrechtes 20-10'000"
            }
          ]
        }
      ],
      "stand": "2026-03-01",
      "quelleUrl": "https://bgs.so.ch/app/de/texts_of_law/615.11",
      "abgerufen": "2026-06-16",
      "fassungsToken": "0a1d469935a59317fd8ce1a93a7f4e22",
      "sha": "d2123c9a4c0774adb2ec58383bd75c982643cf684995ee299e2fdf8fa0a5952e"
    },
    {
      "id": "kanton/SO/615.11/art_24",
      "ebene": "kanton",
      "quelle": "SO",
      "erlass": "GT (BGS 615.11)",
      "artikel": "24",
      "artikelLabel": "§ 24 Abs. 1 lit. a GT (BGS 615.11)",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Folgende Gebühren sind für Dienstleistungen im Erbrecht geschuldet:",
          "items": [
            {
              "marke": "a",
              "text": "Errichtung oder Änderung einer öffentlichen letztwilligen Verfügung oder eines Erbvertrages 200-6'000"
            },
            {
              "marke": "b",
              "text": "Ausarbeitung eines Entwurfes für eine eigenhändige letztwillige Verfügung (einschliesslich Beratung) 50-3'000"
            },
            {
              "marke": "c",
              "text": "Aufhebung einer öffentlichen letztwilligen Verfügung oder eines Erbvertrages 100-400"
            },
            {
              "marke": "d",
              "text": "Bewilligung eines öffentlichen Inventars oder einer amtlichen Liquidation 150"
            },
            {
              "marke": "e",
              "text": "Eröffnung einer Verfügung von Todes wegen ausserhalb eines Erbschaftsinventars 100-2'000"
            },
            {
              "marke": "f",
              "text": "Errichtung eines Erbschaftsinventars 300-10'000"
            },
            {
              "marke": "g",
              "text": "Geschäfte, die nicht zur Feststellung des Nachlasses dienen (Begründung einer Dienstbarkeit, einer Grundlast, eines Grundpfandrechtes, eines vormerkbaren Rechtes usw.) entsprechend dem Zeitaufwand 300-10'000"
            },
            {
              "marke": "h",
              "text": "Erbteilung mit Liquidation des Nachlasses 100-10'000"
            },
            {
              "marke": "i",
              "text": "Durchführung einer amtlichen Liquidation, zusätzlich zur Gebühr für die Errichtung eines Erbschaftsinventars 100-10'000"
            },
            {
              "marke": "j",
              "text": "Erbenbescheinigung 50-1'000"
            }
          ]
        }
      ],
      "stand": "2026-03-01",
      "quelleUrl": "https://bgs.so.ch/app/de/texts_of_law/615.11",
      "abgerufen": "2026-06-16",
      "fassungsToken": "0a1d469935a59317fd8ce1a93a7f4e22",
      "sha": "fbd268f080249dcc41f87824d0c185da86015a1d3059cdbb1c809a7666993f32"
    },
    {
      "id": "kanton/SO/615.11/art_23",
      "ebene": "kanton",
      "quelle": "SO",
      "erlass": "GT (BGS 615.11)",
      "artikel": "23",
      "artikelLabel": "§ 23 Abs. 1 lit. b GT (BGS 615.11)",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Folgende Gebühren sind für Dienstleistungen im Familienrecht geschuldet:",
          "items": [
            {
              "marke": "a",
              "text": "Güterausscheidung in einer besonderen Urkunde 300-3'000"
            },
            {
              "marke": "b",
              "text": "Errichtung oder Änderung eines Ehevertrages 300-3'000"
            },
            {
              "marke": "c",
              "text": "Aufhebung eines Ehevertrages 100-400"
            },
            {
              "marke": "d",
              "text": "Errichtung anderer Urkunden nach Familienrecht 300-3'000"
            }
          ]
        }
      ],
      "stand": "2026-03-01",
      "quelleUrl": "https://bgs.so.ch/app/de/texts_of_law/615.11",
