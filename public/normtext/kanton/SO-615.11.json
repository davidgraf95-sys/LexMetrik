    {
      "id": "kanton/SO/615.11/art_26",
      "ebene": "kanton",
      "quelle": "SO",
      "erlass": "GT (BGS 615.11)",
      "artikel": "26",
      "artikelLabel": "§ 26 Abs. 1 lit. c GT (BGS 615.11)",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Folgende Gebühren sind für Dienstleistungen im Obligationenrecht geschuldet:",
          "items": [
            {
              "marke": "a",
              "text": "Beurkundung einer Bürgschaftserklärung 100-1'000"
            },
            {
              "marke": "b",
              "text": "Errichtung oder Änderung eines Leibrenten- oder Verpfründungsvertrages 100-10'000"
            },
            {
              "marke": "c",
              "text": "Beurkundung nach Gesellschaftsrecht 500-10'000"
            },
            {
              "marke": "d",
              "text": "Beurkundung nach Wechsel- und Checkrecht 100-1'000"
            },
            {
              "marke": "e",
              "text": "freiwillige Versteigerung 200-10'000"
            },
            {
              "marke": "f",
              "text": "Bewilligung einer freiwilligen Versteigerung, sofern sie nicht vom Amtschreiber oder von der Amtschreiberin durchgeführt wird 200"
            }
          ]
        }
      ],
      "stand": "2026-03-01",
      "quelleUrl": "https://bgs.so.ch/app/de/texts_of_law/615.11",
      "abgerufen": "2026-06-16",
