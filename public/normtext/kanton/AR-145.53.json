{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/145.53/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung regelt die Entschädigungen für die rechtsanwaltschaftliche Verbeiständung und Vertretung in Zivil-, Straf- und Verwaltungsgerichtsverfahren."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "6e38ff1b2d72a7d29a5d96b6a4e4e3741be8368309ff3a6d0f56f05f2126c9cb"
    },
    {
      "id": "kanton/AR/145.53/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Verordnung gilt sowohl für die Behörden wie auch für die Rechtsanwälte und -anwältinnen; insbesondere ist der behördliche Kostenspruch für die Beteiligten bindend."
        },
        {
          "absatz": "2",
          "text": "Zulässig bleibt die gegenseitige Abrede der Honorierung nach Zeitaufwand in anderen als den in der Verordnung vorgesehenen Fällen."
        },
        {
          "absatz": "3",
          "text": "Von den Entschädigungen gemäss dieser Verordnung kann abgewichen werden, wenn sie in einem krassen Missverhältnis zu den geleisteten Bemühungen stehen."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "6e2203c4a206f1643d005f79ee504610cfcf7bc897255bc22bf0a15b276a6289"
    },
    {
      "id": "kanton/AR/145.53/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Entschädigung setzt sich aus einem Honorar und den Barauslagen zusammen."
        },
        {
          "absatz": "2",
          "text": "Die Mehrwertsteuer wird als Zuschlag in Rechnung gestellt."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "3e03a7ea8e2b558c8d243a5d296efbb128f3fd0f67bf06ad582e81584c2e4718"
    },
    {
      "id": "kanton/AR/145.53/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kostenrechnung enthält die Berechnungsgrundlagen und die angewandten Verordnungsbestimmungen."
        },
        {
          "absatz": "2",
          "text": "Die Behörden bestimmen die Entschädigung nach Ermessen, wenn ihnen keine oder eine ungenügende Kostenrechnung eingereicht wurde."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "ab0a366b3606b18745ea50f6c9ba8c63cbfb6e51293d5cf1e74b35fe852871fd"
    },
    {
      "id": "kanton/AR/145.53/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Überschreiten der Anwalt oder die Anwältin das mittlere Honorar, so begründen sie dies in der Kostenrechnung."
        },
        {
          "absatz": "2",
          "text": "Unterschreitet die Behörde das mittlere Honorar, so begründet sie dies in ihrem Entscheid."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "5b6b3856ff4b044733ade1ca9588864770a7892cc0c597ee10de17a59418bd8c"
    },
    {
      "id": "kanton/AR/145.53/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Kostenrechnungen können der Anwaltsaufsichtskommission zur Begutachtung vorgelegt werden."
        },
        {
          "absatz": "2",
          "text": "Den Beteiligten kann nach Einholung der notwendigen Akten und Auskünfte ein Vorschlag für die Bemessung der Entschädigung unterbreitet werden."
        },
        {
          "absatz": "3",
          "text": "Die Begutachtung erfolgt unentgeltlich; ausnahmsweise, namentlich bei missbräuchlicher Anrufung der Kommission oder klar übersetzter Rechnung, kann eine Staatsgebühr erhoben werden."
        },
        {
          "absatz": "4",
          "text": "Schiedsabreden vor Rechnungsstellung sind unwirksam."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "46db5264be4f103b43e805fb8caea18d20bb23a796005b3478219670fd034962"
    },
    {
      "id": "kanton/AR/145.53/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Honorare werden bemessen:",
          "items": [
            {
              "marke": "a",
              "text": "nach Streitwert"
            },
            {
              "marke": "b",
              "text": "pauschal oder"
            },
            {
              "marke": "c",
              "text": "nach Zeitaufwand."
            }
          ]
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "1a4cf5152abb7102a728512bf72773550e3cacb480551d3ca651e024b2a495ac"
    },
    {
      "id": "kanton/AR/145.53/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Bemessung nach Streitwert kommt in Zivilprozessen und bei Verwaltungsgerichtsklagen mit bestimmtem oder bestimmbarem Streitwert zur Anwendung."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "b12ff6701f3c99640c7a1c917ec82d0e999ee576b0c9274c73ff82d126418c7a"
    },
    {
      "id": "kanton/AR/145.53/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das mittlere Honorar setzt sich zusammen aus einem festen Betrag und aus einem Prozentsatz des Streitwertes."
        },
        {
          "absatz": "2",
          "text": "Es beträgt für einen Streitwert von",
          "items": [
            {
              "marke": "a",
              "text": "bis Fr. 5 000.– Fr. 500.– + 30,0%"
            },
            {
              "marke": "b",
              "text": "über Fr. 5 000.– bis Fr. 20 000.– Fr. 1 230.– + 15,4%"
            },
            {
              "marke": "c",
              "text": "über Fr. 20 000.– bis Fr. 50 000.– Fr. 1 850.– + 12,3%"
            },
            {
              "marke": "d",
              "text": "über Fr. 50 000.– bis Fr. 100 000.– Fr. 3 600.– + 8,8%"
            },
            {
              "marke": "e",
              "text": "über Fr. 100 000.– bis Fr. 500 000.– Fr. 9 100.– + 3,3%"
            },
            {
              "marke": "f",
              "text": "über Fr. 500 000.– bis Fr. 1 000 000.– Fr. 12 600.– + 2,6%"
            },
            {
              "marke": "g",
              "text": "über Fr. 1 000 000.– bis Fr. 2 000 000.– Fr. 15 600.– + 2,3%"
            },
            {
              "marke": "h",
              "text": "über Fr. 2 000 000.– Fr. 37 600.– + 1,2%"
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Das Honorar schliesst die vorprozessualen Bemühungen und ein allfälliges Vermittlungsverfahren ein."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "73ed965441404c3a8b50027d647f97d73a32b9bbf6282cad4aecfc4037fa759d"
    },
    {
      "id": "kanton/AR/145.53/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im summarischen Verfahren ermässigt sich das mittlere Honorar auf 10 bis 50 Prozent."
        },
        {
          "absatz": "2",
          "text": "Vorbehalten bleibt Art. 68 Abs. 1 der Gebührenverordnung zum Bundesgesetz über Schuldbetreibung und Konkurs."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "c276c7af5ca11bd4de8c61830b36e03d3a1462748e6e279d978d7d5ce6748734"
    },
    {
      "id": "kanton/AR/145.53/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das mittlere Honorar kann zur Berücksichtigung besonderer Umstände bis zu einem Viertel unter- oder überschritten werden."
        },
        {
          "absatz": "2",
          "text": "Als besondere Umstände kommen namentlich in Betracht:",
          "items": [
            {
              "marke": "a",
              "text": "die grundsätzliche Bedeutung und die Schwierigkeit eines Falles,"
            },
            {
              "marke": "b",
              "text": "die wirtschaftlichen Verhältnisse der Beteiligten,"
            },
            {
              "marke": "c",
              "text": "der notwendige Zeitaufwand,"
            },
            {
              "marke": "d",
              "text": "die Vertretung mehrerer Parteien,"
            },
            {
              "marke": "e",
              "text": "ausserordentliche vorprozessuale Bemühungen."
            }
          ]
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "e85af68184941706d7bc34574541bef83cc1833e2787ada09162427ef370a704"
    },
    {
      "id": "kanton/AR/145.53/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zum mittleren Honorar können Zuschläge erhoben werden für:",
          "items": [
            {
              "marke": "a",
              "text": "die Teilnahme an einer zusätzlichen Verhandlung wie Experteninstruktion, Beweiserhebung oder Schlussverhandlung,"
            },
            {
              "marke": "b",
              "text": "eine von der Behörde verlangte oder zugelassene zusätzliche und erhebliche Eingabe,"
            },
            {
              "marke": "c",
              "text": "einen aussergewöhnlich komplizierten Prozess,"
            },
            {
              "marke": "d",
              "text": "vorsorgliche Massnahmen im Hauptprozess,"
            },
            {
              "marke": "e",
              "text": "aufwendige Vergleichsverhandlungen."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Der einzelne Zuschlag beträgt 10 bis 40 Prozent des Grundhonorars. Die Zuschläge dürfen insgesamt das Grundhonorar in der Regel nicht überschreiten."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "ff51f52a8c12d46cba6538524d3532b494dc02b67198a67c9b25fc2fe1a444db"
    },
    {
      "id": "kanton/AR/145.53/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die pauschale Bemessung kommt zur Anwendung:",
          "items": [
            {
              "marke": "a",
              "text": "in Ehe- und Verwandtschaftssachen und im Bereich des Kindes- und Erwachsenenschutzes,"
            },
            {
              "marke": "b",
              "text": "im Strafverfahren,"
            },
            {
              "marke": "c",
              "text": "vor Obergericht in Verwaltungssachen."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "In Ehe- und Verwandtschaftssachen und im Bereich des Kindes- und Erwachsenenschutzes sowie im Strafverfahren kann der Rechtsanwalt oder die Rechtsanwältin das Honorar nach Zeitaufwand bemessen."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "a9a12cfb40bd3cffd47cf6c3747b4760a63c4a9c1a4ebebbb2a5ba8219904194"
    },
    {
      "id": "kanton/AR/145.53/art_14",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "In Ehe- und Verwandtschaftssachen und im Bereich des Kindes- und Erwachsenenschutzes beträgt das Honorar pauschal Fr. 1 200.– bis Fr. 6 500.–."
        },
        {
          "absatz": "2",
          "text": "Für vorsorgliche Massnahmen kann ein Zuschlag von 10 bis 40 Prozent erhoben werden."
        },
        {
          "absatz": "3",
          "text": "Die Pauschale schliesst die vorprozessualen Bemühungen und ein allfälliges Vermittlungsverfahren ein."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "1cec216dd24e5618a5c864efc899423ba386d8164c45bb3e4b5253b9b641e52b"
    },
    {
      "id": "kanton/AR/145.53/art_15",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "15",
      "artikelLabel": "Art. 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im Strafverfahren beträgt das Honorar für die Verteidigung Beschuldigter oder die Vertretung Geschädigter pauschal:",
          "items": [
            {
              "marke": "a",
              "text": "bis Fr. 3 000.–, wenn das Verfahren durch Straf- oder Einstellungsverfügung erledigt wird,"
            },
            {
              "marke": "b",
              "text": "Fr. 1 000.– bis Fr. 6 500.–, wenn das Kantonsgericht entscheidet."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die Honorarpauschale für die Vertretung vor Gericht schliesst die Bemühungen im Untersuchungsverfahren ein."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "56053042acc3612502ef6043dd58c705850b097aaf13fdd6c94e4a9e9684fbf6"
    },
    {
      "id": "kanton/AR/145.53/art_16",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "16",
      "artikelLabel": "Art. 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im Verfahren vor dem Obergericht in Verwaltungssachen beträgt das Honorar pauschal Fr. 1 000.– bis Fr. 10 000.–."
        },
        {
          "absatz": "2",
          "text": "In aussergewöhnlich aufwendigen Verfahren kann das Honorar um die Hälfte erhöht werden."
        },
        {
          "absatz": "3",
          "text": "Vorbehalten bleibt Art. 8."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "6c88b3131c0bd6e8b708a5df8f4b484816eb083b6f7d821e36d6fa39f80d8d16"
    },
    {
      "id": "kanton/AR/145.53/art_17",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "17",
      "artikelLabel": "Art. 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Innerhalb des für eine Pauschale gesetzten Rahmens richtet sich das Honorar nach den besonderen Umständen des Falles."
        },
        {
          "absatz": "2",
          "text": "In Betracht fallen namentlich:",
          "items": [
            {
              "marke": "a",
              "text": "Art und Umfang der Bemühungen,"
            },
            {
              "marke": "b",
              "text": "die Schwierigkeit des Falles,"
            },
            {
              "marke": "c",
              "text": "die wirtschaftlichen Verhältnisse der Beteiligten."
            }
          ]
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "5f66e2f32974498a3e55b85de1652532ae458cccd0088049845e3669c48c5c9f"
    },
    {
      "id": "kanton/AR/145.53/art_18",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Bemessung nach Zeitaufwand kommt zur Anwendung:",
          "items": [
            {
              "marke": "a",
              "text": "in Zivilverfahren, wenn ein Streitwert nicht oder nur schwierig zu ermitteln ist und eine Pauschale ausser Betracht fällt,"
            },
            {
              "marke": "b",
              "text": "im Verfahren vor dem Zwangsmassnahmengericht und der strafrechtlichen Beschwerdeinstanz,"
            },
            {
              "marke": "c",
              "text": "im Falle von Artikel 13 Absatz 2 sowie in Fällen, für die diese Verordnung keine besondere Regelung trifft."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Unnötiger Aufwand fällt ausser Betracht."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "cf83488371353532cdbf54c2bacad76cafad4e169c9ab0aa06771750dee61da7"
    },
    {
      "id": "kanton/AR/145.53/art_19",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "19",
      "artikelLabel": "Art. 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das mittlere Honorar beträgt Fr. 200.– je Stunde."
        },
        {
          "absatz": "2",
          "text": "Es kann zur Berücksichtigung besonderer Umstände bis zu einem Viertel unter- oder überschritten werden."
        },
        {
          "absatz": "3",
          "text": "In der güterrechtlichen Auseinandersetzung kann es erhöht werden für Ansprüche von:",
          "items": [
            {
              "marke": "a",
              "text": "über Fr. 250 000.– auf Fr. 300.–"
            },
            {
              "marke": "b",
              "text": "über Fr. 500 000.– auf Fr. 350.–"
            },
            {
              "marke": "c",
              "text": "über Fr. 1 000 000.– auf Fr. 400.–"
            }
          ]
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "ed471e00caa4ccce4a84644526d6cd04833ea28d287be4e5e460c2eb2d2a9d61"
    },
    {
      "id": "kanton/AR/145.53/art_20",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "20",
      "artikelLabel": "Art. 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wurde das Honorar nach Streitwert oder pauschal bemessen, so beträgt es für das Rechtsmittelverfahren:",
          "items": [
            {
              "marke": "a",
              "text": "im schriftlichen Verfahren 20 bis 50 Prozent,"
            },
            {
              "marke": "b",
              "text": "im Verfahren mit mündlicher Verhandlung 40 bis 75 Prozent."
            }
          ]
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "e9aade8c1c93f6c4a3c851bcd1398ac1943782362a305ce332e25f811998c113"
    },
    {
      "id": "kanton/AR/145.53/art_21",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "21",
      "artikelLabel": "Art. 21",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im ordentlichen Zivilverfahren beträgt das Honorar für einen Verfahrensabschnitt:",
          "items": [
            {
              "marke": "a",
              "text": "für das Vermittlungsverfahren bis zu 20 Prozent,"
            },
            {
              "marke": "b",
              "text": "für den Schriftenwechsel bis zu 75 Prozent,"
            },
            {
              "marke": "c",
              "text": "für die mündliche Verhandlung bis zu 50 Prozent,"
            },
            {
              "marke": "d",
              "text": "für das Rechtsmittelverfahren mit mündlicher Verhandlung bis zu 90 Prozent."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "In anderen Verfahren erfolgt eine angemessene Kürzung."
        },
        {
          "absatz": "3",
          "text": "Die Mehrkosten eines Anwaltswechsels tragen der Mandant oder die Mandantin."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "65f1a800553c5803f2394527d4c90ef278c8b9813cf853b5701aa7b5422ae7ed"
    },
    {
      "id": "kanton/AR/145.53/art_22",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "22",
      "artikelLabel": "Art. 22",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zu den Barauslagen gehören namentlich die notwendigen Kosten für Fahrten, Versand, Fernmeldedienste und Kopien."
        },
        {
          "absatz": "2",
          "text": "Es können berechnet werden:",
          "items": [
            {
              "marke": "a",
              "text": "Fr. –.70 je Kopie,"
            },
            {
              "marke": "b",
              "text": "die Kosten des Bahnbilletts 1. Klasse,"
            },
            {
              "marke": "c",
              "text": "Fr. –.70 je Kilometer für die Benützung eines Personenwagens."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Die Kosten für Kopien eigener Eingaben, die Anschaffung von Fachliteratur und die Benützung juristischer Datenbanken sind durch das Honorar abgegolten."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "c36902bf62d6dfab14f918efc2f427ac170a8e9895e1340ef94d56d06deb05d4"
    },
    {
      "id": "kanton/AR/145.53/art_23",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "23",
      "artikelLabel": "Art. 23",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Staat entschädigt die unentgeltliche Rechtsverbeiständung und die amtliche Verteidigung nach dem notwendigen Zeitaufwand."
        },
        {
          "absatz": "2",
          "text": "Er erstattet die Barauslagen."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "9669a81b072af27b573b792c91ad03929466ef4045d67a2f1d8c9393071276e1"
    },
    {
      "id": "kanton/AR/145.53/art_24",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "24",
      "artikelLabel": "Art. 24",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Honorar beträgt Fr. 200.– je Stunde plus Mehrwertsteuer."
        },
        {
          "absatz": "2",
          "text": "Es ist insgesamt nicht höher als das nach Streitwert oder pauschal zu bemessende Honorar."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "c9829c653bd4ce5c19d740e8e2532b91237ae3230ae2bf33f145f8b4cdb7a093"
    },
    {
      "id": "kanton/AR/145.53/art_25",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "25",
      "artikelLabel": "Art. 25",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Bewilligung der unentgeltlichen Rechtsverbeiständung oder amtlichen Verteidigung wirkt auf den Zeitpunkt der Einreichung des Gesuches zurück."
        },
        {
          "absatz": "2",
          "text": "Vorher geleistete Bemühungen werden in der Regel nicht entschädigt."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "4b8d6dc3d67f381992c53e4f938d3f537bc6fe16eb1c474eb1fc1190f110aa53"
    },
    {
      "id": "kanton/AR/145.53/art_26",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "26",
      "artikelLabel": "Art. 26",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Entschädigung kommt nach Abschluss des Verfahrens und gehöriger Abrechnung zur Auszahlung."
        },
        {
          "absatz": "2",
          "text": "In der Abrechnung sind der Zeitaufwand und die Auslagen im einzelnen aufzuführen und summarisch zu begründen."
        },
        {
          "absatz": "3",
          "text": "In sehr aufwendigen Verfahren können auf besonderes Gesuch hin Teilzahlungen erfolgen."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "e69dc173704dd4a5d98d79108ae50ee3454b77bd1074f81714c090d6f720427d"
    },
    {
      "id": "kanton/AR/145.53/art_27",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "27",
      "artikelLabel": "Art. 27",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Inkrafttreten der Verordnung hängige Verfahren sind nach bisherigem Recht abzurechnen."
        },
        {
          "absatz": "2",
          "text": "Nach Inkrafttreten eingeleitete Rechtsmittelverfahren können nach neuem Recht abgerechnet werden."
        },
        {
          "absatz": "3",
          "text": "Die Entschädigung für die unentgeltliche Rechtsverbeiständung und amtliche Verteidigung richtet sich nach dem im Zeitpunkt ihrer Bewilligung geltenden Recht."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "51c1333665401c438e39e6dc096872cbd76bcd016145d6697b238a5867b05045"
    },
    {
      "id": "kanton/AR/145.53/art_28",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über den Anwaltstarif (145.53)",
      "artikel": "28",
      "artikelLabel": "Art. 28",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung tritt am 1. Juli 1995 in Kraft."
        },
        {
          "absatz": "2",
          "text": "Sie ersetzt die Verordnungen vom 2. Dezember 1957 über die Gebühren der Rechtsanwälte im Gerichtsverfahren (Anwaltstarif) und vom 10. August 1993 über die Entschädigungen für unentgeltliche Rechtsverbeiständung und amtliche Verteidigung."
        }
      ],
      "stand": "2019-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c7266b58e1bbaddf2e46b966ec9855b0",
      "sha": "ee19e97b9b09ebdd16346239f155fc63bab12300f8a18c647ec19642af4e0116"
    }
  ]
}