      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das mittlere Honorar setzt sich zusammen aus einem festen Betrag und aus einem Prozentsatz des Streitwertes."
        },
        {
          "absatz": "2",
          "text": "Es beträgt für einen Streitwert von a) bis Fr. 5 000.– Fr. 500.– + 30,0% b) über Fr. 5 000.– bis Fr. 20 000.– Fr. 1 230.– + 15,4% c) über Fr. 20 000.– bis Fr. 50 000.– Fr. 1 850.– + 12,3% d) über Fr. 50 000.– bis Fr. 100 000.– Fr. 3 600.– + 8,8% e) über Fr. 100 000.– bis Fr. 500 000.– Fr. 9 100.– + 3,3% f) über Fr. 500 000.– bis Fr. 1 000 000.– Fr. 12 600.– + 2,6% g) über Fr. 1 000 000.– bis Fr. 2 000 000.– Fr. 15 600.– + 2,3% h) über Fr. 2 000 000.– Fr. 37 600.– + 1,2%"
        },
        {
          "absatz": "3",
          "text": "Das Honorar schliesst die vorprozessualen Bemühungen und ein allfälliges Vermittlungsverfahren ein."
        }
      ],
      "stand": "1995-07-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.53",
