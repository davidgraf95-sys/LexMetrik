{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/410.180/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Konkordat über die Schulkoordination (410.180)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "titel": "Zweck",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Konkordatskantone bilden eine interkantonale öffentlich-rechtliche Einrichtung zur Förderung des Schulwesens und zur Harmonisierung des entsprechenden kantonalen Rechts."
        }
      ],
      "stand": "1987-04-23",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.180",
      "abgerufen": "2026-06-23",
      "fassungsToken": "23d9920bee0bfa88b2fc69fe99ff2852",
      "sha": "4de34cb2ea6afb1e4010f22c6ef2f56782b7efa35fdcca85e42d6e4657164bc6"
    },
    {
      "id": "kanton/BS/410.180/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Konkordat über die Schulkoordination (410.180)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "titel": "Verpflichtungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Konkordatskantone verpflichten sich, ihre Schulgesetzgebung in den folgenden Punkten anzugleichen:",
          "items": [
            {
              "marke": "a",
              "text": "das Schuleintrittsalter wird auf das vollendete 6. Altersjahr festgelegt. Stichtag ist der 30. Juni. Abweichungen im kantonalen Recht bis zu vier Monaten vor und nach diesem Datum sind zulässig;"
            },
            {
              "marke": "b",
              "text": "die Schulpflicht für Knaben und Mädchen dauert bei mindestens 38 Schulwochen mindestens 9 Jahre;"
            },
            {
              "marke": "c",
              "text": "die ordentliche Ausbildungszeit vom Eintritt in die Schulpflicht bis zur Maturitätsprüfung dauert mindestens 12, höchstens 13 Jahre;"
            },
            {
              "marke": "d",
              "text": "das Schuljahr beginnt zwischen Mitte August und Mitte Oktober."
            }
          ]
        }
      ],
      "stand": "1987-04-23",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.180",
      "abgerufen": "2026-06-23",
      "fassungsToken": "23d9920bee0bfa88b2fc69fe99ff2852",
      "sha": "b63bc78a8be3ddfbef49ee3ac98e306c9a9acc25252591d9ace034d29047f330"
    },
    {
      "id": "kanton/BS/410.180/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Konkordat über die Schulkoordination (410.180)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "titel": "Empfehlungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Konkordatskantone arbeiten zuhanden aller Kantone Empfehlungen aus, insbesondere für folgende Bereiche:",
          "items": [
            {
              "marke": "a",
              "text": "Rahmenlehrpläne;"
            },
            {
              "marke": "b",
              "text": "gemeinsame Lehrmittel;"
            },
            {
              "marke": "c",
              "text": "Sicherstellung des freien Übertritts zwischen gleichwertigen Schulen;"
            },
            {
              "marke": "d",
              "text": "Übertritt in die aufgegliederten Oberstufen;"
            },
            {
              "marke": "e",
              "text": "Anerkennung von Examensabschlüssen und Diplomen, die in gleichwertigen Ausbildungsgängen erworben wurden;"
            },
            {
              "marke": "f",
              "text": "einheitliche Bezeichnung der gleichen Schulstufen und gleichen Schultypen;"
            },
            {
              "marke": "g",
              "text": "gleichwertige Lehrerausbildung."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die Konferenz schweizerischer Lehrerorganisationen ist bei der Ausarbeitung dieser Empfehlungen anzuhören."
        }
      ],
      "stand": "1987-04-23",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.180",
      "abgerufen": "2026-06-23",
      "fassungsToken": "23d9920bee0bfa88b2fc69fe99ff2852",
      "sha": "ae0eac90cc743f122c449769ec6668e16b87d7e1989c1d25e9996ea66e312a8f"
    },
    {
      "id": "kanton/BS/410.180/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Konkordat über die Schulkoordination (410.180)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "titel": "Zusammenarbeit",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Konkordatskantone arbeiten im Bereich der Bildungsplanung und -forschung sowie der Schulstatistik unter sich und mit dem Bund zusammen."
        },
        {
          "absatz": "2",
          "text": "Zu diesem Zweck werden:",
          "items": [
            {
              "marke": "a",
              "text": "für diese Zusammenarbeit notwendige Institutionen gefördert und unterstützt;"
            },
            {
              "marke": "b",
              "text": "Richtlinien für jährliche oder periodische schweizerische Schulstatistiken ausgearbeitet."
            }
          ]
        }
      ],
      "stand": "1987-04-23",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.180",
      "abgerufen": "2026-06-23",
      "fassungsToken": "23d9920bee0bfa88b2fc69fe99ff2852",
      "sha": "89452525df4f8350b3e6c7101956201b1f883265b3fc7f3bc2947b18c900bee1"
    },
    {
      "id": "kanton/BS/410.180/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Konkordat über die Schulkoordination (410.180)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "titel": "Schweizerische Konferenz der kantonalen Erziehungsdirektoren",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Konkordatskantone übertragen der Konferenz der kantonalen Erziehungsdirektoren die Durchführung der unter Art. 2 bis Art. 4 festgelegten Aufgaben."
        },
        {
          "absatz": "2",
          "text": "Kompetenzen und Arbeitsweise werden in einem Geschäftsreglement niedergelegt."
        },
        {
          "absatz": "3",
          "text": "Die Kosten der Konkordatstätigkeit werden nach Massgabe der Einwohnerzahl unter die Kantone verteilt."
        },
        {
          "absatz": "4",
          "text": "Nicht-Konkordatskantone haben in Konkordatsgeschäften beratende Stimme."
        }
      ],
      "stand": "1987-04-23",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.180",
      "abgerufen": "2026-06-23",
      "fassungsToken": "23d9920bee0bfa88b2fc69fe99ff2852",
      "sha": "1cd008de632404538f059c391a4f09c284841bcd72f8a8b66e94f1b7633fcda1"
    },
    {
      "id": "kanton/BS/410.180/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Konkordat über die Schulkoordination (410.180)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "titel": "Regionalkonferenzen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zur Erleichterung und Förderung der Zusammenarbeit schliessen sich die Kantone zu vier Regionalkonferenzen zusammen (Westschweiz und Tessin, Nordwestschweiz, Innerschweiz, Ostschweiz). Über den Beitritt zu einer Regionalkonferenz entscheidet jeder Kanton selbst."
        },
        {
          "absatz": "2",
          "text": "Die Regionalkonferenzen beraten die Geschäfte der Plenarkonferenz vor."
        }
      ],
      "stand": "1987-04-23",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.180",
      "abgerufen": "2026-06-23",
      "fassungsToken": "23d9920bee0bfa88b2fc69fe99ff2852",
      "sha": "65ca6a547376afde184070a60bbbd39f08d4b1398a74b60bc8afb89276c77f33"
    },
    {
      "id": "kanton/BS/410.180/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Konkordat über die Schulkoordination (410.180)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "titel": "Rechtsschutz",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Streitigkeiten, die sich aus dem Konkordat zwischen Kantonen ergeben, entscheidet auf Klage hin das Bundesgericht."
        }
      ],
      "stand": "1987-04-23",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.180",
      "abgerufen": "2026-06-23",
      "fassungsToken": "23d9920bee0bfa88b2fc69fe99ff2852",
      "sha": "013a7113ca637b51d40c5c9281435e4c5aa2c521d332667e8939955830705dcf"
    },
    {
      "id": "kanton/BS/410.180/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Konkordat über die Schulkoordination (410.180)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "titel": "Fristen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Angleichung der Schulgesetzgebungen im Sinne von Art. 2 dieses Konkordats wird etappenweise vollzogen."
        },
        {
          "absatz": "2",
          "text": "Die Konkordatskantone verpflichten sich:",
          "items": [
            {
              "marke": "a",
              "text": "in einem Zeitraum von sechs Jahren das Schuleintrittsalter im Sinne von Art. 2a festzulegen;"
            },
            {
              "marke": "b",
              "text": "die Schulpflicht in einer angemessenen Zeitspanne auf neun Jahre auszudehnen. Die Kantone mit nur siebenjähriger Schulpflicht können dies in zwei Etappen verwirklichen."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Die Festsetzung des Schuljahrbeginns im Sinne von Art. 2d soll grundsätzlich auf den Beginn des Schuljahres 1973/74 erfolgen."
        }
      ],
      "stand": "1987-04-23",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.180",
      "abgerufen": "2026-06-23",
      "fassungsToken": "23d9920bee0bfa88b2fc69fe99ff2852",
      "sha": "24d66c9bc429e00a77594cc61d91fcb5d87324d54c1a8e60d4ff1e3ae75aa837"
    },
    {
      "id": "kanton/BS/410.180/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Konkordat über die Schulkoordination (410.180)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "titel": "Beitritt",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Beitritt zum Konkordat wird dem Vorstand der Schweizerischen Konferenz der kantonalen Erziehungsdirektoren gegenüber erklärt, der dem Bundesrat Mitteilung macht."
        }
      ],
      "stand": "1987-04-23",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.180",
      "abgerufen": "2026-06-23",
      "fassungsToken": "23d9920bee0bfa88b2fc69fe99ff2852",
      "sha": "18edff6ee2d0a254543322e6959681860fa9e7244c5cb22eaa52eeede1e6c5fa"
    },
    {
      "id": "kanton/BS/410.180/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Konkordat über die Schulkoordination (410.180)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "titel": "Austritt",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Austritt aus dem Konkordat muss dem Vorstand der Schweizerischen Konferenz der kantonalen Erziehungsdirektoren gegenüber erklärt werden. Er tritt in Kraft auf Ende des dritten der Austrittserklärung folgenden Kalenderjahres."
        }
      ],
      "stand": "1987-04-23",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.180",
      "abgerufen": "2026-06-23",
      "fassungsToken": "23d9920bee0bfa88b2fc69fe99ff2852",
      "sha": "df39e0dccbd7babc1f5871bc037b6967f9b86e7f8ae94e0f7e7ced3aa2f07235"
    },
    {
      "id": "kanton/BS/410.180/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Konkordat über die Schulkoordination (410.180)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "titel": "Inkrafttreten",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieses Konkordat tritt in Kraft, wenn ihm zehn Kantone beigetreten sind und wenn es vom Schweizerischen Bundesrat genehmigt worden ist."
        }
      ],
      "stand": "1987-04-23",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/410.180",
      "abgerufen": "2026-06-23",
      "fassungsToken": "23d9920bee0bfa88b2fc69fe99ff2852",
      "sha": "d0dc68aae92f4ed78dfa00a047c41c419f44d84fb725c7cda9ac074f8e501cde"
    }
  ]
}