{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/576.100/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieses Gesetz regelt den Vollzug der Bundesgesetzgebung und ihrer Ausführungserlasse über den Zivilschutz und den Kulturgüterschutz."
        },
        {
          "absatz": "2",
          "text": "Für den Zivilschutz regelt es namentlich die Organisation, die Aufgaben und die Zuständigkeiten, den Bau und den Betrieb der Schutzbauten, die Verwaltung des Materials sowie die Finanzierung."
        },
        {
          "absatz": "3",
          "text": "Für den Kulturgüterschutz regelt es namentlich die Organisation, die Zuständigkeiten, die Schutzmassnahmen und deren Kostentragung sowie die Meldepflichten."
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "5f35b0da421a07d64b45419ed14d0e7cde369e82b9e66e27c214bbc779716dad"
    },
    {
      "id": "kanton/BS/576.100/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton ist für den Zivilschutz zuständig, soweit nicht der Bund zuständig ist."
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "5ebd8c8a1520384dafc06d93b29a3f04a2191dac8185b99cceb69006c2805af8"
    },
    {
      "id": "kanton/BS/576.100/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Es besteht eine einzige Zivilschutzorganisation."
        },
        {
          "absatz": "2",
          "text": "Der Regierungsrat bezeichnet die für den Zivilschutz zuständigen kantonalen Stellen."
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "e1989a488e5805dcc75f14b6c1b850fa9614add57c9843dffd515861db78ba25"
    },
    {
      "id": "kanton/BS/576.100/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Zivilschutz nimmt die ihm von der Bundesgesetzgebung und diesem Gesetz ausdrücklich zugewiesenen Aufgaben wahr."
        },
        {
          "absatz": "2",
          "text": "Der Regierungsrat kann dem Zivilschutz weitere Aufgaben des Bevölkerungsschutzes übertragen."
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "0e67a85be958a9fbe7445a21218f8480b77bb9fb3948d2ae8d5961e5be122697"
    },
    {
      "id": "kanton/BS/576.100/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat regelt das Aufgebot zur Ausbildung und zu den Einsätzen."
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "ddd8af4b1b79853342316ebec2da3e37428f2590eb1eabe4af1767ff5eac822f"
    },
    {
      "id": "kanton/BS/576.100/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat legt die Dauer der in der Zuständigkeit des Kantons liegenden Ausbildungen fest."
        },
        {
          "absatz": "2",
          "text": "Freiwillig Schutzdienstleistende absolvieren die Grundausbildung."
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "a2171a75fe72ed96b8059a5c217ca5e6654d1a39845e6dcf85c10006227404c9"
    },
    {
      "id": "kanton/BS/576.100/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat legt die Höhe der Ersatzbeiträge für nicht erstellte Schutzplätze fest."
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "6edff4ddc1c1c5fa02deab855ab98ab4ab6466b4c380a8298ca5771290ebb29a"
    },
    {
      "id": "kanton/BS/576.100/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Baugesuche sind im Rahmen des Baubewilligungsverfahrens der für den Zivilschutz zuständigen kantonalen Stelle vorzulegen:",
          "items": [
            {
              "marke": "a",
              "text": "zur Prüfung der Schutzraumbaupflicht, sofern sie den Bau von Wohnhäusern, Heimen und Spitälern enthalten;"
            },
            {
              "marke": "b",
              "text": "zur Überprüfung der Zulässigkeit von Änderungen an bestehenden Schutzräumen, sofern bei einer Sanierung, einem Umbau oder einer Nutzungsänderung von Gebäuden Änderungen an der Struktur eines Schutzraums oder an den technischen Schutzbausystemen vorgesehen sind;"
            },
            {
              "marke": "c",
              "text": "wenn sie ein Schutzraumprojekt zum Neubau oder zur Erneuerung von Schutzräumen enthalten."
            }
          ]
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "2155a9b951a5ded1684f687cafddb10fd5d591a20de12d7f289e3e7ed3e9bf96"
    },
    {
      "id": "kanton/BS/576.100/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die zivilschutzfremde Nutzung von Schutzbauten ist zulässig."
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "d12fa30cd08d4f33ab48edeb5837d6e40e0bf82adcd2fa1eda00a85d84869940"
    },
    {
      "id": "kanton/BS/576.100/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Material des Zivilschutzes kann den Partnerorganisationen ausgeliehen werden."
        },
        {
          "absatz": "2",
          "text": "Die Partnerorganisation haftet für am entliehenen Material entstandene Schäden oder dessen Verlust."
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "00331b1bf66d76aee2e01ef4a336f7357183545c712c198e5d9f9f12d9ca38d9"
    },
    {
      "id": "kanton/BS/576.100/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton trägt die Kosten für den Zivilschutz, soweit diese nicht der Bund trägt."
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "0061cea213a42bc0fbfecf3f7ffaf23a795c5cfa54fd461b0ef071439e2a908a"
    },
    {
      "id": "kanton/BS/576.100/art_12",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "12",
      "artikelLabel": "§ 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kosten für Einsätze des Zivilschutzes können der Verursacherin oder dem Verursacher auferlegt werden."
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "30f711a98804788181ffe1abfa5e01fe6a494f15dea00be6b271cac052592bbc"
    },
    {
      "id": "kanton/BS/576.100/art_13",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "13",
      "artikelLabel": "§ 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für vermögensrechtliche Ansprüche richten sich die Verfahren über Schadenersatzansprüche und Rückgriffsforderungen betreffend Schäden nach den Vorschriften des Gesetzes über die Haftung des Staates und seines Personals (Haftungsgesetz, HG) vom 17. November 1999. Dabei gelten alle Angehörigen des Zivilschutzes als Personal des Staates."
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "4f0df2f149670b1497e56cc38780793ad8965fda3b022254ef8c6aa14179971a"
    },
    {
      "id": "kanton/BS/576.100/art_14",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "14",
      "artikelLabel": "§ 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton ist für den Kulturgüterschutz zuständig, soweit nicht der Bund zuständig ist."
        },
        {
          "absatz": "2",
          "text": "Der Regierungsrat bezeichnet die für den Kulturgüterschutz zuständige kantonale Stelle."
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "9f397e62e4ced2c18950c3bf415322042f66565833d35bedc6f4db9cf9be9194"
    },
    {
      "id": "kanton/BS/576.100/art_15",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "15",
      "artikelLabel": "§ 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Kulturgüter von nationaler Bedeutung (A-Objekte) und regionaler Bedeutung (B-Objekte), die sich auf dem Kantonsgebiet befinden, werden im Schweizerischen Inventar der Kulturgüter von nationaler und regionaler Bedeutung erfasst."
        },
        {
          "absatz": "2",
          "text": "Der Kanton erstellt und führt ein Inventar für Kulturgüter von lokaler Bedeutung (C-Objekte). Der Regierungsrat regelt das Verfahren zur Erstellung und Nachführung dieses Inventars."
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "64a44ca7026681500429f649fd0e37b7603ef5b969fa60b6648455c7d07e5fb2"
    },
    {
      "id": "kanton/BS/576.100/art_16",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "16",
      "artikelLabel": "§ 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Eigentümerinnen und Eigentümer von beweglichen Kulturgütern erstellen ein Verzeichnis der einzelnen Objekte, das der zuständigen kantonalen Stelle zur Verfügung gestellt wird."
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "fa8b018bdfa598bf114f415a3701a579139c1e4433017c31fd8b398c83bc9482"
    },
    {
      "id": "kanton/BS/576.100/art_17",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "17",
      "artikelLabel": "§ 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton, die weiteren Personen des öffentlichen Rechts sowie Private sind für den Schutz von Kulturgütern verantwortlich, die sich in ihrem Eigentum befinden."
        },
        {
          "absatz": "2",
          "text": "Die zuständige kantonale Stelle kann Schutzmassnahmen baulicher und organisatorischer Natur anordnen. Die Eigentümerinnen und Eigentümer sind verpflichtet, entsprechende Massnahmen zu treffen oder zu dulden. Sie tragen unter Vorbehalt von Abs. 3 und der Kostentragung durch den Bund die Kosten der Massnahmen."
        },
        {
          "absatz": "3",
          "text": "Der Kanton stellt im Rahmen der Möglichkeiten und auf Antrag der Eigentümerinnen und Eigentümer technische und personelle Mittel des Zivilschutzes für die Planung und Durchführung von Schutzmassnahmen zur Verfügung. Diese Dienstleistungen sind kostenlos, soweit sie im Rahmen eines ordentlichen Aufgebots des Zivilschutzes erfolgen."
        },
        {
          "absatz": "4",
          "text": "Die zuständige kantonale Stelle ist berechtigt, Kulturgüter und die getroffenen Schutzmassnahmen zu kontrollieren."
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "a90095329f975c49e743723fc8fcd4ffc72c491294449075e48eae03b8a572af"
    },
    {
      "id": "kanton/BS/576.100/art_18",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "18",
      "artikelLabel": "§ 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für den Bau, den Unterhalt und die Aufhebung von Kulturgüterschutzräumen sind die Bestimmungen des Bundesrechts sowie des kantonalen Rechts betreffend Schutzbauten sinngemäss anwendbar."
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "3d7aecc6faf9816bd5bba0541218bdcf9188ed465a8f9a1dfa9f909ba2c38a99"
    },
    {
      "id": "kanton/BS/576.100/art_19",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "19",
      "artikelLabel": "§ 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Eigentümerinnen und Eigentümer melden der zuständigen kantonalen Stelle:",
          "items": [
            {
              "marke": "a",
              "text": "offensichtliche Gefahren für Schädigungen und Verlust von Kulturgütern;"
            },
            {
              "marke": "b",
              "text": "den Verlust von Kulturgütern;"
            },
            {
              "marke": "c",
              "text": "Schäden an Kulturgütern;"
            },
            {
              "marke": "d",
              "text": "bei beweglichen Kulturgütern den Standortwechsel aus dem Kanton."
            }
          ]
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "2da378a5160b6b538a6ef9161e12f985e75f0c13e5936e7e7cc0a8c89615cd29"
    },
    {
      "id": "kanton/BS/576.100/art_20",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "20",
      "artikelLabel": "§ 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die für den Zivilschutz und den Kulturgüterschutz zuständigen kantonalen Stellen können für Bewilligungen, Kontrollen und Dienstleistungen Gebühren erheben."
        }
      ],
      "stand": "2023-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3605c8859d9beac73e212cb176b5c6f7",
      "sha": "e2b0e6b37acb72cdac7d2a10c21ce2a6b3959e48179dead4b6d4043c6095c980"
    },
    {
      "id": "kanton/BS/576.100/art_21",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Zivil- und Kulturgüterschutzgesetz, ZKG (576.100)",
      "artikel": "21",
      "artikelLabel": "§ 21",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gegen auf dieses Gesetz, seine Ausführungsbestimmungen und auf die Bundesgesetzgebung über den Zivilschutz und den Kulturgüterschutz gestützte Verfügungen kann nach den Vorschriften des Gesetzes betreffend die Organisation des Regierungsrates und der Verwaltung des Kantons Basel-Stadt (Organisationsgesetz, OG) vom 22. April 1976 Rekurs erhoben werden. Davon ausgenommen sind Verfügungen in Bausachen."
        },
        {
          "absatz": "2",
          "text": "Gegen Verfügungen in Bausachen kann nach den Vorschriften des Gesetzes betreffend die Baurekurskommission (BRKG) vom 7. Juni 2000 bei der Baurekurskommission Rekurs erhoben werden."
        }
      ],
