{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/122.11/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Registergesetz (122.11)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Departement Inneres und Sicherheit beaufsichtigt den Vollzug des Registergesetzes, soweit keine besondere Zuständigkeit besteht."
        }
      ],
      "stand": "2019-11-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/122.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9c02bcae6a8a6098067f07c36cdadc69",
      "sha": "a604862cfd7c590afab4efc555e0cfcd63a0f10d88770054570f9f70d9d8b6cb"
    },
    {
      "id": "kanton/AR/122.11/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Registergesetz (122.11)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Departement Inneres und Sicherheit führt eine Koordinationsstelle im Sinne von Art. 9 des Bundesgesetzes über die Harmonisierung der Einwohnerregister und anderer amtlicher Personenregister."
        }
      ],
      "stand": "2019-11-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/122.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9c02bcae6a8a6098067f07c36cdadc69",
      "sha": "cb3d6f43220f3ebd4d56295e61e92f8b101af57a204b34d9ce0408a92bb11eac"
    },
    {
      "id": "kanton/AR/122.11/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Registergesetz (122.11)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gemeinde kann zur Überprüfung der Identität und zur Erfassung der Merkmale die Vorlage amtlicher und privater Dokumente verlangen. Insbesondere können folgende Dokumente verlangt werden:",
          "items": [
            {
              "marke": "a",
              "text": "Pass oder Identitätskarte;"
            },
            {
              "marke": "b",
              "text": "Geburtsschein;"
            },
            {
              "marke": "c",
              "text": "Personenstandausweis, Familienausweis oder Partnerschaftsausweis;"
            },
            {
              "marke": "d",
              "text": "Ausländerausweis;"
            },
            {
              "marke": "e",
              "text": "Führerausweis;"
            },
            {
              "marke": "f",
              "text": "Arbeitsvertrag;"
            },
            {
              "marke": "g",
              "text": "Mietvertrag;"
            },
            {
              "marke": "h",
              "text": "Kaufvertrag für bewohnte Liegenschaft oder Wohnung;"
            },
            {
              "marke": "i",
              "text": "Auszug über die Regelung des Sorgerechts."
            }
          ]
        }
      ],
      "stand": "2019-11-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/122.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9c02bcae6a8a6098067f07c36cdadc69",
      "sha": "8f931139f4368cf60d19fa5058a00a3406776338e83ff0569c62646aa120e2c5"
    },
    {
      "id": "kanton/AR/122.11/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Registergesetz (122.11)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Leiterinnen und Leiter von Kollektivhaushalten nachstehender Kategorien melden der Einwohnerkontrolle die Bewohnerinnen und Bewohner, welche sich seit mindestens drei aufeinanderfolgenden Monaten oder während drei Monaten innerhalb eines Jahres in ihrem Kollektivhaushalt aufhalten:",
          "items": [
            {
              "marke": "a",
              "text": "Alters- und Pflegeheime;"
            },
            {
              "marke": "b",
              "text": "Wohnungen und Heime für Kinder und Jugendliche;"
            },
            {
              "marke": "c",
              "text": "Internate und Studentenwohnheime;"
            },
            {
              "marke": "d",
              "text": "Institutionen für Behinderte;"
            },
            {
              "marke": "e",
              "text": "Klöster und andere Unterkünfte religiöser Vereinigungen."
            }
          ]
        }
      ],
      "stand": "2019-11-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/122.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9c02bcae6a8a6098067f07c36cdadc69",
      "sha": "fc951563f36706a1bd111be44ec5b9bfe2018a4afc4f2bea8267d1c531cab571"
    },
    {
      "id": "kanton/AR/122.11/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Registergesetz (122.11)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Leiterinnen und Leiter von Kollektivhaushalten nachstehender Kategorien melden dem Bundesamt für Statistik jährlich mit Stichtag 31. Dezember die auf vereinfachte Art erhobenen Bewohnerinnen und Bewohner, welche sich seit mindestens drei aufeinanderfolgenden Monaten oder während drei Monaten innerhalb eines Jahres in ihrem Kollektivhaushalt aufhalten:",
          "items": [
            {
              "marke": "a",
              "text": "Spitäler, Heilstätten und ähnliche Institutionen im Gesundheitsbereich;"
            },
            {
              "marke": "b",
              "text": "Einrichtungen der psychiatrischen Langzeitpflege;"
            },
            {
              "marke": "c",
              "text": "Institutionen des Straf- und Massnahmenvollzugs für Jugendliche und Erwachsene;"
            },
            {
              "marke": "d",
              "text": "Gemeinschaftsunterkünfte für Asylsuchende."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Für Bewohnerinnen und Bewohner gemäss Abs. 1 entfällt die individuelle Meldepflicht."
        }
      ],
      "stand": "2019-11-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/122.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9c02bcae6a8a6098067f07c36cdadc69",
      "sha": "a63e9d121d350665bad548711d41357eb2e16cd882b179c9a1bbe5be4eae30d1"
    },
    {
      "id": "kanton/AR/122.11/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Registergesetz (122.11)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Stimmregister sind öffentlich. Es wird in folgende Angaben Einsicht gewährt: Name, Vorname, Adresse und Geburtsdatum."
        }
      ],
      "stand": "2019-11-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/122.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9c02bcae6a8a6098067f07c36cdadc69",
      "sha": "b231fd0388b94223cdf93d5ea73344b11189fc2f36cf5a0b28c671b7610851df"
    },
    {
      "id": "kanton/AR/122.11/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Registergesetz (122.11)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Jede Gemeinde führt elektronisch ein separates Register, in dem die in der Gemeinde stimmberechtigten Auslandschweizerinnen und -schweizer einzutragen sind."
        },
        {
          "absatz": "2",
          "text": "Die Voraussetzungen für die Eintragungen und Streichungen richten sich nach den Bestimmungen der Bundesgesetzgebung über Schweizer Personen und Institutionen im Ausland."
        },
        {
          "absatz": "3",
          "text": "Im Stimmregister sind für alle stimmberechtigten Auslandschweizerinnen und -schweizer einzutragen:",
          "items": [
            {
              "marke": "a",
              "text": "der Name und die Vornamen;"
            },
            {
              "marke": "b",
              "text": "das Geburtsdatum und der Geburtsort;"
            },
            {
              "marke": "c",
              "text": "das Geschlecht;"
            },
            {
              "marke": "d",
              "text": "die Wohnadresse;"
            },
            {
              "marke": "e",
              "text": "sämtliche Heimatgemeinden und Heimatkantone;"
            },
            {
              "marke": "f",
              "text": "Amtssprache für die Abstimmungsunterlagen;"
            },
            {
              "marke": "g",
              "text": "Datum des Beginns des Stimmrechts;"
            },
            {
              "marke": "h",
              "text": "Datum und Grund der Streichung."
            }
          ]
        }
      ],
      "stand": "2019-11-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/122.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9c02bcae6a8a6098067f07c36cdadc69",
      "sha": "fb9511ca8ad0ce44a77bb73a5ff6fcb2a27837ac4648852c45f371b49314c501"
    },
    {
      "id": "kanton/AR/122.11/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Registergesetz (122.11)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Zugriff auf Daten der kantonalen Einwohnerdatenplattform richtet sich nach dem vom Regierungsrat erlassenen und im Internet veröffentlichten Berechtigungskonzept."
        },
        {
          "absatz": "2",
          "text": "Gesuche um Erteilung der Zugriffsberechtigung sind unter Angabe der notwendigen Informationen bei der Koordinationsstelle einzureichen. Die Koordinationsstelle holt die Stellungnahme des Datenschutz-Kontrollorgans ein."
        },
        {
          "absatz": "3",
          "text": "Die berechtigten Stellen und der Umfang ihrer Zugriffsberechtigung werden im Internet veröffentlicht."
        }
      ],
      "stand": "2019-11-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/122.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9c02bcae6a8a6098067f07c36cdadc69",
      "sha": "3b04e3d51e6cf14a35611af4d4feaf4bca3d7ab568fb3ea39d8b3ca76c967f4c"
    },
    {
      "id": "kanton/AR/122.11/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Registergesetz (122.11)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zugriffe auf die kantonale Einwohnerdatenplattform werden protokolliert. Das Protokoll enthält das Lesen von Daten sowie die Datenexporte."
        },
        {
          "absatz": "2",
          "text": "Die Protokolle werden während eines Jahres gespeichert und anschliessend gelöscht."
        }
      ],
      "stand": "2019-11-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/122.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9c02bcae6a8a6098067f07c36cdadc69",
      "sha": "8a0cee5bb17f57587e55a2a215130a97cb788b1f5fe6ceda1dcef77bcad517ae"
    }
  ]
}