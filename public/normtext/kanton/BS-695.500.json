{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/695.500/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Beitragsreglement der Gebäudeversicherung (695.500)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "An die Kosten der notwendigen Aufwendungen für Brandschutzeinrichtungen in Gebäuden aller Risikoklassen leistet die Gebäudeversicherung vorbehältlich Ziff. 4 und 5 Beiträge bis höchstens 50% gemäss der Beitragstabelle unter Ziff. 10. Brandschutzeinrichtungen, an die Beiträge geleistet wurden, sind regelmässig und fachtechnisch richtig zu warten bzw. zu unterhalten."
        },
        {
          "absatz": "2",
          "text": "Beitragsberechtigt sind:",
          "items": [
            {
              "marke": "a",
              "text": "die fachgerechte Erstellung anerkannter automatischer Brandmeldeanlagen;"
            },
            {
              "marke": "b",
              "text": "die fachgerechte Erstellung anerkannter Gaswarnanlagen;"
            },
            {
              "marke": "c",
              "text": "die fachgerechte Erstellung anerkannter Sprinkleranlagen;"
            },
            {
              "marke": "d",
              "text": "die fachgerechte Erstellung von Innenlöscheinrichtungen;"
            },
            {
              "marke": "e",
              "text": "die fachgerechte Erstellung von Blitzschutzanlagen;"
            },
            {
              "marke": "f",
              "text": "die fachgerechte Erstellung von Brandschutztüren und -toren in bestehenden Gebäuden;"
            },
            {
              "marke": "g",
              "text": "die fachgerechte Erstellung von Brandschutzklappen in Ventilationskanälen in bestehenden Gebäuden;"
            },
            {
              "marke": "h",
              "text": "die Umrüstungskosten von technischen Übermittlungssystemen zur Berufsfeuerwehr Basel-Stadt."
            }
          ]
        },
        {
          "absatz": "2bis",
          "text": "Die Beitragsberechtigung gemäss Abs. 2 ist begrenzt auf die direkten Material- und Montagekosten der brandschutzrelevanten Installationen, ohne die Kosten für allfällige Anpassungsarbeiten oder Zusatzinstallationen. Bei Brandschutztüren und -toren ist lediglich der Kostenteil für die Türen oder Tore (inkl. Zargen) ohne feste Wand- und Deckenanschlusselemente beitragsberechtigt."
        },
        {
          "absatz": "3",
          "text": "Ferner leistet die Gebäudeversicherung einen Beitrag von 50% an die Kosten der Wiederauffüllung von Handfeuerlöschern, die bei der Bekämpfung eines Brandes zur Schadenverminderung eingesetzt wurden."
        }
      ],
      "stand": "2023-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d9312d9eea3b74e820f17e085a0178fd",
      "sha": "4e874e8ad36e25bd3b2c6d7410b6bc67d96f942d74c2efbcd49633ec861b7f36"
    },
    {
      "id": "kanton/BS/695.500/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Beitragsreglement der Gebäudeversicherung (695.500)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Vorbehältlich Ziff. 4 und 5 leistet die Gebäudeversicherung Beiträge bis höchstens 50%, im Maximum CHF 150'000 pro Kalenderjahr gemäss der Beitragstabelle unter Ziff. 10, an die Anschaffungskosten von Feuerwehrgeräten der Betriebs- und Werkfeuerwehren bis und mit Stufe 3."
        },
        {
          "absatz": "2",
          "text": "Beitragsberechtigt sind insbesondere:",
          "items": [
            {
              "marke": "a",
              "text": "Autodrehleitern, Anhängeleitern, Strebenleitern, Handschiebeleitern, Anstelleitern;"
            },
            {
              "marke": "b",
              "text": "Tanklöschfahrzeuge, Sonderlöschfahrzeuge;"
            },
            {
              "marke": "c",
              "text": "Motorspritzen;"
            },
            {
              "marke": "d",
              "text": "Pionierfahrzeuge;"
            },
            {
              "marke": "e",
              "text": "Transport- und Pikettfahrzeuge;"
            },
            {
              "marke": "f",
              "text": "fahrbare Schaumgeräte;"
            },
            {
              "marke": "g",
              "text": "Löschgeräte ab 50 kg Nutzinhalt;"
            },
            {
              "marke": "h",
              "text": "Wasserwerfer, Strahlrohre, Luftschaumrohre;"
            },
            {
              "marke": "i",
              "text": "Feuerwehrschläuche;"
            },
            {
              "marke": "j",
              "text": "Armaturen;"
            },
            {
              "marke": "k",
              "text": "Feuerwehr-Beleuchtungsmaterial;"
            },
            {
              "marke": "l",
              "text": "Rettungsgeräte;"
            },
            {
              "marke": "m",
              "text": "Löschdecken;"
            },
            {
              "marke": "n",
              "text": "Pumpen für den Einsatz bei Überflutungen;"
            },
            {
              "marke": "o",
              "text": "vom Schweizerischen Feuerwehrverband (SFV) anerkannte Atemschutzgeräte;"
            },
            {
              "marke": "p",
              "text": "persönliche Ausrüstung für den Branddienst;"
            },
            {
              "marke": "q",
              "text": "weitere, dem Stand der Technik angepasste Geräte und Materialien, sofern sie vom SFV anerkannt sind."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Werkfeuerwehren der Stufe 4 erhalten an ihre Ausbildungs- und Anschaffungskosten einen Pauschalbeitrag von 10% der fakturierten Prämie der von ihnen im Kanton Basel-Stadt geschützten Werkareale."
        },
        {
          "absatz": "4",
          "text": "Die Gebäudeversicherung behält sich vor, Beitragsgesuche durch Fachexperten prüfen zu lassen. Der Weiterverkauf von Geräten, an welche Beiträge ausgerichtet wurden, ist meldepflichtig. Je nach Lebensdauer der Geräte kann ein Teil der Beiträge zurückgefordert werden."
        }
      ],
      "stand": "2023-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d9312d9eea3b74e820f17e085a0178fd",
      "sha": "b337b522ef6ce48780175d38eef5de81d5b14d8be1dfa1a474583433a436f062"
    },
    {
      "id": "kanton/BS/695.500/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Beitragsreglement der Gebäudeversicherung (695.500)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "An die Berufs- und Bezirksfeuerwehren des Kantons Basel-Stadt werden, vorbehältlich § 23 Abs. 2 der VGVG nur in Sonderfällen Beiträge ausgerichtet."
        }
      ],
      "stand": "2023-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d9312d9eea3b74e820f17e085a0178fd",
      "sha": "1afbe762f6b33f667ac262c4d065ece8dfe274d966194bd26143a118b58aca3c"
    },
    {
      "id": "kanton/BS/695.500/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Beitragsreglement der Gebäudeversicherung (695.500)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Berechnung der Beiträge gemäss Ziff. 1, 2 und 9 sind die kumulierten Gesamtkosten der innerhalb eines Jahres subventionsberechtigten Installationen massgebend."
        },
        {
          "absatz": "2",
          "text": "Leistungen Dritter werden für die Berechnung der Beiträge abgezogen."
        }
      ],
      "stand": "2023-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d9312d9eea3b74e820f17e085a0178fd",
      "sha": "59e768940346e86810ac2f4a8f4032047f7141c8b217a28ec7f29d7e2e3bf191"
    },
    {
      "id": "kanton/BS/695.500/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Beitragsreglement der Gebäudeversicherung (695.500)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gesuche für Beiträge gemäss Ziff. 1, 2 und 9 (Schutzeinrichtungen) sind bei der Gebäudeversicherung schriftlich mit den erforderlichen Unterlagen spätestens innert eines Jahres ab deren Inbetriebnahme anzumelden."
        },
        {
          "absatz": "2",
          "text": "Verspätet eingereichte Beitragsgesuche können nicht berücksichtigt werden; der Anspruch auf allfällige Beiträge ist verwirkt."
        },
        {
          "absatz": "3",
          "text": "Ausgeführte Einrichtungen, die den Bestimmungen dieses Reglements nicht entsprechen, sind nicht beitragsberechtigt."
        }
      ],
      "stand": "2023-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d9312d9eea3b74e820f17e085a0178fd",
      "sha": "94c0414a9929249a4c03657798dd78197ba23ee4d3fecc931b9f9e68834d18da"
    },
    {
      "id": "kanton/BS/695.500/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Beitragsreglement der Gebäudeversicherung (695.500)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Brandschutzeinrichtungen, für die Beiträge ausgerichtet wurden, sind jederzeit in voller Einsatzbereitschaft zu halten. Bei Nichtbeachtung kann die Gebäudeversicherung im Schadenfall ihre Leistungen im Sinne von § 28 des Gebäudeversicherungsgesetzes während längstens zehn Jahren teilweise oder ganz zurückfordern."
        },
        {
          "absatz": "2",
          "text": "An die Unterhaltskosten werden keine Beiträge geleistet."
        }
      ],
      "stand": "2023-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d9312d9eea3b74e820f17e085a0178fd",
      "sha": "4f669adcf7722636fa3142354d8fec7e29749a9a35dd660989694edfa5107d23"
    },
    {
      "id": "kanton/BS/695.500/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Beitragsreglement der Gebäudeversicherung (695.500)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Rückwirkend werden keine Nachzahlungen zur Anpassung an die neuen Prämienermässigungssätze ausgerichtet."
        }
      ],
      "stand": "2023-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d9312d9eea3b74e820f17e085a0178fd",
      "sha": "a7148bbf718d1f2b4fad008169fce2e875966a4447d17b616ce2aeec4ee8897a"
    },
    {
      "id": "kanton/BS/695.500/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Beitragsreglement der Gebäudeversicherung (695.500)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "An die Kosten von Halon-Anlagen und Halon-Handfeuerlöschern leistet die Gebäudeversicherung keine Beiträge."
        }
      ],
      "stand": "2023-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.500",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d9312d9eea3b74e820f17e085a0178fd",
      "sha": "62324c61fa2870e2926ce13c5e9aed9358c49a6d6a0f92ed4419421e862923d2"
    },
    {
      "id": "kanton/BS/695.500/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Beitragsreglement der Gebäudeversicherung (695.500)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "An die Kosten der notwendigen Aufwendungen für Elementarschutzeinrichtungen für Gebäude aller Risikoklassen leistet die Gebäudeversicherung vorbehältlich Ziff. 4 und 5 Beiträge bis höchstens 50% gemäss der Beitragstabelle unter Ziff. 10, sofern dadurch ein Schaden erheblich vermindert werden kann. Elementarschutzeinrichtungen, an die Beiträge ausgerichtet wurden, sind regelmässig und fachtechnisch richtig zu unterhalten."
        },
        {
          "absatz": "2",
          "text": "An die Unterhaltskosten werden keine Beiträge geleistet."
        }
      ],
      "stand": "2023-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/695.500",
      "abgerufen": "2026-06-23",
