{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/421.111/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Während der Öffnungszeiten sind Lesesaal, Archivbibliothek und Mikrofilmraum allen interessierten Personen zugänglich. Die Öffnungszeiten werden beim Archiveingang und im Internet bekannt gegeben."
        },
        {
          "absatz": "2",
          "text": "Die Archivmagazine und die Diensträume sind nicht frei zugänglich."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "ae5e8f4c4371ec3f3de900cc32cabf56259f87f24761157f9ace570d6aa8326a"
    },
    {
      "id": "kanton/AR/421.111/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer Archiv- oder Bibliotheksgut im Lesesaal einsehen möchte, hat sich bei der Auskunftsperson anzumelden und das Benützungsformular auszufüllen."
        },
        {
          "absatz": "2",
          "text": "Archivgut für den Lesesaal kann vor Ort, per Brief, Telefon, E-Mail oder Internet bestellt werden. Beim Weggang bzw. vor Schliessung des Lesesaals ist das Archivgut zurückzugeben."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "5be0f129967599ab7c81ef6c2b41f873c0e75daa6f5eaf8aeb892590b6262ee5"
    },
    {
      "id": "kanton/AR/421.111/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Mäntel, Jacken, Taschen, Ess- und Trinkwaren etc. sind in den Garderobekästen zu deponieren. Über Nacht dürfen keine Sachen darin belassen werden. Für die Garderobe wird nicht gehaftet."
        },
        {
          "absatz": "2",
          "text": "Im Lesesaal sind Essen und Trinken sowie die Benützung von Mobiltelefonen verboten."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "62fa06ca9f26896a1b38835f5f4790680c4009d15f923efdbfb14e1daa3faba6"
    },
    {
      "id": "kanton/AR/421.111/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dokumente, an denen keine Schutzinteressen bestehen, sind im Rahmen der gesetzlichen Benützungsordnung und dieses Benützungsreglements allgemein zugänglich."
        },
        {
          "absatz": "2",
          "text": "Öffentliche Schutzinteressen gelten spätestens nach 30 Jahren, private Schutzinteressen gelten spätestens nach 120 Jahren seit Erstellung eines Dokumentes als erloschen."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "109c5a2e89e04a105a356d8f189b1c4b35355eee0a04b32c4e68d7fa6ba1cc23"
    },
    {
      "id": "kanton/AR/421.111/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dokumente, an denen öffentliche oder private Schutzinteressen bestehen, sind nicht allgemein zugänglich. Wer solches Archivgut einsehen will, hat dem Staatsarchiv ein schriftliches Gesuch einzureichen, worin das Interesse darzulegen ist und die interessierenden Dokumente möglichst genau zu bezeichnen sind."
        },
        {
          "absatz": "2",
          "text": "Die Einsicht wird gewährt, wenn ein berechtigtes Interesse nachgewiesen wird und soweit keine überwiegenden öffentlichen oder privaten Interessen entgegenstehen. Vorbehalten bleiben besondere Auflagen und Bedingungen."
        },
        {
          "absatz": "3",
          "text": "Ist die Einsicht strittig, erlässt das Staatsarchiv eine rekursfähige Verfügung."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "ff89e9ebec48520a8f0e4f382f02a3094a0f3e1bfb2de182a9dfe1db06f7c0f5"
    },
    {
      "id": "kanton/AR/421.111/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Archivgut ist mit grösstmöglicher Sorgfalt zu behandeln."
        },
        {
          "absatz": "2",
          "text": "Einträge auf Archivgut und das Anbringen von Fremdmaterialien (Büroklammern, Haftnotizzettel etc.) sind untersagt. Archivgut darf nicht als Schreibunterlage verwendet werden."
        },
        {
          "absatz": "3",
          "text": "Bei Akten und Karteien ist die bestehende Ordnung samt Dokumentenabfolge unverändert zu belassen."
        },
        {
          "absatz": "4",
          "text": "Bei Benützung von Fotografien und anderer heikler Dokumente sind Textilhandschuhe zu verwenden."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "dc35143674be298606bdd33c1537c15d2a52c27539867f91cf2137958c9b4517"
    },
    {
      "id": "kanton/AR/421.111/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Archivgut ist im Lesesaal einzusehen. Es darf nicht daraus entfernt werden."
        },
        {
          "absatz": "2",
          "text": "Aus konservatorischen Gründen können anstatt gefährdete Originale Mikrofilme oder Digitalisate vorgelegt werden. In diesen Fällen besteht kein Anspruch auf Einsicht in die Originale."
        },
        {
          "absatz": "3",
          "text": "Archivgut wird nicht an Privatpersonen ausgeliehen. Für Ausstellungs- oder Forschungszwecke kann Archivgut an Museen, Archive oder Bibliotheken ausgeliehen werden."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "8b248c86653a044894b7f357faa411ec48bc0d68c94f93e723bbd02980a7ebe9"
    },
    {
      "id": "kanton/AR/421.111/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Fotografieren von allgemein zugänglichem Archivgut für den privaten Gebrauch ist erlaubt. Die Verwendung von Blitzlicht oder Fotolampen ist nicht gestattet."
        },
        {
          "absatz": "2",
          "text": "Kopien oder Scans von Archivgut sind beim Archivpersonal zu bestellen."
        },
        {
          "absatz": "3",
          "text": "Reproduktionen von Archivgut sind nur für den privaten Gebrauch freigegeben. Vorbehalten bleiben besondere vertragliche Regelungen."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "bf62c398c55a4539b1c0c00a9690c451d2c9509b0b73b2d238bc016632751455"
    },
    {
      "id": "kanton/AR/421.111/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Publikation von Archivgut aus den Beständen des Staatsarchivs ist ein Hinweis auf die Herkunft (Staatsarchiv Appenzell Ausserrhoden) anzubringen."
        },
        {
          "absatz": "2",
          "text": "Von Publikationen, die unter Verwendung von ausserrhodischem Archivgut entstanden sind, sind dem Staatsarchiv unentgeltlich zwei Belegexemplare abzugeben."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "2c77012c20a1f3965e56335721c3ddc4d8022f1fea778425c09ee6326cf0b67b"
    },
    {
      "id": "kanton/AR/421.111/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Staatsarchiv hilft beim Auffinden einschlägigen Archivguts oder wichtiger Publikationen."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "75a1041513315ff2f267565916c0019c5631960acd3648f0a6338b4a8d027517"
    },
    {
      "id": "kanton/AR/421.111/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Mittels Druckschriften und im Internet informiert das Staatsarchiv über ausserrhodische Archivbestände."
        },
        {
          "absatz": "2",
          "text": "Das Staatsarchiv stellt im Lesesaal Findmittel zu Beständen von Staatsarchiv, Gemeindearchiven und Kirchenarchiven zur Verfügung."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "8000104d455a478b974fc303a6a0712a5d2d0491435574388088e4ffd282142b"
    },
    {
      "id": "kanton/AR/421.111/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Als Hilfsmittel zur Archivbenützung stellt das Staatsarchiv eine Präsenzbibliothek zur Verfügung."
        },
        {
          "absatz": "2",
          "text": "Der Bibliothekskatalog ist im Internet recherchierbar."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "1a16c0f3e96d1494ca31fb23706385b7748eebc8828641316314f3d024c6e2ce"
    },
    {
      "id": "kanton/AR/421.111/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zur Konsultation von Mikrofilmen steht ein Mikrofilm-Lesegerät zur Verfügung."
        },
        {
          "absatz": "2",
          "text": "Zur Recherche im elektronischen Archivverzeichnis sowie zur Konsultation von digitalem Archivgut steht eine Arbeitsstation zur Verfügung."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "63b13790ed524da730fba23600e64a8825c64f748e8dc910d7d27fab3a1dd82d"
    },
    {
      "id": "kanton/AR/421.111/art_14",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Staatsarchiv erstellt gegen Entgelt archivbezogene Recherchen und quellenbasierte Transkriptionen oder vermittelt dafür ausgewiesene Fachpersonen."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "cca119a4b37e39a187ea763a8360f96292cabbb44d1149d461d7ed8c7d9142a3"
    },
    {
      "id": "kanton/AR/421.111/art_15",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "15",
      "artikelLabel": "Art. 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Staatsarchiv digitalisiert gegen Gebühr Archivdokumente im Haus oder lässt davon auf Rechnung Mikrofilme, Digitalisate und Fotos herstellen."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "c15e16a0a02aff46ca557d60b989cb414c33b2fbe7c03a014f9c731be23fda5f"
    },
    {
      "id": "kanton/AR/421.111/art_16",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "16",
      "artikelLabel": "Art. 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Einsichtnahme in Archivgut ist unentgeltlich. Besondere Dienstleistungen sind kostenpflichtig."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "df29c812fc907e2ef2efdf5b4350e1c5e3506de9db2e5b3f6c47927d8e006647"
    },
    {
      "id": "kanton/AR/421.111/art_17",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "17",
      "artikelLabel": "Art. 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Es gelten nachfolgende Gebührenansätze:",
          "items": [
            {
              "marke": "a",
              "text": "Kopie von Druckschriften (Selbstbedienung) Fr. -.20"
            },
            {
              "marke": "b",
              "text": "Kopie ab Mikrofilm (Selbstbedienung) Fr. 1.00"
            },
            {
              "marke": "c",
              "text": "Scan ab Mikrofilm (Selbstbedienung) Fr. 1.00"
            },
            {
              "marke": "d",
              "text": "Kopie von Archivgut Fr. 1.00"
            },
            {
              "marke": "e",
              "text": "Scan ab Originalvorlage (je nach Format) Fr. 10.00 bis Fr. 100.00"
            },
            {
              "marke": "f",
              "text": "Foto ab Negativ/Dia/Scan (je nach Format) Fr. 20.00 bis Fr. 100.00"
            },
            {
              "marke": "g",
              "text": "Benützung des Mikrofilmgeräts, pro Halbtag Fr. 10.00"
            },
            {
              "marke": "h",
              "text": "Zustellgebühr (Porto, Verpackung) Fr. 5.00"
            }
          ]
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "d888e225fe46b2c2eb1ba565fbae81420785a74f6f82649cc7fa6e057e20ae93"
    },
    {
      "id": "kanton/AR/421.111/art_18",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Recherchen und Transkriptionen im Auftrag (je Arbeitsstunde) Fr. 80.00"
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "568e1989eb63cac79e99473a04a180c929b66abaf39e920e637f2cbb712f1f98"
    },
    {
      "id": "kanton/AR/421.111/art_19",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "19",
      "artikelLabel": "Art. 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Entgelt für die Veröffentlichung von Archivdokumenten sowie für weitere besondere Dienstleistungen des Staatsarchivs wird nach Vereinbarung festgelegt."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "940001ec195f180dd33ad7d7ce8cf4a9aea923c6e4da4d5f14deab6d70615577"
    },
    {
      "id": "kanton/AR/421.111/art_20",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "20",
      "artikelLabel": "Art. 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer in grober Weise oder wiederholt gegen die Benützungsbestimmungen verstösst, kann von der weiteren Archivbenützung ausgeschlossen werden."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/421.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "15e9c3f8bbd02125910c9031c7588300",
      "sha": "05ee1f8ffbc818cdf7c3c460938c04d93580eed07e274e5b4bfe367508ac48d5"
    },
    {
      "id": "kanton/AR/421.111/art_21",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Benützungsreglement für das Staatsarchiv (421.111)",
      "artikel": "21",
      "artikelLabel": "Art. 21",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer vorsätzlich als archivwürdig bezeichnete Dokumente beschädigt, verheimlicht, veräussert oder auf andere Weise der geordneten Archivierung entzieht, wird mit Busse bestraft."
        },
        {
          "absatz": "2",
          "text": "Wer vorsätzlich oder grobfahrlässig gegen das Benützungsreglement oder gegen im Einzelfall getroffene Anordnungen über die Benützung von Archivgut verstösst, wird mit Busse bestraft."
        }
