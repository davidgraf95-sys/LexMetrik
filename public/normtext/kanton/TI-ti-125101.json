      "artikel": "23",
      "artikelLabel": "Art. 23",
      "bloecke": [
        {
          "absatz": null,
          "text": "Per il decreto d'accusa, il decreto di non luogo a procedere e il decreto di abbandono, la tassa è fissata tra 100 e 10'000 franchi. Giudice dei provvedimenti coercitivi"
        }
      ],
      "stand": "2010-11-30",
      "quelleUrl": "https://www.lexfind.ch/tolv/125101/it",
      "abgerufen": "2026-06-19",
