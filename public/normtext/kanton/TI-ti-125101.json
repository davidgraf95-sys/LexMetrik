      "ebene": "kanton",
      "quelle": "TI",
      "erlass": "Legge sulla tariffa giudiziaria (LTG) (RL 178.200)",
      "artikel": "33",
      "artikelLabel": "Art. 33",
      "bloecke": [
        {
          "absatz": null,
          "text": "Nei procedimenti condotti secondo le norme di procedura civile e penale cantonali si applica la tariffa previgente. Entrata in vigore"
        }
      ],
      "stand": "2010-11-30",
      "quelleUrl": "https://www.lexfind.ch/tolv/125101/it",
      "abgerufen": "2026-06-19",
      "fassungsToken": "af0835906dc04efabfeec94042e1d771d28f2dba32fdde8b4dc16570b8bc956a",
      "sha": "e0b487a3a663c37298ea9b7886eb4ef40e1fcb9529d07eab71c04095b5ef6d84"
    },
    {
      "id": "kanton/TI/ti-125101/art_34",
      "ebene": "kanton",
      "quelle": "TI",
      "erlass": "Legge sulla tariffa giudiziaria (LTG) (RL 178.200)",
      "artikel": "34",
      "artikelLabel": "Art. 34",
      "bloecke": [
        {
          "absatz": null,
          "text": "Trascorsi i termini per l'esercizio del diritto di referendum, la presente legge è pubblicata nel Bollettino ufficiale delle leggi e degli atti esecutivi e entra in vigore il 1° gennaio 2011. Pubblicata nel BU 2011, 38. [1] Art. modificato dalla L 4.6.2012; in vigore dal 10.8.2012 - BU 2012, 365. [2] Art. modificato dalla L 4.6.2012; in vigore dal 10.8.2012 - BU 2012, 365."
        }
