{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/RiE 772.150/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung zum Energiesparfonds für Gemeindeliegenschaften (RiE 772.150)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Finanzierung von Energiesparmassnahmen an Gemeindeliegenschaften wird ein zweckgebundener Energiesparfonds gebildet."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 772.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b8a707741d4c1196c83503933ad96520",
      "sha": "984832f53fa09f17a85882beeb5d9ab51d8880633fcf36f6aa74041b0a56a0d4"
    },
    {
      "id": "kanton/BS/RiE 772.150/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung zum Energiesparfonds für Gemeindeliegenschaften (RiE 772.150)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Aus dem Energiesparfonds werden Massnahmen finanziert, welche die Energie- oder Ressourceneffizienz von Liegenschaften im Finanz- oder Verwaltungsvermögen der Gemeinde verbessern."
        },
        {
          "absatz": "2",
          "text": "Massnahmen, welche den ordentlichen Instandsetzungsrückstellungen der betroffenen Gebäude belastet werden können, dürfen nicht aus dem Energiesparfonds finanziert werden."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 772.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b8a707741d4c1196c83503933ad96520",
      "sha": "d8c1188712b204af122511c62beda94b6a24467a8dafb861d66e880c5ec33280"
    },
    {
      "id": "kanton/BS/RiE 772.150/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung zum Energiesparfonds für Gemeindeliegenschaften (RiE 772.150)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Energiesparfonds wird zu Lasten der Jahresrechnung 2013 mit einem Betrag von 2 Millionen Franken geäufnet. Anschliessend werden dem Fonds jährlich maximal 0.5% der Netto-Steuererträge der Einwohnergemeinde gemäss Jahresrechnung zugewiesen."
        },
        {
          "absatz": "2",
          "text": "Die Verzinsung des Fondskapitals erfolgt gemäss § 21 Abs. 4 der Finanzhaushaltordnung."
        },
        {
          "absatz": "3",
          "text": "Über die konkrete Mittelzuweisung entscheidet der Gemeinderat mit der Jahresrechnung. Er berücksichtigt dabei den Geschäftsgang der Gemeinde."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 772.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b8a707741d4c1196c83503933ad96520",
      "sha": "fbc93cdb92918e5366a308b952cd7943143af6d9678518725fbc3b763d1714fb"
    },
    {
      "id": "kanton/BS/RiE 772.150/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung zum Energiesparfonds für Gemeindeliegenschaften (RiE 772.150)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Zuständigkeit für Entnahmen aus dem Energiesparfonds richtet sich nach den ordentlichen Ausgabenkompetenzen der §§ 36 und 37 der Gemeindeordnung."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 772.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b8a707741d4c1196c83503933ad96520",
      "sha": "ac865b82cdc2a35a1d48c13764896abd88221a59dee2b5ad0956878d0cfb68b6"
    },
    {
      "id": "kanton/BS/RiE 772.150/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung zum Energiesparfonds für Gemeindeliegenschaften (RiE 772.150)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Fonds wird im Eigenkapital ausgewiesen. Der Gemeinderat legt mit der Rechnung Rechenschaft ab über Stand und Verwendung der Fondskapitalien."
        }
      ],
      "stand": "2023-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 772.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b8a707741d4c1196c83503933ad96520",
      "sha": "40da989454261f07834d1a23eb54137237bb3f9f5081c58a0d4e8398cbb1d7a6"
    }
  ]
}