{
  "erzeugt": "2026-06-22",
  "eintraege": [
    {
      "id": "kanton/AR/233.3/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung regelt die Rechtskosten und Entschädigungen in der Zivil- und Strafrechtspflege."
        },
        {
          "absatz": "2",
          "text": "Vorbehalten bleiben besondere Bestimmungen des Bundesrechts."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "38f7ab8af65c5baa9270f8ae7addeaa2538ea33dde01b0366d5118c7d20bbe05"
    },
    {
      "id": "kanton/AR/233.3/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Rechtskosten setzen sich zusammen aus den Gebühren und Auslagen."
        },
        {
          "absatz": "2",
          "text": "Verrichtungen, für die keine Gebühren festgesetzt sind, werden unentgeltlich besorgt."
        },
        {
          "absatz": "3",
          "text": "Die Rechtskosten sind nach Massgabe des Prozessrechts den Parteien oder dem Staat aufzuerlegen."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "49ccc6a47984d09eee01179fa375f7a5d3ccc0e61ad01df2978a4ee6c68df91e"
    },
    {
      "id": "kanton/AR/233.3/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gebühren sind ein Entgelt für amtliche Verrichtungen."
        },
        {
          "absatz": "2",
          "text": "Soweit im folgenden nichts anderes bestimmt wird, sind in der Gebühr für Verfügungen und Entscheide der richterlichen Behörden sämtliche Kosten, insbesondere für Einschreibung, Korrespondenzen inkl. Porti, Telefone, Vorladungen, Fotokopien und Abschriften, Einvernahmen und Begründung inbegriffen. Die Auslagen können zusätzlich zur Gebühr in Rechnung gestellt werden."
        },
        {
          "absatz": "3",
          "text": "In der Gebühr für Verfügungen der Strafverfolgungsbehörden sind die Kosten für die Abschriften und die Zustellung inbegriffen."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "51edf4c556ec7702661c282a3c938159a17c079f4ec6732267ee7e95b66f7931"
    },
    {
      "id": "kanton/AR/233.3/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bestehen für eine Entscheidgebühr ein Mindest- und ein Höchstansatz, so ist sie nach der Bedeutung des Geschäfts, der Grösse des Zeitaufwands, den Einkommens- und Vermögensverhältnissen der Parteien und der Art ihrer Prozessführung zu bemessen. Art. 80 Abs. 3 ZPO bleibt vorbehalten."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "f30f51983a1d1c0b7ba161691f16a055bec83f0639470c3f168b6e8b17715a11"
    },
    {
      "id": "kanton/AR/233.3/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die nebenamtlichen Gerichtspräsidenten und Einzelrichter haben Anspruch auf die von ihnen erhobenen Gebühren; ebenso die Vermittler, sofern die Gemeinde keine andere Regelung trifft. Im übrigen fallen die Rechtskosten in die Staatskasse."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "a890b00f3e333d95554e17d22092015890482212cec46d3b20639ca41877eb35"
    },
    {
      "id": "kanton/AR/233.3/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "In Zivil- und Strafsachen hat jede Partei Anspruch auf unentgeltliche Zustellung des begründeten Urteils."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "3704473f81c920fc4c6fa5f7f322208a76ee44801d52be63746e625074973a4f"
    },
    {
      "id": "kanton/AR/233.3/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "In Zivilfällen sind bei Anhängigmachung einer Klage, eines Rechtsmittels oder eines anderen Begehrens von den Parteien folgende Einschreibgebühren zu bezahlen:",
          "items": [
            {
              "marke": "a",
              "text": "beim Einzelrichter des Kantonsgerichtes Fr. 100.–"
            },
            {
              "marke": "b",
              "text": "beim Kantonsgericht Fr. 300.–"
            },
            {
              "marke": "bbis",
              "text": "bei Scheidungsverfahren Fr. 300.–"
            },
            {
              "marke": "c",
              "text": "beim Einzelrichter des Obergerichtes Fr. 100.–"
            },
            {
              "marke": "d",
              "text": "beim Obergericht Fr. 300.–"
            },
            {
              "marke": "e",
              "text": "beim Versicherungsgericht Fr. 200.–"
            },
            {
              "marke": "f",
              "text": "bei der Justizaufsichtskommission Fr. 100.–"
            }
          ]
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "404adde24b868fd51ff86614e77d38f4cce95d95191491a9f337d2fb8bb92622"
    },
    {
      "id": "kanton/AR/233.3/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Einschreibgebühr wird nicht erhoben, wenn",
          "items": [
            {
              "marke": "a",
              "text": "ein kostenloses Verfahren vorgeschrieben ist,"
            },
            {
              "marke": "b",
              "text": "der klagenden Partei die unentgeltliche Rechtspflege gewährt wurde,"
            },
            {
              "marke": "c",
              "text": "eine Gemeinde, der Kanton oder der Bund als Kläger auftritt."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die Vorschusspflicht der Parteien richtet sich im übrigen nach Art. 79 ZPO."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "675947913582af62f6be608ba741be338cd81ccd5855e61b15fc57cf32347235"
    },
    {
      "id": "kanton/AR/233.3/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Vermittler ist berechtigt, einen Kostenvorschuss in der Höhe der voraussichtlichen Gebühren und Auslagen zu verlangen."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "57cb04c87bbe1f31d74db8c8a33fb1651e2d83433fe15b63219bc1c000f4e35a"
    },
    {
      "id": "kanton/AR/233.3/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühren und Auslagen sind gesondert in Rechnung zu stellen. Auf Verlangen einer Partei sind sie zu detaillieren."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "2bae74520b74e0e42f196c4c27f14053f41ef5a2fac1f863f5f30e0bdee05a24"
    },
    {
      "id": "kanton/AR/233.3/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kosten in Strafverfahren sind für jeden Fall auf einer besonderen Kostennote aufzuzeichnen und in den Entscheid aufzunehmen. Die Kostennote ist den Akten beizulegen."
        },
        {
          "absatz": "2",
          "text": "Für einfache Fälle, die nicht zu einer Überweisung an das Kantonsgericht führen, kann die Staatsanwaltschaft abweichende Weisungen erlassen."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "dd0beb80a2084201da573dab7c95719e87c2eb39baf4ae781fb2200d36232767"
    },
    {
      "id": "kanton/AR/233.3/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die nebenamtlichen Einzelrichter in Zivilsachen und die Vermittler besorgen den Einzug der von ihnen erhobenen Kosten selbst. Die übrigen Kosten werden von der kantonalen Gerichtskasse in Rechnung gestellt und eingezogen."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "96f853026e4a26f9a73c62ecfc822beb334aa2f88321fa8f06c1ae098eddda77"
    },
    {
      "id": "kanton/AR/233.3/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Vermittler stellt für die Durchführung eines Vermittlungsvorstands oder für einen Kostenspruch eine Gebühr von Fr. 50.– bis Fr. 200.– in Rechnung."
        },
        {
          "absatz": "2",
          "text": "Beträgt der Zeitaufwand mehr als eine Stunde, so darf der Vermittler für jede weitere aufgewendete Stunde Fr. 100.– berechnen."
        },
        {
          "absatz": "3",
          "text": "Bei einem Streitwert von Fr. 100 000.– und mehr können die Ansätze verdoppelt werden."
        },
        {
          "absatz": "4",
          "text": "Für die Verschiebung eines Vermittlungsvorstands kann eine Gebühr von Fr. 10.– bis Fr. 100.– verlangt werden."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "25c4e9f963907b6d5c8a0832a53df3e855e9ae3acda33b397f527f3ed7c46668"
    },
    {
      "id": "kanton/AR/233.3/art_14",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Einzelrichter des Kantonsgerichts erheben für einen Entscheid oder eine Verfügung eine Gebühr von Fr. 30.– bis Fr. 1 500.–."
        },
        {
          "absatz": "2",
          "text": "In Scheidungssachen wird eine Gebühr von Fr. 500.– bis Fr. 6 000.– erhoben."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "5e0c2b3f0b4e82fe70f98df26b1c09b17a360674dd4aaa5346427cd31ac274e5"
    },
    {
      "id": "kanton/AR/233.3/art_16",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "16",
      "artikelLabel": "Art. 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Einzelrichter des Obergerichts erheben für einen Entscheid oder eine Verfügung eine Gebühr von Fr. 30.– bis Fr. 2 000.–."
        },
        {
          "absatz": "2",
          "text": "In Scheidungssachen wird eine Gebühr von Fr. 500.– bis Fr. 6 000.– erhoben."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "966580b600e586be72a463614695793c6fba9d70ac02cbbf1f3ff448bce7c929"
    },
    {
      "id": "kanton/AR/233.3/art_17",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "17",
      "artikelLabel": "Art. 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Kantonsgericht erhebt folgende Gebühren:",
          "items": [
            {
              "marke": "a",
              "text": "Beschluss: Fr. 100.– bis Fr. 3 000.–"
            },
            {
              "marke": "b",
              "text": "Urteil oder Vorentscheid: Fr. 100.– bis Fr. 5 000.–"
            },
            {
              "marke": "c",
              "text": "Augenschein, Experteninstruktion, Einvernahme, Vorbereitungsverhandlung: Fr. 20.– bis Fr. 150.– pro Std."
            }
          ]
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "900ff8cf54d89ea288d138a025c130e6ad3b88b3f68dc272c19e90296daacd00"
    },
    {
      "id": "kanton/AR/233.3/art_19",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "19",
      "artikelLabel": "Art. 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Obergericht erhebt folgende Gebühren:",
          "items": [
            {
              "marke": "a",
              "text": "Beschluss: Fr. 100.– bis Fr. 3 000.–"
            },
            {
              "marke": "b",
              "text": "Urteil oder Vorentscheid: Fr. 200.– bis Fr. 5 000.–"
            },
            {
              "marke": "c",
              "text": "Beschluss, Urteil oder Vorentscheid in Schiedsgerichtssachen gemäss Art. 260–262 ZPO: Fr. 100.– bis Fr. 5 000.–"
            },
            {
              "marke": "d",
              "text": "Augenschein, Experteninstruktion, Einvernahme, Vorbereitungsverhandlung: Fr. 20.– bis Fr. 150.– pro Std."
            }
          ]
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "a12474b7f99e0ee3e795fdb9eff2ee50f9c8fd14fe1c6f0464ce04716c129ae4"
    },
    {
      "id": "kanton/AR/233.3/art_20",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "20",
      "artikelLabel": "Art. 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühren gemäss Artikel 14 bis 19 können erhöht werden bei einem Streitwert von:",
          "items": [
            {
              "marke": "a",
              "text": "über Fr. 50 000.– bis Fr. 100 000.– auf das Doppelte"
            },
            {
              "marke": "b",
              "text": "über Fr. 100 000.– bis Fr. 250 000.– auf das Dreifache"
            },
            {
              "marke": "c",
              "text": "je weiteren Fr. 250 000.– um 100 % des einfachen Ansatzes"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Sie können auch in anderen besonders aufwendigen Fällen vervierfacht werden."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "7cf8ea5dc2bdae326e9d82a68aca7c3a5b70b864c83b96148af17dd32028c218"
    },
    {
      "id": "kanton/AR/233.3/art_21",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "21",
      "artikelLabel": "Art. 21",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Justizaufsichtskommission erhebt folgende Gebühren:",
          "items": [
            {
              "marke": "a",
              "text": "Entscheid oder Beschluss: Fr. 30.– bis Fr. 1 000.–"
            }
          ]
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "682369ec987e9ab609de600dee925e57a8f7833e4de0ba7d4391276e5aed384a"
    },
    {
      "id": "kanton/AR/233.3/art_22",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "22",
      "artikelLabel": "Art. 22",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Anwaltsaufsichtskommission erhebt folgende Gebühren:",
          "items": [
            {
              "marke": "a",
              "text": "Entscheid oder Beschluss: Fr. 30.– bis Fr. 1 000.–"
            }
          ]
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "936ee0b084f209cef795c0d663ff58a6ef87cbbfefa0f55200bf33710924af9e"
    },
    {
      "id": "kanton/AR/233.3/art_23",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "23",
      "artikelLabel": "Art. 23",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die zum Vollzug von Urteilen zuständigen Behörden erheben für den Vollzugsbefehl Fr. 20.– bis Fr. 500.–."
        },
        {
          "absatz": "2",
          "text": "Die Auslagen werden separat in Rechnung gestellt, wobei das Departement Inneres und Sicherheit die Stundenansätze für die Inanspruchnahme der Polizei festsetzt."
        },
        {
          "absatz": "3",
          "text": "Vom Gesuchsteller kann ein Kostenvorschuss für die mutmasslichen Vollzugskosten verlangt werden."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "ba6ab9bbcef566fe41bddbc0d37dea91ddd36a26fbe3b16f508ec666cefde87a"
    },
    {
      "id": "kanton/AR/233.3/art_24",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "24",
      "artikelLabel": "Art. 24",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Vermittler stellt für die Durchführung eines Vermittlungsvorstands eine Gebühr von Fr. 50.– bis Fr. 200.– in Rechnung."
        },
        {
          "absatz": "2",
          "text": "Beträgt der Zeitaufwand mehr als eine Stunde, so darf der Vermittler für jede weitere aufgewendete Stunde Fr. 100.– berechnen."
        },
        {
          "absatz": "3",
          "text": "Für die Verschiebung eines Vermittlungsvorstands kann eine Gebühr von Fr. 10.– bis Fr. 100.– verlangt werden."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "3ffd0447e457a507a7bcbea7e5f4f14fa273fa8ed4cd43c3ff589449eb26eb17"
    },
    {
      "id": "kanton/AR/233.3/art_25",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "25",
      "artikelLabel": "Art. 25",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Verhöramt erhebt folgende Gebühren:",
          "items": [
            {
              "marke": "a",
              "text": "…"
            },
            {
              "marke": "c",
              "text": "Überweisungs- und Einstellungsverfügung: Fr. 20.– bis Fr. 10 000.–"
            },
            {
              "marke": "d",
              "text": "nachträgliche richterliche Anordnung: Fr. 20.– bis Fr. 500.–"
            },
            {
              "marke": "e",
              "text": "Strafverfügung: Fr. 20.– bis Fr. 2 000.–"
            },
            {
              "marke": "f",
              "text": "Einvernahme, Augenschein: Fr. 20.– bis Fr. 1 000.–"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "In besonders aufwendigen Fällen können die Gebühren verdoppelt, in Bagatellsachen bis auf die Hälfte des Mindestansatzes ermässigt werden."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "c84afbe67c49998f101c0d9a028322af7e15855d4c74a6d45a1736f1a408bd8d"
    },
    {
      "id": "kanton/AR/233.3/art_26",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "26",
      "artikelLabel": "Art. 26",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Staatsanwaltschaft erhebt folgende Gebühren:",
          "items": [
            {
              "marke": "a",
              "text": "Überweisungsverfügung: Fr. 10.– bis Fr. 2 500.–"
            },
            {
              "marke": "b",
              "text": "Rekursentscheid: Fr. 20.– bis Fr. 1 000.–"
            },
            {
              "marke": "c",
              "text": "Vertretung der Anklage vor Gericht: Fr. 100.– bis Fr. 2 000.–"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "In besonders aufwendigen Fällen können die Gebühren verdoppelt werden."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "92798021dfea4c50f40e6e5f7f2210ec38f0f533eef8a81084e6dc56259f677c"
    },
    {
      "id": "kanton/AR/233.3/art_27",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "27",
      "artikelLabel": "Art. 27",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Jugendanwalt erhebt folgende Gebühren:",
          "items": [
            {
              "marke": "a",
              "text": "Straf- oder Überweisungsverfügung: Fr. 20.– bis Fr. 400.–"
            },
            {
              "marke": "b",
              "text": "nachträgliche richterliche Anordnung oder Vollzugsverfügung: Fr. 20.– bis Fr. 100.–"
            }
          ]
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "97c79ca54f5836164230e0cb6d17ecf8340a1a1da22289325d1cec7f3bcff133"
    },
    {
      "id": "kanton/AR/233.3/art_28",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "28",
      "artikelLabel": "Art. 28",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Einzelrichter erhebt eine Gebühr von Fr. 50.– bis Fr. 2'000.–."
        },
        {
          "absatz": "2",
          "text": "In besonders aufwendigen Fällen kann die Gebühr verdreifacht werden."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "7e5e65d72b4ed70f12b3315242eb2646303df907a35280c390b2da82fef4d708"
    },
    {
      "id": "kanton/AR/233.3/art_29",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "29",
      "artikelLabel": "Art. 29",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Kantonsgericht und das Obergericht erheben folgende Gebühren:",
          "items": [
            {
              "marke": "a",
              "text": "Beschluss, nachträgliche richterliche Anordnung: Fr. 250.– bis Fr. 1 000.–"
            },
            {
              "marke": "b",
              "text": "Urteil oder Vorentscheid: Fr. 200.– bis Fr. 5 000.–"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "In besonders aufwendigen Fällen oder wenn Zivilansprüche zu beurteilen sind, können die Gebühren vervierfacht werden."
        },
        {
          "absatz": "3",
          "text": "Sind Zivilansprüche zu beurteilen, die nach den Bestimmungen über die Gebühren in der Zivilrechtspflege (Artikel 14 bis 20) eine höhere Gebühr rechtfertigen, so kann diese zur Anwendung gelangen."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "e0b753f5e413993ffad0ec7bd0506744ff0e1a6708ee660e99dbdb0587275c26"
    },
    {
      "id": "kanton/AR/233.3/art_31",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "31",
      "artikelLabel": "Art. 31",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Jugendgericht erhebt folgende Gebühren:",
          "items": [
            {
              "marke": "a",
              "text": "Beschluss oder nachträgliche richterliche Anordnung: Fr. 20.– bis Fr. 200.–"
            },
            {
              "marke": "b",
              "text": "Urteil oder Vorentscheid: Fr. 20.– bis Fr. 500.–"
            }
          ]
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "24bb61353be295d39861001b78b4bfb28f0fc3fa7a6abf8f3d0fa1d3e9caa847"
    },
    {
      "id": "kanton/AR/233.3/art_32",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "32",
      "artikelLabel": "Art. 32",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Administrativbehörden erheben folgende Gebühren:",
          "items": [
            {
              "marke": "a",
              "text": "Verfügungen des Departements Inneres und Sicherheit: Fr. 20.– bis Fr. 500.–"
            },
            {
              "marke": "b",
              "text": "Verfügungen und Entscheide des Regierungsrates: Fr. 50.– bis Fr. 1 000.–"
            },
            {
              "marke": "c",
              "text": "Behandlung eines Begnadigungsgesuchs durch den Kantonsrat: Fr. 100.– bis Fr. 1 000.–"
            },
            {
              "marke": "d",
              "text": "Bescheinigung oder Auszug durch den Strafregisterführer: Fr. 15.–"
            }
          ]
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "583866856d2ceed35e7111627f244f8b21b6d73253526cc438bf72b859db5ce3"
    },
    {
      "id": "kanton/AR/233.3/art_33",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "33",
      "artikelLabel": "Art. 33",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Zustellung von Akten an nicht am Verfahren beteiligte Personen beträgt die Gebühr Fr. 10.– bis Fr. 200.–."
        },
        {
          "absatz": "2",
          "text": "Die Gebühr kann angemessen erhöht werden, wenn es sich um ein besonders aufwendiges Verfahren handelt und dem interessierten Dritten entsprechende eigene Auslagen grösseren Umfanges erspart bleiben."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "41aed5d1dca51a5f06f02ddaf3a1720b5f8a57338d374abf7d83cfb07d787837"
    },
    {
      "id": "kanton/AR/233.3/art_34",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "34",
      "artikelLabel": "Art. 34",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Auslagen sind alle Ausgaben, die infolge einer amtlichen Verrichtung entstehen, wie namentlich Publikationskosten, Zeugen- und Expertenentschädigungen, Kosten für polizeiliche Verrichtungen und Untersuchungshäftlinge."
        },
        {
          "absatz": "2",
          "text": "Die Fahrtenentschädigungen sind nach den effektiven Ausgaben oder nach der Verordnung über Taggelder und Spesen zu berechnen."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "460f3ad839739fb96d7e938dbfc7f39c2fd373b42fc74bda0fe80c16e07850d7"
    },
    {
      "id": "kanton/AR/233.3/art_35",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "35",
      "artikelLabel": "Art. 35",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zeugen sind angemessen zu entschädigen, wobei ihr allfälliger Verdienstausfall und ihre Barauslagen zu berücksichtigen sind."
        },
        {
          "absatz": "2",
          "text": "Experten sind nach der geleisteten Arbeit und der Bedeutung der Streitsache zu entschädigen."
        },
        {
          "absatz": "3",
          "text": "Wird die Forderung eines Zeugen oder Experten vom Richter als übersetzt bezeichnet, so ist dem Rechnungssteller Gelegenheit zur Vernehmlassung zu geben. Hierauf fällt der Richter einen Entscheid, der zu begründen ist. Der Entscheid kann bei der Justizaufsichtskommission angefochten werden."
        },
        {
          "absatz": "4",
          "text": "Im Strafuntersuch gelten diese Bestimmungen sinngemäss. Entscheide des Verhöramtes betreffend übersetzte Forderungen sind bei der Staatsanwaltschaft anzufechten, welche endgültig entscheidet."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "7d6e95ee7a47e8e6e18078e163d2c4b5e9d4f8eed58c80abfdac3aef23525c18"
    },
    {
      "id": "kanton/AR/233.3/art_42_bis",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "42_bis",
      "artikelLabel": "Art. 42bis",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat kann die in dieser Verordnung enthaltenen Ansätze periodisch der Teuerung anpassen."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "d07dffd9a53add95af92ce63c1b497e0cae0c1d8c65d378c9b3cb599e0af750b"
    },
    {
      "id": "kanton/AR/233.3/art_43",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührenordnung (bGS 233.3)",
      "artikel": "43",
      "artikelLabel": "Art. 43",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung tritt am 1. Juli 1981 in Kraft."
        },
        {
          "absatz": "2",
          "text": "Mit ihrem Inkrafttreten wird die Verordnung vom 17. Juni 1974 über die Rechtskosten und Entschädigungen in der Zivil- und Strafrechtspflege (Gebührenordnung) aufgehoben."
        }
      ],
      "stand": "2017-12-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.3",
      "abgerufen": "2026-06-22",
      "fassungsToken": "1c7272548e4f37a8d233866eafeb503a",
      "sha": "fd9461a36eb6b0dc458c93b729c3fb106ad42ae9820b39fe65e39a3364b10f03"
    }
  ]
}