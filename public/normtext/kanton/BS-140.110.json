{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/140.110/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gleichstellungsverordnung, GlV (140.110)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Fachstelle für Gleichstellung wird im Präsidialdepartement geführt."
        },
        {
          "absatz": "2",
          "text": "Die Anstellung der Leitung erfolgt nach Anhörung der Gleichstellungskommission."
        }
      ],
      "stand": "2025-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/140.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd59db15fb3c9719f0aa7b3a499f92f2",
      "sha": "82473dffc8d2748e3975bff98c33807537f51a763c22d19f11b36423f75c2ff2"
    },
    {
      "id": "kanton/BS/140.110/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gleichstellungsverordnung, GlV (140.110)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zur Überprüfung kantonaler Erlassentwürfe auf ihre Auswirkungen auf die Gleichstellung informieren die Departemente die Fachstelle für Gleichstellung über Erlassentwürfe, die gleichstellungsrelevant sein könnten."
        }
      ],
      "stand": "2025-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/140.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd59db15fb3c9719f0aa7b3a499f92f2",
      "sha": "72191ea690722df2f7e7ca075c15e25827aefa61d65b025863ead9c51a80003f"
    },
    {
      "id": "kanton/BS/140.110/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gleichstellungsverordnung, GlV (140.110)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Lohngleichheitsnachweise",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Vergabe von Staatsbeiträgen können Nachweise zur Einhaltung der Lohngleichheit von Frauen und Männern verlangt werden."
        },
        {
          "absatz": "2",
          "text": "Die Fachstelle für Gleichstellung legt Anforderungen an die Nachweise fest, insbesondere das zu verwendende Instrument. Die Anforderungen bedürfen der Genehmigung durch den Regierungsrat."
        }
      ],
      "stand": "2025-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/140.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd59db15fb3c9719f0aa7b3a499f92f2",
      "sha": "90551fe5dc87ec1fda8df2586944a973cc9e7212d339b429c03dc202ccca6510"
    },
    {
      "id": "kanton/BS/140.110/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gleichstellungsverordnung, GlV (140.110)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Lohngleichheitskontrollen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im Rahmen von Staatsbeitragsverhältnissen können Lohngleichheitskontrollen durchgeführt werden."
        },
        {
          "absatz": "2",
          "text": "Für die Durchführung der Kontrollen ist die Fachstelle für Gleichstellung zuständig. Sie kann Dritte mit der Durchführung beauftragen."
        }
      ],
      "stand": "2025-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/140.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd59db15fb3c9719f0aa7b3a499f92f2",
      "sha": "9dd9c9f4fb54bed0fa2cdcb844faa4b730d7d4431b4a501a7b94731fcdfef3b0"
    },
    {
      "id": "kanton/BS/140.110/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gleichstellungsverordnung, GlV (140.110)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "titel": "Organisation",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gleichstellungskommission ist dem Präsidialdepartement administrativ zugeordnet."
        },
        {
          "absatz": "2",
          "text": "Das Kommissionssekretariat wird von der Fachstelle für Gleichstellung geführt."
        }
      ],
      "stand": "2025-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/140.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd59db15fb3c9719f0aa7b3a499f92f2",
      "sha": "6f3b5a82d59a2de2a6ebac18e6af3134ca2a4dca610040df5e4cafd3df85fade"
    },
    {
      "id": "kanton/BS/140.110/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gleichstellungsverordnung, GlV (140.110)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "titel": "Zusammensetzung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gleichstellungskommission besteht aus neun Mitgliedern einschliesslich Präsidium."
        },
        {
          "absatz": "2",
          "text": "Die Mitglieder sollen über Sachkompetenz in Gleichstellungsfragen verfügen und sich in ihrem Fachwissen ergänzen."
        }
      ],
      "stand": "2025-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/140.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd59db15fb3c9719f0aa7b3a499f92f2",
      "sha": "f43f73900fa173d5e8bfa7062dbe4efa4bd34c8b6b23edaebd907e208462888b"
    },
    {
      "id": "kanton/BS/140.110/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gleichstellungsverordnung, GlV (140.110)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "titel": "Wahl",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat wählt die Mitglieder der Gleichstellungskommission für eine Amtsdauer von vier Jahren. Eine dreimalige Wiederwahl ist möglich."
        },
        {
          "absatz": "2",
          "text": "Das Präsidialdepartement unterbreitet dem Regierungsrat Wahlanträge."
        }
      ],
      "stand": "2025-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/140.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd59db15fb3c9719f0aa7b3a499f92f2",
      "sha": "5701e323e82440c327466b3cc35bef951040428e2dd43a20717ee94dcd32a44d"
    },
    {
      "id": "kanton/BS/140.110/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gleichstellungsverordnung, GlV (140.110)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "titel": "Konstituierung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Präsidium der Gleichstellungskommission wird vom Regierungsrat bezeichnet."
        },
        {
          "absatz": "2",
          "text": "Im Übrigen konstituiert sich die Gleichstellungskommission selbst."
        }
      ],
      "stand": "2025-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/140.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd59db15fb3c9719f0aa7b3a499f92f2",
      "sha": "2938c187ca5d87872d75fe216d5cd6c8e999aa6f5d6d5ab47c6ccb34ad423620"
    },
    {
      "id": "kanton/BS/140.110/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gleichstellungsverordnung, GlV (140.110)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "titel": "Aufgaben",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gleichstellungskommission steht der Fachstelle für Gleichstellung bei deren Aufgabenerfüllung, insbesondere in Bezug auf die Erarbeitung und Umsetzung des Aktionsplans gemäss § 5 Abs. 2 lit. a i. V. m. § 4 Abs. 3 KGlG beratend zur Seite."
        },
        {
          "absatz": "2",
          "text": "Sie äussert sich selbstständig zu Gleichstellungsfragen."
        }
      ],
      "stand": "2025-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/140.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd59db15fb3c9719f0aa7b3a499f92f2",
      "sha": "26fbc160d7c46cc7f5f91eae3ec5288adb92a59ed6e014a2b7992eb528644dd8"
    },
    {
      "id": "kanton/BS/140.110/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gleichstellungsverordnung, GlV (140.110)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "titel": "Zusammenarbeit mit der Fachstelle für Gleichstellung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gleichstellungskommission und die Fachstelle für Gleichstellung koordinieren sich bei der Erfüllung ihrer Aufgaben."
        },
        {
          "absatz": "2",
          "text": "Die Fachstelle für Gleichstellung nimmt mit beratender Stimme an den Sitzungen der Gleichstellungskommission teil."
        }
      ],
      "stand": "2025-06-15",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/140.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "bd59db15fb3c9719f0aa7b3a499f92f2",
      "sha": "705e0f1299023bdd9abf5d1aa456746b887964fb19fde6d9412c208b6e99342b"
    }
  ]
}