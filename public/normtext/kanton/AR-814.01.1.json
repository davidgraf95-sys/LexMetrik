{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/814.01.1/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif für die Feuerungskontrolle (814.01.1)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieser Tarif regelt die Erhebung von Gebühren für die Kontrolle von Feuerungsanlagen gemäss Art. 26 Abs. 2 des Gesetzes."
        }
      ],
      "stand": "2021-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "7e5b543e70cfd4f34e185a87c66f94fc",
      "sha": "95a59a987dd7a84f62f09690d4ba649853722da015aa99a939f5a6e6830866a9"
    },
    {
      "id": "kanton/AR/814.01.1/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif für die Feuerungskontrolle (814.01.1)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühren enthalten keine Mehrwertsteuer und werden bemessen:",
          "items": [
            {
              "marke": "a",
              "text": "nach festen Gebührenansätzen gemäss Art. 3–5;"
            },
            {
              "marke": "b",
              "text": "in den übrigen Fällen nach Aufwand."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Wenn die Gebühr nach Aufwand bemessen wird, gilt ein Stundenansatz von Fr. 83.–."
        }
      ],
      "stand": "2021-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "7e5b543e70cfd4f34e185a87c66f94fc",
      "sha": "292a0fda84efa212b5bd4e477c130471ee3a19ab35235b1268f23a2d139460e9"
    },
    {
      "id": "kanton/AR/814.01.1/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif für die Feuerungskontrolle (814.01.1)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zur Deckung der administrativen Kosten wird für sämtliche messpflichtigen Öl-, Gas- und Holzfeuerungen eine pauschale Grundgebühr für die ordentliche Feuerungskontrolle von Fr. 35.– erhoben."
        },
        {
          "absatz": "2",
          "text": "Die Grundgebühr bei den der privaten Kontrolle unterstellten Anlagen wird beim privaten Kontrolleur erhoben."
        },
        {
          "absatz": "3",
          "text": "Bei den übrigen Anlagen wird die Grundgebühr bei der Anlageeigentümerin oder bei dem Anlageeigentümer zusammen mit der Messgebühr gemäss Art. 4 bzw. Art. 4a erhoben."
        }
      ],
      "stand": "2021-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "7e5b543e70cfd4f34e185a87c66f94fc",
      "sha": "f80e5d5b1a26f092e53542493aba8ea3f14492fe08b6e2f63899834377e32ebc"
    },
    {
      "id": "kanton/AR/814.01.1/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif für die Feuerungskontrolle (814.01.1)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für ordentliche Messungen oder erste Nachmessungen von Öl- und Gasfeuerungen wird eine pauschale Gebühr von Fr. 55.– erhoben."
        },
        {
          "absatz": "2",
          "text": "Für die Messung an Feuerungsanlagen, bei welchen der Betrieb über mehrere Stufen oder mit den beiden Brennstoffen Öl und Gas zu kontrollieren ist, werden folgende Zuschläge verrechnet:",
          "items": [
            {
              "marke": "a",
              "text": "pro zusätzlich zu messende Leistungsstufe des Brenners (2. Stufe, modulierend) Fr. 30.–"
            },
            {
              "marke": "b",
              "text": "für den zusätzlichen Brennstoff (Zweistoff-Anlage Öl/Gas) Fr. 55.–"
            }
          ]
        }
      ],
      "stand": "2021-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "7e5b543e70cfd4f34e185a87c66f94fc",
      "sha": "1ffddb88a9047973a5fc56c58066b33763d65fc9ed2bcf11ee659b396a374324"
    },
    {
      "id": "kanton/AR/814.01.1/art_4_a",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif für die Feuerungskontrolle (814.01.1)",
      "artikel": "4_a",
      "artikelLabel": "Art. 4a",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für ordentliche Kohlenmonoxidmessungen von Holzfeuerungen wird eine pauschale Gebühr von Fr. 240.– erhoben."
        }
      ],
      "stand": "2021-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "7e5b543e70cfd4f34e185a87c66f94fc",
      "sha": "96d586ec9fdf7b3a3d0fa95e236ecc2bcff4ca2331d15b8e8dfafc85b2f3de31"
    },
    {
      "id": "kanton/AR/814.01.1/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif für die Feuerungskontrolle (814.01.1)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Sichtkontrolle von Feststofffeuerungen gelten in Verbindung mit der Anlagereinigung folgende Gebühren:",
          "items": [
            {
              "marke": "a",
              "text": "Abnahme- bzw. Erstkontrolle Fr. 35.–"
            },
            {
              "marke": "b",
              "text": "jede weitere Anlage innerhalb des gleichen Haushalts Fr. 20.–"
            },
            {
              "marke": "c",
              "text": "Wiederkehrende Kontrolle"
            },
            {
              "marke": "1",
              "text": "ohne Beanstandung Fr. 15.–"
            },
            {
              "marke": "2",
              "text": "mit Beanstandung Fr. 35.–"
            }
          ]
        }
      ],
      "stand": "2021-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "7e5b543e70cfd4f34e185a87c66f94fc",
      "sha": "f193d9daf95b4dc4e8570bff51ba234156a3c741e1bd324c124f73f6ad02ab67"
    },
    {
      "id": "kanton/AR/814.01.1/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif für die Feuerungskontrolle (814.01.1)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ausserordentliche oder zusätzliche Kontrollen, Messungen, Brennstoff- und Ascheanalysen sowie ausserordentliche Aufwendungen für Anordnungen aufgrund von Kontrollen werden nach Aufwand verrechnet."
        }
      ],
      "stand": "2021-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "7e5b543e70cfd4f34e185a87c66f94fc",
      "sha": "ccb672f79743f4bf77b6cc59f5c13117ceeaf585748d1f180cf74c6a79dd2bc2"
    },
    {
      "id": "kanton/AR/814.01.1/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif für die Feuerungskontrolle (814.01.1)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieser Tarif tritt am 1. Oktober 2005 in Kraft. Der Gebührentarif für die Feuerungskontrolle vom 25. Oktober 1994 wird aufgehoben."
        }
      ],
      "stand": "2021-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.1",
      "abgerufen": "2026-06-23",
      "fassungsToken": "7e5b543e70cfd4f34e185a87c66f94fc",
      "sha": "59332410ddf2f3c70ab4d1f2d546792ddeb10f1aee9f6e2e8fd5fdc65b84bb13"
    }
  ]
}