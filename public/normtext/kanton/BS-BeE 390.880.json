{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/BeE 390.880/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Bestattungsordnung (BeE 390.880)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Soweit die vorliegende Ordnung nichts Abweichendes bestimmt, richtet sich das Friedhofwesen nach den kantonalen Vorschriften."
        },
        {
          "absatz": "2",
          "text": "Der Gemeinderat ist für den Vollzug der Bestimmungen über das Friedhofwesen zuständig, soweit dieser nicht dem Kanton übertragen wurde."
        }
      ],
      "stand": "2023-02-20",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 390.880",
      "abgerufen": "2026-06-23",
      "fassungsToken": "db0e33d22412e17dd65fbb9ce52de0af",
      "sha": "e293baa203282ee5275e20ea8b19845771a91ad039c8e7248b1670d5991c8107"
    },
    {
      "id": "kanton/BS/BeE 390.880/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Bestattungsordnung (BeE 390.880)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Auf dem Friedhof Bettingen werden folgende Bestattungsarten durchgeführt:",
          "items": [
            {
              "marke": "a",
              "text": "Erdbestattung: Sargbeisetzung im Reihengrab;"
            },
            {
              "marke": "b",
              "text": "Feuerbestattung: Urnenbeisetzung im Reihengrab, im Gemeinschaftsgrab oder im naturnahen Bestattungsfeld."
            }
          ]
        }
      ],
      "stand": "2023-02-20",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 390.880",
      "abgerufen": "2026-06-23",
      "fassungsToken": "db0e33d22412e17dd65fbb9ce52de0af",
      "sha": "b31684afa12bac3fbba9c78c05d70d214c072e0d597ab34532150f74d9e01a86"
    },
    {
      "id": "kanton/BS/BeE 390.880/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Bestattungsordnung (BeE 390.880)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Auf dem Friedhof Bettingen bestehen folgende Grabarten:",
          "items": [
            {
              "marke": "a",
              "text": "Reihengräber für die Sargbeisetzung;"
            },
            {
              "marke": "b",
              "text": "Reihengräber für die Urnenbeisetzung;"
            },
            {
              "marke": "c",
              "text": "Gemeinschaftsgrab für die Urnenbeisetzung;"
            },
            {
              "marke": "d",
              "text": "naturnahes Bestattungsfeld für die Urnenbeisetzung."
            }
          ]
        }
      ],
      "stand": "2023-02-20",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 390.880",
      "abgerufen": "2026-06-23",
      "fassungsToken": "db0e33d22412e17dd65fbb9ce52de0af",
      "sha": "35fa995a24e818f603b83673d41cbde49316fda6b24e1b07bfd9847b1ab19c24"
    },
    {
      "id": "kanton/BS/BeE 390.880/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Bestattungsordnung (BeE 390.880)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Anspruch auf unentgeltliche Bestattung auf dem Friedhof Bettingen hat:",
          "items": [
            {
              "marke": "a",
              "text": "wer im Zeitpunkt des Todes Wohnsitz in Bettingen hatte;"
            },
            {
              "marke": "b",
              "text": "wer auf dem Gemeindegebiet verstorben ist;"
            },
            {
              "marke": "c",
              "text": "wer das Bürgerrecht von Bettingen und im Kanton Basel-Stadt Wohnsitz hatte;"
            },
            {
              "marke": "d",
              "text": "Eltern, die ihren Wohnsitz in Bettingen haben oder das Bürgerrecht von Bettingen und Wohnsitz im Kanton Basel-Stadt haben, für ihre totgeborenen oder fehlgeborenen Kinder nach Art. 9 und 9a der Zivilstandsverordnung vom 28. April 2004."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die unentgeltliche Bestattung umfasst die nach kantonalem Recht vorgesehenen Leistungen."
        }
      ],
      "stand": "2023-02-20",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 390.880",
      "abgerufen": "2026-06-23",
      "fassungsToken": "db0e33d22412e17dd65fbb9ce52de0af",
      "sha": "c12a8b9abc8cf86666da4d3d18dbc9fae5029b07fe54cd5f4e847ec6274f3278"
    },
    {
      "id": "kanton/BS/BeE 390.880/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Bestattungsordnung (BeE 390.880)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Auf Gesuch der Angehörigen oder anderer nahestehender Personen kann auf dem Friedhof Bettingen bestattet werden:",
          "items": [
            {
              "marke": "a",
              "text": "wer das Bürgerrecht von Bettingen und Wohnsitz ausserhalb des Kantons Basel-Stadt hatte;"
            },
            {
              "marke": "b",
              "text": "wessen Angehörige Wohnsitz in Bettingen haben;"
            },
            {
              "marke": "c",
              "text": "wer sonst eine besonders enge Beziehung zu Bettingen hatte."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Über Gesuche entscheidet im Einzelfall der Gemeinderat."
        },
        {
          "absatz": "3",
          "text": "Für Bestattungen nach Abs. 1 werden Gebühren erhoben. Diese richten sich nach dem Vertrag zwischen dem Kanton Basel-Stadt einerseits und der Einwohnergemeinde Bettingen anderseits betreffend den Gottesacker Bettingen vom 1./13. Februar 2012. Ergänzend richten sich die Gebühren nach der Verordnung über Gebühren im Bestattungswesen vom 14. Dezember 2004."
        }
      ],
      "stand": "2023-02-20",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 390.880",
      "abgerufen": "2026-06-23",
