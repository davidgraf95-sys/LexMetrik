      "erlass": "PFV (833.151)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Leistungserbringer legen die Tarife für Pflegeleistungen und nicht-pflegerische Leistungen im Rahmen der Höchstansätze dieser Verordnung fest."
        },
        {
          "absatz": "2",
          "text": "Die Tarife dürfen die effektiven Kosten gemäss Kostenrechnung nicht übersteigen."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "c6ee08181270bb5917d4a1a10b13c4d6a21e4645b71f59a17f4b028bcc664dbe"
    },
    {
      "id": "kanton/AR/833.151/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Pflegeheime im Sinne dieser Verordnung sind Leistungserbringer, soweit sie auf der kantonalen Pflegeheimliste aufgeführt sind."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "5d6b25aedb4d0ae30db0eb961614408bc35fb0c7d4653954ab6a7862c1270010"
    },
