    },
    {
      "id": "kanton/AR/833.151/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Pflegeheime ermitteln den Pflegebedarf nach dem System BESA oder RAI-Nursing Home (RAI-NH)."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "bb9ddd944f3065479344a231a195e12f5a31ac3cc4a2675d18a97d22b757ec01"
    },
    {
      "id": "kanton/AR/833.151/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Betreuungskosten umfassen die Kosten für Leistungen, die infolge Alter, Invalidität, Unfall oder Krankheit notwendig sind und keine Pflegeleistungen darstellen. Massgebende Grundlage für deren Bestimmung ist die Tätigkeitsliste der Koordinationsgruppe Langzeitpflege Schweiz."
        },
        {
          "absatz": "2",
          "text": "Soweit nicht der effektive Betreuungsaufwand erhoben wird, ist der Anteil der Betreuungskosten nach den Vorgaben des Amtes für Soziales zu bestimmen."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "c9debdbf054a504eae204771c885fb0fe2062ce74c2aa0b179f95416dce9297f"
    },
    {
      "id": "kanton/AR/833.151/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Pflegeheime weisen auf ihren Rechnungen die Kosten der Pflegeleistungen und die Kosten der nicht-pflegerischen Leistungen separat aus."
        },
        {
          "absatz": "2",
          "text": "Die Rechnungen sind wie folgt zu gliedern:",
          "items": [
            {
              "marke": "a",
              "text": "Beitrag des Krankenversicherers nach der Verordnung des EDI über Leistungen in der obligatorischen Krankenpflegeversicherung (Krankenpflege-Leistungsverordnung);"
            },
            {
              "marke": "b",
              "text": "Beitrag der versicherten Person:"
            },
            {
              "marke": "1",
              "text": "Eigenanteil Pflegekosten;"
            },
            {
              "marke": "2",
              "text": "Betreuungskosten;"
            },
            {
              "marke": "3",
              "text": "Pensionskosten;"
            },
            {
              "marke": "4",
              "text": "Kosten für weitere Leistungen;"
            },
            {
              "marke": "c",
              "text": "Beitrag der Gemeinde an die ungedeckten Pflegekosten."
            }
          ]
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "675475e0ac61a213e0748f64e84b48c9932f8268f8e817a41e4422c936f96dcf"
    },
    {
      "id": "kanton/AR/833.151/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Pflegeheime führen ihre Kostenrechnung nach den Richtlinien des Branchenverbandes Curaviva Schweiz (Handbuch «Kostenrechnung und Leistungsstatistik für Alters- und Pflegeheime»). Werden pflegerelevante Anlagekosten geltend gemacht, ist eine Anlagebuchhaltung zu führen (Handbuch «Anlagebuchhaltung für Alters- und Pflegeheime»)."
        },
        {
          "absatz": "2",
          "text": "Die Kostenrechnung ist dem Amt für Soziales bis spätestens 30. April des Folgejahres einzureichen."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "abc6560045299d767de35b89b4bea777c78c45e5d1f9f3ba34e18e00e6371723"
    },
    {
      "id": "kanton/AR/833.151/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Tages- und Nachtstrukturen sind Leistungserbringer, welche ausserhäuslich Tages- und Nachtpflege anbieten, soweit sie zur Abrechnung mit der obligatorischen Krankenversicherung zugelassen sind."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "47098b5099ca24d60eaaa798f125866f3cc7eac21d8be4743403eb8e74906f73"
    },
    {
      "id": "kanton/AR/833.151/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für Tages- und Nachtstrukturen gelten sinngemäss die Bestimmungen über Pflegeheime."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "409950994ee3faef08c22a2fe6fa4acacbac79d5948f578dd3ab3d0791036d3c"
    },
    {
      "id": "kanton/AR/833.151/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Leistungserbringer der Pflege und Hilfe zu Hause sind Spitex-Organisationen und Pflegefachpersonen, die zur Abrechnung mit der obligatorischen Krankenversicherung zugelassen sind."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "7c16bdd12a71ce0e4246ba2adeb6076b96aa55b368f456fcd59568aa7616e8d5"
    },
    {
      "id": "kanton/AR/833.151/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die von Leistungserbringern ohne kommunalen Versorgungsauftrag erbrachten Pflegeleistungen gelten folgende Höchstansätze:",
          "mehrspaltig": {
            "kopf": [
              "Massnahme",
              "Franken je Stunde"
            ],
            "zeilen": [
              [
                "Abklärung, Beratung und Koordination nach Art. 7 Abs. 2 lit. a KLV",
                "121.80"
              ],
              [
                "Untersuchung und Behandlung nach Art. 7 Abs. 2 lit. b KLV",
                "112.30"
              ],
              [
                "Grundpflege nach Art. 7 Abs. 2 lit. c KLV",
                "100.40"
              ]
            ]
          }
        },
        {
          "absatz": "2",
          "text": "Für die von Leistungserbringern mit kommunalem Versorgungsauftrag erbrachten Pflegeleistungen gelten folgende Höchstansätze:",
          "mehrspaltig": {
            "kopf": [
              "Massnahme",
              "Franken je Stunde"
            ],
            "zeilen": [
              [
                "Abklärung, Beratung und Koordination nach Art. 7 Abs. 2 lit. a KLV",
                "145.50"
              ],
              [
                "Untersuchung und Behandlung nach Art. 7 Abs. 2 lit. b KLV",
                "134.20"
              ],
              [
                "Grundpflege nach Art. 7 Abs. 2 lit. c KLV",
                "120.00"
              ]
            ]
          }
        },
        {
          "absatz": "3",
          "text": "Für Leistungserbringer, die über keine standardisierte Kostenrechnung verfügen, gelten anstelle von Abs. 1 folgende Normansätze:",
          "mehrspaltig": {
            "kopf": [
              "Massnahme",
              "Franken je Stunde"
            ],
            "zeilen": [
              [
                "Abklärung, Beratung und Koordination nach Art. 7 Abs. 2 lit. a KLV",
                "97.40"
              ],
              [
                "Untersuchung und Behandlung nach Art. 7 Abs. 2 lit. b KLV",
                "89.90"
              ],
              [
                "Grundpflege nach Art. 7 Abs. 2 lit. c KLV",
                "80.30"
              ]
            ]
          }
        },
        {
          "absatz": "4",
          "text": "Soweit Angehörige der versicherten Person (Ehe oder eingetragene Partnerschaft, Eltern, Nachkommen, Geschwister, faktische Lebensgemeinschaft) als Angestellte einer Spitex-Organisation in der Grundpflege tätig werden, gilt abweichend von Abs. 1 - 3 ein Höchst- oder Normansatz von Fr. 64.20 je Stunde."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "75c804a4bea5a02337e1c125a1ca9bc9bed09b2d2d457e67926f78441f733ea7"
    },
    {
      "id": "kanton/AR/833.151/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Leistungserbringer ermitteln den Pflegebedarf nach dem System RAI-Home-Care (RAI-HC)."
        },
        {
          "absatz": "2",
          "text": "Spitex-Organisationen, die auf ein Fachgebiet spezialisiert sind, und Pflegefachpersonen können mit den Krankenversicherern ein anderes Bedarfsermittlungssystem vereinbaren."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "8ca8b42ba3b8205c38025d844aad66805d426e4c8a002bf13004d6990ec40799"
    },
    {
      "id": "kanton/AR/833.151/art_14",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Hilfe zu Hause umfasst die stellvertretende Haushaltsführung, die sozial-begleitende Unterstützung und die Betreuung von Kindern."
        },
        {
          "absatz": "2",
          "text": "Spitex-Organisationen erbringen ihre Leistungen aufgrund einer Bedarfsabklärung, welche den gesundheitsbedingten Unterstützungsbedarf nachweist."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "eb2456437e78c33053515a44184f1179b6e8a83b63394f88fd8eb097bbab0dfa"
    },
    {
      "id": "kanton/AR/833.151/art_15",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "15",
      "artikelLabel": "Art. 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ergänzende Dienstleistungen werden den Leistungsbezügern und Leistungsbezügerinnen zu marktüblichen Preisen in Rechnung gestellt."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "cec128dd0de81145141a562f5f728d0705c8e3b760746e7eb1b0a04eef5a80c6"
    },
    {
      "id": "kanton/AR/833.151/art_16",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "16",
      "artikelLabel": "Art. 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Leistungserbringer weisen auf ihren Rechnungen die Kosten der Pflegeleistungen und die Kosten der nicht-pflegerischen Leistungen separat aus."
        },
        {
          "absatz": "2",
          "text": "Die Rechnungen sind wie folgt zu gliedern:",
          "items": [
            {
              "marke": "a",
              "text": "Beitrag des Krankenversicherers nach der Verordnung des EDI über Leistungen in der obligatorischen Krankenpflegeversicherung (Krankenpflege-Leistungsverordnung);"
            },
            {
              "marke": "b",
              "text": "Beitrag der versicherten Person:"
            },
            {
              "marke": "1",
              "text": "Eigenanteil Pflegekosten;"
            },
            {
              "marke": "2",
              "text": "Kosten der Hilfe zu Hause;"
            },
            {
              "marke": "3",
              "text": "Kosten für ergänzende Dienstleistungen."
            },
            {
              "marke": "c",
              "text": "Beitrag der Gemeinde:"
            },
            {
              "marke": "1",
              "text": "ungedeckte Pflegekosten;"
            },
            {
              "marke": "2",
              "text": "allfälliger Beitrag an die Hilfe zu Hause."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Wird die Pflege für eine versicherte Person von mehreren Leistungserbringern erbracht, haben sie sich darüber zu verständigen, wer den Eigenanteil in Rechnung stellt."
        },
        {
          "absatz": "4",
          "text": "Auf der Rechnung ist auszuweisen, wenn die Grundpflege durch Angehörige erbracht wird (Art. 12 Abs. 4)."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "be644f2a07436f8b357b2f2028ba86b319be3ce8f8e1a4046466c6762a7b4c67"
    },
    {
      "id": "kanton/AR/833.151/art_17",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "17",
      "artikelLabel": "Art. 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Leistungserbringer weisen jährlich die individuellen Kosten für die Pflege zu Hause und für die Hilfe zu Hause aus. Sie führen zu diesem Zweck eine standardisierte Kostenrechnung nach den Richtlinien des Spitex Verbands Schweiz («Spitex-Finanzmanual, Handbuch zum standardisierten Rechnungswesen für Spitex-Organisationen»). Diese Pflicht entfällt bei der Anwendung von Normansätzen."
        },
        {
          "absatz": "2",
          "text": "Die Kostenrechnung ist dem Amt für Soziales bis spätestens 30. April des Folgejahres einzureichen."
        },
        {
          "absatz": "3",
          "text": "Das Amt für Soziales kann weitere Vorgaben zur Kostenrechnung festlegen."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "64447a8b2b4b1c7d7c4a4222405e84cfdc663b6a50b8a0477690324b70b7d74d"
    },
    {
      "id": "kanton/AR/833.151/art_18",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Spitex-Organisationen mit einem kommunalen Versorgungsauftrag haben obligatorisch eine standardisierte Kostenrechnung und eine Finanzbuchhaltung zu führen."
        },
        {
          "absatz": "2",
          "text": "Sie weisen mit Pflegeleistungen erzielte Überschüsse einem zweckgebundenen Schwankungsfonds zu. Durch Pflegeleistungen entstandene Defizite sind durch Mittel aus dem Fonds auszugleichen."
        },
        {
          "absatz": "3",
          "text": "Erreicht der Schwankungsfonds den Wert von 10 Prozent der gesamten Vollkosten der Pflegeleistungen eines Betriebsjahres, sind die Tarife für Pflegeleistungen im Folgejahr nach unten anzupassen."
        },
        {
          "absatz": "4",
          "text": "Überschreitet die Unterdeckung des Schwankungsfonds den Wert von 10 Prozent der gesamten Vollkosten für die Pflegeleistungen eines Betriebsjahres, wird der darüber liegende Teil des Defizits aus frei erwirtschafteten Mitteln ausgeglichen."
        },
        {
          "absatz": "5",
          "text": "Für die Hilfe zu Hause gilt ein Höchstansatz von Fr. 77.50 je Stunde. Die Gemeinde übernimmt im Rahmen dieses Höchstansatzes mindestens 45 Prozent des in Rechnung gestellten Tarifs."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "5115f42ebf02d4874896f66fb1bc90ec9147422283fdc6e3e1d96ccd46594bbc"
    },
    {
      "id": "kanton/AR/833.151/art_19",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "19",
      "artikelLabel": "Art. 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton leistet Ausbildungsbeiträge an Spitex-Organisationen, die überwiegend auf kantonalem Gebiet tätig sind."
        },
        {
          "absatz": "2",
          "text": "Beiträge werden ausgerichtet für die Ausbildungen",
          "items": [
            {
              "marke": "a",
              "text": "Fachfrau/Fachmann Gesundheit;"
            },
            {
              "marke": "b",
              "text": "Fachfrau/Fachmann Betreuung;"
            },
            {
              "marke": "c",
              "text": "diplomierte Pflegefachfrau/diplomierter Pflegefachmann."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Der Beitrag beträgt Fr. 2‘000.– je Ausbildung auf der Sekundarstufe II und Fr. 4‘000.– je Ausbildung auf der Tertiärstufe."
        },
        {
          "absatz": "4",
          "text": "Gesuche um Ausbildungsbeiträge sind dem Amt für Soziales spätestens bis zum 31. März des Vorjahres einzureichen."
        },
        {
          "absatz": "5",
          "text": "Bei Abbruch der Ausbildung ist das Amt für Soziales umgehend zu informieren. Der Ausbildungsbeitrag ist vollständig zurückzuerstatten, wenn der Abbruch innerhalb der ersten sechs Monate des Ausbildungsjahres erfolgt. Bei einem späteren Abbruch ist die Hälfte zurückzuerstatten."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "64e0a444101f44447844a43d638aa46d6a1e10381f3c905ed303867e08c22c8f"
    },
    {
      "id": "kanton/AR/833.151/art_20",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "20",
      "artikelLabel": "Art. 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton leistet einen Beitrag an die kantonalen Dachorganisationen zur Durchführung von Fort- und Weiterbildungsveranstaltungen. Er übernimmt höchstens 30 Prozent der ausgewiesenen Kosten."
        },
        {
          "absatz": "2",
          "text": "Gesuche sind dem Amt für Soziales bis spätestens 31. März des Vorjahres einzureichen."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "3a51902767ef2d69b5a1f05ebd57ab780e467a96faea868eac38f34b0628b45b"
    },
    {
      "id": "kanton/AR/833.151/art_21",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "21",
      "artikelLabel": "Art. 21",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Amt für Soziales beaufsichtigt die Pflegefinanzierung und sorgt für ein angemessenes Controlling. Es erstattet regelmässig Bericht zuhanden des Regierungsrates und der Gemeinden."
        },
        {
          "absatz": "2",
          "text": "Die Leistungserbringer sind verpflichtet, dem Amt für Soziales unentgeltlich die notwendigen Daten zur Verfügung zu stellen und alle erforderlichen Auskünfte zu erteilen."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "c8d0ef64d8c1c69c1e513b79d6ec7bbd9cf4afaf0feb339a59fb1398a5d62091"
    },
    {
      "id": "kanton/AR/833.151/art_22",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "PFV (833.151)",
      "artikel": "22",
      "artikelLabel": "Art. 22",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Amt für Soziales kann betriebsbezogene Daten veröffentlichen, soweit diese zur Vergleichbarkeit der Leistungserbringer in Bezug auf Angebot, Kosten und Qualität sowie zur Information der Bevölkerung erforderlich sind. Dazu gehören insbesondere Daten über Rechtsträger, Rechtsform, Leistungen und Kosten, Personalbestand."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/833.151",
      "abgerufen": "2026-06-23",
      "fassungsToken": "acc90bed4e1aef222886c068aa997180",
      "sha": "fb60765fe69a62f3a15e7558ec22dc749daaaa6209b3ea27af3f1b7ca0725d8a"
    }
  ]
}