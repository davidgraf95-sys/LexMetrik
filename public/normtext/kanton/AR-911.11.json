{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/911.11/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Wirtschaftsförderung (911.11)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Aufgaben der Wirtschaftsförderungsstelle werden dem Amt für Wirtschaft und Arbeit übertragen."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/911.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c33ac1c1dab874f83db68e4aa4a74bec",
      "sha": "2b7a3d20976e49257b9d3c395432c3b85c3969bec8c50b27b5caec0cd61208ef"
    },
    {
      "id": "kanton/AR/911.11/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Wirtschaftsförderung (911.11)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ein allfälliger Leistungsauftrag mit Dritten umfasst:",
          "items": [
            {
              "marke": "a",
              "text": "Allgemeine Grundsätze der Zusammenarbeit;"
            },
            {
              "marke": "b",
              "text": "Zielsetzungen und Leistungen;"
            },
            {
              "marke": "c",
              "text": "Form und Höhe der Vergütungen;"
            },
            {
              "marke": "d",
              "text": "Budget und Mittelverwendung;"
            },
            {
              "marke": "e",
              "text": "Berichterstattung und Controlling;"
            },
            {
              "marke": "f",
              "text": "Dauer und Kündigung des Leistungsauftrages."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Jede Änderung des Leistungsauftrags bedarf der Schriftform."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/911.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c33ac1c1dab874f83db68e4aa4a74bec",
      "sha": "5cd5e1f12e0d50fff7a13789e5bceae5485e67c1a76e14aa4a97800a60072f6b"
    },
    {
      "id": "kanton/AR/911.11/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Wirtschaftsförderung (911.11)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Nehmen Gemeinden oder Dritte die Wirtschaftsförderungsstelle für Leistungen in Anspruch, welche über Art. 4 Abs. 1 des Gesetzes hinausgehen, übernehmen sie ganz oder teilweise die damit verbundenen Kosten."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/911.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c33ac1c1dab874f83db68e4aa4a74bec",
      "sha": "46f13e0981d2b56f8ab2526f142f62dd1a0bf478379fe75479d1e617336ce58a"
    },
    {
      "id": "kanton/AR/911.11/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Wirtschaftsförderung (911.11)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Als innovativ im Sinne von Art. 5 Abs. 1 des Gesetzes gelten insbesondere Vorhaben, die es den Unternehmen ermöglichen,",
          "items": [
            {
              "marke": "a",
              "text": "ihre Produkte oder Dienstleistungen weiterzuentwickeln, neue Produkte herzustellen sowie neue Verfahren oder Dienstleistungen einzuführen, um damit den Anforderungen des Marktes zu entsprechen, oder"
            },
            {
              "marke": "b",
              "text": "Produktions- und Dienstleistungszweige zu errichten, die im Kanton nicht oder nur schwach vertreten sind."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Daneben verdienen Vorhaben eine besondere Berücksichtigung, welche:",
          "items": [
            {
              "marke": "a",
              "text": "innerhalb der Branche Vorbildcharakter haben;"
            },
            {
              "marke": "b",
              "text": "einem Betrieb oder einer Branche den Zugang zu den internationalen Märkten öffnen;"
            },
            {
              "marke": "c",
              "text": "das Angebot an wirtschaftsnahen Dienstleistungen in einem wichtigen Bereich ergänzen;"
            },
            {
              "marke": "d",
              "text": "überbetrieblichen oder überregionalen Charakter haben;"
            },
            {
              "marke": "e",
              "text": "die Schaffung von tragfähigen Weiterbildungsstrukturen zum Ziel haben;"
            },
            {
              "marke": "f",
              "text": "im Hinblick auf die Ökologisierung der Wirtschaft Vorbildcharakter haben."
            }
          ]
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/911.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c33ac1c1dab874f83db68e4aa4a74bec",
      "sha": "5c914c80b85af900137c054ff71d320f318e76cb19544c49efc3fe8b02f3595c"
    },
    {
      "id": "kanton/AR/911.11/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Wirtschaftsförderung (911.11)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die einzelbetrieblichen Förderungsbeiträge können in folgenden Formen ausgerichtet werden:",
          "items": [
            {
              "marke": "a",
              "text": "Zinslose Darlehen für höchstens 10 Jahre;"
            },
            {
              "marke": "b",
              "text": "Zinskostenbeiträge für höchstens 10 Jahre;"
            },
            {
              "marke": "c",
              "text": "à-fonds-perdu-Beiträge;"
            },
            {
              "marke": "d",
              "text": "jährlicher Förderpreis."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Gegenstand der einzelbetrieblichen Förderungsbeiträge sind namentlich Massnahmen zur Erhaltung und Schaffung von Arbeitsplätzen sowie zur Exportförderung."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/911.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c33ac1c1dab874f83db68e4aa4a74bec",
      "sha": "25f47f1872e37a91a7afb65e58e98c15b15294d21b6337daae154808cc4e45eb"
    },
    {
      "id": "kanton/AR/911.11/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Wirtschaftsförderung (911.11)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Einzelbetriebliche Förderungsbeiträge können insbesondere von folgenden Auflagen abhängig gemacht werden:",
          "items": [
            {
              "marke": "a",
              "text": "Vornahme der vereinbarten Investitionen;"
            },
            {
              "marke": "b",
              "text": "Erhaltung oder Schaffung einer bestimmten Anzahl an Arbeitsplätzen;"
            },
            {
              "marke": "c",
              "text": "Einräumung von Vorkaufs- und Rückkaufsrechten an mit öffentlichen Mitteln mitfinanzierten Liegenschaften."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Sind einzelbetriebliche Förderungsbeiträge aufgrund von irreführenden Angaben bezogen worden, fordert die Wirtschaftsförderungsstelle diese Mittel ganz oder teilweise zurück."
        },
        {
          "absatz": "3",
          "text": "Werden die mit der Leistungsvereinbarung eingegangenen Verpflichtungen nicht oder nicht vollständig eingehalten, wird die Vereinbarung gekündigt. Die ausbezahlten Förderungsbeiträge sind von der Wirtschaftsförderungsstelle ganz oder teilweise zurückzufordern."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/911.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c33ac1c1dab874f83db68e4aa4a74bec",
      "sha": "d4a0941291096b792246e4c5fab61ecd73e3939c3ad9bcb53be10371ff2d7bac"
    },
    {
      "id": "kanton/AR/911.11/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Wirtschaftsförderung (911.11)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer um die Ausrichtung von einzelbetrieblichen Förderungsbeiträgen ersucht, hat der Wirtschaftsförderungsstelle alle für die Beurteilung des Vorhabens notwendigen Auskünfte zu erteilen, Unterlagen einzureichen sowie Einblick in die Geschäftsbücher zu gewähren."
        },
        {
          "absatz": "2",
          "text": "Es sind mindestens die folgenden Unterlagen beizubringen:",
          "items": [
            {
              "marke": "a",
              "text": "Businessplan;"
            },
            {
              "marke": "b",
              "text": "Nachweis, wonach das Vorhaben die sachlichen Voraussetzungen von Art. 5 des Gesetzes erfüllt;"
            },
            {
              "marke": "c",
              "text": "Verträge über eine allfällige Kreditgewährung."
            }
          ]
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/911.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c33ac1c1dab874f83db68e4aa4a74bec",
      "sha": "99f89b70bd13c3c268cf9dce14d14a0908902eabaf16c2c269791d114dc64f9a"
    },
    {
      "id": "kanton/AR/911.11/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Wirtschaftsförderung (911.11)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "In Einzelfällen kann die Wirtschaftsförderungsstelle Massnahmen im Sinne von Art. 6 des Gesetzes treffen, die über die vom Bund geforderten kantonalen Leistungen hinausgehen."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/911.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c33ac1c1dab874f83db68e4aa4a74bec",
      "sha": "a03c212ed17a0b7bf385194077a264d72851d6ff7f28868351464e3098118ce0"
    },
    {
      "id": "kanton/AR/911.11/art_8_a",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Wirtschaftsförderung (911.11)",
      "artikel": "8_a",
      "artikelLabel": "Art. 8a",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Finanzhilfen werden als à-fonds-perdu-Beiträge, Darlehen als zinsgünstige oder zinslose Darlehen für höchstens 25 Jahre ausgerichtet."
        },
        {
          "absatz": "2",
          "text": "Finanzhilfen oder Darlehen können mit Auflagen gemäss Art. 6 verknüpft werden."
        },
        {
          "absatz": "3",
          "text": "Gesuche für Finanzhilfen und Darlehen sind entsprechend den Bestimmungen von Art. 7 bei der Wirtschaftsförderungsstelle einzureichen."
        },
        {
          "absatz": "4",
          "text": "Das zuständige Departement entscheidet über die Förderung von Vorhaben bis Fr. 150'000."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/911.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c33ac1c1dab874f83db68e4aa4a74bec",
      "sha": "c7dffacca669bb2a28c9b760c75b641ab6d495607d565b7672e5098b7ef0dff9"
    },
    {
      "id": "kanton/AR/911.11/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die Wirtschaftsförderung (911.11)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung tritt zusammen mit dem Gesetz in Kraft."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/911.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c33ac1c1dab874f83db68e4aa4a74bec",
      "sha": "93a711e05ef64e6fd87caae36b36c42a18bf42748774113f708d777134fb6f9a"
    }
  ]
}