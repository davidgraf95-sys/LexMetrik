{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/310.140/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Weiterbildungsfinanzierungvereinbarung, WFV (310.140)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Vereinbarung legt den Mindestbeitrag fest, mit dem sich die Standortkantone an den Kosten der Spitäler für die erteilte strukturierte Weiterbildung von Ärztinnen und Ärzten gemäss Medizinalberufegesetz beteiligen."
        },
        {
          "absatz": "2",
          "text": "Sie regelt zudem den Ausgleich des unterschiedlichen Kostenaufwands der Kantone durch die Gewährung des Mindestbeitrags gemäss Abs. 1."
        }
      ],
      "stand": "2022-01-25",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/310.140",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3b88559bf247526e53edba36148c637e",
      "sha": "5c917a479262e7221ffafda74f60326ffd038ddd2e0035758f2e67bf83680566"
    },
    {
      "id": "kanton/BS/310.140/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Weiterbildungsfinanzierungvereinbarung, WFV (310.140)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Standortkantone richten den Spitälern pro Jahr und Ärztin und Arzt in Weiterbildung (Vollzeitäquivalent) pauschal CHF 15‘000 aus, sofern die betreffende Ärztin/der betreffende Arzt im Zeitpunkt der Erlangung des Universitätszulassungsausweises ihren/seinen Wohnsitz in einem der Vereinbarung beigetretenen Kanton hatte."
        },
        {
          "absatz": "2",
          "text": "Allfällige höhere Beiträge der Standortkantone oder Beiträge der Standortkantone für Ärztinnen und Ärzte, die im Zeitpunkt der Erlangung des Universitätszulassungsausweises ihren Wohnsitz nicht in einem der Vereinbarung beigetretenen Kanton hatten, werden unter den Kantonen nicht ausgeglichen."
        },
        {
          "absatz": "3",
          "text": "Die Standortkantone überprüfen, ob die Weiterbildungsstätten ihrer Spitäler über eine Anerkennung gemäss der vom Bund akkreditierten Weiterbildungsordnung verfügen."
        },
        {
          "absatz": "4",
          "text": "Der Beitrag gemäss Art. 2 Abs. 1 wird jeweils an die Preisentwicklung angepasst, wenn der Landesindex der Konsumentenpreise (LIK) um mindestens 10 Prozent gestiegen ist. Ausgangspunkt ist der Stand des LIK bei Vertragsabschluss (Basis Dezember 2010=100). Das gemäss Art. 6 Abs. 2 zu erlassende Geschäftsreglement regelt die Einzelheiten. Die Beschlussfassung erfolgt bis zum 30. Juni mit Wirkung ab dem folgenden Kalenderjahr."
        }
      ],
      "stand": "2022-01-25",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/310.140",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3b88559bf247526e53edba36148c637e",
      "sha": "187b86cc66a930c2d73c356973abfa452f60c1a9fa179183e9e77f64aecfd4cc"
    },
    {
      "id": "kanton/BS/310.140/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Weiterbildungsfinanzierungvereinbarung, WFV (310.140)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Anzahl der Ärztinnen und Ärzte (Vollzeitäquivalente), für die den Spitälern Beiträge gewährt werden, richtet sich nach der Erhebung des Bundesamtes für Statistik (BFS). Vorbehalten bleiben Korrekturen gemäss Art. 2 Abs. 2 und aufgrund von Plausibilisierungen gemäss Art. 6 Abs. 2 Bst. e."
        }
      ],
      "stand": "2022-01-25",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/310.140",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3b88559bf247526e53edba36148c637e",
      "sha": "f7e0c6a2d1d1e8cd4f86886b1417a8aeca260bcef80d19a329b73b84661bcc84"
    },
    {
      "id": "kanton/BS/310.140/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Weiterbildungsfinanzierungvereinbarung, WFV (310.140)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Standortkanton ist der Kanton, in dem das Spital liegt."
        }
      ],
      "stand": "2022-01-25",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/310.140",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3b88559bf247526e53edba36148c637e",
      "sha": "1ed6b48e92ec7c7ec804d78d2e9f238661ec41ac26cf08f7b31a6798fa34d818"
    },
    {
      "id": "kanton/BS/310.140/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Weiterbildungsfinanzierungvereinbarung, WFV (310.140)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Ausgleich unter den Kantonen wird in folgenden Schritten ermittelt:",
          "items": [
            {
              "marke": "1",
              "text": "Ermittlung der Beitragsleistungen gem. Art. 2 Abs. 1 pro Kanton;"
            },
            {
              "marke": "2",
              "text": "Summierung der Beitragsleistungen aller Vereinbarungskantone;"
            },
            {
              "marke": "3",
              "text": "Teilung der Summe durch die Bevölkerung der Vereinbarungskantone;"
            },
            {
              "marke": "4",
              "text": "Multiplikation des gemittelten pro Kopf-Beitrages eines jeden Vereinbarungskantons mit seiner Bevölkerung;"
            },
            {
              "marke": "5",
              "text": "Gegenüberstellung der Beitragsleistung eines jeden Vereinbarungskantons mit den gemittelten Werten;"
            },
            {
              "marke": "6",
              "text": "Die Differenz der Werte gemäss Schritt 5 bildet den vom Vereinbarungskanton als Ausgleich zu zahlenden bzw. zu beziehenden Beitrag."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Der Ausgleich erfolgt jährlich."
        }
      ],
      "stand": "2022-01-25",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/310.140",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3b88559bf247526e53edba36148c637e",
      "sha": "f95439763b96642badb949cc01ad545bb27123cc2b9c73d7d962d39b8e0ed3e8"
    },
    {
      "id": "kanton/BS/310.140/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Weiterbildungsfinanzierungvereinbarung, WFV (310.140)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Vollzug dieser Vereinbarung obliegt der Versammlung der Vereinbarungskantone (Versammlung)."
        },
        {
          "absatz": "2",
          "text": "Die Versammlung hat folgende Aufgaben:",
          "items": [
            {
              "marke": "a",
              "text": "Wahl des Vorsitzes;"
            },
            {
              "marke": "b",
              "text": "Erlass eines Geschäftsreglements;"
            },
            {
              "marke": "c",
              "text": "Bezeichnung der Geschäftsstelle;"
            },
            {
              "marke": "d",
              "text": "Anpassungen des Mindestbeitrags gemäss Art. 2 Abs. 4;"
            },
            {
              "marke": "e",
              "text": "Plausibilisierung der Vollzeitäquivalente gemäss Art. 3;"
            },
            {
              "marke": "f",
              "text": "Festlegung des Ausgleichs gemäss Art. 5;"
            },
            {
              "marke": "g",
              "text": "Jährliche Berichterstattung an die Vereinbarungskantone."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Die Beschlüsse der Versammlung erfordern Einstimmigkeit. Die Beschlüsse gemäss Abs. 2 lit. d, e und f gelten ab dem folgenden Jahr."
        }
      ],
      "stand": "2022-01-25",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/310.140",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3b88559bf247526e53edba36148c637e",
      "sha": "4a951528ca2275ef1a7944221cfcfcc89279af1c8937259eab69389db1fead4b"
    },
    {
      "id": "kanton/BS/310.140/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Weiterbildungsfinanzierungvereinbarung, WFV (310.140)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Vollzugskosten dieser Vereinbarung werden von den Vereinbarungskantonen nach Massgabe der Bevölkerungszahl getragen."
        }
      ],
      "stand": "2022-01-25",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/310.140",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3b88559bf247526e53edba36148c637e",
      "sha": "c55cad353d1b8c5535e5f7e7abe65ae6bc89ed3d3494aae2b2fa6f4d2ea893c6"
    },
    {
      "id": "kanton/BS/310.140/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Weiterbildungsfinanzierungvereinbarung, WFV (310.140)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Vereinbarungskantone verpflichten sich, vor Anrufung des Bundesgerichts das im IV. Abschnitt der IRV geregelte Streitbeilegungsverfahren anzuwenden."
        }
      ],
      "stand": "2022-01-25",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/310.140",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3b88559bf247526e53edba36148c637e",
      "sha": "0dc291574f9767c9f682cf0cbd2bcf333e43f1df8e9427ddf4369d1cd1ee9555"
    },
    {
      "id": "kanton/BS/310.140/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Weiterbildungsfinanzierungvereinbarung, WFV (310.140)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Beitritt zu dieser Vereinbarung wird mit der Mitteilung an die GDK wirksam."
        }
      ],
      "stand": "2022-01-25",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/310.140",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3b88559bf247526e53edba36148c637e",
      "sha": "47b63d21842eee4016047845e1e22ead606f4e92843d9ec766636463a719abcc"
    },
    {
      "id": "kanton/BS/310.140/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Weiterbildungsfinanzierungvereinbarung, WFV (310.140)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Vereinbarung tritt in Kraft, wenn ihr mindestens 18 Kantone beigetreten sind. Sie ist dem Bund zur Kenntnis zu bringen."
        }
      ],
      "stand": "2022-01-25",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/310.140",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3b88559bf247526e53edba36148c637e",
      "sha": "cb3eb849bcaebce75ee1cdfce5fbdc6e668530421340c619999a04cd3e1aefdf"
    },
    {
      "id": "kanton/BS/310.140/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Weiterbildungsfinanzierungvereinbarung, WFV (310.140)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Jeder Vereinbarungskanton kann den Austritt aus der Vereinbarung beschliessen und durch Erklärung gegenüber der GDK austreten. Der Austritt wird mit dem Ende des auf die Erklärung folgenden Kalenderjahres wirksam und beendet die Vereinbarung, wenn durch den Austritt die Zahl der Vereinbarungskantone unter 18 fällt."
        },
        {
          "absatz": "2",
          "text": "Der Austritt kann frühestens auf das Ende des 5. Jahres seit Inkrafttreten der Vereinbarung erklärt werden."
        }
      ],
      "stand": "2022-01-25",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/310.140",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3b88559bf247526e53edba36148c637e",
      "sha": "cc858e089dece7113b2fc0d5e4471c02e47dba545a51ac679340e87e154188d6"
    },
    {
      "id": "kanton/BS/310.140/art_12",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Weiterbildungsfinanzierungvereinbarung, WFV (310.140)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Vereinbarung gilt unbefristet."
        }
      ],
      "stand": "2022-01-25",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/310.140",
      "abgerufen": "2026-06-23",
      "fassungsToken": "3b88559bf247526e53edba36148c637e",
      "sha": "7fe63565b2338e8bb249bab83d0bdc2672d74c0eed6f82110b77c16e3870fc29"
    }
  ]
}