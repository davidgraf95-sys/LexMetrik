      "erlass": "Tarif des émoluments des notaires (RS 178.104)",
      "artikel": "13",
      "artikelLabel": "Art. 13 al. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Sous réserve de l'alinéa 2, l'émolument proportionnel est calculé comme il suit:",
          "items": [
            {
              "marke": "a",
              "text": "jusqu'à 5'000 francs 200 francs"
            },
            {
              "marke": "b",
              "text": "et en sus de 5000 francs à 200'000 francs 5‰"
            },
            {
              "marke": "c",
              "text": "de 200'000 francs à 500'000 francs 4‰"
            },
            {
              "marke": "d",
              "text": "de 500'000 francs à 1'000'000 de francs 3‰"
            },
            {
              "marke": "e",
              "text": "de 1'000'000 de francs à 10'000'000 de francs 2‰"
            },
            {
              "marke": "f",
              "text": "au-delà de 10'000'000 de francs 1‰"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "L'émolument proportionnel pour la constitution de gages immobiliers est calculé selon le barème suivant:",
          "items": [
            {
              "marke": "a",
              "text": "jusqu'à 10'000 francs: 200 francs"
            },
            {
              "marke": "b",
              "text": "de 10'001 francs à 100'000 francs en sus 5‰"
            },
            {
              "marke": "c",
              "text": "de 100'001 francs à 200'000 francs en sus 4‰"
            },
            {
              "marke": "d",
              "text": "de 200'001 francs à 500'000 francs en sus 3‰"
            },
            {
              "marke": "e",
              "text": "de 500'001 francs à 1'000'000 de francs en sus 2‰"
            },
            {
              "marke": "f",
              "text": "au-delà de 1'000'000 de francs en sus 1‰"
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Demeure réservé l'article 14 du présent règlement."
        }
      ],
      "stand": "2009-01-01",
