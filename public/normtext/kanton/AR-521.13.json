{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/521.13/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung regelt die Erhebung von Kosten, welche durch polizeiliche Handlungen entstanden sind, soweit nicht besondere eidgenössische oder kantonale Vorschriften bestehen."
        },
        {
          "absatz": "2",
          "text": "Polizeiliche Kosten bestehen aus Gebühren und allfälligen Auslagen."
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "81536e908fd5a51c69dc127ede6443eb84512f23e398a7622721f147285b0d76"
    },
    {
      "id": "kanton/AR/521.13/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer polizeiliche Handlungen verursacht, kann zur Zahlung eines angemessenen Teils der entstandenen Kosten verpflichtet werden."
        },
        {
          "absatz": "2",
          "text": "Keine Kosten werden erhoben:",
          "items": [
            {
              "marke": "a",
              "text": "für Rechtshilfehandlungen, es sei denn, es handle sich um ausserordentliche Kosten;"
            },
            {
              "marke": "b",
              "text": "Soweit die Angelegenheit durch das Ordnungsbussenverfahren oder eine Bussenerhebung auf der Stelle erledigt wurde."
            }
          ]
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "63afc1aed628adc5431d04761ea30f16df84c27ebc84de6c39eee6761a760124"
    },
    {
      "id": "kanton/AR/521.13/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Innerhalb des Gebührenrahmens sind die Gebühren in der Regel nach dem Zeit- und Arbeitsaufwand festzulegen."
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "49dc0f7280418bbaf2c8ec91bdfef65f5d055d2ff791827d72e05921673e8ec8"
    },
    {
      "id": "kanton/AR/521.13/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Kleinere Auslagen sind in der Gebühr enthalten."
        },
        {
          "absatz": "2",
          "text": "Erhebliche Auslagen wie Kosten für Expertisen, das externe Erstellen von Plänen, das Prüfen von Fahrzeugen durch Expertinnen oder Experten usw. werden gesondert in Rechnung gestellt."
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "fdbdec6f92552e63de2b9dfabb03d60f9b4d1210bdf4e0657b582c1a13f7cdfe"
    },
    {
      "id": "kanton/AR/521.13/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Innerhalb von Strafverfahren werden Gebühren und Auslagen durch das Erstellen einer Kostennote an die zuständige Behörde weitergeleitet, unabhängig davon, ob die Täterschaft bekannt oder unbekannt ist. In begründeten Fällen, wie beispielsweise einem Teilfreispruch, kann die zuständige Behörde die polizeilichen Kosten nachträglich kürzen oder aufheben. Im Anschluss an einen rechtskräftig ergangenen Schuldspruch sind der Kantonspolizei die entsprechenden polizeilichen Kosten zu überweisen."
        },
        {
          "absatz": "2",
          "text": "Arbeiten des Kriminaltechnischen Dienstes (KTD) werden separat verrechnet."
        },
        {
          "absatz": "3",
          "text": "Bei Gebühren und Auslagen ausserhalb von Strafverfahren wird durch das Polizeikommando eine Rechnung erstellt. Diese wird der verursachenden Person oder der allenfalls zuständigen bzw. Auftrag gebenden Institution oder Behörde zugestellt."
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "549a50c2c0f7c0102e5fe95bab7fffdbf367a78d3a4062e48f59447fd4afefeb"
    },
    {
      "id": "kanton/AR/521.13/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Eine allfällige Mehrwertsteuer ist in den Gebühren dieses Tarifs nicht enthalten."
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "da6efe338e9575f80a018aa9283d0af0a2f4c084941197c886dec693d4260585"
    },
    {
      "id": "kanton/AR/521.13/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Grundgebühren:",
          "items": [
            {
              "marke": "a",
              "text": "geringer Aufwand (bis 1 Stunde) Fr. 80.–"
            },
            {
              "marke": "b",
              "text": "mittlerer Aufwand (bis 2 Stunden) Fr. 150.–"
            },
            {
              "marke": "c",
              "text": "grosser Aufwand (über 2 Stunden) bis Fr. 500.–"
            }
          ]
        },
        {
          "absatz": "1bis",
          "text": "Einvernahmen:",
          "items": [
            {
              "marke": "a",
              "text": "Einvernahmedauer unter 1 Stunde Fr. 50.–"
            },
            {
              "marke": "b",
              "text": "Einvernahmedauer 1 bis 2 Stunden Fr. 100.–"
            },
            {
              "marke": "c",
              "text": "Einvernahmedauer über 2 Stunden Fr. 150.–"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Spezialitäten:",
          "items": [
            {
              "marke": "a",
              "text": "Benützung Videoraum Fr. 400.–"
            },
            {
              "marke": "b",
              "text": "je Spezialfahrzeug (z.B. Einsatzleitfahrzeug) Fr. 300.–"
            },
            {
              "marke": "c",
              "text": "Ausrücken Kommando-Pikett Fr. 140.–"
            },
            {
              "marke": "d",
              "text": "Suchlauf Fahrzeugüberprüfungen SVA Fr. 100.–"
            },
            {
              "marke": "e",
              "text": "Blutprobe/Urinprobe je Fr. 80.–"
            },
            {
              "marke": "f",
              "text": "Demontage Mofas Fr. 80.–"
            },
            {
              "marke": "g",
              "text": "Erstellung technischer Prüfbericht Fr. 80.–"
            },
            {
              "marke": "h",
              "text": "je Fotoblatt ohne Beizug KTD Fr. 20.–"
            },
            {
              "marke": "i",
              "text": "Skizze ohne Beizug KTD Fr. 20.–"
            },
            {
              "marke": "j",
              "text": "Drogenschnelltest (bei positivem Ergebnis) Fr. 80.–"
            },
            {
              "marke": "k",
              "text": "Atemalkoholprobe (bei positivem Ergebnis)"
            },
            {
              "marke": "1",
              "text": "Atemalkoholtestgerät (Testgerät) Fr. 80.–"
            },
            {
              "marke": "2",
              "text": "Atemalkoholmessgerät (Messgerät) Fr. 100.–"
            },
            {
              "marke": "l",
              "text": "Benützung USB-Stick Fr. 25.–"
            },
            {
              "marke": "m",
              "text": "Hausdurchsuchung, je eingesetzter Mitarbeiter und Stunde Fr. 140.–"
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Die aufgeführten Spezialitäten sind auch auf die folgenden Artikel anwendbar."
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "d36ce0f0bc623a6134e14c65e9ea37cd44e12d63122d52c7aef6b3cb67dd2728"
    },
    {
      "id": "kanton/AR/521.13/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Schlussberichte:",
          "items": [
            {
              "marke": "a",
              "text": "normaler Bericht, je angeschuldigte Person Fr. 400.–"
            },
            {
              "marke": "b",
              "text": "komplexer Bericht, je angeschuldigte Person bis Fr.1'500.–"
            }
          ]
        },
        {
          "absatz": "1bis",
          "text": "Berichte IT-Ermittler:",
          "items": [
            {
              "marke": "a",
              "text": "normaler Bericht, je angeschuldigte Person Fr. 250.–"
            },
            {
              "marke": "b",
              "text": "komplexer Bericht, je angeschuldigte Person bis Fr. 2'500.–"
            },
            {
              "marke": "c",
              "text": "Auswertungen IT-Geräte bis Fr. 1'500.–"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Für Verzeigungen, welche zusammen mit dem Schlussbericht erstellt und an die Staatsanwaltschaft überwiesen werden, sind keine Grundgebühren gemäss Art. 7 zu erheben."
        },
        {
          "absatz": "3–4",
          "text": "…"
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "e0477225b1bb802b475cb1387c9c3d492227c8afddf0e87ad1f8dd09a39a2295"
    },
    {
      "id": "kanton/AR/521.13/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Verordnung über die Arbeits- und Ruhezeit der berufsmässigen Motorfahrzeugführer und -führerinnen (ARV 1):",
          "items": [
            {
              "marke": "a",
              "text": "Stundenplanbewilligung Fr. 100.–"
            },
            {
              "marke": "b",
              "text": "Jährliche Verlängerung der Stundenplanbewilligung Fr. 60.–"
            },
            {
              "marke": "c",
              "text": "Tachoscheibenauswertung im Auftrag der zuständigen Strafverfolgungsbehörde, je Stunde Fr. 140.–"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Begleitung von Spezialtransporten:",
          "items": [
            {
              "marke": "a",
              "text": "Für jede eingesetzte Person, je Stunde Fr. 140.–"
            },
            {
              "marke": "b",
              "text": "Für jedes eingesetzte Fahrzeug"
            },
            {
              "marke": "1",
              "text": "Personenwagen und Pikett-Bus, je km Fr. 1.50"
            },
            {
              "marke": "2",
              "text": "Mannschaftstransport und Spezialfahrzeug, je km Fr. 3.–"
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Verkehrstechnik:",
          "items": [
            {
              "marke": "a",
              "text": "Bewilligung, geringer Aufwand Fr. 50.–"
            },
            {
              "marke": "b",
              "text": "Bewilligung, mittlerer Aufwand Fr. 100.–"
            },
            {
              "marke": "c",
              "text": "Bewilligung, grosser Aufwand bis Fr. 500.–"
            }
          ]
        },
        {
          "absatz": "4",
          "text": "Unfallaufnahme:",
          "items": [
            {
              "marke": "a",
              "text": "einfacher Verkehrsunfall (einfache Aufnahme mit geringem Aufwand, ohne weitere Abklärungen und ohne Einvernahme) Fr. 200.–"
            },
            {
              "marke": "b",
              "text": "mittlerer Verkehrsunfall (aufwändigere Aufnahme mit Abklärungen, aber ohne Einvernahmen) Fr. 400.–"
            },
            {
              "marke": "c",
              "text": "schwerer Verkehrsunfall (mehrere Beteiligte, Schwerverletzte oder getötete Personen, erhebliche Abklärungen, aber ohne Einvernahmen) Fr. 800.–"
            }
          ]
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "cae807639a9c4ef14d00714de8b22a851278ca262b635b115ed3df24f81ce28a"
    },
    {
      "id": "kanton/AR/521.13/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Grundgebühren des KTD:",
          "items": [
            {
              "marke": "a",
              "text": "Kurzbericht inkl. Ausrücken Fr. 150.–"
            },
            {
              "marke": "b",
              "text": "Ausführlicher Bericht inkl. Ausrücken bis Fr. 1'500.–"
            },
            {
              "marke": "c",
              "text": "Untersuchung im Auftrag der zuständigen Strafverfolgungsbehörde, je Stunde Fr. 140.–"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Weitere Kostenpunkte des KTD:",
          "items": [
            {
              "marke": "a",
              "text": "Jeder weitere Tag Tatortarbeit, je Fachperson Fr. 300.–"
            },
            {
              "marke": "b",
              "text": "…"
            },
            {
              "marke": "d",
              "text": "Chemische Diebesfalle Fr. 160.–"
            },
            {
              "marke": "e",
              "text": "Technische Diebesfalle Fr. 400.–"
            },
            {
              "marke": "f",
              "text": "Auswertung von Videoaufnahmen aus technischen Diebesfallen, je Stunde Fr. 140.–"
            },
            {
              "marke": "g",
              "text": "DNA-Identifikation (Bearbeitungsgebühr je Spur, zuzüglich Auswertungskosten IRM) Fr. 50.–"
            },
            {
              "marke": "h",
              "text": "Daktyloskopie-Identifikation, je Fall und identifizierte Person Fr. 200.–"
            },
            {
              "marke": "i",
              "text": "Dokumentenprüfung, je gefälschtes Dokument Fr. 200.–"
            }
          ]
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "f377740e222868237840a124eab7edb050e4a84a853ea54a0a5c7488686aa161"
    },
    {
      "id": "kanton/AR/521.13/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im Kantonsgefängnis sowie in den Zellen auf dem Polizeiposten werden für Unterkunft und Verpflegung folgende Tagespauschalen verrechnet:",
          "items": [
            {
              "marke": "a",
              "text": "Haft, je Hafttag Fr. 180.–"
            },
            {
              "marke": "b",
              "text": "Strafvollzug: gemäss jeweiligem Jahresbeschluss der ostschweizerischen Strafvollzugskommission"
            },
            {
              "marke": "c",
              "text": "Ausschaffungshaft: gemäss der eidgenössischen Verordnung über den Vollzug der Weg- und Ausweisung von ausländischen Personen"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Ankunfts- und Abgangstage werden voll verrechnet."
        },
        {
          "absatz": "3",
          "text": "Bei Zwischenaufenthalten werden lediglich die effektiven Verpflegungskosten verrechnet."
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "c54c82353c5d0b4ab278ee6d6eaf1135eee72ad18111affa056220c5f6e83b91"
    },
    {
      "id": "kanton/AR/521.13/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Interkantonale Transporte von verhafteten Personen werden grundsätzlich mittels «Train-Street» durchgeführt und nicht gesondert verrechnet."
        },
        {
          "absatz": "2",
          "text": "Für Gefangenentransporte, Begleitungen, Vorführungen, Einweisungen in Spitäler, Kliniken oder Heime, welche die Kantonspolizei selbst durchführt, werden zu Lasten der Auftrag gebenden Behörde bzw. zuständigen Institution folgende Gebühren erhoben:",
          "items": [
            {
              "marke": "a",
              "text": "Für jede eingesetzte Person, je Stunde Fr. 140.–"
            },
            {
              "marke": "b",
              "text": "Für jedes eingesetzte Fahrzeug"
            },
            {
              "marke": "1",
              "text": "Personenwagen und Pikett-Bus, je km Fr. 1.50"
            },
            {
              "marke": "2",
              "text": "Mannschaftstransport und Spezialfahrzeug, je km Fr. 3.–"
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Für Jugendliche, welche den Erziehungsberechtigten am Wohnort übergeben werden, werden Fr. 100.– verrechnet."
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "b749933b24d5908637976079b2886bf47d0a389b487c9f40cd44be878e9ab7a6"
    },
    {
      "id": "kanton/AR/521.13/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Muss die Kantonspolizei wegen Häuslicher Gewalt intervenieren, so werden der verursachenden Person, unabhängig von einer allfälligen Verzeigung oder Strafverfolgung, folgende Gebühren verrechnet:",
          "items": [
            {
              "marke": "a",
              "text": "Geringer Aufwand; in der Regel ohne Wegweisung Fr. 150.–"
            },
            {
              "marke": "b",
              "text": "Mittlerer Aufwand; in der Regel mit Wegweisung Fr. 300.–"
            },
            {
              "marke": "c",
              "text": "Erheblicher Aufwand; in der Regel mit Wegweisung Fr. 500.– bis Fr. 800.–"
            },
            {
              "marke": "d",
              "text": "…"
            },
            {
              "marke": "e",
              "text": "Begleitung an den Ort der Wegweisung Fr. 80.–"
            }
          ]
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "8e830bc3a0296cc44e36de01cb3bc4fd5e75b48f87e991086127f1c35263fb43"
    },
    {
      "id": "kanton/AR/521.13/art_13_bis",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "13_bis",
      "artikelLabel": "Art. 13bis",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Muss die Kantonspolizei wegen Stalking intervenieren, so werden der verursachenden Person, unabhängig von einer allfälligen Verzeigung oder Strafverfolgung, folgende Gebühren verrechnet:",
          "items": [
            {
              "marke": "a",
              "text": "Geringer Aufwand Fr. 150.–"
            },
            {
              "marke": "b",
              "text": "Mittlerer Aufwand Fr. 300.–"
            },
            {
              "marke": "c",
              "text": "Erheblicher Aufwand Fr. 500.– bis Fr. 800.–"
            }
          ]
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "6c5a43fe50f575abb30d370899319ef0faf8088930a8b5f379eea7cad2e8b909"
    },
    {
      "id": "kanton/AR/521.13/art_13_ter",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "13_ter",
      "artikelLabel": "Art. 13ter",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Muss die Kantonspolizei eine Person vorübergehend von einem Ort wegweisen oder fernhalten, so werden dieser folgende Gebühren verrechnet:",
          "items": [
            {
              "marke": "a",
              "text": "Geringer Aufwand; in der Regel schriftliche Verfügung nach mündlicher Wegweisung/Fernhaltung (ohne Verzeigung) Fr. 100.–"
            },
            {
              "marke": "b",
              "text": "Mittlerer Aufwand; in der Regel erste schriftliche Wegweisung/Fernhaltung Fr. 150.–"
            }
          ]
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "cc097272e5669e5013c81a8d4285151ff3fd6d757d73a03818f724338d7823b5"
    },
    {
      "id": "kanton/AR/521.13/art_14",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bewilligungen:",
          "items": [
            {
              "marke": "a",
              "text": "Kleiner Anlass Fr. 50.–"
            },
            {
              "marke": "b",
              "text": "Mittlerer Anlass Fr. 150.–"
            },
            {
              "marke": "c",
              "text": "Grossanlass bis Fr. 1 000.–"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Dienstleistungen bei privaten Veranstaltungen:",
          "items": [
            {
              "marke": "a",
              "text": "Für jede eingesetzte Person, je Stunde Fr. 140.–"
            },
            {
              "marke": "b",
              "text": "Für jedes eingesetzte Fahrzeug"
            },
            {
              "marke": "1",
              "text": "Personenwagen und Pikett-Bus, je km Fr. 1.50"
            },
            {
              "marke": "2",
              "text": "Mannschaftstransport und Spezialfahrzeug, je km Fr. 3.–"
            },
            {
              "marke": "c",
              "text": "Pauschalen bei Veranstaltungen:"
            },
            {
              "marke": "1",
              "text": "Geringer Aufwand (4–6 Personen) Fr. 1 000.–"
            },
            {
              "marke": "2",
              "text": "Mittlerer Aufwand (7–12 Personen) Fr. 2 000.–"
            },
            {
              "marke": "3",
              "text": "Mittelgrosser Aufwand (13–18 Personen) Fr. 4 000.–"
            },
            {
              "marke": "4",
              "text": "Grosser Aufwand (19–28 Personen) Fr. 6 000.–"
            },
            {
              "marke": "5",
              "text": "Sehr grosser Aufwand (über 28 Personen) Fr. 8 000.–"
            },
            {
              "marke": "d",
              "text": "Anlässe mit grossem Gefährdungspotenzial: Je Zuschauer pauschal Fr. –.50"
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Je nach öffentlichem Interesse der Wohnbevölkerung am Anlass kann die Gebühr für Dienstleistungen vom Polizeikommando reduziert oder vom Departement Inneres und Sicherheit teilweise oder ganz erlassen werden."
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "97758a2abe0a0555962c81e4c00a63239a2c0593824af8ef6fafbb3f24f18977"
    },
    {
      "id": "kanton/AR/521.13/art_15",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "15",
      "artikelLabel": "Art. 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für Berichte im Auftrag anderer Amtsstellen werden, soweit es sich nicht um Rechtshilfehandlungen gemäss Art. 2 Abs. 2 handelt, folgende Gebühren erhoben:",
          "items": [
            {
              "marke": "a",
              "text": "Kurzer Bericht Fr. 50.–"
            },
            {
              "marke": "b",
              "text": "Bericht mit durchschnittlichem Aufwand Fr. 100.–"
            },
            {
              "marke": "c",
              "text": "Aufwändiger Bericht Fr. 200.–"
            }
          ]
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "395d98c2f7f905f2f489a2671ff11acdfb0f4b0ee52974082c6b578d1c49dd25"
    },
    {
      "id": "kanton/AR/521.13/art_16",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "16",
      "artikelLabel": "Art. 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Beim Polizeikommando aufgeschaltete Alarmanlagen:",
          "items": [
            {
              "marke": "a",
              "text": "Einmalige Anschlussgebühr Fr. 400.–"
            },
            {
              "marke": "b",
              "text": "Änderung des Alarmdossiers Fr. 200.–"
            },
            {
              "marke": "c",
              "text": "Monatliche Abonnementstaxe Fr. 50.–"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Fehlalarme von aufgeschalteten Alarmanlagen:",
          "items": [
            {
              "marke": "a",
              "text": "Einbruch- und Überfallalarm:"
            },
            {
              "marke": "1",
              "text": "Erster Fehlalarm je Kalenderjahr keine Gebühr"
            },
            {
              "marke": "2",
              "text": "Zweiter Fehlalarm je Kalenderjahr Fr. 150.–"
            },
            {
              "marke": "3",
              "text": "Für jeden weiteren Fehlalarm Fr. 300.–"
            },
            {
              "marke": "b",
              "text": "Bedrohungsalarm:"
            },
            {
              "marke": "1",
              "text": "Grundgebühr je Fehlalarm Fr. 200.–"
            },
            {
              "marke": "2",
              "text": "Zusätzlich je ausgerückte Person der Kantonspolizei Fr. 140.–"
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Fehlalarme von Fremdanlagen (nicht beim Polizeikommando aufgeschaltet):",
          "items": [
            {
              "marke": "a",
              "text": "Erster Fehlalarm je Kalenderjahr keine Gebühr"
            },
            {
              "marke": "b",
              "text": "Für jeden weiteren Fehlalarm Fr. 400.–"
            }
          ]
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "f0e15b424450998ff30299f95053295a130311143ad89760accd1c306d27b74c"
    },
    {
      "id": "kanton/AR/521.13/art_16_bis",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "16_bis",
      "artikelLabel": "Art. 16bis",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für Firma:",
          "items": [
            {
              "marke": "a",
              "text": "Auf drei Jahre befristete generelle Bewilligung Fr. 500.– bis Fr. 1'000.–"
            },
            {
              "marke": "b",
              "text": "Auf drei Jahre befristete Bewilligung für Firma, welche ausschliesslich im verkehrspolizeilichen Bereich tätig ist Fr. 300.– bis Fr. 500.–"
            },
            {
              "marke": "c",
              "text": "…"
            },
            {
              "marke": "d",
              "text": "Angestellten-Bewilligung"
            },
            {
              "marke": "1",
              "text": "Erstzertifizierung, je Person Fr. 300.– bis Fr. 500.–"
            },
            {
              "marke": "2",
              "text": "Rezertifizierung, je Person Fr. 200.– bis Fr. 400.–"
            },
            {
              "marke": "3",
              "text": "Unbefristete Bewilligung bei Firmen gemäss lit. b, je Person Fr. 200.– bis Fr. 400.–"
            },
            {
              "marke": "e",
              "text": "…"
            }
          ]
        },
        {
          "absatz": "1bis",
          "text": "…"
        },
        {
          "absatz": "1ter",
          "text": "Für die Abmeldung von Angestellten wird keine Gebühr verrechnet."
        },
        {
          "absatz": "1quater",
          "text": "Die Prüfungsgebühren werden nach Aufwand in Rechnung gestellt."
        },
        {
          "absatz": "2",
          "text": "Für die Verweigerung oder den Entzug der Bewilligung wird bis Fr. 1 000.– verrechnet."
        },
        {
          "absatz": "3",
          "text": "Für eine Verwarnung werden Fr. 100.– in Rechnung gestellt."
        },
        {
          "absatz": "4",
          "text": "Für andere Verfügungen werden bis zu Fr. 300.– verrechnet."
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "351876d04c2ada66ae66b20b2d403a1820fdb17f7f86e7007af5cf5e5ed2039f"
    },
    {
      "id": "kanton/AR/521.13/art_16_quater",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "16_quater",
      "artikelLabel": "Art. 16quater",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Bewilligung des Verkaufs von Sprengmitteln und pyrotechnischen Gegenständen werden folgende Gebühren erhoben",
          "items": [
            {
              "marke": "a",
              "text": "Erwerbsschein für Sprengmittel Fr. 100.–"
            },
            {
              "marke": "b",
              "text": "Bewilligung zur Erstellung von Sprengmittelmagazinen (Verbrauchermagazine), je nach Aufwand Fr. 200.– bis Fr. 600.–"
            },
            {
              "marke": "c",
              "text": "Feuerwerksverkaufsbewilligung, gültig für zwei Jahre Fr. 100.–"
            },
            {
              "marke": "d",
              "text": "Erwerb- und Abbrandbewilligung Feuerwerk Kat. F4 Fr. 80.–"
            }
          ]
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "9f7f01173d63de1cc72384345f1ca2bbe31ae2d8afb318079eae546187baa5fd"
    },
    {
      "id": "kanton/AR/521.13/art_16_ter",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "16_ter",
      "artikelLabel": "Art. 16ter",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Auswertung von Videoüberwachungen wird je Stunde Fr. 140.– verrechnet."
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "857d2a24a75490892dc7cce5766100f67e044f3f1478b8597728d22d08ca5367"
    },
    {
      "id": "kanton/AR/521.13/art_17",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "17",
      "artikelLabel": "Art. 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dienstleistungen:",
          "items": [
            {
              "marke": "a",
              "text": "Ausweisverlustanzeige Fr. 10.–"
            },
            {
              "marke": "b",
              "text": "Fahrzeugumschreibungen Fr. 10.–"
            },
            {
              "marke": "c",
              "text": "Weitere Dienstleistungen effektive Auslagen"
            },
            {
              "marke": "d",
              "text": "Vermittlung von aufgefundenen Mobiltelefonen Fr. 10.–"
            },
            {
              "marke": "e",
              "text": "Begleitung von Viehtrieben ausserhalb der koordinierten Fahrten"
            },
            {
              "marke": "1",
              "text": "Für jede eingesetzte Person, je Stunde Fr. 140.–"
            },
            {
              "marke": "2",
              "text": "Für jedes eingesetzte Fahrzeug, je km Fr. 1.50"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Polizeieinsätze ausserhalb von Strafverfahren",
          "items": [
            {
              "marke": "a",
              "text": "Ist die Kantonspolizei im Auftrag von Amtsstellen ausserhalb von Strafverfahren tätig oder verursacht eine Person grobfahrlässig oder mutwillig einen Polizeieinsatz, ohne dass anschliessend eine Verzeigung erfolgt, können folgende Gebühren erhoben werden:"
            },
            {
              "marke": "1",
              "text": "Polizeilicher Kurzeinsatz: Pauschalgebühr für \"polizeilichen Kurzeinsatz\" Fr. 100.–"
            },
            {
              "marke": "2",
              "text": "Ausserhalb von polizeilichen Kurzeinsätzen: Für jede eingesetzte Person, je Stunde Fr. 140.–"
            },
            {
              "marke": "3",
              "text": "Ausserhalb von polizeilichen Kurzeinsätzen: Für jedes eingesetzte Fahrzeug"
            },
            {
              "marke": "3",
              "text": "Personenwagen und Pikett-Bus, je km Fr. 1.50"
            },
            {
              "marke": "3",
              "text": "Mannschaftstransport und Spezialfahrzeug, je km Fr. 3.–"
            },
            {
              "marke": "b",
              "text": "Für Suchaktionen werden in der Regel keine Kosten verrechnet, es sei denn, der Suchaktion liege ein vorwerfbares Verhalten zu Grunde (z.B. Irreführung der Rechtspflege). In diesem Fall kann der verursachenden Person in Anwendung der obigen Ansätze ein dem Verschulden angemessener Teil der entstandenen Kosten in Rechnung gestellt werden."
            },
            {
              "marke": "c",
              "text": "Zustellung von Betreibungsurkunden:"
            },
            {
              "marke": "1",
              "text": "Einfache Zustellung, je Zustellung Fr. 50.–"
            },
            {
              "marke": "2",
              "text": "Zustellung mit Zuführung Fr. 70.–"
            },
            {
              "marke": "3",
              "text": "…"
            }
          ]
        }
      ],
      "stand": "2017-09-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "52b8efca7b4c05692454665e8653d0a4",
      "sha": "50a871a92ee58f47be091bf47b6c1e882b8f7e51faaee6f25950c50764951f2b"
    },
    {
      "id": "kanton/AR/521.13/art_18",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gebührentarif der Kantonspolizei (521.13)",
      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung tritt am 1. Januar 2003 in Kraft."
        }
      ],
