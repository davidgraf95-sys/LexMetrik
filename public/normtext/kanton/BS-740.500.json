      "erlass": "Verordnung betreffend die Entschädigung der Expropriationskommission (740.500)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Präsident der Expropriationskommission, seine Stellvertreter, die übrigen Mitglieder und ihre Stellvertreter sowie der Sekretär beziehen für ihre Tätigkeit eine Entschädigung gemäss Zeitaufwand."
        }
      ],
      "stand": "1991-09-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/740.500",
      "abgerufen": "2026-06-23",
