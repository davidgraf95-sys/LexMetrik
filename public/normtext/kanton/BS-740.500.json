      "erlass": "Verordnung betreffend die Entschädigung der Expropriationskommission (740.500)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Mitglieder der Expropriationskommission, ihre Stellvertreter und der Sekretär stellen der Gerichtskasse für jedes Verfahren Rechnung, sobald es abgeschlossen ist."
        }
      ],
      "stand": "1991-09-01",
