      "quelle": "BS",
      "erlass": "Verordnung betreffend die Entschädigung der Expropriationskommission (740.500)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der maximale Stundenansatz entspricht dem Honorar für Advokaten im Kostenerlass und orientiert sich im Übrigen am berufsüblichen Honorar der Mitwirkenden."
        }
      ],
      "stand": "1991-09-01",
