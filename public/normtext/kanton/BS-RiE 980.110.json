{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/RiE 980.110/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die Vergabekommission Entwicklungszusammenarbeit (RiE 980.110)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "titel": "Vergabekommission Entwicklungszusammenarbeit",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Gemeinderat wählt auf seine eigene Amtsdauer eine Vergabekommission Entwicklungszusammenarbeit."
        }
      ],
      "stand": "2022-01-31",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 980.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e80a4cdecfd37c2c8c413db0df82bcae",
      "sha": "029a23677f684532d1b33e585119941fba2c31dc068309f1d4c5eb472f9c8768"
    },
    {
      "id": "kanton/BS/RiE 980.110/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die Vergabekommission Entwicklungszusammenarbeit (RiE 980.110)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Zusammensetzung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Vergabekommission gehören fünf Mitglieder an, nämlich:",
          "items": [
            {
              "marke": "a",
              "text": "das zuständige Mitglied des Gemeinderats;"
            },
            {
              "marke": "b",
              "text": "ein Mitglied der zuständigen einwohnerrätlichen Sachkommission;"
            },
            {
              "marke": "c",
              "text": "ein weiteres Mitglied des Einwohnerrats;"
            },
            {
              "marke": "d",
              "text": "zwei Personen mit Wohnsitz in Riehen, welche einen Fachbezug zur Thematik mitbringen."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Das Präsidium wird durch das zuständige Mitglied des Gemeinderats besetzt. Das Vizepräsidium wird durch die Vergabekommission gewählt."
        },
        {
          "absatz": "3",
          "text": "Die Leitung der zuständigen Abteilung der Verwaltung berät die Vergabekommission fachlich und führt das Protokoll."
        }
      ],
      "stand": "2022-01-31",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 980.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e80a4cdecfd37c2c8c413db0df82bcae",
      "sha": "e87064492568c83d113b62c6fd9be0ba5afeaf52f8e03eede5039ea486eca6da"
    },
    {
      "id": "kanton/BS/RiE 980.110/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die Vergabekommission Entwicklungszusammenarbeit (RiE 980.110)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Aufgaben",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Vergabekommission prüft die Anträge der Hilfsorganisationen für die Vergabe von Geldern in der Entwicklungszusammenarbeit und unterbreitet dem Gemeinderat einmal jährlich einen Vergabevorschlag."
        },
        {
          "absatz": "2",
          "text": "Im ersten Jahr der Legislaturperiode beinhaltet der Vergabevorschlag den Vorschlag für die Schwerpunktthemen für die Vergabe in den kommenden vier Jahre."
        },
        {
          "absatz": "3",
          "text": "Die Vergabekommission prüft jährlich die Berichte der unterstützten Projekte und erstattet dem Gemeinderat Bericht."
        }
      ],
      "stand": "2022-01-31",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 980.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e80a4cdecfd37c2c8c413db0df82bcae",
      "sha": "01914dba5fcb79de2cb0979eb3b1cbba00b458e274277b6a889ab57621bf57f2"
    },
    {
      "id": "kanton/BS/RiE 980.110/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die Vergabekommission Entwicklungszusammenarbeit (RiE 980.110)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Vergabekriterien",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Gemeinderat legt die Kriterien für die Vergabe von Geldern in der Entwicklungszusammenarbeit im In- und Ausland in einer Richtlinie fest."
        }
      ],
      "stand": "2022-01-31",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 980.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e80a4cdecfd37c2c8c413db0df82bcae",
      "sha": "c21b74336dfc093be5e15389d8cecfa8bf3d0648c3e6f9781b17f9cfd201dafc"
    },
    {
      "id": "kanton/BS/RiE 980.110/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die Vergabekommission Entwicklungszusammenarbeit (RiE 980.110)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "titel": "Kompetenzen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Vergabekommission hat ausschliesslich beratende Funktion."
        },
        {
          "absatz": "2",
          "text": "Sie stellt Antrag an den Gemeinderat und berichtet über die von ihr beratenen Geschäfte."
        }
      ],
      "stand": "2022-01-31",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 980.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e80a4cdecfd37c2c8c413db0df82bcae",
      "sha": "465152144b4e17360c8e4f6772f0e5cb282a6ed64cc3111365c5535ca085fa2e"
    },
    {
      "id": "kanton/BS/RiE 980.110/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement für die Vergabekommission Entwicklungszusammenarbeit (RiE 980.110)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "titel": "Abwicklung der Geschäfte",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Vergabekommission erhält von der Verwaltung einmal jährlich die vollständigen, formell vorgeprüften und aufbereiteten Vergabeanträge der Hilfsorganisationen."
        },
        {
          "absatz": "2",
          "text": "Sie trifft eine Projektauswahl und erarbeitet gestützt auf die Richtlinien des Gemeinderats ihren Vergabevorschlag zuhanden des Gemeinderats."
        },
        {
          "absatz": "3",
          "text": "Sie kann externe Fachpersonen anhören oder sich durch solche beraten lassen."
        }
      ],
      "stand": "2022-01-31",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 980.110",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e80a4cdecfd37c2c8c413db0df82bcae",
      "sha": "6b02c0712aef61ff1272cf862a1727cabbdd7395ed7b9caf8ced321594dda193"
    }
  ]
}