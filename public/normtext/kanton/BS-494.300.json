{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/494.300/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kulturfördergesetz (494.300)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieses Gesetz regelt die Kulturförderung durch den Kanton."
        },
        {
          "absatz": "2",
          "text": "Es bezweckt die Förderung des kulturellen Schaffens, der Vermittlung der Kultur sowie die Förderung des kulturellen Austauschs."
        },
        {
          "absatz": "3",
          "text": "Vorbehalten bleiben: - Gesetz über das Archivwesen (Archivgesetz) vom 11. September 1996; - Gesetz über die Museen des Kantons Basel-Stadt (Museumsgesetz) vom 16. Juni 1999; - Gesetz über das Universitätsgut (Universitätsgutsgesetz) vom 16. Juni 1999; - Gesetz über den Denkmalschutz vom 20. März 1980; - Gesetz betreffend Vorführung von Filmen vom 11. Februar 1971."
        }
      ],
      "stand": "2022-05-30",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/494.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2c2a6f0d469f90e0cfab4e91a85eb6fd",
      "sha": "b4b4623b114f1a2082dca780606661482f12cd8aa27595853a8b6100813c2ac4"
    },
    {
      "id": "kanton/BS/494.300/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kulturfördergesetz (494.300)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton fördert ein vielfältiges und qualitativ hochwertiges Kulturschaffen und Kulturangebot. Er fördert inklusive Angebote."
        },
        {
          "absatz": "2",
          "text": "Er setzt sich für gute Rahmenbedingungen für das Kulturschaffen und Kulturangebot ein."
        },
        {
          "absatz": "3",
          "text": "Er setzt sich für die Verbesserung der sozialen Sicherheit der Kulturschaffenden ein."
        },
        {
          "absatz": "4",
          "text": "Er gewährleistet geeignete Strukturen und transparente Verfahren zur Beurteilung von Gesuchen und Vergabe von Fördermitteln."
        },
        {
          "absatz": "5",
          "text": "Er garantiert die Freiheit der Kunst."
        },
        {
          "absatz": "6",
          "text": "Er zeigt sich offen gegenüber neuen kulturellen Ausdrucksformen."
        },
        {
          "absatz": "7",
          "text": "Er setzt sich insbesondere für die Förderung der Jugend- und Alternativkultur in allen Sparten und entsprechende Rahmenbedingungen ein."
        }
      ],
      "stand": "2022-05-30",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/494.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2c2a6f0d469f90e0cfab4e91a85eb6fd",
      "sha": "ac1b1d64fc98c00896dbbd39c89e7d1e8c895ca335ba4547835819c02a347042"
    },
    {
      "id": "kanton/BS/494.300/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kulturfördergesetz (494.300)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton koordiniert seine Kulturförderung mit den Gemeinden und sucht die Zusammenarbeit mit dem Bund sowie über die Kantons- und Landesgrenzen hinaus. Insbesondere pflegt er die Zusammenarbeit mit dem Kanton Basel-Landschaft und setzt sich für dessen angemessene Beteiligung an den kulturellen Zentrumsleistungen des Kantons ein."
        },
        {
          "absatz": "2",
          "text": "Er strebt die Zusammenarbeit mit Privaten an, die im Leitbild definiert ist."
        }
      ],
      "stand": "2022-05-30",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/494.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2c2a6f0d469f90e0cfab4e91a85eb6fd",
      "sha": "430466d377989e6450d767e90162e2a640f67384da707f6b61bead71a313c4d0"
    },
    {
      "id": "kanton/BS/494.300/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kulturfördergesetz (494.300)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton fördert die Kultur insbesondere durch folgende Mittel und Massnahmen:",
          "items": [
            {
              "marke": "a",
              "text": "er gewährt Finanzhilfen;"
            },
            {
              "marke": "b",
              "text": "er schliesst Verträge;"
            },
            {
              "marke": "c",
              "text": "er trifft die erforderlichen Massnahmen im Bereich der Infrastruktur und der Vermittlung und berät Kulturschaffende;"
            },
            {
              "marke": "d",
              "text": "er setzt weitere zur Förderung geeignete Mittel ein."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Er zeichnet Personen oder Institutionen aus, die sich um die Kultur besonders verdient gemacht haben."
        }
      ],
      "stand": "2022-05-30",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/494.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2c2a6f0d469f90e0cfab4e91a85eb6fd",
      "sha": "15bf79a401a6e3af2b8b6fb83311e4734a7c20f9e72cff2c5169a3cd03d09316"
    },
    {
      "id": "kanton/BS/494.300/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kulturfördergesetz (494.300)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton fördert das Kulturschaffen in den verschiedenen Sparten."
        },
        {
          "absatz": "2",
          "text": "Er unterstützt kulturelle Anlässe sowie Vorhaben Dritter und führt alleine oder mit Dritten zusammen kulturelle Anlässe durch."
        }
      ],
      "stand": "2022-05-30",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/494.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2c2a6f0d469f90e0cfab4e91a85eb6fd",
      "sha": "690bf8aba808b752e71b36239d4d06d8aaab497f3bd9a58faada4f2e2b139b1f"
    },
    {
      "id": "kanton/BS/494.300/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kulturfördergesetz (494.300)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton fördert die Kulturvermittlung und den Zugang zur Kultur."
        },
        {
          "absatz": "2",
          "text": "Er unterstützt Dritte, insbesondere auch Bildungsinstitutionen, bei der Kulturvermittlung und bei der Förderung des Zugangs zur Kultur."
        },
        {
          "absatz": "3",
          "text": "Er unterstützt insbesondere junge Menschen im Rahmen der Kulturvermittlung und durch die Förderung ihres Zugangs zur Kultur."
        }
      ],
      "stand": "2022-05-30",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/494.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2c2a6f0d469f90e0cfab4e91a85eb6fd",
      "sha": "3ed5f7b8ef5946ebdc943f8ee85fc7ff2efd7ff8c2779b49cadb5e93a780bf8a"
    },
    {
      "id": "kanton/BS/494.300/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kulturfördergesetz (494.300)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton fördert den Kulturaustausch."
        },
        {
          "absatz": "2",
          "text": "Er beteiligt sich an Austauschprogrammen und unterstützt Dritte in dieser Tätigkeit."
        }
      ],
      "stand": "2022-05-30",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/494.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2c2a6f0d469f90e0cfab4e91a85eb6fd",
      "sha": "f73b6bc3046b447970133d1190cfbba56e937c8acd384d8d5f3d10d6b4ea2632"
    },
    {
      "id": "kanton/BS/494.300/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kulturfördergesetz (494.300)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat legt die Kulturförderpolitik unter Mitwirkung aller interessierter Personen in einem Kulturleitbild periodisch fest."
        },
        {
          "absatz": "2",
          "text": "Der Grosse Rat nimmt vom Kulturleitbild Kenntnis."
        },
        {
          "absatz": "3",
          "text": "Der Regierungsrat berichtet über die Umsetzung des Leitbilds."
        }
      ],
      "stand": "2022-05-30",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/494.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2c2a6f0d469f90e0cfab4e91a85eb6fd",
      "sha": "24e23400c6680392503757c709c21c4a89e40eafb059003e8a2c79275d390b32"
    },
    {
      "id": "kanton/BS/494.300/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kulturfördergesetz (494.300)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das für die Kulturförderung zuständige Departement setzt die durch den Regierungsrat festgelegte Kulturförderpolitik um."
        },
        {
          "absatz": "2",
          "text": "Es führt zu diesem Zweck eine Fachbehörde."
        },
        {
          "absatz": "3",
          "text": "Es kann Vergabeentscheide an Fachkommissionen delegieren und beratende Organe einsetzen."
        }
      ],
      "stand": "2022-05-30",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/494.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2c2a6f0d469f90e0cfab4e91a85eb6fd",
      "sha": "30277e837514e42e3edd76dd3aa3f1f4aef96c231aa71ea5826760b059fb1465"
    },
    {
      "id": "kanton/BS/494.300/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kulturfördergesetz (494.300)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Fachbehörde vollzieht das Kulturfördergesetz und hat insbesondere folgende Aufgaben:",
          "items": [
            {
              "marke": "a",
              "text": "Sie führt die ihr zugeordneten Dienststellen;"
            },
            {
              "marke": "b",
              "text": "sie ist die Anlaufstelle des Kantons für alle Fragen der Kulturförderung;"
            },
            {
              "marke": "c",
              "text": "sie bearbeitet Fördergesuche;"
            },
            {
              "marke": "d",
              "text": "sie veröffentlicht jährlich einen Tätigkeitsbericht;"
            },
            {
              "marke": "e",
              "text": "sie ist für die Umsetzung weiterer kulturpolitischer Aufgaben zuständig."
            }
          ]
        }
      ],
      "stand": "2022-05-30",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/494.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2c2a6f0d469f90e0cfab4e91a85eb6fd",
      "sha": "aca14bca13d514b079db1ed2235eb2bc3562aab8aded10caccdb7743b8928f30"
    },
    {
      "id": "kanton/BS/494.300/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kulturfördergesetz (494.300)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kulturförderung im Kanton wird insbesondere finanziert durch die im Budget eingestellten Mittel, von Dritten zur Verfügung gestellte Mittel und weitere öffentliche Beiträge."
        },
        {
          "absatz": "2",
          "text": "Von den im Budget eingestellten Mitteln für die Kulturförderung werden mindestens 5 % für die Jugend- und Alternativkultur gemäss § 2 Abs. 7 eingesetzt. Der Regierungsrat berichtet dem Grossen Rat alle vier Jahre."
        }
      ],
      "stand": "2022-05-30",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/494.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2c2a6f0d469f90e0cfab4e91a85eb6fd",
      "sha": "d1d8c063914620243ffd5be82578561b4c801ec6e498156700b8308fe35fd83a"
    },
    {
      "id": "kanton/BS/494.300/art_12",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kulturfördergesetz (494.300)",
      "artikel": "12",
      "artikelLabel": "§ 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat erlässt die zu diesem Gesetz notwendigen Verordnungen."
        },
        {
          "absatz": "2",
          "text": "Dieses Gesetz gewährt keinen Rechtsanspruch auf staatliche Leistungen."
        }
      ],
      "stand": "2022-05-30",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/494.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2c2a6f0d469f90e0cfab4e91a85eb6fd",
      "sha": "a1b6d3b3ee0074a9a38d6c48a213fbabc9f7f51328ee3fa4497d8cb39387014c"
    },
    {
      "id": "kanton/BS/494.300/art_12_a",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kulturfördergesetz (494.300)",
      "artikel": "12_a",
      "artikelLabel": "§ 12a",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Umsetzung des § 11 Abs. 2 erfolgt ab Inkrafttreten der Bestimmung stufenweise innert drei Jahren."
        }
      ],
      "stand": "2022-05-30",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/494.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "2c2a6f0d469f90e0cfab4e91a85eb6fd",
      "sha": "9c9d2c150f6beaada58bbfb2cd2229e49062402b6978c1cd6729dc236337a01a"
    },
    {
      "id": "kanton/BS/494.300/art_13",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Kulturfördergesetz (494.300)",
      "artikel": "13",
      "artikelLabel": "§ 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieses Gesetz ist zu publizieren. Es unterliegt dem Referendum. Nach Eintritt der Rechtskraft bestimmt der Regierungsrat den Zeitpunkt der Wirksamkeit."
        }
      ],
      "stand": "2022-05-30",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/494.300",
      "abgerufen": "2026-06-23",
