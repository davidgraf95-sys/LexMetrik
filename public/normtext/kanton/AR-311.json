{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/311/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die allgemeinen Bestimmungen dieses Gesetzes finden auf alle Strafbestimmungen des kantonalen Rechts Anwendung, soweit die entsprechenden Erlasse keine Sondervorschriften enthalten."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "47ed1f297b627ee3361e7fad59f2e9fc851f801e5e14c953649a947a4df77ed9"
    },
    {
      "id": "kanton/AR/311/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die allgemeinen Bestimmungen des Schweizerischen Strafgesetzbuches finden unter Vorbehalt abweichender Vorschriften kantonaler Erlasse auf die nach kantonalem Recht strafbaren Handlungen sinngemäss Anwendung."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "4a7ac82efcae38604f7fb77d2d3c5d16c084866fb37e7f24b1653838e46d9a35"
    },
    {
      "id": "kanton/AR/311/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Übertretungen des kantonalen Rechts sind auch strafbar, wenn sie fahrlässig begangen werden, sofern nicht nach dem Wortlaut oder dem Sinn der Strafbestimmung nur die vorsätzliche Begehung mit Strafe bedroht ist."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "bfedcd30da9ab2ea36bf5b1b2b51808e5011fd954ea05a9271ba649182832017"
    },
    {
      "id": "kanton/AR/311/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Hat jemand durch dieselbe Handlung neben einer kantonalen Übertretung ein Verbrechen oder ein Vergehen begangen, so wird die Übertretung kantonalen Rechts nicht verfolgt."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "f8e1aa07e6695ed0185ff02c540aab80931bbdf4ca18bceb2e205ba57f54d536"
    },
    {
      "id": "kanton/AR/311/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Kantons- und Regierungsrat sind befugt, zur Durchsetzung der von ihnen erlassenen Verordnungen Bussen anzudrohen."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "efede732c35728d16318ee73bd6b6b7c8f1ce3d9d25f09335c60af3dd1aac3f1"
    },
    {
      "id": "kanton/AR/311/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gemeinden sind befugt, zur Durchsetzung der von ihnen erlassenen Reglemente und Verordnungen Bussen anzudrohen."
        },
        {
          "absatz": "2",
          "text": "Für die Anwendung solcher Bestimmungen gelten die Vorschriften dieses Gesetzes und der Schweizerischen Strafprozessordnung. Zuwiderhandlungen werden nur auf Anzeige der Gemeindebehörden verfolgt."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "aeda4038e17721147772da839544beaec2c3836c8e7271b9ea329334cff51c85"
    },
    {
      "id": "kanton/AR/311/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Mitglieder des Kantonsrates und des Regierungsrates können wegen Äusserungen im Kantonsrat und in dessen Kommissionen nur strafrechtlich verfolgt werden, wenn zwei Drittel der anwesenden Mitglieder des Kantonsrates dazu die Ermächtigung erteilen."
        },
        {
          "absatz": "2",
          "text": "Die Gemeinden sind befugt, Bestimmungen über die Immunität auf Gemeindeebene zu erlassen."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "929032f0981cf6632d4332efb24fb7538e9d307bb91df211ab4f570875fcdb80"
    },
    {
      "id": "kanton/AR/311/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Mitglieder des Regierungsrates und des Obergerichtes können wegen Straftaten im Amte nur verfolgt werden, wenn eine Mehrheit des Kantonsrates dazu die Ermächtigung erteilt. In diesem Falle bestimmt der Kantonsrat das weitere Verfahren."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "d5834195a7e4ad802266b962f3957992fc30c0d4c844998b10267a5e112e1a7a"
    },
    {
      "id": "kanton/AR/311/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer vorsätzlich bei Unglücksfällen oder bei Gemeingefahr der Aufforderung eines Beamten oder eines Behördemitgliedes, Nothilfe zu leisten, ohne genügenden Grund nicht nachkommt, wird mit Busse bestraft."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "bd1e99850d56f62ca0ce47d769630eb35c6155f48066513e4f8db58e4fefae18"
    },
    {
      "id": "kanton/AR/311/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer in Notwehr oder Notstand eine Person getötet oder schwer verletzt hat und dies nicht sofort der Polizei meldet, wird mit Busse bestraft."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "49045abd2a03eb7ccef51507bfdc55c1a88e43e3b1a03f23c67364c4f9778375"
    },
    {
      "id": "kanton/AR/311/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer durch aufdringliches Betteln jemanden belästigt, wer Kinder oder Personen, die von ihm abhängen, zum Bettel ausschickt, wird mit Busse bestraft."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "9aa2de6fa7137159e9cfc8882ff03d24200509a40a048804dace54e46e12c534"
    },
    {
      "id": "kanton/AR/311/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer Glücksspiele um hohe Geldbeträge veranstaltet, in seinen Räumen duldet oder an solchen teilnimmt, wird mit Busse bestraft."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "1ccd38b1d96d3c9ea5d8a9f43e62b2454d57cb530da243415b6e9d77b52c32b5"
    },
    {
      "id": "kanton/AR/311/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer vorsätzlich durch Werfen von Gegenständen, Ausgiessen von Flüssigkeiten oder Verbreiten von Gasen die Bevölkerung gefährdet oder belästigt, wird mit Busse bestraft."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "5820c9cc70e529e570197968d12dcb10d5565f0c7ddbc08d77b16423861494f9"
    },
    {
      "id": "kanton/AR/311/art_14",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer Schusswaffen oder Munition einer Person unter 16 Jahren oder einer Person, bei der die für den Gebrauch dieser Gegenstände erforderliche Kenntnis oder Vorsicht nicht vorausgesetzt werden kann, verkauft oder ohne gehörige Beaufsichtigung anvertraut, wer zum Scherz oder sonst leichtfertig mit einer Schusswaffe auf einen Menschen anschlägt, wird mit Busse bestraft."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "cd39649d76aab32fe33f385a54be7ad6833051d113b1ec34771f13765e115b85"
    },
    {
      "id": "kanton/AR/311/art_15",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "15",
      "artikelLabel": "Art. 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer ein wildes oder bösartiges Tier nicht gehörig verwahrt und beaufsichtigt, wer durch vorsätzliches Hetzen, Reizen oder Scheumachen von Tieren eine Gefahr für Menschen, Tiere und Sachen herbeiführt, wird mit Busse bestraft."
        },
        {
          "absatz": "2",
          "text": "Der Richter kann die Tötung des Tieres anordnen."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "2f44f07b64ad79703960190e86e23301e11e75e801c705c8542a150ea726080e"
    },
    {
      "id": "kanton/AR/311/art_16",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "16",
      "artikelLabel": "Art. 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer vorsätzlich Dietriche, Schlüssel, Stempel oder amtliche Formulare unberechtigterweise anfertigt oder an Unberechtigte liefert, wer Dietriche, Schlüssel, Stempel, Siegel oder amtliche Formulare vorsätzlich missbraucht oder sich zu diesem Zweck verschafft, wird mit Busse bestraft."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "9502f481c8e0a6eb4992df9cb0afd7f4bd038c90b14479b332c702607d0188ab"
    },
    {
      "id": "kanton/AR/311/art_17",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "17",
      "artikelLabel": "Art. 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer wider besseres Wissen der Allgemeinheit dienende Sicherheits- und Hilfsdienste oder Medizinalpersonen alarmiert, wer Sirenen, Signalgeräte, Rufanlagen und ähnliche Vorrichtungen missbräuchlich verwendet, wer vorsätzlich die Bevölkerung durch falschen Feuerruf, durch falsche Nachrichten, Gerüchte und dergleichen in Angst oder Schrecken versetzt, wird mit Busse bestraft."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "88cb95cca2fb86f3e5eaa3c4822c7030864de596c2fe96886ffcc33c5d003862"
    },
    {
      "id": "kanton/AR/311/art_18",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer mutwillig durch Lärm die Nachtruhe stört, wer in grober Weise die Ruhe an Sonn- und Feiertagen stört, wird mit Busse bestraft."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "ace64709067eeec2183abb28d61e313a2799cfd6db3a6dda5e69ef867944ecdd"
    },
    {
      "id": "kanton/AR/311/art_19",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "19",
      "artikelLabel": "Art. 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer sich in angetrunkenem oder berauschtem Zustand öffentlich ungebührlich aufführt, wer in anderer Weise öffentlich Sitte und Anstand grob verletzt, wird mit Busse bestraft."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "d2295a39a27f388e1a5f54f71b9e26bf8e1c33df0ce4694a6588e753a17fe1b0"
    },
    {
      "id": "kanton/AR/311/art_20",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "20",
      "artikelLabel": "Art. 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer Gebäude, Mauern oder Denkmäler durch Zeichen, Inschriften oder auf ähnliche Weise verunstaltet, wird mit Busse bestraft."
        },
        {
          "absatz": "2",
          "text": "Versuch und Gehilfenschaft sind strafbar."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "870d46d940e1af72d3f726c2ab07c7a427ae68ff943dc1542371b75b3865ed34"
    },
    {
      "id": "kanton/AR/311/art_23",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "23",
      "artikelLabel": "Art. 23",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer sein vermeintliches oder wirkliches Recht, wenn es bestritten ist, erzwingt, ohne dazu durch Gesetz oder amtliche Verfügung ermächtigt zu sein, wird, auf Antrag, mit Busse bestraft."
        },
        {
          "absatz": "2",
          "text": "Versuch und Gehilfenschaft sind strafbar."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "074b5cd6c542a101b9dbd0feff72c906f3db2ebe22b770f17c034d15eede09d9"
    },
    {
      "id": "kanton/AR/311/art_24",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "24",
      "artikelLabel": "Art. 24",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer öffentlich angeschlagene amtliche Bekanntmachungen vorsätzlich entfernt, beschädigt, entstellt oder besudelt, wird mit Busse bestraft."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "e17d3826ad9b9bc70cad7591d64abbfb1c026f771af698cac2180df457b0eeee"
    },
    {
      "id": "kanton/AR/311/art_25",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "25",
      "artikelLabel": "Art. 25",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer unberechtigt mit einer Person, die polizeilich festgenommen worden ist, sich in Untersuchungs- oder Ausschaffungshaft, im Straf- oder Massnahmenvollzug befindet, in Kontakt tritt oder ihr etwas überbringt, wird mit Busse bestraft."
        },
        {
          "absatz": "2",
          "text": "Versuch und Gehilfenschaft sind strafbar."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "b11cd4b14075b92b3caeef9beb5ae9817a982f4a5a003c2289455ff73835dfe5"
    },
    {
      "id": "kanton/AR/311/art_26",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "26",
      "artikelLabel": "Art. 26",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer Beamten oder Behördemitgliedern mit polizeilichen Funktionen, die sich gehörig ausweisen, die Ausübung ihres Dienstes erschwert oder verunmöglicht, wer Beamten oder Behördemitgliedern auf berechtigte Aufforderung hin die Angabe seines Namens oder andere Angaben über die eigene Person verweigert oder unrichtig macht, wird mit Busse bestraft."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "948b2d8ebf4f19befba8b524e46ef45e8268c8d131facb158e2269fbb5a17281"
    },
    {
      "id": "kanton/AR/311/art_27",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "27",
      "artikelLabel": "Art. 27",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer sich ohne Berechtigung als Inhaber eines akademischen Grades bezeichnet oder wer den akademischen Grad einer Anstalt führt, der dem gleich lautenden Grad einer schweizerischen staatlichen Hochschule offensichtlich nicht gleichwertig ist, wer ohne Berechtigung kundgibt, dass er ein Diplom über eine Ausbildung oder einen Fähigkeitsausweis erworben habe, wird mit Busse bestraft."
        },
        {
          "absatz": "2",
          "text": "Der Richter kann die Veröffentlichung des Urteils anordnen."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "d8e6a3653b9d2945b5c26d97761f69160b437b7192f050be1b12972e71819707"
    },
    {
      "id": "kanton/AR/311/art_29",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "29",
      "artikelLabel": "Art. 29",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer als Behördemitglied oder Beamter des Kantons oder einer Gemeinde den ihm obliegenden Pflichten vorsätzlich nicht nachkommt, wird mit Bussebestraft."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "989a0416b253d1e1f35af09d63963b1e344f05d1daca157229f64946854612bd"
    },
    {
      "id": "kanton/AR/311/art_30",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Gesetz über das kantonale Strafrecht (311)",
      "artikel": "30",
      "artikelLabel": "Art. 30",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer einen Beamten oder eine Behörde durch Vorspiegelung oder Unterdrückung von Tatsachen arglistig irreführt oder deren Irrtum arglistig benutzt und so unrechtmässig eine Konzession, eine Bewilligung oder eine andere Leistung des Gemeinwesens erschleicht, wird mit Busse bestraft."
        },
        {
          "absatz": "2",
          "text": "Versuch und Gehilfenschaft sind strafbar."
        }
      ],
      "stand": "2011-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/311",
      "abgerufen": "2026-06-23",
      "fassungsToken": "c0919f3a6dc17d1bff740ac501984924",
      "sha": "7e7c6b20ff5851b73502e013c52ed852153bfaac0823d15239d41c7958b9f3d2"
    },
