{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/575.100/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Wehrpflichtersatzabgabe (575.100)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "titel": "Kantonale Behörde für die Wehrpflichtersatzabgabe",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zuständig für die Veranlagung und den Bezug der Wehrpflichtersatzabgabe ist die Wehrpflichtersatzverwaltung. Veranlagung und Bezug erfolgen nach Massgabe der bundesrechtlichen Vorschriften."
        }
      ],
      "stand": "2016-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/575.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e16d1a333bf8ae2ff1982ffaacd32cf4",
      "sha": "564235eb7467516810f14359ae451eb81f5b57bb2d4de3973a17210dba55ea8d"
    },
    {
      "id": "kanton/BS/575.100/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Wehrpflichtersatzabgabe (575.100)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Kreiskommando",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Kreiskommando Basel-Stadt ist insbesondere zuständig für",
          "items": [
            {
              "marke": "a",
              "text": "Meldung von Zuzug und Wegzug von Ersatzpflichtigen;"
            },
            {
              "marke": "b",
              "text": "Mithilfe bei Nachforschungen, bei Vorladungen und bei polizeilichen Ausschreibungen."
            }
          ]
        }
      ],
      "stand": "2016-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/575.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e16d1a333bf8ae2ff1982ffaacd32cf4",
      "sha": "21755d2c3ddae085b6ed11d86d410aabdd3d00997b96f0e6c012d24b11f6e4c7"
    },
    {
      "id": "kanton/BS/575.100/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Wehrpflichtersatzabgabe (575.100)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Kantonale Steuerverwaltung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Steuerverwaltung Basel-Stadt meldet der Wehrpflichtersatzverwaltung von jedem im Kanton wohnhaften Ersatzpflichtigen:",
          "items": [
            {
              "marke": "a",
              "text": "die für die Veranlagung der Ersatzabgabe massgebenden Einkommensbestandteile aufgrund der rechtskräftigen Veranlagung bzw. Einschätzung zur direkten Bundessteuer oder, wenn keine solche vorliegt, zur Kantonssteuer;"
            },
            {
              "marke": "b",
              "text": "das Ergebnis von Revisionen für die direkte Bundessteuer oder die Kantonssteuer;"
            },
            {
              "marke": "c",
              "text": "die Eröffnung und das Ergebnis von Nachsteuerverfahren für die direkte Bundessteuer oder die Kantonssteuer."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die Steuerverwaltung Basel-Stadt gewährt der Wehrpflichtersatzverwaltung Einsicht in die Akten der direkten Bundessteuer sowie der Kantonssteuer von Ersatzpflichtigen und ermöglicht den Zugriff auf alle für die Veranlagung und den Bezug der Wehrpflichtersatzabgabe erforderlichen Daten."
        }
      ],
      "stand": "2016-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/575.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e16d1a333bf8ae2ff1982ffaacd32cf4",
      "sha": "4a6ff202cd19ffd00148c92070901fdfbe79944099a6a7d9b1f5c8a2c4063ce1"
    },
    {
      "id": "kanton/BS/575.100/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Wehrpflichtersatzabgabe (575.100)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Rekurskommission",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Rekurskommission ist die Steuerrekurskommission Basel-Stadt."
        }
      ],
      "stand": "2016-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/575.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e16d1a333bf8ae2ff1982ffaacd32cf4",
      "sha": "649be5993bab586a7d23cbb817d27618112d29f8f5d23ebc414b54c65c67cb8a"
    },
    {
      "id": "kanton/BS/575.100/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Wehrpflichtersatzabgabe (575.100)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "titel": "Gebühr für die zweite Mahnung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die zweite Mahnung wird eine Gebühr von Fr. 50.- erhoben."
        }
      ],
      "stand": "2016-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/575.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e16d1a333bf8ae2ff1982ffaacd32cf4",
      "sha": "a8caf2519f3b2084a25e3cfe62d1737776fcbbd866f5ee65611dd5a4854125a6"
    },
    {
      "id": "kanton/BS/575.100/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Wehrpflichtersatzabgabe (575.100)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "titel": "Stundung und Erlass",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zuständig für die Stundung und den Erlass von Ersatzabgaben, Zinsen und Kosten sowie Bussen ist die Wehrpflichtersatzverwaltung."
        }
      ],
      "stand": "2016-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/575.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e16d1a333bf8ae2ff1982ffaacd32cf4",
      "sha": "6c2a2aeae19b0291b967bfa35e36fe32013c7fbd589fd0ccc139eaf2be9c1ff5"
    },
    {
      "id": "kanton/BS/575.100/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Wehrpflichtersatzabgabe (575.100)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "titel": "Strafverfolgung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ordentliche Strafverfolgungsbehörde im Sinn von Art. 44 Abs. 2 WPEG ist die Staatsanwaltschaft Basel-Stadt."
        },
        {
          "absatz": "2",
          "text": "Die gerichtliche Beurteilung einer Strafverfügung der Wehrpflichtersatzverwaltung im Sinn von Art. 44 Abs. 4 WPEG erfolgt durch das Strafgericht."
        }
      ],
      "stand": "2016-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/575.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e16d1a333bf8ae2ff1982ffaacd32cf4",
      "sha": "66c26c3908c29dfb6c8deb01faeaaf7308c24af5aed49637a3c8307c87a5af28"
    },
    {
      "id": "kanton/BS/575.100/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Wehrpflichtersatzabgabe (575.100)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "titel": "Aufhebung bisherigen Rechts und Wirksamkeit",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Verordnung über den Wehrpflichtersatz vom 14. Januar 1997 wird aufgehoben."
        },
        {
          "absatz": "2",
          "text": "Diese Verordnung ist zu publizieren; sie wird auf den 1. Januar 2004 wirksam."
        }
      ],
      "stand": "2016-07-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/575.100",
