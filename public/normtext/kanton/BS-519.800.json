{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/519.800/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Gebühren des Instituts für Rechtsmedizin (519.800)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "titel": "Geltungsbereich",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung regelt die vom Institut für Rechtsmedizin (IRM) für seine Dienstleistungen zu erhebenden Gebühren gemäss dem Gebührentarif im Anhang."
        }
      ],
      "stand": "2015-01-25",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/519.800",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9f6b34e55a55be39021d403ea5121982",
      "sha": "4a0107371731fdf37cac3152d26bd3034d4787a93e38f6a485ccb272136a7339"
    },
    {
      "id": "kanton/BS/519.800/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Gebühren des Instituts für Rechtsmedizin (519.800)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Taxpunktsystem",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühren werden nach dem Taxpunkt-System berechnet."
        },
        {
          "absatz": "2",
          "text": "Der Wert eines Taxpunktes beträgt einen Franken (1 TPW = 1 CHF)."
        },
        {
          "absatz": "3",
          "text": "Für Dienstleistungen, welche im Anhang nicht aufgeführt sind, richten sich die Gebühren nach Zeit- und Materialaufwand."
        }
      ],
      "stand": "2015-01-25",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/519.800",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9f6b34e55a55be39021d403ea5121982",
      "sha": "f21064b8ac2c660c6c3a64149a099fc47bd2e4c99a8f76daa0e0693d986b3185"
    },
    {
      "id": "kanton/BS/519.800/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Gebühren des Instituts für Rechtsmedizin (519.800)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Zuschläge",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ausserhalb der Arbeitszeit von 8 bis 18 Uhr erbrachte Leistungen werden mit einem Zuschlag von 25% verrechnet."
        }
      ],
      "stand": "2015-01-25",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/519.800",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9f6b34e55a55be39021d403ea5121982",
      "sha": "3266725bd65a790ceb160962c93417d962fcf27866b1bd2dfa7076944c6cafa8"
    },
    {
      "id": "kanton/BS/519.800/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Gebühren des Instituts für Rechtsmedizin (519.800)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Gegenstand",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Gebührentarif gemäss Anhang umfasst die Leistungen aller drei Abteilungen des IRM und ist wie folgt gegliedert:",
          "items": [
            {
              "marke": "a",
              "text": "Leistungen Forensische Medizin und Verkehrsmedizin"
            },
            {
              "marke": "b",
              "text": "Leistungen Forensische Chemie und Toxikologie"
            },
            {
              "marke": "c",
              "text": "Leistungen Forensische Genetik"
            },
            {
              "marke": "d",
              "text": "Gemeinsame Leistungen (Expertentätigkeit, Administration)"
            }
          ]
        }
      ],
      "stand": "2015-01-25",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/519.800",
      "abgerufen": "2026-06-23",
      "fassungsToken": "9f6b34e55a55be39021d403ea5121982",
      "sha": "93204d89f34537d20fe8894a5b265d50f7d34b0c9202159928f1671539abef36"
    },
    {
      "id": "kanton/BS/519.800/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Gebühren des Instituts für Rechtsmedizin (519.800)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "titel": "Aufhebung bisherigen Rechts und Wirksamkeit",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung ersetzt die Verordnung über den Gebührentarif für Untersuchungen des Gerichtschemischen Laboratoriums vom 29. September 1992 sowie die Verordnung über die Gebühren des Gerichtsärztlichen Dienstes vom 14. April 1993."
        },
        {
          "absatz": "2",
          "text": "Diese Verordnung ist zu publizieren; sie wird sofort wirksam."
        }
      ],
      "stand": "2015-01-25",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/519.800",
      "abgerufen": "2026-06-23",
