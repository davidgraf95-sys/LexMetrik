{
  "erzeugt": "2026-06-16",
  "eintraege": [
    {
      "id": "kanton/NW/268.12/art_20",
      "ebene": "kanton",
      "quelle": "NW",
      "erlass": "Beurkundungsgebührenverordnung, BeurkGebV (NG 268.12)",
      "artikel": "20",
      "artikelLabel": "§ 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Errichtung eines Vertrages auf Übertragung von Grundeigentum nach Art. 657 Abs. 1 ZGB (Kauf, Tausch, Schenkung) beträgt die Gebühr:",
          "items": [
            {
              "marke": "1",
              "text": "2.5‰ der Vertragssumme bis Fr. 200'000.–"
            },
            {
              "marke": "2",
              "text": "plus 2‰ vom Mehrbetrag über Fr. 200'000.– bis Fr. 500'000.–"
            },
            {
              "marke": "3",
              "text": "plus 1.5‰ vom Mehrbetrag über Fr. 500'000.– bis Fr. 1'000'000.–"
            },
            {
              "marke": "4",
              "text": "plus 1‰ vom Mehrbetrag über Fr. 1'000'000.– bis Fr. 5'000'000.–"
            },
            {
              "marke": "5",
              "text": "plus 0.5‰ vom Mehrbetrag über Fr. 5'000'000.–;"
            },
            {
              "marke": "6",
              "text": "die Mindestgebühr beträgt Fr. 300.–."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die Gebühr ist nach dem mutmasslichen Verkehrswert zu berechnen, sofern im Vertrag keine oder eine niedrigere Vertragssumme angegeben ist."
        },
        {
          "absatz": "3",
          "text": "Bei der Übertragung von kleinen Grundstücken im Sinne von § 41 Abs. 3 der Beurkundungsverordnung beträgt die Gebühr Fr. 200.– bis Fr. 600.–."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://gesetze.nw.ch/app/de/texts_of_law/268.12",
      "abgerufen": "2026-06-16",
      "fassungsToken": "3a2ce17eb52aacc46c08bf9c05932b54",
      "sha": "0ec1785ca207d48499fddabd2eb990cb530fb06580caa970be650cc83f0e0e92"
    },
    {
      "id": "kanton/NW/268.12/art_26",
      "ebene": "kanton",
      "quelle": "NW",
      "erlass": "Beurkundungsgebührenverordnung, BeurkGebV (NG 268.12)",
      "artikel": "26",
      "artikelLabel": "NG 268.12 § 26 i.V.m. § 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Begründung eines Baurechtes nach Art. 779a ZGB ist die Gebühr gemäss § 20 zu berechnen. Als Vertragssumme gilt die Leistung des Bauberechtigten. Ist der Bauberechtigte zu periodischen Leistungen verpflichtet, gilt als Vertragssumme der mutmassliche Verkehrswert des Bodens und, soweit sie Gegenstand der Leistung des Baurechtgebers sind, der Gebäude."
        },
        {
          "absatz": "2",
          "text": "…"
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://gesetze.nw.ch/app/de/texts_of_law/268.12",
      "abgerufen": "2026-06-16",
      "fassungsToken": "3a2ce17eb52aacc46c08bf9c05932b54",
      "sha": "b79941e51b3f2ebde963157e93338f0df00319843e9366ae112ad959166ffebd"
    },
    {
      "id": "kanton/NW/268.12/art_31",
      "ebene": "kanton",
      "quelle": "NW",
      "erlass": "Beurkundungsgebührenverordnung, BeurkGebV (NG 268.12)",
      "artikel": "31",
      "artikelLabel": "NG 268.12 § 31 i.V.m. § 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Begründung eines Vorkaufs-, Kaufs- und Rückkaufsrechts (Art. 216 Abs. 2 OR) ist die Gebühr gemäss § 20 (Übertragung von Grundeigentum) zu berechnen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://gesetze.nw.ch/app/de/texts_of_law/268.12",
      "abgerufen": "2026-06-16",
      "fassungsToken": "3a2ce17eb52aacc46c08bf9c05932b54",
      "sha": "fe49312eb2f0f08a3d4830107151d8ec035dfa318554c65540789d97b8c02167"
    },
    {
      "id": "kanton/NW/268.12/art_24",
      "ebene": "kanton",
      "quelle": "NW",
      "erlass": "Beurkundungsgebührenverordnung, BeurkGebV (NG 268.12)",
      "artikel": "24",
      "artikelLabel": "NG 268.12 § 24 (Nutzniessung), § 25 (Wohnrecht), § 26a (andere Dienstbarkeiten)",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Bestellung einer Nutzniessung (Art. 746 ZGB) beträgt die Gebühr Fr. 300.– bis Fr. 1'000.–."
        },
        {
          "absatz": "2",
          "text": "Bei der Inventaraufnahme (Art. 763 ZGB) ist die Gebühr vom Inventarwert gemäss § 16 zu berechnen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://gesetze.nw.ch/app/de/texts_of_law/268.12",
      "abgerufen": "2026-06-16",
      "fassungsToken": "3a2ce17eb52aacc46c08bf9c05932b54",
      "sha": "73e02bc64fafd80cb706f9ab3f915998bd58b8469504a4b0ec76ad58af2e2cba"
    },
    {
      "id": "kanton/NW/268.12/art_28",
      "ebene": "kanton",
      "quelle": "NW",
      "erlass": "Beurkundungsgebührenverordnung, BeurkGebV (NG 268.12)",
      "artikel": "28",
      "artikelLabel": "NG 268.12 § 28",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Errichtung eines Grundpfandes (Art. 799 ZGB) beträgt die Gebühr:",
          "items": [
            {
              "marke": "1",
              "text": "1.5‰ von der Pfandsumme bis Fr. 200'000.–"
            },
            {
              "marke": "2",
              "text": "plus 1.25‰ vom Mehrbetrag über Fr. 200'000.– bis Fr. 500'000.–"
            },
            {
              "marke": "3",
              "text": "plus 1‰ vom Mehrbetrag über Fr. 500'000.– bis Fr. 1'000'000.–"
            },
            {
              "marke": "4",
              "text": "plus 0.5‰ vom Mehrbetrag über Fr. 1'000'000.– bis Fr. 5'000'000.–"
            },
            {
              "marke": "5",
              "text": "plus 0.2‰ vom Mehrbetrag über Fr. 5'000'000.–;"
            },
            {
              "marke": "6",
              "text": "die Mindestgebühr beträgt Fr. 200.–."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Werden in der gleichen öffentlichen Urkunde mehrere Pfandrechte errichtet, ist die Gebühr vom Gesamtbetrag der Pfandsummen zu berechnen."
        },
        {
          "absatz": "3",
          "text": "Bei der Erhöhung der Pfandsumme ist die Gebühr vom Betrag der Erhöhung nach den Ansätzen gemäss Abs. 1 und 2 zu berechnen."
        },
        {
          "absatz": "4",
          "text": "Bei der Umwandlung der Pfandart sowie bei der Aufteilung und Verlegung von Pfandrechten beträgt die Gebühr die Hälfte der Ansätze nach Abs. 1."
        },
        {
          "absatz": "5",
          "text": "Bei anderen Änderungen beträgt die Gebühr Fr. 200.– bis Fr. 600.–."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://gesetze.nw.ch/app/de/texts_of_law/268.12",
      "abgerufen": "2026-06-16",
      "fassungsToken": "3a2ce17eb52aacc46c08bf9c05932b54",
      "sha": "cc314834592fc3d12114fcc546af6491843838f1b41e334a6fd76b097793727f"
    },
    {
      "id": "kanton/NW/268.12/art_18",
      "ebene": "kanton",
      "quelle": "NW",
      "erlass": "Beurkundungsgebührenverordnung, BeurkGebV (NG 268.12)",
      "artikel": "18",
      "artikelLabel": "NG 268.12 §18 Abs.1 Ziff.1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der öffentlichen letztwilligen Verfügung (Art. 499 ZGB) beträgt die Gebühr:",
          "items": [
            {
              "marke": "1",
              "text": "für die Errichtung"
            },
            {
              "marke": "2",
              "text": "für die Abänderung oder die Aufhebung Fr. 250.– bis Fr. 2'000.–."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die Berechnung des Verfügungswertes richtet sich sinngemäss nach § 20."
        },
        {
          "absatz": "3",
          "text": "Dieselben Ansätze gelten auch beim Erbvertrag (Art. 512 ZGB)."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://gesetze.nw.ch/app/de/texts_of_law/268.12",
      "abgerufen": "2026-06-16",
      "fassungsToken": "3a2ce17eb52aacc46c08bf9c05932b54",
      "sha": "6d7efe7821a6fbd37ecd37c5c23a139d05af5cfd7b9fe8906608a374eb20744d"
    },
    {
      "id": "kanton/NW/268.12/art_15",
      "ebene": "kanton",
      "quelle": "NW",
      "erlass": "Beurkundungsgebührenverordnung, BeurkGebV (NG 268.12)",
      "artikel": "15",
      "artikelLabel": "NG 268.12 § 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Abschluss, Abänderung oder Aufhebung eines Ehevertrages (Art. 184 ZGB) oder eines Vermögensvertrages (Art. 25 PartG) beträgt die Gebühr Fr. 350.– bis Fr. 3'000.–."
        },
        {
          "absatz": "2",
          "text": "Ist mit dem Abschluss oder der Abänderung des Ehevertrages oder eines Vermögensvertrages ein Inventar (Art. 195a ZGB) verbunden, bezieht die Urkundsperson überdies die Gebühr gemäss § 16."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://gesetze.nw.ch/app/de/texts_of_law/268.12",
      "abgerufen": "2026-06-16",
      "fassungsToken": "3a2ce17eb52aacc46c08bf9c05932b54",
      "sha": "0e42ff06e6bb0d16385ed21c3ca9a8061df291178d6a9f820d6b32f9deeb2e9d"
    },
    {
      "id": "kanton/NW/268.12/art_32",
      "ebene": "kanton",
      "quelle": "NW",
      "erlass": "Beurkundungsgebührenverordnung, BeurkGebV (NG 268.12)",
      "artikel": "32",
      "artikelLabel": "NG 268.12 § 32",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Schenkung dinglicher Rechte an Grundstücken (Art. 243 Abs. 2 OR) beträgt die Gebühr, soweit nicht die Paragraphen 20, 27 und 28 anwendbar sind, Fr. 200.– bis Fr. 800.–."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://gesetze.nw.ch/app/de/texts_of_law/268.12",
      "abgerufen": "2026-06-16",
      "fassungsToken": "3a2ce17eb52aacc46c08bf9c05932b54",
      "sha": "a12c4b9db7008218c8fd71a71c0b52b0e2130e3b5c8066a9ffd5b8f874fb4d40"
    },
    {
      "id": "kanton/NW/268.12/art_17_a",
      "ebene": "kanton",
      "quelle": "NW",
      "erlass": "Beurkundungsgebührenverordnung, BeurkGebV (NG 268.12)",
      "artikel": "17_a",
      "artikelLabel": "NG 268.12 § 17a",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Errichtung, Abänderung oder Aufhebung eines Vorsorgeauftrags (Art. 361 ZGB) beträgt die Gebühr Fr. 300.– bis Fr. 1'000.–."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://gesetze.nw.ch/app/de/texts_of_law/268.12",
      "abgerufen": "2026-06-16",
      "fassungsToken": "3a2ce17eb52aacc46c08bf9c05932b54",
      "sha": "c9702f492e9bb0941519f37781ae6b9a5a6cfefce6dc0518972a640617b4a94a"
    },
    {
      "id": "kanton/NW/268.12/art_35",
      "ebene": "kanton",
      "quelle": "NW",
      "erlass": "Beurkundungsgebührenverordnung, BeurkGebV (NG 268.12)",
      "artikel": "35",
      "artikelLabel": "NG 268.12 § 35 i.V.m. § 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Errichtung eines Verpfründungsvertrages (Art. 522 OR) ist die Gebühr vom Vermögenswert nach den Ansätzen gemäss § 20 zu berechnen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://gesetze.nw.ch/app/de/texts_of_law/268.12",
      "abgerufen": "2026-06-16",
      "fassungsToken": "3a2ce17eb52aacc46c08bf9c05932b54",
      "sha": "095bf98184086961494dfa0884d3d067780457aa2a31f1dd2c9b29e4b8222513"
    },
    {
      "id": "kanton/NW/268.12/art_36",
      "ebene": "kanton",
      "quelle": "NW",
      "erlass": "Beurkundungsgebührenverordnung, BeurkGebV (NG 268.12)",
      "artikel": "36",
      "artikelLabel": "NG 268.12 § 36 Ziff. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Gründung einer Aktiengesellschaft (Art. 629 OR) oder einer Kommanditaktiengesellschaft (Art. 764 Abs. 2 OR) beträgt die Gebühr:",
          "items": [
            {
              "marke": "1",
              "text": "Fr. 1'000.– bis zu einem Aktienkapital von Fr. 200'000.–"
            },
            {
              "marke": "2",
              "text": "plus 3‰ vom Mehrbetrag über Fr. 200'000.– bis Fr. 500'000.–"
            },
            {
              "marke": "3",
              "text": "plus 2‰ vom Mehrbetrag über Fr. 500'000.– bis Fr. 1'000'000.–"
            },
            {
              "marke": "4",
              "text": "plus 1.0‰ vom Mehrbetrag über Fr. 1'000'000.– bis Fr. 5'000'000.–"
            },
            {
              "marke": "5",
              "text": "plus 0.5‰ vom Mehrbetrag über Fr. 5'000'000.–."
            }
          ]
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://gesetze.nw.ch/app/de/texts_of_law/268.12",
      "abgerufen": "2026-06-16",
      "fassungsToken": "3a2ce17eb52aacc46c08bf9c05932b54",
      "sha": "eb571cafd4cf56041c7f141898efd775d450ffa92519ab8b291864c98c6c35a0"
    },
    {
      "id": "kanton/NW/268.12/art_41",
      "ebene": "kanton",
      "quelle": "NW",
      "erlass": "Beurkundungsgebührenverordnung, BeurkGebV (NG 268.12)",
      "artikel": "41",
      "artikelLabel": "NG 268.12 § 41 Abs. 1 i.V.m. § 36",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Gründung einer Gesellschaft mit beschränkter Haftung (Art. 777 OR) ist die Gebühr nach den Ansätzen von § 36, bei der Erhöhung des Stammkapitals (Art. 781 OR) gemäss § 37 und bei der Herabsetzung des Stammkapitals (Art. 782 OR) gemäss § 38 zu berechnen."
        },
        {
          "absatz": "2",
          "text": "Bei anderen Beschlüssen, für die Abs. 1 nicht anwendbar ist, beträgt die Gebühr Fr. 300.– bis Fr. 2'000.–."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://gesetze.nw.ch/app/de/texts_of_law/268.12",
      "abgerufen": "2026-06-16",
      "fassungsToken": "3a2ce17eb52aacc46c08bf9c05932b54",
      "sha": "0cbf9708d70d6ac4bde1bc0c57692007374d91d1ea9bb245964c11226ce7c84f"
    },
    {
      "id": "kanton/NW/268.12/art_37",
      "ebene": "kanton",
      "quelle": "NW",
      "erlass": "Beurkundungsgebührenverordnung, BeurkGebV (NG 268.12)",
      "artikel": "37",
      "artikelLabel": "NG 268.12 § 37 (AG) / § 41 Abs. 1 i.V.m. § 37 (GmbH)",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Erhöhung des Aktienkapitals (Art. 650–656 OR) richtet sich die Gebühr für den Beschluss der Generalversammlung nach § 40 und für den Beschluss des Verwaltungsrates nach § 36."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://gesetze.nw.ch/app/de/texts_of_law/268.12",
      "abgerufen": "2026-06-16",
      "fassungsToken": "3a2ce17eb52aacc46c08bf9c05932b54",
      "sha": "dfda30a0b1b6092479b359f2bf4563c01f6aacadd6262eed4efa0bb43cb32528"
    },
    {
      "id": "kanton/NW/268.12/art_38",
      "ebene": "kanton",
      "quelle": "NW",
      "erlass": "Beurkundungsgebührenverordnung, BeurkGebV (NG 268.12)",
      "artikel": "38",
      "artikelLabel": "NG 268.12 § 38 (AG) / § 41 Abs. 1 i.V.m. § 38 (GmbH)",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Herabsetzung des Aktienkapitals beträgt die Gebühr für die Beurkundung betreffend Beschlussfassung und Statutenänderung (Art. 732 OR) Fr. 400.– bis Fr. 3'000.–."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://gesetze.nw.ch/app/de/texts_of_law/268.12",
      "abgerufen": "2026-06-16",
      "fassungsToken": "3a2ce17eb52aacc46c08bf9c05932b54",
      "sha": "29f34779d20eca7c28e8f1a72525093a2333c2e68b54d8f5d3dd908a5cfc6e9c"
    },
    {
      "id": "kanton/NW/268.12/art_14",
      "ebene": "kanton",
      "quelle": "NW",
      "erlass": "Beurkundungsgebührenverordnung, BeurkGebV (NG 268.12)",
      "artikel": "14",
      "artikelLabel": "NG 268.12 § 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Errichtung einer Stiftung unter Lebenden (Art. 81 ZGB) beträgt die Gebühr Fr. 250.– bis Fr. 3'000.–."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://gesetze.nw.ch/app/de/texts_of_law/268.12",
      "abgerufen": "2026-06-16",
      "fassungsToken": "3a2ce17eb52aacc46c08bf9c05932b54",
      "sha": "3a633dcd0cbf2e94f63d5379608ead8d703aef5d4dde67b99cc4dfcba053325c"
    },
    {
      "id": "kanton/NW/268.12/art_34",
      "ebene": "kanton",
      "quelle": "NW",
      "erlass": "Beurkundungsgebührenverordnung, BeurkGebV (NG 268.12)",
      "artikel": "34",
      "artikelLabel": "NG 268.12 § 34 Abs. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Errichtung einer Bürgschaft (Art. 493 Abs. 1 OR), bei der Erhöhung der Haftungssumme, bei der Umwandlung einer einfachen in eine Solidarbürgschaft (Art. 493 Abs. 5 OR) sowie bei Beurkundungen nach Art. 493 Abs. 6 OR beträgt die Gebühr 1.5‰ des Haftungsbetrages, mindestens aber Fr. 250.– und höchstens Fr. 1'000.–."
        },
        {
          "absatz": "2",
          "text": "Sind von der Urkundsperson für dieselbe Schuld getrennt abgegebene Bürgschaftserklärungen in derselben Urkunde einzeln zu beurkunden, wird von der zweiten Beurkundung an für jede weitere zur Gebühr nach Abs. 1 ein Zuschlag von 25 Prozent, mindestens aber Fr. 100.– erhoben; der Gesamtbetrag der Zuschläge darf 100 Prozent der Grundgebühr nicht übersteigen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://gesetze.nw.ch/app/de/texts_of_law/268.12",
      "abgerufen": "2026-06-16",
      "fassungsToken": "3a2ce17eb52aacc46c08bf9c05932b54",
      "sha": "1033b6701776a87c116a2dd90b92a68f27b86e66313c445f2837f07c141bffec"
    },
    {
      "id": "kanton/NW/268.12/art_47",
      "ebene": "kanton",
      "quelle": "NW",
      "erlass": "Beurkundungsgebührenverordnung, BeurkGebV (NG 268.12)",
      "artikel": "47",
      "artikelLabel": "NG 268.12 § 47 (beurkundungsbeduerftig) bzw. § 48 (nicht beurkundungsbeduerftig)",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Beurkundung von beurkundungsbedürftigen Geschäften, für die keine andere Gebühr vorgesehen ist, beträgt die Gebühr Fr. 200.– bis Fr. 2'000.–."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://gesetze.nw.ch/app/de/texts_of_law/268.12",
      "abgerufen": "2026-06-16",
      "fassungsToken": "3a2ce17eb52aacc46c08bf9c05932b54",
      "sha": "9bd15016d5b437ca18f0830c32c3db9d5a09a3aaa134d631ee3f4f1cb3ae248b"
    },
    {
      "id": "kanton/NW/268.12/art_49",
      "ebene": "kanton",
      "quelle": "NW",
      "erlass": "Beurkundungsgebührenverordnung, BeurkGebV (NG 268.12)",
      "artikel": "49",
      "artikelLabel": "NG 268.12 § 49 Abs. 1 (Beglaubigung Unterschrift)",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Beglaubigung einer Unterschrift beträgt die Gebühr Fr. 25.–."
        },
        {
          "absatz": "2",
          "text": "Bei gleichzeitiger Beglaubigung mehrerer Unterschriften auf demselben Schriftstück beträgt die Gebühr Fr. 25.– für die erste und Fr. 10.– für jede weitere Unterschrift."
        },
        {
          "absatz": "3",
          "text": "Dasselbe gilt bei der Beglaubigung von Handzeichen."
        }
