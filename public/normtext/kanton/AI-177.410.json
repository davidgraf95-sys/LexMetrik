{
  "erzeugt": "2026-06-17",
  "eintraege": [
    {
      "id": "kanton/AI/177.410/art_1",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Honorarordnung wird angewendet für die Vorbereitung und Durchführung eines Verfahrens:",
          "items": [
            {
              "marke": "a",
              "text": "der Zivil- oder Strafrechtspflege;"
            },
            {
              "marke": "b",
              "text": "der Verwaltungsrechtspflege, wenn ein Gericht zuständig ist oder wenn ein gesetzlicher Anspruch auf Ersatz der ausseramtlichen Kosten besteht."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die Bestimmungen dieser Honorarordnung werden in Steuerstreitigkeiten vor Verwaltungsgericht (Art. 14 VerwGG) auf den eidgenössisch dipl. Steuerexperten sachgemäss angewendet."
        },
        {
          "absatz": "3",
          "text": "Die in dieser Honorarordnung genannten Beträge lauten auf Schweizer Franken."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "86690a33cd75c5bcf10139fb74dc99789f8103f02acb9b529ee9d2495df5a31c"
    },
    {
      "id": "kanton/AI/177.410/art_2",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Honorarordnung bindet den Richter und den Rechtsanwalt."
        },
        {
          "absatz": "2",
          "text": "Die zugesprochenen Parteikosten binden den Rechtsanwalt nicht, wenn das Gesetz keine volle Entschädigung vorsieht."
        },
        {
          "absatz": "3",
          "text": "Rechtsanwalt und Mandant können durch Einzelabrede und unter Hinweis auf die Bestimmungen dieser Honorarordnung die Bemessung des Honorars nach Zeitaufwand zu einem bestimmten Stundenansatz vereinbaren."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "0da35680607c64c01540c1fe6c7e6399ad1b6a88241d37153659953ac697dc10"
    },
    {
      "id": "kanton/AI/177.410/art_3",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Vom Honorar nach dieser Honorarordnung kann abgewichen werden, soweit dieses in einem krassen Missverhältnis zu den Bemühungen des Rechtsanwalts steht."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "7095bc3d9b737fb8b7ffc2ee18343adf795e3179e620236e48668359013dd996"
    },
    {
      "id": "kanton/AI/177.410/art_4",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Rechtsanwalt hat in der Honorarnote die Berechnungsgrundlagen und die angewendeten Bestimmungen dieser Honorarordnung anzugeben."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "5f43a304e5b02a1cd2ff682882f43dcc1f3c75df16529be6c64f92ec476c8432"
    },
    {
      "id": "kanton/AI/177.410/art_5",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Überschreitet der Rechtsanwalt das mittlere Honorar, hat er dies in der Honorarnote zu begründen."
        },
        {
          "absatz": "2",
          "text": "Unterschreitet der Richter das mittlere Honorar, begründet er dies im Entscheid."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "7daac891ad51d646d74e9c1482986a9152c551cb788ade5914acc24a2fb5dc3f"
    },
    {
      "id": "kanton/AI/177.410/art_6",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Reicht der Rechtsanwalt keine Honorarnote ein, werden die Parteikosten in den gesetzlich zulässigen Fällen nach Ermessen zugesprochen."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "66eb99459c328bc18e2398af7113ae839e97775457303a3988db3819e73cb43f"
    },
    {
      "id": "kanton/AI/177.410/art_7",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "…"
        },
        {
          "absatz": "2",
          "text": "Die Gegenpartei kann sich zu einer Honorarnote im schriftlichen Verfahren durch eine Stellungnahme und im mündlichen Verfahren anlässlich der Verhandlung äussern."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "ec320635ec3c451d918b302769e37c1f976eb5a4e77a386cee130fc684cddeca"
    },
    {
      "id": "kanton/AI/177.410/art_9",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Streitwert richtet sich sachgemäss nach den Bestimmungen der Schweizerischen Zivilprozessordnung (ZPO)."
        },
        {
          "absatz": "2",
          "text": "In Rechtsmittelverfahren berechnet sich der Streitwert nach dem Umfang der Anfechtung."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "3f508991a45405ade16a2e4e45711bcc8e9d702f0655151003601ff559572cbf"
    },
    {
      "id": "kanton/AI/177.410/art_10",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das mittlere Honorar im Zivilprozess beträgt für einen Streitwert:",
          "items": [
            {
              "marke": "a",
              "text": "bis 5'000.--: 500.-- +30,0% des Streitwertes"
            },
            {
              "marke": "b",
              "text": "über 5'000.-- bis 20'000.--: 1'230.-- +15,4% des Streitwertes"
            },
            {
              "marke": "c",
              "text": "über 20'000.-- bis 50'000.--: 1'850.-- +12,3% des Streitwertes"
            },
            {
              "marke": "d",
              "text": "über 50'000.-- bis 100'000.--: 3'600.-- + 8,8% des Streitwertes"
            },
            {
              "marke": "e",
              "text": "über 100'000.-- bis 500'000.--: 9'100.-- + 3,3% des Streitwertes"
            },
            {
              "marke": "f",
              "text": "über 500'000.-- bis 1'000'000.--: 12'600.-- + 2,6% des Streitwertes"
            },
            {
              "marke": "g",
              "text": "über 1'000'000.-- bis 2'000'000.--: 15'600.-- + 2,3% des Streitwertes"
            },
            {
              "marke": "h",
              "text": "über 2'000'000.--: 37'600.-- + 1,2% des Streitwertes"
            }
          ]
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "2572ad27a511b770166df7b80f9ea3ad1358e6fc01690a404a099d06546a840d"
    },
    {
      "id": "kanton/AI/177.410/art_11",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Verfügungen im summarischen Verfahren wird das mittlere Honorar auf 10 bis 50% herabgesetzt."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "0db8783c71424fde978c71c8f8f66f8b48d9fb4e16e31808972cbe87cb0ac3e0"
    },
    {
      "id": "kanton/AI/177.410/art_12",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im Verfahren vor Kantonsgericht, Abteilung Zivil- und Strafgericht, als einziger Instanz im Sinne von Art. 5 ff. ZPO wird das mittlere Honorar um einen Fünftel erhöht."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "840e455267350a8111ab6a5c6c439eb8e1e51052d2a2ff2252f1ee311b1a7005"
    },
    {
      "id": "kanton/AI/177.410/art_13",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das mittlere Honorar kann zur Berücksichtigung besonderer Umstände, namentlich der grundsätzlichen Bedeutung und der Schwierigkeit des Falles, der wirtschaftlichen Verhältnisse der Beteiligten, des notwendigen Zeitaufwands, der Vertretung mehrerer Parteien und ausserordentlicher vorprozessualer Bemühungen, um bis zu einem Viertel unter- oder überschritten werden."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "a3afb2cfb5ca524e64b689d516b6b297d30223747882bc8fa5adb2406cabd568"
    },
    {
      "id": "kanton/AI/177.410/art_14",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zum Grundhonorar können Zuschläge erhoben werden für:",
          "items": [
            {
              "marke": "a",
              "text": "die Teilnahme an einer Instruktions- oder Vorverhandlung, Experteninstruktion, Beweiserhebung oder Schlussverhandlung;"
            },
            {
              "marke": "b",
              "text": "eine vom Richter verlangte oder zugelassene zusätzliche und erhebliche Eingabe;"
            },
            {
              "marke": "c",
              "text": "einen aussergewöhnlich komplizierten Prozess;"
            },
            {
              "marke": "d",
              "text": "vorsorgliche Massnahmen im Hauptprozess;"
            },
            {
              "marke": "e",
              "text": "aufwendige Vergleichsverhandlungen."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Der einzelne Zuschlag beträgt 10 bis 40% des Grundhonorars. Die Zuschläge dürfen zusammen das Grundhonorar in der Regel nicht überschreiten."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "5eb8c3d0cb27cfbcf789369969d3c7b8f528c636a202bc3d5b84fe67879337e0"
    },
    {
      "id": "kanton/AI/177.410/art_15",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "15",
      "artikelLabel": "Art. 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Innerhalb des für eine Pauschale gesetzten Rahmens wird das Grundhonorar nach den besonderen Umständen, namentlich nach Art und Umfang der Bemühungen, der Schwierigkeit des Falles und den wirtschaftlichen Verhältnissen der Beteiligten, bemessen."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "f1af6995ab453c131a3950250441c2733495f42275a54d684bf368b0317e890e"
    },
    {
      "id": "kanton/AI/177.410/art_16",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "16",
      "artikelLabel": "Art. 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "In Familiensachen beträgt das Honorar pauschal:",
          "items": [
            {
              "marke": "a",
              "text": "für Ehescheidung, Ehetrennung und Auflösung der eingetragenen Partnerschaft: 1'500.-- bis 10'000.--"
            },
            {
              "marke": "b",
              "text": "für Vaterschaft, Kindesunterhalt und Abänderung eines Urteils: 1'000.-- bis 7'500.--"
            },
            {
              "marke": "c",
              "text": "für Eheschutz: 1'000.-- bis 7'500.--"
            },
            {
              "marke": "d",
              "text": "für Angelegenheiten des Kindes- und Erwachsenenschutzes: 1'000.-- bis 7'500.--"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Für vorsorgliche Massnahmen kann ein Zuschlag von 10 bis 40% des Grundhonorars erhoben werden."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "28d48305d73e601593731fd1cd8d1aa996636da2ab6eda9d79d180476842faea"
    },
    {
      "id": "kanton/AI/177.410/art_17",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "17",
      "artikelLabel": "Art. 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im Strafprozess beträgt das Honorar für die Verteidigung des Angeschuldigten oder die Vertretung des Klägers pauschal:",
          "items": [
            {
              "marke": "a",
              "text": "500.-- bis 5'000.-- , wenn das Verfahren durch Verfügung der Staatsanwaltschaft abgeschlossen wird;"
            },
            {
              "marke": "b",
              "text": "1'000.-- bis 10'000.-- , wenn der Einzelrichter zuständig ist;"
            },
            {
              "marke": "c",
              "text": "1'500.-- bis 15'000.-- , wenn das Bezirksgericht zuständig ist."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Im Verfahren vor dem Zwangsmassnahmengericht beträgt das Honorar für die Verteidigung pauschal 300.-- bis 3'000.--."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "3cb94d1d2be7cc7e8fab35b7c96a615f7590baac8d3ff6132b1e3727cb048316"
    },
    {
      "id": "kanton/AI/177.410/art_18",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im Verfahren vor der verwaltungsgerichtlichen Abteilung des Kantonsgerichts beträgt das Honorar pauschal 1'000.-- bis 12'000.--."
        },
        {
          "absatz": "2",
          "text": "Für ein aussergewöhnlich kompliziertes oder umfangreiches Verfahren kann das Honorar bis zum Doppelten erhöht werden."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "8718cea5a4bbe1177c0fde285fca9a25364f876db97559d78c34e98095a0ba74"
    },
    {
      "id": "kanton/AI/177.410/art_19",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "19",
      "artikelLabel": "Art. 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Honorar wird nach Zeitaufwand bemessen:",
          "items": [
            {
              "marke": "a",
              "text": "in Zivilstreitsachen, wenn ein Streitwert nicht oder nur schwierig zu ermitteln ist;"
            },
            {
              "marke": "b",
              "text": "in Fällen, für die diese Honorarordnung keine besondere Regelung trifft."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "In Familiensachen, in Angelegenheiten des Kindes- und Erwachsenenschutzrechts sowie im Strafprozess kann der Rechtsanwalt das Honorar nach Zeitaufwand bemessen."
        },
        {
          "absatz": "3",
          "text": "Unnötiger Aufwand fällt ausser Betracht."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "d484241ffa03853a2e3ed0b8729c810addedf7f0b3b38cc6fa5af9fc866af08c"
    },
    {
      "id": "kanton/AI/177.410/art_20",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "20",
      "artikelLabel": "Art. 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das mittlere Honorar beträgt 250.-- je Stunde."
        },
        {
          "absatz": "2",
          "text": "Es kann zur Berücksichtigung besonderer Umstände um bis zu einem Viertel unter- oder überschritten werden."
        },
        {
          "absatz": "3",
          "text": "Bei Forderungsstreitigkeiten und der güterrechtlichen Auseinandersetzung kann es erhöht werden für Ansprüche von:",
          "items": [
            {
              "marke": "a",
              "text": "über 250'000.--: auf 300.--"
            },
            {
              "marke": "b",
              "text": "über 500'000.--: auf 350.--"
            },
            {
              "marke": "c",
              "text": "über 1'000'000.--: auf 400.--"
            }
          ]
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "b42dc5c466c5471029beeef12a8210abc4fb6b58a7972ba02fd385d8b6bd3107"
    },
    {
      "id": "kanton/AI/177.410/art_21",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "21",
      "artikelLabel": "Art. 21",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei unentgeltlicher Rechtspflege oder amtlicher Verteidigung beträgt das Honorar 200.-- je Stunde."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "ecd2da269c57ec4e642a907312077821a6a2e2f78a8c397e8e573583c221e039"
    },
    {
      "id": "kanton/AI/177.410/art_22",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "22",
      "artikelLabel": "Art. 22",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Honorar des unentgeltlichen Vertreters in Ehe-, Familien- und Verwandtschaftssachen und des amtlichen Verteidigers wird grundsätzlich als Pauschale bemessen."
        },
        {
          "absatz": "2",
          "text": "In aussergewöhnlichen Fällen kann das Honorar ausnahmsweise nach Zeitaufwand bemessen werden."
        },
        {
          "absatz": "3",
          "text": "Für die unentgeltliche Rechtsberatung in Familiensachen, welche zu einer Einigung führt, beträgt das Honorar pauschal 1'000.-- bis 4'000.--."
        },
        {
          "absatz": "4",
          "text": "Abs. 1–3 dieses Artikels gelangen in Angelegenheiten der eingetragenen Partnerschaft und deren Auflösung sinngemäss zur Anwendung."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "dfa8f43cdb3d14c91aec7680a1da36f02c47fee6182318b916eac60c62879783"
    },
    {
      "id": "kanton/AI/177.410/art_23",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "23",
      "artikelLabel": "Art. 23",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Unterliegt die Gegenpartei, hat der unentgeltliche Vertreter die vollen Parteikosten bei der Gegenpartei einzutreiben."
        },
        {
          "absatz": "2",
          "text": "Für den nicht gedeckten Teil haftet bis zur Höhe des herabgesetzten Honorars der Staat. Im Ausmass der Entschädigung geht die Forderung auf Ersatz der Parteikosten an den Staat über."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "6520ddad51de950e314afb902fca4f73a5dc5cbd6ccb983d9c0486879000b0b5"
    },
    {
      "id": "kanton/AI/177.410/art_24",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "24",
      "artikelLabel": "Art. 24",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der unentgeltliche Vertreter und der amtliche Verteidiger dürfen von ihrem Mandanten kein zusätzliches Honorar fordern."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "03f2dd0b7f73e81c6b5a0926e2b7a268fda3790f8874b6cd1d645bf2e247d26e"
    },
    {
      "id": "kanton/AI/177.410/art_25",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "25",
      "artikelLabel": "Art. 25",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Honorar im Hauptverfahren schliesst ein:",
          "items": [
            {
              "marke": "a",
              "text": "im Zivilprozess die vorprozessualen Bemühungen und das Schlichtungsverfahren;"
            },
            {
              "marke": "b",
              "text": "im Strafprozess das Untersuchungsverfahren."
            }
          ]
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "91c9f554c9c1d760c65b7281fdbcc9ba2dda0035eef35a6e2442c3c77dbc100b"
    },
    {
      "id": "kanton/AI/177.410/art_26",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "26",
      "artikelLabel": "Art. 26",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wird das Honorar nach dem Streitwert oder als Pauschale bemessen, beträgt es für das Rechtsmittelverfahren:",
          "items": [
            {
              "marke": "a",
              "text": "im schriftlichen Verfahren 20 bis 50%;"
            },
            {
              "marke": "b",
              "text": "im Verfahren mit mündlicher Verhandlung 40 bis 75%."
            }
          ]
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "0cfb482819663bb14f19511a40a334e88bd7e2e90c16ef564761c9f11a4a7d72"
    },
    {
      "id": "kanton/AI/177.410/art_27",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "27",
      "artikelLabel": "Art. 27",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im ordentlichen Zivilprozess beträgt das Honorar für einen Verfahrensabschnitt:",
          "items": [
            {
              "marke": "a",
              "text": "im Schlichtungsverfahren bis zu einem Fünftel;"
            },
            {
              "marke": "b",
              "text": "im Schriftenwechsel bis zu drei Vierteln;"
            },
            {
              "marke": "c",
              "text": "in der mündlichen Verhandlung bis zur Hälfte;"
            },
            {
              "marke": "d",
              "text": "im Rechtsmittelverfahren mit mündlicher Verhandlung bis zu neun Zehnteln."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "In anderen Verfahren wird das Honorar für einen unvollständigen Prozess angemessen gekürzt."
        },
        {
          "absatz": "3",
          "text": "Die Mehrkosten eines Anwaltswechsels trägt der Mandant."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "89c6299988163c06cf2b1437981f6179154a9f6e9298e978736a062d38b077cf"
    },
    {
      "id": "kanton/AI/177.410/art_28",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "28",
      "artikelLabel": "Art. 28",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zu den Barauslagen gehören insbesondere die Kosten für Fahrten, Versand, Fernmeldedienstleistungen und notwendige Kopien."
        },
        {
          "absatz": "2",
          "text": "Es können berechnet werden:",
          "items": [
            {
              "marke": "a",
              "text": "0.50 je Kopie;"
            },
            {
              "marke": "b",
              "text": "die Kosten des Bahnbillets 1. Klasse;"
            },
            {
              "marke": "c",
              "text": "0.70 je Kilometer für die Benützung eines Personenwagens."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Die Kosten für Kopien eigener Eingaben, die Anschaffung von Fachliteratur und die Benützung juristischer Datenbanken werden durch das Honorar abgegolten."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "574c8557dde9af8a7a9794611c23e0dc6c4028aecb38ac58c93ea1531fc6dd5a"
    },
    {
      "id": "kanton/AI/177.410/art_29",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "29",
      "artikelLabel": "Art. 29",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Versand-, Fernmelde- und Kopierkosten können pauschal mit 4% des Honorars, höchstens aber mit 1'000.-- berechnet werden."
        },
        {
          "absatz": "2",
          "text": "Soweit Untersuchungs- oder Parteiakten einen ausserordentlichen Umfang haben, können zusätzliche Kopierkosten berechnet werden."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "9cd0f61dd3911fc12b7a94fb8a5667ac5ae5d207e060d3ccaafa506719fd0184"
    },
    {
      "id": "kanton/AI/177.410/art_30",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "30",
      "artikelLabel": "Art. 30",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Mehrwertsteuer wird zum Honorar und den Barauslagen hinzugerechnet."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
      "abgerufen": "2026-06-17",
      "fassungsToken": "a834c3e4b8b33e91ae0e1d11998990ac",
      "sha": "fcfda49e731fa19e957c7484db2421b9e1d6d04dee2c0f4e960c24030cdce89f"
    },
    {
      "id": "kanton/AI/177.410/art_31",
      "ebene": "kanton",
      "quelle": "AI",
      "erlass": "AnwHV (GS 177.410)",
      "artikel": "31",
      "artikelLabel": "Art. 31",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung findet Anwendung für die Instanz, bei der das Verfahren im Zeitpunkt ihres Inkrafttretens anhängig ist."
        }
      ],
      "stand": "2024-01-01",
      "quelleUrl": "https://ai.clex.ch/app/de/texts_of_law/177.410",
