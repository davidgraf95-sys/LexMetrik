{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/321.200/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Vollziehungsverordnung zur eidgenössischen Epidemiengesetzgebung, VvEpG (321.200)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "titel": "Zweck",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung regelt den Vollzug der eidgenössischen Epidemiengesetzgebung durch die kantonalen Behörden."
        }
      ],
      "stand": "2019-01-31",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/321.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d046fca39c1084c42bd8d7efb2e61d4e",
      "sha": "4b99f20116e264afddc2c8db3bd2cca68fb0bed03b9355452fdd1d0dcfc258aa"
    },
    {
      "id": "kanton/BS/321.200/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Vollziehungsverordnung zur eidgenössischen Epidemiengesetzgebung, VvEpG (321.200)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Generelle Zuständigkeit",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Sofern die vorliegende Verordnung nichts anderes bestimmt, ist die Kantonsärztin oder der Kantonsarzt die zuständige kantonale Behörde für den Vollzug der eidgenössischen Epidemiengesetzgebung."
        },
        {
          "absatz": "2",
          "text": "Die Kantonsärztin oder der Kantonsarzt wird unterstützt durch:",
          "items": [
            {
              "marke": "a",
              "text": "die Amtsärztinnen und Amtsärzte;"
            },
            {
              "marke": "b",
              "text": "die Kantonszahnärztin oder den Kantonszahnarzt;"
            },
            {
              "marke": "c",
              "text": "die Kantonsapothekerin oder den Kantonsapotheker;"
            },
            {
              "marke": "d",
              "text": "die Kantonstierärztin oder den Kantonstierarzt;"
            },
            {
              "marke": "e",
              "text": "die Kantonschemikerin oder den Kantonschemiker."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Die Kantonsärztin oder der Kantonsarzt kann weitere Stellen mit Vollzugsaufgaben betrauen."
        }
      ],
      "stand": "2019-01-31",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/321.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d046fca39c1084c42bd8d7efb2e61d4e",
      "sha": "2be6112c262d9c34534a777d0847499e0907cef1ce181dbb9f8655509fd3a5fe"
    },
    {
      "id": "kanton/BS/321.200/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Vollziehungsverordnung zur eidgenössischen Epidemiengesetzgebung, VvEpG (321.200)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Notfallpläne",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Gesundheitsdepartement erarbeitet, beschliesst und veröffentlicht Notfallpläne zum Schutz vor besonderen Gefährdungen der öffentlichen Gesundheit."
        }
      ],
      "stand": "2019-01-31",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/321.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d046fca39c1084c42bd8d7efb2e61d4e",
      "sha": "5c4ff8d2d63be907ff20ae1698d9259bcb1670c50d7c6b0bd1d444b2d12e687f"
    },
    {
      "id": "kanton/BS/321.200/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Vollziehungsverordnung zur eidgenössischen Epidemiengesetzgebung, VvEpG (321.200)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Nationale Programme",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Gesundheitsdepartement unterstützt den Bund bei der Erarbeitung von themenspezifischen nationalen Programmen zur Erkennung, Überwachung, Verhütung und Bekämpfung von übertragbaren Krankheiten und ist für die Umsetzung auf kantonaler Ebene zuständig."
        }
      ],
      "stand": "2019-01-31",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/321.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d046fca39c1084c42bd8d7efb2e61d4e",
      "sha": "f6ff1ebd15c92e4d8d63f2e6947d97a5bf15c2c6996c47cd3f85449a636bd63d"
    },
    {
      "id": "kanton/BS/321.200/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Vollziehungsverordnung zur eidgenössischen Epidemiengesetzgebung, VvEpG (321.200)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "titel": "Meldepflicht",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Neben der Kantonsärztin oder dem Kantonsarzt sind folgende kantonale Behörden gemäss Art. 12 Abs. 4 EpG verpflichtet, dem Bundesamt für Gesundheit Beobachtungen zu melden, welche auf eine Gefahr für die öffentliche Gesundheit hinweisen:",
          "items": [
            {
              "marke": "a",
              "text": "die Kantonstierärztin oder der Kantonstierarzt;"
            },
            {
              "marke": "b",
              "text": "die Kantonschemikerin oder der Kantonschemiker;"
            },
            {
              "marke": "c",
              "text": "die Kantonsapothekerin oder der Kantonsapotheker."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die in Abs. 1 genannten Behörden überwachen in ihrem Zuständigkeitsbereich die Einhaltung der Meldepflichten nach Art. 12 EpG."
        }
      ],
      "stand": "2019-01-31",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/321.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d046fca39c1084c42bd8d7efb2e61d4e",
      "sha": "0d3828c6120f402ac630adfe7615e20619f5d9122b1587f983e5a35807cdbb31"
    },
    {
      "id": "kanton/BS/321.200/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Vollziehungsverordnung zur eidgenössischen Epidemiengesetzgebung, VvEpG (321.200)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "titel": "Obligatorische Impfungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Anordnung eines Impfobligatoriums nach Art. 22 EpG ist der Regierungsrat zuständig."
        }
      ],
      "stand": "2019-01-31",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/321.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d046fca39c1084c42bd8d7efb2e61d4e",
      "sha": "775e9b51b8f31e81e102a6250bc8304dc5400598949f73d66cc2acf7df901766"
    },
    {
      "id": "kanton/BS/321.200/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Vollziehungsverordnung zur eidgenössischen Epidemiengesetzgebung, VvEpG (321.200)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "titel": "Heilmittel",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kantonsapothekerin oder der Kantonsapotheker ist zuständig für den Empfang, die Lagerung und die Verteilung der vom Bund gelieferten Heilmittel zur Bekämpfung übertragbarer Krankheiten des Menschen. Sie oder er bezeichnet die kantonalen Anlieferstellen und meldet diese dem Bund. Dabei stellt sie oder er sicher, dass die Heilmittel auch in einer Krisensituation rechtzeitig weiterverteilt werden können."
        },
        {
          "absatz": "2",
          "text": "Die Kantonsapothekerin oder der Kantonsapotheker überwacht die Einhaltung der Prioritätenliste nach Art. 61 EpV."
        }
      ],
      "stand": "2019-01-31",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/321.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d046fca39c1084c42bd8d7efb2e61d4e",
      "sha": "216a348c6e3b255d982a07b8c2f309e5b94848e8cb631c1b1ea359f552c17371"
    },
    {
      "id": "kanton/BS/321.200/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Vollziehungsverordnung zur eidgenössischen Epidemiengesetzgebung, VvEpG (321.200)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "titel": "Leichenpass",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Zuständigkeit für die Ausstellung der erforderlichen internationalen Transportbewilligung (Leichenpass) richtet sich nach der baselstädtischen Verordnung über das Bestattungs- und Friedhofwesen (Friedhofordnung) vom 18. Juni 2013."
        }
      ],
      "stand": "2019-01-31",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/321.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d046fca39c1084c42bd8d7efb2e61d4e",
      "sha": "3840471b20480e8dc70c587a33b2d3e82ca429d951433da87785c11d4cf14b06"
    }
  ]
}