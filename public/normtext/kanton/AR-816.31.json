{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/816.31/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über das Bestattungswesen (816.31)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Bestattungswesen ist Aufgabe der Gemeinden. Sie sorgen für die Bereitstellung von Friedhöfen. Mehrere Gemeinden können sich für die Anlage und die Benützung eines Friedhofes zusammenschliessen."
        },
        {
          "absatz": "2",
          "text": "Die Gemeinden erlassen Bestattungs- und Friedhof-Ordnungen."
        },
        {
          "absatz": "3",
          "text": "Die Bestattungen und die Friedhöfe unterstehen der Oberaufsicht des Departements Gesundheit und Soziales."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/816.31",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cabba5c4f89c5548b3a0257714894b66",
      "sha": "10a1e421497b867fc3651ad77d522b8ad2d7b2610b3eb11cbabc7a0ed00ccb0d"
    },
    {
      "id": "kanton/AR/816.31/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über das Bestattungswesen (816.31)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gemeinden sorgen für eine würdige Bestattung."
        },
        {
          "absatz": "2",
          "text": "Niemandem darf wegen Glaubensansichten oder aus anderen Gründen ein Begräbnis auf einem öffentlichen Friedhof versagt werden."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/816.31",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cabba5c4f89c5548b3a0257714894b66",
      "sha": "ec953524fdc2aaec7f0fcaa37de50f784a5a638a9005d3b4bd36ded9a44fc605"
    },
    {
      "id": "kanton/AR/816.31/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über das Bestattungswesen (816.31)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Friedhöfe dürfen die öffentliche Gesundheit und die Umwelt nicht gefährden."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/816.31",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cabba5c4f89c5548b3a0257714894b66",
      "sha": "4a5427be3672ba64e3ea8000e3d05439ea8b97282b1797195faff02d00b05f70"
    },
    {
      "id": "kanton/AR/816.31/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über das Bestattungswesen (816.31)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Als Bestattungsarten sind sowohl die Erdbestattung (Beisetzung der eingesargten Leiche in einem Erdgrab) als auch die Feuerbestattung (Einäscherung der eingesargten Leiche) zulässig. Der Feuerbestattung kann die Beisetzung der Asche, in einer Urne oder offen, folgen."
        },
        {
          "absatz": "2",
          "text": "Erdbestattungen dürfen nur auf Friedhöfen erfolgen."
        },
        {
          "absatz": "3",
          "text": "Feuerbestattungen haben in einem Krematorium zu erfolgen."
        },
        {
          "absatz": "4",
          "text": "Über die Asche können Angehörige auch persönlich verfügen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/816.31",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cabba5c4f89c5548b3a0257714894b66",
      "sha": "957ce014338b39f962a2a84c03453c2eaacc15d1dd683cf4a2597da80357b183"
    },
    {
      "id": "kanton/AR/816.31/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über das Bestattungswesen (816.31)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Bestattung hat nicht vor zweimal 24 Stunden und spätestens nach fünfmal 24 Stunden seit Todeseintritt zu erfolgen."
        },
        {
          "absatz": "2",
          "text": "Ausnahmen aus organisatorischen oder sanitätspolizeilichen Gründen kann die Gemeinde, gestützt auf eine ärztliche Bescheinigung, bewilligen."
        },
        {
          "absatz": "3",
          "text": "Die Bestattung darf erst vorgenommen werden, wenn die Leiche vom zuständigen Zivilstandsamt aufgrund einer ärztlichen Todesbescheinigung zur Bestattung freigegeben worden ist."
        },
        {
          "absatz": "4",
          "text": "Ist eine amtliche Untersuchung über den Todesfall im Gang, so ist die Einwilligung der Untersuchungsbehörde erforderlich."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/816.31",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cabba5c4f89c5548b3a0257714894b66",
      "sha": "9ed3183c93591051de0a8833358d9d91dd6b15778f59d6f2efda1299ebe120cb"
    },
    {
      "id": "kanton/AR/816.31/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über das Bestattungswesen (816.31)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Grabesruhe beträgt mindestens 20 Jahre. Vorbehalten sind amtliche oder gerichtlich angeordnete Exhumationen."
        },
        {
          "absatz": "2",
          "text": "Auf Begehren von Angehörigen sind Urnen von der Gemeinde vor Ablauf dieser Frist zur Entnahme freizugeben, soweit dieser vorzeitigen Freigabe keine wesentlichen Interessen entgegenstehen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/816.31",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cabba5c4f89c5548b3a0257714894b66",
      "sha": "0fc76f5acce62920c5af2839fe7bb2676b8f4bb251b4ce4505f76f1c86d026ff"
    },
    {
      "id": "kanton/AR/816.31/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über das Bestattungswesen (816.31)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Ausstellung von Leichenpässen für den Transport von Leichen vom und ins Ausland erfolgt durch die zuständige kantonale Stelle."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/816.31",
      "abgerufen": "2026-06-23",
      "fassungsToken": "cabba5c4f89c5548b3a0257714894b66",
      "sha": "7ee83859e5e593cf73934fcc7adc3320aa6f57ffbc90acb26e4f33ef8e2d8b92"
    },
    {
      "id": "kanton/AR/816.31/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über das Bestattungswesen (816.31)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Verordnung tritt mit der Annahme durch den Kantonsrat in Kraft."
        },
        {
          "absatz": "2",
          "text": "Mit Inkrafttreten dieser Verordnung wird die Verordnung über das Begräbniswesen vom 31. Mai 1929 aufgehoben."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/816.31",
      "abgerufen": "2026-06-23",
