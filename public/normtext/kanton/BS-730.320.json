{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/730.320/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Veloparkplatzverordnung, VeloPPV (730.320)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Verordnung legt die erforderliche Anzahl Abstellplätze für Velos und Mofas fest und macht Angaben zu deren Lage, Zugänglichkeit und Ausstattung."
        },
        {
          "absatz": "2",
          "text": "Es sind Abstellplätze für das Kurzzeitparkieren wie für das Langzeitparkieren anzulegen und auszugestalten."
        },
        {
          "absatz": "3",
          "text": "Die Anzahl Abstellplätze gemäss §§ 2-4 enthält den Bedarf an Abstellplätzen für Velos, inklusive Spezialvelos wie insbesondere Lastenvelos, E-Bikes, Tandems sowie für Mofas."
        },
        {
          "absatz": "4",
          "text": "Die Verordnung ist vollständig anzuwenden bei Neubauten mit weniger als 4'000 m&sup2; Bruttogeschossfläche sowie bei allen wesentlichen baulichen Änderungen oder Nutzungsänderungen, die einer Baubewilligung bedürfen. Sie gilt nicht für Abstellplätze auf Allmend."
        },
        {
          "absatz": "5",
          "text": "Für Neubauten mit mehr als 4'000 m&sup2; Bruttogeschossfläche sind die §§ 5-7 anzuwenden."
        }
      ],
      "stand": "2017-01-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/730.320",
      "abgerufen": "2026-06-23",
      "fassungsToken": "80079ac2767c4316a617b33741c4a06a",
      "sha": "5cd92e1e2ed94dbc8a4c10664ae86c92aded59ecb37c8ea56620ffe510c67810"
    },
    {
      "id": "kanton/BS/730.320/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Veloparkplatzverordnung, VeloPPV (730.320)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Als Berechnungsgrundlage bei Ladengeschäften dient die Bruttogeschossfläche der Verkaufsfläche sowie die Fläche aller für den Betrieb des Ladens genutzten Nebenräume."
        },
        {
          "absatz": "2",
          "text": "Pro folgende Bruttogeschossflächen (BGF) ist mindestens ein Abstellplatz für das Kurzzeitparkieren erforderlich:",
          "mehrspaltig": {
            "kopf": [
              "Nutzungsart",
              "1 Abstellplatz pro m&sup2; BGF"
            ],
            "zeilen": [
              [
                "Verkauf des täglichen Bedarfs",
                "50 m&sup2;"
              ],
              [
                "kundschaftsintensive Dienstleistungen und Gastronomie",
                "75 m&sup2;"
              ],
              [
                "Sonstiger Verkauf",
                "200 m&sup2;"
              ],
              [
                "Sonstige Dienstleistung",
                "400 m&sup2;"
              ],
              [
                "Gewerbe und Industrie",
                "1'000 m&sup2;"
              ]
            ]
          }
        },
        {
          "absatz": "3",
          "text": "Pro folgende Bruttogeschossflächen (BGF) ist mindestens ein Abstellplatz für das Langzeitparkieren erforderlich:",
          "mehrspaltig": {
            "kopf": [
              "Nutzungsart",
              "1 Abstellplatz pro m&sup2; BGF"
            ],
            "zeilen": [
              [
                "Dienstleistung und Gastronomie",
                "100 m&sup2;"
              ],
              [
                "Verkauf",
                "150 m&sup2;"
              ],
              [
                "Gewerbe und Industrie",
                "250 m&sup2;"
              ]
            ]
          }
        }
      ],
      "stand": "2017-01-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/730.320",
      "abgerufen": "2026-06-23",
      "fassungsToken": "80079ac2767c4316a617b33741c4a06a",
      "sha": "e8f258070dc7dfd521fd0cf5b1ff2723146b377fa1150a489288ea5e0840c1e8"
    },
    {
      "id": "kanton/BS/730.320/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Veloparkplatzverordnung, VeloPPV (730.320)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Wohnnutzungen sind pro Zimmer ein Abstellplatz, jedoch höchstens vier pro Wohnung zu erstellen."
        }
      ],
      "stand": "2017-01-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/730.320",
      "abgerufen": "2026-06-23",
      "fassungsToken": "80079ac2767c4316a617b33741c4a06a",
      "sha": "c31acefa20ef2d345caf469655b7e293bbf7bb2b7a1e1f98c325503b3b5263bc"
    },
    {
      "id": "kanton/BS/730.320/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Veloparkplatzverordnung, VeloPPV (730.320)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für weitere Nutzungen wie namentlich Einkaufszentren, Spitäler, Heime, Schulen, Hotels, Kultur-, Sport- und Freizeiteinrichtungen ist die Anzahl der Abstellplätze durch Erhebung oder auf der Grundlage des Standardbedarfs der VSS-Norm zu Bedarfsermittlung und Standortwahl von Veloparkierungsanlagen zu ermitteln."
        }
      ],
      "stand": "2017-01-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/730.320",
      "abgerufen": "2026-06-23",
      "fassungsToken": "80079ac2767c4316a617b33741c4a06a",
      "sha": "c2b2149652819f68b3db52fbf3c71759dd93d2a1f020bb07d78eb5548bb9dc69"
    },
    {
      "id": "kanton/BS/730.320/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Veloparkplatzverordnung, VeloPPV (730.320)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Standort, Zugänglichkeit und Ausgestaltung sowie namentlich dem Platzbedarf pro Abstellplatz je nach Fahrzeugart sind die massgebenden VSS-Normen zu berücksichtigen."
        },
        {
          "absatz": "2",
          "text": "Die Abstellplätze sind so anzulegen, dass diese erreicht werden können, ohne dass die Fahrzeuge getragen werden müssen."
        }
      ],
      "stand": "2017-01-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/730.320",
      "abgerufen": "2026-06-23",
      "fassungsToken": "80079ac2767c4316a617b33741c4a06a",
      "sha": "7606444f93e84cbf725da31497fbf3fc2ab33babc3399b8d79c73780a52658b1"
    },
    {
      "id": "kanton/BS/730.320/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Veloparkplatzverordnung, VeloPPV (730.320)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Aus wichtigen Gründen, namentlich beim Nachweis eines reduzierten Bedarfs kann von der Anzahl der Abstellplätze abgewichen werden."
        },
        {
          "absatz": "2",
          "text": "Die Erstellungspflicht entfällt,",
          "items": [
            {
              "marke": "a",
              "text": "bei einer Gesamtanzahl von weniger als 5 zu erstellenden Abstellplätzen;"
            },
            {
              "marke": "b",
              "text": "wenn das Gebäude mit den Fahrzeugen nur erreicht werden kann, indem diese getragen werden;"
            },
            {
              "marke": "c",
              "text": "bei Umbauten, wenn für die Erstellung von Abstellplätzen im Erdgeschoss bestehende Nutzungen entfallen würden."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Die Erstellungspflicht entfällt oder kann reduziert werden,",
          "items": [
            {
              "marke": "a",
              "text": "wenn der Erstellung überwiegende Interessen, insbesondere aus dem Bereich des Denkmal-, Ortsbild-, Natur- oder Landschaftsschutzes entgegenstehen;"
            },
            {
              "marke": "b",
              "text": "wenn die Erstellung unzumutbar ist."
            }
          ]
        }
      ],
      "stand": "2017-01-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/730.320",
      "abgerufen": "2026-06-23",
      "fassungsToken": "80079ac2767c4316a617b33741c4a06a",
      "sha": "4e1c4eb0a8d6df9adf2280be95f2dd66e573812bdd2178192bfa49b13c143885"
    },
    {
      "id": "kanton/BS/730.320/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Veloparkplatzverordnung, VeloPPV (730.320)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Wirksamwerden der neuen Vorschriften hängige Verfahren unterstehen dem neuen Recht."
        },
        {
          "absatz": "2",
          "text": "Rechtsmittelverfahren unterstehen dem Recht, das für den erstinstanzlichen Entscheid massgebend war."
        }
      ],
      "stand": "2017-01-29",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/730.320",
      "abgerufen": "2026-06-23",
      "fassungsToken": "80079ac2767c4316a617b33741c4a06a",
      "sha": "05f3a18f317b750a9206ce028146bc1b35da553aab0a1788fe75be92976a4833"
    }
  ]
}