{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/419.100/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schulgeldverordnung (419.100)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die vorliegende Verordnung gilt für den Besuch von staatlichen Schulen auf den Ebenen der Volksschule und der weiterführenden Schulen."
        }
      ],
      "stand": "2010-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/419.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "0076d70d797e746ec1732b39372b33b2",
      "sha": "7ca1420e7bb02165c6ab2943e4c0ff6a87b63b3aa5efecd480ff3958c5e34765"
    },
    {
      "id": "kanton/BS/419.100/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schulgeldverordnung (419.100)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton Basel-Stadt erhebt für Schülerinnen und Schüler mit Wohnsitz ausserhalb des Kantonsgebietes ein Schulgeld."
        },
        {
          "absatz": "2",
          "text": "Die Definition des Wohnsitzes richtet sich nach Art. 4 des Regionalen Schulabkommens (RSA 2009)."
        }
      ],
      "stand": "2010-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/419.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "0076d70d797e746ec1732b39372b33b2",
      "sha": "717001885f8c7d9afc7cbc84038d179edef4547cca64d29b0f1bc4816d9c8a1e"
    },
    {
      "id": "kanton/BS/419.100/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schulgeldverordnung (419.100)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Kanton Basel-Stadt schliesst mit Kantonen oder Gemeinden Abkommen ab."
        },
        {
          "absatz": "2",
          "text": "Wird im Rahmen eines solchen Abkommens die Zahlungsbereitschaft für ein Angebot geleistet, wird das Schulgeld vom entsprechenden Kanton oder der entsprechenden Gemeinde übernommen."
        },
        {
          "absatz": "3",
          "text": "Wird das Schulgeld nicht übernommen, muss es von den Schülerinnen und Schülern bzw. ihren gesetzlichen Vertreterinnen und Vertretern bezahlt werden."
        }
      ],
      "stand": "2010-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/419.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "0076d70d797e746ec1732b39372b33b2",
      "sha": "d3e41d1ebb9042fe2f676be79fc9275bab38be7d0f0ff875dc38fe7ef2e22bd3"
    },
    {
      "id": "kanton/BS/419.100/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schulgeldverordnung (419.100)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das jährliche Schulgeld entspricht den in den entsprechenden Abkommen und Vereinbarungen festgesetzten Schulgeldern. Diese werden in der Regel alle zwei Jahre von den Vereinbarungspartnern neu festgelegt."
        }
      ],
      "stand": "2010-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/419.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "0076d70d797e746ec1732b39372b33b2",
      "sha": "511028938e4272f557da75a739c2677158707510791bbaadd15797706d1768a0"
    },
    {
      "id": "kanton/BS/419.100/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schulgeldverordnung (419.100)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Schulgeld wird vom Erziehungsdepartement semesterweise in Rechnung gestellt."
        },
        {
          "absatz": "2",
          "text": "Besucht eine Schülerin oder ein Schüler die Schule nicht bereits ab Semesterbeginn, so wird das Schulgeld pro rata temporis erhoben."
        }
      ],
      "stand": "2010-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/419.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "0076d70d797e746ec1732b39372b33b2",
      "sha": "408b28cc253562125675ab7980dcbd04f5fcd54a699a4c64c7f39628c360c002"
    },
    {
      "id": "kanton/BS/419.100/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Schulgeldverordnung (419.100)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bezahlte Schulgelder werden nicht rückerstattet. Über begründete Ausnahmen entscheidet die Leiterin bzw. der Leiter Bildung des Erziehungsdepartements."
        }
      ],
      "stand": "2010-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/419.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "0076d70d797e746ec1732b39372b33b2",
      "sha": "e6a188cee10a8d1ede8f73e94ada2900d1e500b50e278eb6a54167cd65af6492"
    }
  ]
}