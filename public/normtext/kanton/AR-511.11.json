{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/511.11/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung regelt den Vollzug der dem Kanton und den Gemeinden übertragenen Aufgaben im Bevölkerungsschutz."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "1e7e70ca6f638b4995d2b3f4ad9b3f8f3173b5a394014fe383a7f15aa1846f40"
    },
    {
      "id": "kanton/AR/511.11/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Amt für Militär und Bevölkerungsschutz (nachfolgend Amt genannt) ist die für den Bevölkerungsschutz zuständige Stelle im Kanton."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "89ef2c9d67e1ae30c7341effb0450f0010abe44f8023fb7d3657c090cecb4374"
    },
    {
      "id": "kanton/AR/511.11/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der kantonale Führungsstab (KFS) gliedert sich in einen Kernstab, einen erweiterten Stab (Dienste) und in die Führungsunterstützung."
        },
        {
          "absatz": "2",
          "text": "Der KFS untersteht der Sicherheitsdirektorin oder dem Sicherheitsdirektor."
        },
        {
          "absatz": "3",
          "text": "Der Regierungsrat legt die Einzelheiten der Organisation fest."
        },
        {
          "absatz": "4",
          "text": "Im Einverständnis mit der Stabschefin oder dem Stabschef können weitere Personen zur Mitarbeit beigezogen werden."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "23e4c074ffa3475da563a727ce2619b398e069adbd57bf27562432eb289bc207"
    },
    {
      "id": "kanton/AR/511.11/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Führungsstäbe der Gemeinden (GFS) bestehen aus mindestens drei Personen."
        },
        {
          "absatz": "2",
          "text": "Der Gemeinderat legt die Organisation des Führungsstabes fest und wählt die Mitglieder."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "ab7020eb313ae23bf1e7dff1ef2de423d53b2ca1c6f7e468e43bcefba0fd3c05"
    },
    {
      "id": "kanton/AR/511.11/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Sicherheitsdirektorin oder der Sicherheitsdirektor wählt die Einsatzkoordinatorinnen und -koordinatoren."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "ee8c9ed91de940389de123f136bfa824bf34fdcf669c2073eadf960abda56d8a"
    },
    {
      "id": "kanton/AR/511.11/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei Alltags- und Grossereignissen ist eine Einsatzleitung der im Einsatz stehenden Organisationen für die Gesamtführung zuständig."
        },
        {
          "absatz": "2",
          "text": "Bei Einsätzen, die über eine längere Zeit dauern, übernehmen, wenn mehrere Partnerorganisationen zusammenarbeiten, Gemeindeführungsstäbe die Koordination oder Führung. Die Einsatzleitung ist diesen unterstellt."
        },
        {
          "absatz": "3",
          "text": "Sind mehrere Gemeinden betroffen, übernimmt der kantonale Führungsstab die Koordination oder Führung."
        },
        {
          "absatz": "4",
          "text": "Einsatzkoordinatorinnen und -koordinatoren unterstützen die Führungsstäbe."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "17815b43d11a694acc78ec41c0fdabdbfabe2c7d44cca6ef670d181375e7fe13"
    },
    {
      "id": "kanton/AR/511.11/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die für die Kontrollführung erforderlichen Personal- und Rekrutierungsdaten werden vom Amt von einer durch die Gemeinde bezeichneten Melde- und Kontaktstelle und aus dem Personal-Informations-System der Armee zur Weiterbearbeitung übernommen."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "f1bc6d709606e2ca2d5a6f7ceb9b9d510a4cd592d226339b5995de4bdf6e26f8"
    },
    {
      "id": "kanton/AR/511.11/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Mitglieder der Führungsstäbe sowie Spezialistinnen und Spezialisten erhalten eine Zuweisung im Status einer oder eines Schutzdienstpflichtigen."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "f48418671327c653fd0da66184542224d30cc9cbaf60dd56e1ee4dad2a91c32b"
    },
    {
      "id": "kanton/AR/511.11/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Einteilung erfolgt gemäss der Funktionstabelle für Schutzdienstpflichtige."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "caf697858b5a357d14929410cd5eda699a97988c250366f2180a05dceca8611e"
    },
    {
      "id": "kanton/AR/511.11/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Beförderungen und Enthebungen aus der Funktion erfolgen durch das jeweilige Wahlorgan."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "60fb9c57d363ba8cb70823a8f6a89288a8041c0b0d83c792bcfa17e5f5561af0"
    },
    {
      "id": "kanton/AR/511.11/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Orientierung der Dienstleistenden erfolgt durch die aufbietende Stelle in der Regel mindestens drei Monate vor der Dienstleistung."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "ee5209568617bbb6f8ea0fda18aac6663dfd80f0d9cc139668964a151af658e8"
    },
    {
      "id": "kanton/AR/511.11/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die jeweils zuständige Stelle erlässt schriftliche Aufgebote."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "0e7738beab70eba6f142e0cab78d1f04f83b6d062ecb81114ca213fd441b2b66"
    },
    {
      "id": "kanton/AR/511.11/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Einsatzleitung oder der zuständige Führungsstab erlässt Aufgebote für Mitglieder der Führungsstäbe."
        },
        {
          "absatz": "2",
          "text": "Aufgebote für Einsätze der Angehörigen des Bevölkerungsschutzes können kurzfristig erfolgen."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "ac84853005c7c994c32906bd2cd8e45ad43adeea1e112a1f65671d5a91ca5002"
    },
    {
      "id": "kanton/AR/511.11/art_14",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Besoldung erfolgt analog den Graden der Schutzdienstpflichtigen."
        },
        {
          "absatz": "2",
          "text": "Bei Ausbildungsanlässen gelten die effektiven Arbeitstage als Teilnehmertage."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "8750d0322a20bd1521826fa074f690427ae4723e5112c5cdfb2b8f7d66b419e1"
    },
    {
      "id": "kanton/AR/511.11/art_15",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "15",
      "artikelLabel": "Art. 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Von der Dienstleistung dispensierte Schutzdienstpflichtige haben keinen Anspruch auf Nachholung des Dienstes im selben Jahr."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "cc8a1c06197d4b8c8afc274188059ab58d6943f9da09db1d5e230d16f8831f6a"
    },
    {
      "id": "kanton/AR/511.11/art_16",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "16",
      "artikelLabel": "Art. 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Amt ist zuständig für die Grund-, Kader und Stabsausbildung der Führungsorgane des KFS, der GFS und des Personals für die Führungsunterstützung."
        },
        {
          "absatz": "2",
          "text": "Die jeweils zuständige Stelle kann Fachpersonal für Kurse und Übungen aufbieten sowie Führungspersonal anfordern."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "e1de2d241685c911b625843308fd5b2b5595040027b2d27dba59ff7b7b66cf68"
    },
    {
      "id": "kanton/AR/511.11/art_17",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "17",
      "artikelLabel": "Art. 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die jeweils zuständige Stelle koordiniert gemeinsame Übungen der Führungsstäbe mit den Partnerorganisationen."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "5b1d6014873a1ccffebedf438bbf4578683db7805dd67afab08b1536f0a75cb6"
    },
    {
      "id": "kanton/AR/511.11/art_18",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Alarmierung wird durch die kantonale Notrufzentrale der Kantonspolizei sichergestellt."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "6bd0dd85ada1e3468d166bd5e4ef0e99583893d3859ec2f88947b8f0932b037a"
    },
    {
      "id": "kanton/AR/511.11/art_19",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "19",
      "artikelLabel": "Art. 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Amt sorgt zusammen mit den Gemeinden für ein flächendeckendes Sirenennetz und dessen ständige Betriebsbereitschaft. Es ist verantwortlich für die jährlich durchzuführenden Sirenenprobealarme."
        },
        {
          "absatz": "2",
          "text": "Die Notrufzentrale der Kantonspolizei löst den Sirenenalarm auf Anweisung der Führungsorgane aus."
        },
        {
          "absatz": "3",
          "text": "Der Gemeinderat ist für die Information verantwortlich, wenn die Führung zur Bewältigung von besonderen oder ausserordentlichen Lagen bei ihm liegt. Er kann diese Aufgabe dem GFS delegieren. In allen andern Fällen ist der Regierungsrat für die Informationsführung zuständig. Er kann diese Aufgabe delegieren."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "c0045473450261f820162de1e6e74af49bbe70ffbd28b7e150585fb827f71bde"
    },
    {
      "id": "kanton/AR/511.11/art_20",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "20",
      "artikelLabel": "Art. 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Amt regelt mit dem Bund, den Gemeinden, den Partnern und Dritten die Verrechnung der Kosten und Entschädigungen."
        },
        {
          "absatz": "2",
          "text": "Sind mehrere Gemeinden betroffen, koordiniert der Kanton bei besonderen und ausserordentlichen Lagen die Aufteilung der anfallenden Kosten."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "acd083a57b491e285bf91c741a447087460bc24dd4803ef7ad74cf15af8eb5fe"
    },
    {
      "id": "kanton/AR/511.11/art_21",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung zum Bevölkerungsschutzgesetz (511.11)",
      "artikel": "21",
      "artikelLabel": "Art. 21",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung tritt am 1. Januar 2005 in Kraft."
        }
      ],
      "stand": "2005-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/511.11",
      "abgerufen": "2026-06-23",
      "fassungsToken": "8600c0db0ee8188fe7680d9cd9c7548d",
      "sha": "0d1e20aa6e6cb4436ac8e7a7e95b5dbe494116079f3dd22201286e7d9678d8ce"
    }
  ]
}