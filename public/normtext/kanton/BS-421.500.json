      "quelle": "BS",
      "erlass": "Grossratsbeschluss betreffend Errichtung einer Berufsmittelschule (421.500)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wird die Berufsmittelschule dem Erziehungsdepartement unterstellt und durch die Allgemeine Gewerbeschule geführt."
        }
      ],
      "stand": "1971-02-11",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/421.500",
