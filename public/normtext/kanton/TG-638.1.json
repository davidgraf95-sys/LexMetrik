{
  "erzeugt": "2026-06-22",
  "eintraege": [
    {
      "id": "kanton/TG/638.1/art_1",
      "ebene": "kanton",
      "quelle": "TG",
      "erlass": "VGG (RB 638.1)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung regelt die Gebühren der Strafverfolgungs- und Gerichtsbehörden mit Ausnahme jener der Kantonspolizei."
        },
        {
          "absatz": "2",
          "text": "Die Kosten des Verfahrens vor den Strafverfolgungs- und Gerichtsbehörden umfassen die Verfahrensgebühr und die Barauslagen."
        },
        {
          "absatz": "3",
          "text": "Sie werden in der Regel von jeder Instanz bei Abschluss des Verfahrens für alle ihre Verrichtungen gesamthaft festgesetzt."
        },
        {
          "absatz": "4",
          "text": "Entsteht ausserhalb eines Verfahrens ein nicht unerheblicher Aufwand, kann eine reduzierte Gebühr erhoben werden."
        }
      ],
      "stand": "2022-01-01",
      "quelleUrl": "https://www.rechtsbuch.tg.ch/app/de/texts_of_law/638.1",
      "abgerufen": "2026-06-22",
      "fassungsToken": "6f2f004c1f2a618b6105e7849f26921f",
      "sha": "ff6cfe90e72ee0073ecd21d5dc0d6e88994b2999cba9a9cc7e4214baaf6081c7"
    },
    {
      "id": "kanton/TG/638.1/art_2",
      "ebene": "kanton",
      "quelle": "TG",
      "erlass": "VGG (RB 638.1)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ausnahmsweise, namentlich in Fällen wirtschaftlicher Härte, sind die Behörden befugt, von der Erhebung einer Gebühr ganz oder zum Teil abzusehen."
        },
        {
          "absatz": "2",
          "text": "Dem Kanton werden, ausser wenn er als Zivilpartei auftritt, keine Kosten auferlegt. Vorbehalten bleiben Auslagen im Rahmen der unentgeltlichen Prozessführung."
        },
        {
          "absatz": "3",
          "text": "..."
        }
      ],
      "stand": "2022-01-01",
      "quelleUrl": "https://www.rechtsbuch.tg.ch/app/de/texts_of_law/638.1",
      "abgerufen": "2026-06-22",
      "fassungsToken": "6f2f004c1f2a618b6105e7849f26921f",
      "sha": "244d6943e066f9f6b0c2250ea1d3cb5163e9349402c136bd2e281869d79a28ca"
    },
    {
      "id": "kanton/TG/638.1/art_3",
      "ebene": "kanton",
      "quelle": "TG",
      "erlass": "VGG (RB 638.1)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Verfahrensgebühr ist innerhalb des vorgesehenen Rahmens nach dem Aufwand der Behörde zu bemessen. Zu berücksichtigen sind die Bedeutung des Falles, die Vermögensverhältnisse der kostenpflichtigen Partei und der Streitwert."
        },
        {
          "absatz": "2",
          "text": "In besonders aufwendigen Verfahren kann die Gebühr bis auf höchstens das Doppelte, in Strafsachen bis auf höchstens das Vierfache erhöht werden."
        },
        {
          "absatz": "3",
          "text": "…"
        }
      ],
      "stand": "2022-01-01",
      "quelleUrl": "https://www.rechtsbuch.tg.ch/app/de/texts_of_law/638.1",
      "abgerufen": "2026-06-22",
      "fassungsToken": "6f2f004c1f2a618b6105e7849f26921f",
      "sha": "33096526e8d9c95e09ce5dce26b198e766680bcc9890c38b93095df7d4badd36"
    },
    {
      "id": "kanton/TG/638.1/art_4",
      "ebene": "kanton",
      "quelle": "TG",
      "erlass": "VGG (RB 638.1)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Barauslagen umfassen die im Verfahren entstandenen Kosten für Zeugenentschädigungen, Gutachten, Übersetzungen und andere Ausgaben."
        },
        {
          "absatz": "2",
          "text": "Geringe Barauslagen wie Porti, Telefongebühren und dergleichen werden nicht belastet."
        },
        {
          "absatz": "3",
          "text": "…"
        }
      ],
      "stand": "2022-01-01",
      "quelleUrl": "https://www.rechtsbuch.tg.ch/app/de/texts_of_law/638.1",
      "abgerufen": "2026-06-22",
      "fassungsToken": "6f2f004c1f2a618b6105e7849f26921f",
      "sha": "a7fcc11aa361c905cb883fe914efa10abed465449ce84db5d1d8c3d636b4396f"
    },
    {
      "id": "kanton/TG/638.1/art_4_a",
      "ebene": "kanton",
      "quelle": "TG",
      "erlass": "VGG (RB 638.1)",
      "artikel": "4_a",
      "artikelLabel": "§ 4a",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Mehrere Beteiligte haften für die ihnen gemeinsam auferlegten Kosten solidarisch, soweit die Behörde nichts anderes bestimmt."
        }
      ],
      "stand": "2022-01-01",
      "quelleUrl": "https://www.rechtsbuch.tg.ch/app/de/texts_of_law/638.1",
      "abgerufen": "2026-06-22",
      "fassungsToken": "6f2f004c1f2a618b6105e7849f26921f",
      "sha": "3017d2268b1b5745cc6a27fa70bd0c6f031b1a766188cc5edb6cb9143ecaf136"
    },
    {
      "id": "kanton/TG/638.1/art_5",
      "ebene": "kanton",
      "quelle": "TG",
      "erlass": "VGG (RB 638.1)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Rechtskräftig festgesetzte Gebühren können erlassen oder gestundet werden, soweit deren Bezahlung für den Schuldner unmöglich ist oder eine grosse Härte bedeuten würde. Zuständig ist die entscheidende Behörde. Vorbehalten bleibt § 28 Abs. 4 des Gesetzes über die Zivil- und Strafrechtspflege (ZSRG)."
        },
        {
          "absatz": "2",
          "text": "…"
        }
      ],
      "stand": "2022-01-01",
      "quelleUrl": "https://www.rechtsbuch.tg.ch/app/de/texts_of_law/638.1",
      "abgerufen": "2026-06-22",
      "fassungsToken": "6f2f004c1f2a618b6105e7849f26921f",
      "sha": "1a7a658da02a363fd6e6cbd4443c6597fb9c61691f11fa5a65abfc6386ab9c5e"
    },
    {
      "id": "kanton/TG/638.1/art_6",
      "ebene": "kanton",
      "quelle": "TG",
      "erlass": "VGG (RB 638.1)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Strafverfolgungsbehörden erheben folgende Gebühren:",
          "items": [
            {
              "marke": "1",
              "text": "Strafuntersuchung der Jugendanwaltschaft Fr. 100 bis Fr. 5'000"
            },
            {
              "marke": "2",
              "text": "Strafbefehle oder andere Verfügungen der Jugendanwaltschaft Fr. 50 bis Fr. 1'000"
            },
            {
              "marke": "3",
              "text": "Strafuntersuchung der Generalstaatsanwaltschaft und der Staatsanwaltschaften Fr. 500 bis Fr. 50'000"
            },
            {
              "marke": "4",
              "text": "Strafbefehle oder andere Verfügungen der Generalstaatsanwaltschaft und der Staatsanwaltschaften Fr. 100 bis Fr. 2'000"
            }
          ]
        }
      ],
      "stand": "2022-01-01",
      "quelleUrl": "https://www.rechtsbuch.tg.ch/app/de/texts_of_law/638.1",
      "abgerufen": "2026-06-22",
      "fassungsToken": "6f2f004c1f2a618b6105e7849f26921f",
      "sha": "318f344d1028720f77454833d19d32b1533b179b5f0f7e18f55ef444d320dc6f"
    },
    {
      "id": "kanton/TG/638.1/art_6_a",
      "ebene": "kanton",
      "quelle": "TG",
      "erlass": "VGG (RB 638.1)",
      "artikel": "6_a",
      "artikelLabel": "§ 6a",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Zwangsmassnahmengericht erhebt für seine Entscheide Gebühren von Fr. 100 bis Fr. 10'000."
        }
      ],
      "stand": "2022-01-01",
      "quelleUrl": "https://www.rechtsbuch.tg.ch/app/de/texts_of_law/638.1",
      "abgerufen": "2026-06-22",
      "fassungsToken": "6f2f004c1f2a618b6105e7849f26921f",
      "sha": "6d7f7aeaf1cce1b0fb53bcab148ef23fa20a85ddc4c47370b15865e3697c71ad"
    },
    {
      "id": "kanton/TG/638.1/art_7",
      "ebene": "kanton",
      "quelle": "TG",
      "erlass": "VGG (RB 638.1)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Friedensrichter erheben folgende Gebühren:",
          "items": [
            {
              "marke": "1",
              "text": "Schlichtungsverhandlung bei einem Streitwert"
            },
            {
              "marke": "1",
              "text": "bis Fr. 2'000 Fr. 100 bis Fr. 150"
            },
            {
              "marke": "1",
              "text": "über Fr. 2'000 bis Fr. 8'000 Fr. 120 bis Fr. 200"
            },
            {
              "marke": "1",
              "text": "über Fr. 8'000 bis Fr. 30'000 Fr. 160 bis Fr. 300"
            },
            {
              "marke": "1",
              "text": "über Fr. 30'000 bis Fr. 100'000 Fr. 240 bis Fr. 400"
            },
            {
              "marke": "1",
              "text": "über Fr. 100'000 Fr. 320 bis Fr. 500"
            },
            {
              "marke": "2",
              "text": "Schlichtungsverhandlung ohne bestimmten Streitwert Fr. 100 bis Fr. 500"
            },
            {
              "marke": "3",
              "text": "Klageabschreibung nach Vorladung zur Schlichtungsverhandlung Fr. 100"
            },
            {
              "marke": "4",
              "text": "Entscheidvorschlag oder Endentscheid als Einzelrichter Fr. 100 bis Fr. 500"
            }
          ]
        }
      ],
      "stand": "2022-01-01",
      "quelleUrl": "https://www.rechtsbuch.tg.ch/app/de/texts_of_law/638.1",
      "abgerufen": "2026-06-22",
      "fassungsToken": "6f2f004c1f2a618b6105e7849f26921f",
      "sha": "ad5bf966450d960f6a6fa88817f2a3e32297339d2fa6b1b7188b0d25043dea91"
    },
    {
      "id": "kanton/TG/638.1/art_8",
      "ebene": "kanton",
      "quelle": "TG",
      "erlass": "VGG (RB 638.1)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Einzelrichter der Bezirksgerichte erheben folgende Gebühren:",
          "items": [
            {
              "marke": "1",
              "text": "Entscheid im summarischen Verfahren Fr. 100 bis Fr. 5'000"
            },
            {
              "marke": "2",
              "text": "Endentscheid als Einzelrichter in Zivilsachen (unter Vorbehalt von Ziff. 5) Fr. 200 bis Fr. 3'000"
            },
            {
              "marke": "3",
              "text": "Prozessleitender Entscheid Fr. 100 bis Fr. 600"
            },
            {
              "marke": "4",
              "text": "…"
            },
            {
              "marke": "5",
              "text": "Endentscheid bei Ehescheidung, Ehetrennung, Auflösung eingetragener Partnerschaft, Änderung und Ergänzung eines Scheidungs- und Ehetrennungsurteils sowie bei der Ungültigkeitserklärung einer Ehe oder einer eingetragenen Partnerschaft auf gemeinsames Begehren und bei umfassender Einigung: Ansätze gemäss § 11."
            },
            {
              "marke": "6",
              "text": "…"
            }
          ]
        }
      ],
      "stand": "2022-01-01",
      "quelleUrl": "https://www.rechtsbuch.tg.ch/app/de/texts_of_law/638.1",
      "abgerufen": "2026-06-22",
      "fassungsToken": "6f2f004c1f2a618b6105e7849f26921f",
      "sha": "4cb2aec6297322c6b40482254fd7aae50d8d1e704b01598bdc9d6c7853d6b945"
    },
    {
      "id": "kanton/TG/638.1/art_10",
      "ebene": "kanton",
      "quelle": "TG",
      "erlass": "VGG (RB 638.1)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kindes- und Erwachsenenschutzbehörden erheben für Anordnungen und Entscheide folgende Gebühren:",
          "items": [
            {
              "marke": "1",
              "text": "Kollegialbehörde Fr. 100 bis Fr. 5'000"
            },
            {
              "marke": "2",
              "text": "Vorsorgliche Massnahmen Fr. 100 bis Fr. 2'000"
            },
            {
              "marke": "3",
              "text": "Einzelrichter Fr. 100 bis Fr. 1'000"
            }
          ]
        }
      ],
      "stand": "2022-01-01",
      "quelleUrl": "https://www.rechtsbuch.tg.ch/app/de/texts_of_law/638.1",
      "abgerufen": "2026-06-22",
      "fassungsToken": "6f2f004c1f2a618b6105e7849f26921f",
      "sha": "8daf33ba77b3445e32a8960cb8aae0dd2ff154c1afef9695e019fb5f50fb6eea"
    },
    {
      "id": "kanton/TG/638.1/art_11",
      "ebene": "kanton",
      "quelle": "TG",
      "erlass": "VGG (RB 638.1)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Bezirksgerichte erheben folgende Gebühren:",
          "items": [
            {
              "marke": "1",
              "text": "Endentscheide in Zivilsachen mit bestimmbarem Streitwert:"
            },
            {
              "marke": "1",
              "text": "von Fr. 30'000 bis Fr. 100'000 Fr. 1'000 bis Fr. 4'000"
            },
            {
              "marke": "1",
              "text": "über Fr. 100'000 bis Fr. 500'000 Fr. 2'000 bis Fr. 8'000"
            },
            {
              "marke": "1",
              "text": "über Fr. 500'000 bis Fr. 1'000'000 Fr. 7'000 bis Fr. 15'000"
            },
            {
              "marke": "1",
              "text": "über Fr. 1'000'000 1 bis 3 % des Streitwertes"
            },
            {
              "marke": "2",
              "text": "Endentscheid in Zivilsachen ohne bestimmbaren Streitwert, soweit nicht nach den streitigen vermögensrechtlichen Ansprüchen die Ansätze von Ziff. 1 anwendbar sind Fr. 300 bis Fr. 20'000"
            },
            {
              "marke": "3",
              "text": "Endentscheid in Strafsachen für jeden Beschuldigten Fr. 200 bis Fr. 25'000"
            },
            {
              "marke": "4",
              "text": "andere Entscheide Fr. 100 bis Fr. 10'000"
            }
          ]
        }
      ],
      "stand": "2022-01-01",
      "quelleUrl": "https://www.rechtsbuch.tg.ch/app/de/texts_of_law/638.1",
      "abgerufen": "2026-06-22",
      "fassungsToken": "6f2f004c1f2a618b6105e7849f26921f",
      "sha": "bda3cbb8e8a77ab5aef2adbd1677900e31180e671c56c417f0e35189033a3397"
    },
    {
      "id": "kanton/TG/638.1/art_13",
      "ebene": "kanton",
      "quelle": "TG",
      "erlass": "VGG (RB 638.1)",
      "artikel": "13",
      "artikelLabel": "§ 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Obergericht erhebt folgende Gebühren:",
          "items": [
            {
              "marke": "1",
              "text": "Endentscheide in Zivilsachen mit bestimmbarem Streitwert:"
            },
            {
              "marke": "1",
              "text": "von Fr. 2'000 bis Fr. 8'000 Fr. 500 bis Fr. 1'500"
            },
            {
              "marke": "1",
              "text": "über Fr. 8'000 bis Fr. 30'000 Fr. 1'000 bis Fr. 3'000"
            },
            {
              "marke": "1",
              "text": "über Fr. 30'000 bis Fr. 100'000 Fr. 1'500 bis Fr. 4'500"
            },
            {
              "marke": "1",
              "text": "über Fr. 100'000 bis Fr. 500'000 Fr. 3'000 bis Fr. 12'000"
            },
            {
              "marke": "1",
              "text": "über Fr. 500'000 bis Fr. 1'000'000 Fr. 10'000 bis Fr. 20'000"
            },
            {
              "marke": "1",
              "text": "über Fr. 1'000'000 1,5 bis 4,5 % des Streitwertes"
            },
            {
              "marke": "2",
              "text": "Endentscheid in Zivilsachen ohne bestimmbaren Streitwert, soweit nicht nach den streitigen vermögensrechtlichen Ansprüchen die Ansätze von Ziff. 1 anwendbar sind Fr. 500 bis Fr. 20'000"
            },
            {
              "marke": "3",
              "text": "Endentscheid in Strafsachen für jeden Beschuldigten Fr. 300 bis Fr. 25'000"
            },
            {
              "marke": "4",
              "text": "Entscheid im summarischen Verfahren Fr. 100 bis Fr. 20'000"
            },
            {
              "marke": "5",
              "text": "Prozessleitender Entscheid Fr. 100 bis Fr. 5'000"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Der Obergerichtspräsident und der Einzelrichter des Obergerichtes erheben folgende Gebühren:",
          "items": [
            {
              "marke": "1",
              "text": "Entscheid Fr. 200 bis Fr. 20'000"
            }
          ]
        }
      ],
      "stand": "2022-01-01",
      "quelleUrl": "https://www.rechtsbuch.tg.ch/app/de/texts_of_law/638.1",
      "abgerufen": "2026-06-22",
      "fassungsToken": "6f2f004c1f2a618b6105e7849f26921f",
