      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Bezirksgerichte erheben folgende Gebühren:",
          "items": [
            {
              "marke": "1",
              "text": "Endentscheide in Zivilsachen mit bestimmbarem Streitwert:"
            },
            {
              "marke": "2",
              "text": "Endentscheid in Zivilsachen ohne bestimmbaren Streitwert, soweit nicht nach den streitigen vermögensrechtlichen Ansprüchen die Ansätze von Ziff. 1 anwendbar sind Fr. 300 bis Fr. 20'000"
            },
            {
              "marke": "3",
              "text": "Endentscheid in Strafsachen für jeden Beschuldigten Fr. 200 bis Fr. 25'000"
            },
            {
              "marke": "4",
              "text": "andere Entscheide Fr. 100 bis Fr. 10'000"
            }
          ]
        }
      ],
