    },
    {
      "id": "kanton/TG/638.1/art_14",
      "ebene": "kanton",
      "quelle": "TG",
      "erlass": "VGG (RB 638.1)",
      "artikel": "14",
      "artikelLabel": "§ 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Verwaltungsgericht erhebt folgende Gebühren:",
          "items": [
            {
              "marke": "1",
              "text": "Entscheid im Beschwerdeverfahren Fr. 100 bis Fr. 20'000"
            },
            {
              "marke": "2",
              "text": "Entscheid über Klagen mit bestimmbarem Streitwert:"
            },
            {
              "marke": "2",
              "text": "bis Fr. 8'000 Fr. 500 bis Fr. 1'500"
            },
            {
              "marke": "2",
              "text": "über Fr. 8'000 bis Fr. 30'000 Fr. 1'000 bis Fr. 3'000"
            },
            {
              "marke": "2",
              "text": "über Fr. 30'000 bis Fr. 100'000 Fr. 1'500 bis Fr. 4'500"
            },
            {
              "marke": "2",
              "text": "über Fr. 100'000 bis Fr. 500'000 Fr. 3'000 bis Fr. 12'000"
            },
            {
              "marke": "2",
              "text": "über Fr. 500'000 bis Fr. 1'000'000 Fr. 10'000 bis Fr. 20'000"
            },
            {
              "marke": "2",
              "text": "über Fr. 1'000'000 1,5 bis 4,5 % des Streitwertes"
            },
            {
              "marke": "3",
              "text": "Entscheid über Klagen ohne bestimmbaren Streitwert Fr. 400 bis Fr. 5'000"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die übrigen externen Verwaltungsrechtspflegeorgane, die Anwaltskommission sowie die Rekurskommission in Anwaltssachen erheben folgende Gebühren:",
          "items": [
            {
              "marke": "1",
              "text": "Entscheid Fr. 100 bis Fr. 5'000"
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Die Vorsitzenden der Behörden gemäss Abs. 1 und Abs. 2 erheben folgende Gebühren:",
          "items": [
            {
              "marke": "1",
              "text": "Verfügung Fr. 100 bis Fr. 2'000"
            }
          ]
        }
      ],
      "stand": "2022-01-01",
      "quelleUrl": "https://www.rechtsbuch.tg.ch/app/de/texts_of_law/638.1",
      "abgerufen": "2026-06-22",
      "fassungsToken": "6f2f004c1f2a618b6105e7849f26921f",
      "sha": "2cd0dd69c43d0a94c448b1f97d34b48794bb206d4cdbd61d3360886d57094708"
    },
    {
      "id": "kanton/TG/638.1/art_15",
      "ebene": "kanton",
      "quelle": "TG",
      "erlass": "VGG (RB 638.1)",
      "artikel": "15",
      "artikelLabel": "§ 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für Verfahren, die vor Inkrafttreten dieser Verordnung anhängig gemacht worden sind oder sich auf Entscheide beziehen, die vorher gefällt worden sind, gilt das neue Recht."
        }
      ],
      "stand": "2022-01-01",
