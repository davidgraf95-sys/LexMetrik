      "erlass": "Verordnung über das Strafregister (331.1)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die kantonale Koordinationsstelle erfüllt die Aufgaben gemäss Art. 14 Abs. 1 der VOSTRA-Verordnung."
        },
        {
          "absatz": "2",
          "text": "Sie unterstützt die beteiligten Behörden beim Vollzug der Gesetzgebung über das Strafregister."
        }
      ],
