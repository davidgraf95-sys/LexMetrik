      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über das Strafregister (331.1)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Departement Inneres und Sicherheit entscheidet nach Rücksprache mit den anschlussberechtigten Behörden, ob sie an VOSTRA angeschlossen werden."
        },
        {
          "absatz": "2",
          "text": "Die kantonale Koordinationsstelle übernimmt für Behörden, die nicht an VOSTRA angeschlossen sind, die Aufgaben nach Art. 14 Abs. 2 der VOSTRA-Verordnung."
        }
