    },
    {
      "id": "kanton/AR/521.12/art_20",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die elektronische Bearbeitung von polizeilichen Datensammlungen (521.12)",
      "artikel": "20",
      "artikelLabel": "Art. 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zugriff auf die Daten haben Mitarbeiterinnen oder Mitarbeiter der Kantonspolizei, die sie zur Erfüllung ihrer Aufgaben benötigen."
        }
      ],
      "stand": "2003-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "88872263c981ae5a13d6235beea8f226",
      "sha": "20e6caff30fcd49a53ce33c023abef14032c3e188025e70084050c045d6d964d"
    },
    {
      "id": "kanton/AR/521.12/art_21",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die elektronische Bearbeitung von polizeilichen Datensammlungen (521.12)",
      "artikel": "21",
      "artikelLabel": "Art. 21",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kantonspolizei sichert die Daten durch:",
          "items": [
            {
              "marke": "a",
              "text": "Regelung der Zugriffs- und Eingabeberechtigung;"
            },
            {
              "marke": "b",
              "text": "Schutz der Räume, in denen sich Datenstationen befinden, gegen den Zutritt Unbefugter;"
            },
            {
              "marke": "c",
              "text": "technische Massnahmen zum Schutz der Daten gegen unbefugte Kenntnisnahme, Bearbeitung und Entwendung."
            }
          ]
        }
      ],
      "stand": "2003-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "88872263c981ae5a13d6235beea8f226",
      "sha": "2cc6473ba92d96212702c3d72a47b274fff4efdbeae9215acf49873ad15b88ea"
    },
    {
      "id": "kanton/AR/521.12/art_22",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die elektronische Bearbeitung von polizeilichen Datensammlungen (521.12)",
      "artikel": "22",
      "artikelLabel": "Art. 22",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kantonspolizei entscheidet über Auskunfts-, Berichtigungs- und Löschungsbegehren."
        }
      ],
      "stand": "2003-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "88872263c981ae5a13d6235beea8f226",
      "sha": "845d3b73f69bac5af87062eea0848ff3cae4b6a845645e2b991a7ade94ddf29f"
    },
    {
      "id": "kanton/AR/521.12/art_23",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die elektronische Bearbeitung von polizeilichen Datensammlungen (521.12)",
      "artikel": "23",
      "artikelLabel": "Art. 23",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer ein Auskunftsbegehren stellt, hat sich über seine Identität auszuweisen."
        }
      ],
      "stand": "2003-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "88872263c981ae5a13d6235beea8f226",
      "sha": "7f958709bb01858631bae06305d8b99a9b2cea42c8939f45e28345bc5df09a61"
    },
    {
      "id": "kanton/AR/521.12/art_24",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die elektronische Bearbeitung von polizeilichen Datensammlungen (521.12)",
      "artikel": "24",
      "artikelLabel": "Art. 24",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Verfahren richtet sich nach dem Gesetz über die Verwaltungsrechtspflege."
        }
      ],
      "stand": "2003-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/521.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "88872263c981ae5a13d6235beea8f226",
      "sha": "12e09ef586bd43e26ecd8562f459494c7ea91c0d06ccc220de853b874765eecd"
    },
    {
      "id": "kanton/AR/521.12/art_25",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die elektronische Bearbeitung von polizeilichen Datensammlungen (521.12)",
      "artikel": "25",
      "artikelLabel": "Art. 25",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Auskunft, Berichtigung und Löschung erfolgen kostenlos."
        },
        {
          "absatz": "2",
          "text": "Eine Gebühr kann verlangt werden, wenn:",
          "items": [
            {
              "marke": "a",
              "text": "das Berichtigungs- oder das Löschungsbegehren abgewiesen wird;"
            },
            {
              "marke": "b",
              "text": "die betroffene Person während der letzten zwölf Monate schon die gleiche Auskunft erhalten hat."
            }
          ]
        }
      ],
