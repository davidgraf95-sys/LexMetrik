    {
      "id": "kanton/AR/521.12/art_18",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die elektronische Bearbeitung von polizeilichen Datensammlungen (521.12)",
      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Abgelegte Akten können elektronisch registriert werden."
        },
        {
          "absatz": "2",
          "text": "Das Register dient ausschliesslich dem Aktennachweis."
        }
      ],
      "stand": "2003-01-01",
