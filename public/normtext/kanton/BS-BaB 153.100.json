    },
    {
      "id": "kanton/BS/BaB 153.100/art_33",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "33",
      "artikelLabel": "§ 33",
      "titel": "Bürgerratsschreiber/Bürgerratsschreiberin",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Bürgerratsschreiber oder die Bürgerratsschreiberin wird vom Bürgerrat für eine Amtsdauer von sechs Jahren gewählt. Er oder sie muss Schweizer Bürger oder Bürgerin sein."
        },
        {
          "absatz": "2",
          "text": "In den Verhandlungen des Bürgerrates und der Kommissionen, zu denen er oder sie eingeladen ist, hat er oder sie beratende Stimme."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
