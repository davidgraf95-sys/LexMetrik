{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/BaB 153.100/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "titel": "Ort der Verhandlungen; Öffentlichkeit",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Verhandlungen des Bürgerrates werden in der Regel im Stadthaus abgehalten. Sie sind nicht öffentlich."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "ad0cb7ae7c2c4add9cffb550c482611d50c6c450b43b6f3626dca62d79b9b4fc"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Aufgaben und Befugnisse des Präsidenten/der Präsidentin",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Präsident/die Präsidentin oder, in Vertretung, der Statthalter/die Statthalterin, bereitet die Sitzungen vor und leitet sie. Er/sie überwacht den Vollzug der Beschlüsse."
        },
        {
          "absatz": "2",
          "text": "Er/sie kann an den Bürgerrat gelangende Geschäfte an Kommissionen zur Berichterstattung oder Erledigung überweisen."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "1953709eeb1c7ce734df75eaa459a44bd4fea64819229150d2ce4fbb5818999f"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Sitzungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Bürgerrat versammelt sich, so oft es die Geschäfte erfordern."
        },
        {
          "absatz": "2",
          "text": "Der Präsident/die Präsidentin lädt von sich aus ein oder auf Begehren zweier Mitglieder."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "51c25e1c8bf264b9d6873436d0e29c3d57f14050cf58fad2a0c4f2df93288e22"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Protokoll",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Über die Verhandlungen führt der Bürgerratsschreiber/die Bürgerratsschreiberin ein Protokoll."
        },
        {
          "absatz": "2",
          "text": "Über Geschäfte gemäss § 11 wird ein besonderes Protokoll geführt, das bis zur vollständigen Erledigung des Geschäftes nur den Mitgliedern des Bürgerrates offen steht."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "4c9b9bde5d8e8fe2ca5adfbc01a15d1c31d3683196af6a52bece0c96c12ba28e"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "titel": "Publikationen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Reglemente und Wahlen werden im Kantonsblatt publiziert."
        },
        {
          "absatz": "2",
          "text": "Die Publikationen tragen die rechtsverbindliche Unterschrift."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "955f4b2ab3ee53b144725e9c186fee8204e78dc35ecbc72ff70b90b0ce2a129a"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "titel": "Unterschrift",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für den Bürgerrat rechtsverbindlich unterzeichnen der Präsident/die Präsidentin oder, in Vertretung, der Statthalter/die Statthalterin oder bei deren Verhinderung ein anderes Mitglied des Bürgerrates mit dem Bürgerratsschreiber/der Bürgerratsschreiberin oder, in Vertretung, mit einem seiner Stellvertreter."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "754c6ab6e0a7c7b214a710b5d2454ca958761ad4db0e78d851b281bed6fdf479"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "titel": "Entschädigung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Mitglieder des Bürgerrates beziehen eine ihrer Beanspruchung angemessene jährliche Entschädigung und für ihre Mitarbeit in Kommissionen, Ausschüssen und Delegationen ein angemessenes Sitzungsgeld."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "c219d069dbb920d65a7c23c3922d96eb78e18a5b308007c3881b0466f82a2631"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "titel": "Rücktritt",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Rücktritt aus dem Bürgerrat ist dem Präsidenten/der Präsidentin des Bürgergemeinderates schriftlich zu erklären; er kann nicht widerrufen werden."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "0f30496aa29b80270aa092be89202f9c230d727796abff16a528620b36984767"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "titel": "Beschlussfähigkeit",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Bürgerrat ist beschlussfähig, wenn wenigstens vier seiner Mitglieder anwesend sind."
        },
        {
          "absatz": "2",
          "text": "Ausnahmsweise genügt die Anwesenheit dreier Mitglieder, wenn alle drei den Behandlungsgegenstand als dringlich oder aber als unwichtig bezeichnen."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "97b09c8875bd2967a7a3aa4eed36c835306d130f52f972a0173b70d0dde45b59"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_9_a",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "9_a",
      "artikelLabel": "§ 9a",
      "titel": "Offenlegung von Interessenbindungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Mitglieder des Bürgerrats beraten und stimmen ohne Instruktion."
        },
        {
          "absatz": "2",
          "text": "Sie geben bei Amtsantritt ihre Interessenbindungen schriftlich bekannt."
        },
        {
          "absatz": "3",
          "text": "Änderungen sind der Bürgerratsschreiberin oder dem Bürgerratsschreiber laufend bekanntzugeben."
        },
        {
          "absatz": "4",
          "text": "Die Interessenbindungen werden in einem Verzeichnis abgebildet. Das Verzeichnis wird veröffentlicht."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "574c92661eb15c0163109bb10e0f15fefa6bac155af77de12a9372bbac73dabd"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_9_b",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "9_b",
      "artikelLabel": "§ 9b",
      "titel": "Ausstand",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Ausstandspflicht der Mitglieder des Bürgerrats gilt für die Vorbereitung, die Beratung und die Beschlussfassung im Plenum und in den Kommissionen."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "dd5590688f72ab3f2051079818f02c8a7e283de0a582c9488abb6c968af33a5d"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "titel": "Tagesordnung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zu Beginn der Sitzung wird die Tagesordnung bereinigt. Hat der Bürgerrat die Tagesordnung genehmigt, kann nur mit einem Mehr von zwei Dritteln der Stimmen davon abgewichen werden."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "a6885a55e9761ae9502e9988a52ce7a18dbb2051a6cd37d29d4ca10aefba1169"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "titel": "Geheimhaltung, Vertraulichkeit und Informationen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Sitzungen des Bürgerrates sind nicht öffentlich und unterliegen der Vertraulichkeit."
        },
        {
          "absatz": "2",
          "text": "Jede an der Sitzung des Bürgerrates teilnehmende Person ist verpflichtet, ein Geschäft geheim zu halten, falls dies im Einzelfall beschlossen wird."
        },
        {
          "absatz": "3",
          "text": "Der Bürgerrat informiert die Öffentlichkeit über seine Geschäfte und Beschlüsse nach Massgabe des kantonalen Informations- und Datenschutzgesetzes."
        },
        {
          "absatz": "4",
          "text": "Der Bürgerrat erlässt Richtlinien für seine Informationstätigkeit."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "bca0b7965ae2dbb5edf8d0244e938a8d8144ca7fb76e6ed804376d780c751a37"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_12",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "12",
      "artikelLabel": "§ 12",
      "titel": "Akteneinsicht",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Protokoll des Bürgerrates steht den Mitgliedern des Bürgergemeinderates zur Einsicht offen."
        },
        {
          "absatz": "2",
          "text": "Akten über Geschäfte, welche beim Bürgergemeinderat hängig sind, stehen den Mitgliedern des Bürgergemeinderates zur Einsicht offen. Bei andern Geschäften bedarf es dazu der Einwilligung des Bürgerratspräsidenten/der Bürgerratspräsidentin. Hegt dieser/diese Bedenken, so entscheidet der Bürgerrat. Einsichtnahme durch andere Personen bedarf der Zustimmung des Bürgerrates."
        },
        {
          "absatz": "3",
          "text": "Die Kommissionen des Bürgergemeinderates und des Bürgerrates haben im Rahmen der ihnen übertragenen Aufgaben unbeschränkte Akteneinsicht."
        },
        {
          "absatz": "4",
          "text": "Die Bestimmungen über die Akteneinsicht bei Geschäften der Kommissionen bleiben vorbehalten."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "2b8937934aef9adc121655d5a248368f4a4f0bde57f465d955555aac7ff3503a"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_13",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "13",
      "artikelLabel": "§ 13",
      "titel": "Vorgehen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Bürgerrat fasst seine Beschlüsse in offener Abstimmung, sofern nicht zwei Mitglieder das geheime Verfahren verlangen."
        },
        {
          "absatz": "2",
          "text": "Der Bürgerrat entscheidet mit Stimmenmehrheit. Der Präsident/diePräsidentin nimmt an der Abstimmung teil; bei Stimmengleichheit gibt er/sie den Stichentscheid."
        },
        {
          "absatz": "3",
          "text": "Jeder Bürgerrat hat das Recht, seine von einem Beschluss der Mehrheit abweichende Meinung begründet zu Protokoll zu geben."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "e157d2199b2f3f2d008f78b332281418421d7dd385ef6dd92924a449ce9c8001"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_14",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "14",
      "artikelLabel": "§ 14",
      "titel": "Wiedererwägung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Ein Beschluss kann mit einem Mehr von zwei Dritteln der Stimmen in Wiedererwägung gezogen werden, sofern ihm keine Rechtskraft entgegensteht oder keine unwiderrufliche Dispositionen getroffen worden sind."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "75690b89f77f788f69fd6c7f1d1141d42ac82a79e003bd0f32966f61b15ed684"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_15",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "15",
      "artikelLabel": "§ 15",
      "bloecke": [
        {
          "absatz": null,
          "text": ""
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_16",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "16",
      "artikelLabel": "§ 16",
      "titel": "Vorgehen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wahlen werden offen durchgeführt, sofern nicht ein Mitglied das geheime Verfahren verlangt."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "3d6b9fb0c4c8d613acecab6859a0510abfcf20f0da718d0052823f9cc2cd8f77"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_17",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "17",
      "artikelLabel": "§ 17",
      "titel": "Wahlgänge; absolutes und relatives Mehr",
      "bloecke": [
        {
          "absatz": "1",
          "text": "DieWahlen erfolgen im ersten und zweiten Wahlgang nach dem Grundsatz des absoluten Mehr. Das absolute Mehr erreicht, wer mehr als die Hälfte der gültigen Stimmen erhalten hat."
        },
        {
          "absatz": "2",
          "text": "Erreichen im ersten und im zweiten Wahlgang weniger Kandidaten, als zu wählen sind, das absolute Mehr, so entscheidet im dritten Wahlgang das relative Mehr. Bei gleicher Stimmenzahl entscheidet das Los, das vom Präsidenten/der Präsidentin, dem Rat sichtbar, gezogen wird."
        },
        {
          "absatz": "3",
          "text": "Trifft der Bürgerrat eine Wahl unter seinen Mitgliedern, so unterliegen diese keiner Beschränkung ihrer Stimmabgabe."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "33c3a3bb5784ea4d2e3ca8bbbf419602cbe34313b350af8f3f104dcaa34228fd"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_18",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "18",
      "artikelLabel": "§ 18",
      "titel": "Wiedererwägung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Eine Wahl kann mit einem Mehr von zwei Dritteln der Stimmen in Wiedererwägung gezogen werden, sofern sie dem Betroffenen noch nicht formell bekanntgegeben worden ist. Die Bestimmungen über die Wählbarkeitsvoraussetzungen bleiben vorbehalten."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "ae47b5e7cf71b5d0ae091c290a8e07784c475b6e6cc3b0049cb6824230c9044a"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_19",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "19",
      "artikelLabel": "§ 19",
      "titel": "Ersatzwahlen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Bürgerrat nimmt Ersatzwahlen so bald als möglich vor."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "dfb2dcd4a6dc9f910179bb085461d7e278a933b947ce963d185979d3dd9102c4"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_20",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "20",
      "artikelLabel": "§ 20",
      "titel": "Kommissionsarten; Amtsdauer",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dem Bürgerrat stehen zur Erfüllung seiner Aufgaben Ausschüsse, Spezialkommissionen sowie die Einbürgerungskommission zur Seite."
        },
        {
          "absatz": "2",
          "text": "Ihre Amtsdauer erlischt spätestens mit derjenigen des Bürgerrates."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "845cc952269a915d80b351f640c5e48276e645d17ae477f4d0dea71c145c9b32"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_21",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "21",
      "artikelLabel": "§ 21",
      "titel": "Ausschüsse",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Bürgerrat kann zur Planung und Vorbereitung von Geschäften aus seiner Mitte Ausschüsse bestellen, denen er Entscheidungsbefugnisse und Ausgabenkompetenzen übertragen kann."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "528e3a80aefb0d7c7e7c688a1ecb415f977493da5c901969f25042570beafca9"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_22",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "22",
      "artikelLabel": "§ 22",
      "titel": "Spezialkommissionen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Bürgerrat kann für bestimmte Aufgaben Spezialkommissionen einsetzen, in die er auch Aussenstehende als Mitglieder wählen kann."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "19fe8acec46ab55c3aaa04f4b005f019e2ba591e29edd1ca3ad9b268d63f2efb"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_23",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "23",
      "artikelLabel": "§ 23",
      "bloecke": [
        {
          "absatz": null,
          "text": ""
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_24",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "24",
      "artikelLabel": "§ 24",
      "titel": "Leitung der Verhandlungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Präsident/die Präsidentin, oder in Vertretung der Statthalter/die Statthalterin, bereitet die Sitzungen vor und leitet sie. Er/sie überwacht den Vollzug der Beschlüsse."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "5d25d72bbc527fad57f0d88baee7bff5ff0f1818374357ef49a8ca21d5c06df7"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_25",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "25",
      "artikelLabel": "§ 25",
      "titel": "Sitzungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kommissionen versammeln sich, so oft es die Geschäfte erfordern."
        },
        {
          "absatz": "2",
          "text": "Der Präsident/die Präsidentin lädt von sich aus ein oder auf Begehren zweier Mitglieder."
        },
        {
          "absatz": "3",
          "text": "Die Sitzungen der Kommissionen sind nicht öffentlich."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "127d72c23e820c65134d2e5c128165efcf9e5e72d4ddf5fc8d132f2f32c90a03"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_26",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "26",
      "artikelLabel": "§ 26",
      "titel": "Beschlussfähigkeit",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kommissionen sind beschlussfähig, wenn die Mehrheit der stimmberechtigten Mitglieder anwesend ist."
        },
        {
          "absatz": "2",
          "text": "Die getrennt tagenden Kammern der Einbürgerungskommission sind beschlussfähig, wenn mindestens drei Mitglieder anwesend sind."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "dd986e826762fd19b998060077ec2825147c1d11c2988dfc64fd0f7cbf4d9651"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_27",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "27",
      "artikelLabel": "§ 27",
      "titel": "Protokoll",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Über die Verhandlungen wird ein Protokoll geführt."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "fd4a52de168f3bee3bb6a2d340f2f205466178f4de9c094f0393e0e8d35d3c95"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_28",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "28",
      "artikelLabel": "§ 28",
      "titel": "Abstimmungen und Wahlen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Vorschriften dieser Geschäftsordnung über die Abstimmungen und Wahlen im Bürgerrat gelten für die Kommissionen sinngemäss."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "f10e83fe5265047799984e3520aaab6cbe910a45d62edb644d7f8668d08c28a2"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_29",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "29",
      "artikelLabel": "§ 29",
      "titel": "Akteneinsicht",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Einsicht in die Protokolle und Kommissionsakten steht Drittpersonen nur mit Bewilligung der Kommission oder – wenn sie aufgelöst ist – des Bürgerrates zu."
        },
        {
          "absatz": "2",
          "text": "Bis zur Erledigung oder Veröffentlichung eines Geschäftes haben die Einsichtsberechtigten ihre Wahrnehmungen geheim zu halten."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "2c981012e896f4b76024eb1fd9f808023c1139c94fe5b72a83a96e0f59f287a7"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_30",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "30",
      "artikelLabel": "§ 30",
      "titel": "Entschädigung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Mitglieder der Kommissionen erhalten für jede Sitzung einer Kommission, Subkommission oder Delegation ein angemessenes Sitzungsgeld, abgestuft nach der jeweiligen Funktion als Präsident/Präsidentin, Protokollführer und Mitglied."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "64d686aace1e35da185dacb9aefb79c0c680508f1f47c3853a6d297bf41a075a"
    },
    {
      "id": "kanton/BS/BaB 153.100/art_31",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Geschäftsordnung des Bürgerrates der Stadt Basel (BaB 153.100)",
      "artikel": "31",
      "artikelLabel": "§ 31",
      "titel": "Geheimhaltung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Jede an einer Kommissionssitzung teilnehmende Person ist verpflichtet, ein Geschäft geheim zu halten, falls dies ausdrücklich beschlossen wird."
        },
        {
          "absatz": "2",
          "text": "Bei Verletzung der Pflicht zur Geheimhaltung kann der Präsident/diePräsidentin nach Abklärung des Sachverhaltes den Bürgerrat orientieren und allfällige Anträge stellen."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BaB 153.100",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b2a30b665e89616b70e7b0d571348980",
      "sha": "3548cd7da9dd6466c63242df2b9c47d5d1a01fa411a963b9b67e9a05a8afab1a"
    },
