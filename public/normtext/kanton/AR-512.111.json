{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/512.111/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die kantonale Militärverwaltung (512.111)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die kantonale Militärverwaltung steht unter der Aufsicht des Departementes Inneres und Sicherheit."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/512.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "dfd9a10971488b5cc0875864ec51527a",
      "sha": "d8b82ede0749158810c8f660e5d66ea36153c6266c0d8e0b6552d0407af62eb4"
    },
    {
      "id": "kanton/AR/512.111/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die kantonale Militärverwaltung (512.111)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Kreiskommando ist Teil des Amtes für Militär und Bevölkerungsschutz. Der Regierungsrat wählt die Kreiskommandantin oder den Kreiskommandanten."
        },
        {
          "absatz": "2",
          "text": "Das Kreiskommando vollzieht die eidgenössischen und kantonalen Vorschriften über das Militärwesen, soweit keine andere Zuständigkeit vorgesehen ist."
        },
        {
          "absatz": "3",
          "text": "Dem Kreiskommando obliegt insbesondere:",
          "items": [
            {
              "marke": "a",
              "text": "die allgemeine Auskunftserteilung an Wehrpflichtige;"
            },
            {
              "marke": "b",
              "text": "die Erfassung der Wehrpflichtigen des Kantons;"
            },
            {
              "marke": "c",
              "text": "die kantonale Stammkontrollführung und die Sektionskontrolle;"
            },
            {
              "marke": "d",
              "text": "die Durchführung von Orientierungstagen;"
            },
            {
              "marke": "e",
              "text": "der Erlass der Rekrutierungsaufgebote;"
            },
            {
              "marke": "f",
              "text": "die Behandlung von Dienstverschiebungsgesuchen;"
            },
            {
              "marke": "g",
              "text": "die Organisation der Entlassung aus der Militärdienstpflicht;"
            },
            {
              "marke": "h",
              "text": "der Vollzug ausserdienstlicher Disziplinarstrafen;"
            },
            {
              "marke": "i",
              "text": "die Administration des ausserdienstlichen Schiesswesens inklusive der Schiesspflichtkontrolle."
            }
          ]
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/512.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "dfd9a10971488b5cc0875864ec51527a",
      "sha": "a34f892e1e32d2c6e59845274b62e0429ee68518923e740d63eb3006da4f6432"
    },
    {
      "id": "kanton/AR/512.111/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die kantonale Militärverwaltung (512.111)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gemeinden stellen dem Kreiskommando die Daten der Stellungspflichtigen und die Mutationsdaten der Wehrpflichtigen gemäss den bundesrechtlichen Vorgaben zur Verfügung."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/512.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "dfd9a10971488b5cc0875864ec51527a",
      "sha": "9a2eff7466ef23505a6b535cdb14f1bf06cb3e6a09890210d558f527c8d18fb4"
    },
    {
      "id": "kanton/AR/512.111/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die kantonale Militärverwaltung (512.111)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die kantonale Schiesskommission unterstützt das Kreiskommando beim Vollzug des ausserdienstlichen Schiesswesens. Das Departement wählt die Mitglieder der Kommission."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/512.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "dfd9a10971488b5cc0875864ec51527a",
      "sha": "43639bf528bfbb7ff6ffd1463110b59f0ab6f27f348204bf1b1f0a7eec8507a4"
    },
    {
      "id": "kanton/AR/512.111/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die kantonale Militärverwaltung (512.111)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Vom Kreiskommando erlassene Verfügungen in Militärstrafsachen können mit Disziplinarbeschwerde beim Departement angefochten werden. Das Verfahren richtet sich nach Art. 206 ff. des Militärstrafgesetzes."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/512.111",
      "abgerufen": "2026-06-23",
      "fassungsToken": "dfd9a10971488b5cc0875864ec51527a",
      "sha": "8ef74bec1810ae671a608107ab9c8e9690f5c64204ca304e6425bc788c473513"
    },
    {
      "id": "kanton/AR/512.111/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Verordnung über die kantonale Militärverwaltung (512.111)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung tritt am 2. Dezember 2009 in Kraft."
        }
      ],
      "stand": "2016-01-01",
