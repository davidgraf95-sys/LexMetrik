{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/BeE 153.840/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend die Erhebung von Verwaltungsgebühren, Verwaltungsgebührenreglement (BeE 153.840)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "titel": "Geltungsbereich",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieses Reglement regelt die Erhebung von Gebühren für Bewilligungen, Bescheinigungen und verschiedene Dienstleistungen der Gemeindeverwaltung."
        }
      ],
      "stand": "2024-12-26",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4129865f1d8a868c0350c5e0e8e58370",
      "sha": "b2a44d7d8c0c066fe3ebedea0d7e1ac724e6d911b1d99bb408d7e034724892d9"
    },
    {
      "id": "kanton/BS/BeE 153.840/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend die Erhebung von Verwaltungsgebühren, Verwaltungsgebührenreglement (BeE 153.840)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Definition und Höhe der Gebühren",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühren sind das Entgelt für Verwaltungshandlungen der Gemeinde und alle damit notwendig zusammenhängenden Tätigkeiten wie Abklärungen, Beratungen und Verhandlungen."
        },
        {
          "absatz": "2",
          "text": "Die Gebühren bemessen sich grundsätzlich nach dem gesamten mittelbaren und unmittelbaren Verwaltungsaufwand und sollen kostendeckend sein. Im Übrigen sind die Grundsätze des Gesetzes über die Verwaltungsgebühren massgeblich."
        },
        {
          "absatz": "3",
          "text": "Für ausserordentlichen Verwaltungsaufwand sowie bei besonders hohen Vermögensinteressen der Gebührenpflichtigen kann die Gebühr um das Doppelte erhöht werden."
        }
      ],
      "stand": "2024-12-26",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4129865f1d8a868c0350c5e0e8e58370",
      "sha": "1ad6bae0827805eb2cc85329739be1b767ad06f2852b163ca033a3a69ec805f0"
    },
    {
      "id": "kanton/BS/BeE 153.840/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend die Erhebung von Verwaltungsgebühren, Verwaltungsgebührenreglement (BeE 153.840)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Gebührenerlass",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gebühren können auf Antrag ganz oder teilweise erlassen werden, wenn ein finanzieller Härtefall vorliegt, wenn gemeinnützige Zwecke verfolgt werden oder wenn die Gebühr unter Würdigung der gesamten Umstände als zu hoch erscheint. Das begründete Erlassgesuch ist an die Gemeindeverwaltung zu richten."
        }
      ],
      "stand": "2024-12-26",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4129865f1d8a868c0350c5e0e8e58370",
      "sha": "fade6c2a3f8855dfee8c42158553010560e39b75e14ad50a58b8fe632d27d637"
    },
    {
      "id": "kanton/BS/BeE 153.840/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend die Erhebung von Verwaltungsgebühren, Verwaltungsgebührenreglement (BeE 153.840)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Kanzleigebühren",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Es werden folgende Kanzleigebühren erhoben:",
          "items": [
            {
              "marke": "1",
              "text": "Für das Erstellen von Fotokopien / A4, pro Kopie Fr. 0.50"
            },
            {
              "marke": "2",
              "text": "Für das Erstellen von Fotokopien / A3, pro Kopie Fr. 1.00"
            },
            {
              "marke": "3",
              "text": "Spesen für Porti, Telefon, Fax, Publikationen usw. nach Aufwand"
            }
          ]
        }
      ],
      "stand": "2024-12-26",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 153.840",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4129865f1d8a868c0350c5e0e8e58370",
      "sha": "53fe834362732dec3cf1ef504ac38cef700ee6e78209437a593c58ad893d05d0"
    },
    {
      "id": "kanton/BS/BeE 153.840/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend die Erhebung von Verwaltungsgebühren, Verwaltungsgebührenreglement (BeE 153.840)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "titel": "Zahlungsfristen und Mahngebühren",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Zahlungsfrist von Gebühren beträgt 30 Tage. Nach Ablauf dieser Frist kann ein Verzugszins von 5% erhoben werden."
        },
        {
          "absatz": "2",
          "text": "Für nicht rechtzeitig bezahlte Gebühren können Mahngebühren und Umtriebsgebühren für Inkassomassnahmen erhoben werden. Diese betragen:",
          "items": [
            {
              "marke": "1",
              "text": "erste Mahnung gratis"
            },
            {
              "marke": "2",
              "text": "Mahngebühren ab zweiter Mahnung je Fr. 40.00"
            },
            {
              "marke": "3",
              "text": "Umtriebsgebühr für Inkassomassnahmen Fr. 50.00"
            }
          ]
        }
      ],
      "stand": "2024-12-26",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/BeE 153.840",
      "abgerufen": "2026-06-23",
