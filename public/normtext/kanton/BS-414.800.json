{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/414.800/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für die Schulbibliotheken (414.800)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "titel": "Geltungsbereich",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Ordnung gilt für die Schulbibliotheken der staatlichen Schulen des Kantons Basel-Stadt."
        }
      ],
      "stand": "2009-08-10",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/414.800",
      "abgerufen": "2026-06-23",
      "fassungsToken": "ef1eb14704a362c17dc6bc0ea648d530",
      "sha": "76c36a55ca921079e848588a2c702100877d2b34b93fd1280290615480f2abdc"
    },
    {
      "id": "kanton/BS/414.800/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für die Schulbibliotheken (414.800)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Auftrag",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Schulbibliotheken sind Informations- und Lernzentren für Schülerinnen und Schüler, Lehrpersonen und weitere Mitarbeitende der Schulen. Sie haben insbesondere folgende Aufgaben:",
          "items": [
            {
              "marke": "a",
              "text": "Sie unterstützen den Unterricht der Lehrpersonen."
            },
            {
              "marke": "b",
              "text": "Sie fördern die Sachkompetenz, im Speziellen die Lesekompetenz, die Lesefreude sowie das selbstständige Arbeiten der Schülerinnen und Schüler."
            },
            {
              "marke": "c",
              "text": "Sie helfen den Schülerinnen und Schülern sowie den Lehrpersonen, einen bewussten Umgang mit Information und verschiedenen Medien zu finden."
            }
          ]
        }
      ],
      "stand": "2009-08-10",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/414.800",
      "abgerufen": "2026-06-23",
      "fassungsToken": "ef1eb14704a362c17dc6bc0ea648d530",
      "sha": "cf7b49323f50faf02ce89397fb76590e33bef96c88890d95a43b7f3167a8f981"
    },
    {
      "id": "kanton/BS/414.800/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für die Schulbibliotheken (414.800)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Rahmenbedingungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Jede Schule oder mehrere Schulen in einer Schulanlage verfügen über eine Schulbibliothek."
        },
        {
          "absatz": "2",
          "text": "Sie befindet sich an einer gut erreichbaren Lage. Grösse und Einrichtung erlauben es, dass individuell und in der Regel in Gruppen oder mit einer Klasse gearbeitet werden kann."
        },
        {
          "absatz": "3",
          "text": "Sie verfügt über Leseplätze und multimediale Arbeitsplätze sowie über einen Internetanschluss, der den Zugriff auf schulrelevante Datenbanken ermöglicht."
        },
        {
          "absatz": "4",
          "text": "Sie ist als Freihandbibliothek gestaltet."
        },
        {
          "absatz": "5",
          "text": "Sie arbeitet nach den Richtlinien für Schulbibliotheken der Schweizerischen Arbeitsgemeinschaft der allgemeinen öffentlichen Bibliotheken SAB."
        }
      ],
      "stand": "2009-08-10",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/414.800",
      "abgerufen": "2026-06-23",
      "fassungsToken": "ef1eb14704a362c17dc6bc0ea648d530",
      "sha": "752591d2e315884252510651bdc433beff51a1b056a50593920ce0afb8d860d1"
    },
    {
      "id": "kanton/BS/414.800/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für die Schulbibliotheken (414.800)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Medienangebot",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Medienangebot umfasst Bücher und Nonbooks wie Zeitschriften, Zeitungen, Spiele, Hörbücher, elektronische Datenträger und Datenbanken."
        },
        {
          "absatz": "2",
          "text": "Umfang und Zusammensetzung des Medienbestands richten sich nach den Bedürfnissen der Benutzenden. Bei der Auswahl werden die Anliegen des Unterrichts, der allgemeinen Förderung und Weiterbildung sowie der Freizeitgestaltung berücksichtigt."
        },
        {
          "absatz": "3",
          "text": "Jährlich wird ein Teil des Medienbestands ausgeschieden und durch neue Medien ersetzt."
        }
      ],
      "stand": "2009-08-10",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/414.800",
      "abgerufen": "2026-06-23",
      "fassungsToken": "ef1eb14704a362c17dc6bc0ea648d530",
      "sha": "68a8c14626ee2dc2d8d0b165c9d264348b5dc7830cc5d6887c648bab74714646"
    },
    {
      "id": "kanton/BS/414.800/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für die Schulbibliotheken (414.800)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "titel": "Erfassen des Medienbestands",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Schulbibliotheken erfassen ihren Medienbestand in Katalogen, die für alle Benutzenden zugänglich sind."
        }
      ],
      "stand": "2009-08-10",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/414.800",
      "abgerufen": "2026-06-23",
      "fassungsToken": "ef1eb14704a362c17dc6bc0ea648d530",
      "sha": "9de39e46427957c33aa166433ef5071c1206402b649a6c85e24bfb2e77b05394"
    },
    {
      "id": "kanton/BS/414.800/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für die Schulbibliotheken (414.800)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "titel": "Benutzung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Schulbibliotheken stellen die Medien unentgeltlich zur Verfügung."
        },
        {
          "absatz": "2",
          "text": "Sie sind mindestens während den vom Erziehungsdepartement festgelegten Zeiten geöffnet."
        },
        {
          "absatz": "3",
          "text": "Zur Regelung der Benutzungsbedingungen, insbesondere der Nutzungsberechtigten, der Öffnungszeiten und der Aufsicht, erlässt die Schulleitung unter Mitwirkung der Leiterin oder des Leiters der Schulbibliothek sowie der Schulkonferenz eine Benutzungsordnung."
        }
      ],
      "stand": "2009-08-10",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/414.800",
      "abgerufen": "2026-06-23",
      "fassungsToken": "ef1eb14704a362c17dc6bc0ea648d530",
      "sha": "50407eeb24a5118bc634139d0e38dc1e25b24cdd001207971ea0f72bb24ba7e1"
    },
    {
      "id": "kanton/BS/414.800/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für die Schulbibliotheken (414.800)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "titel": "Aufsicht",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Schulbibliothek untersteht in personellen, organisatorischen und administrativen Belangen der Schulleitung."
        }
      ],
      "stand": "2009-08-10",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/414.800",
      "abgerufen": "2026-06-23",
      "fassungsToken": "ef1eb14704a362c17dc6bc0ea648d530",
      "sha": "1974a9d52a70e1ff9da140c609ee7cbbc2b6f8d0734cbfb60ff758a2736d2ba0"
    },
    {
      "id": "kanton/BS/414.800/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für die Schulbibliotheken (414.800)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "titel": "Leitung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Schulbibliotheken werden in der Regel in der Volksschule von Lehrpersonen, die sich mittels bibliothekarischer Kurse dafür qualifiziert haben, und in den weiterführenden Schulen von ausgebildeten Bibliothekarinnen und Bibliothekaren geleitet."
        },
        {
          "absatz": "2",
          "text": "Die Leiterinnen und Leiter der Schulbibliotheken sind verpflichtet, sich regelmässig fortzubilden."
        }
      ],
      "stand": "2009-08-10",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/414.800",
      "abgerufen": "2026-06-23",
      "fassungsToken": "ef1eb14704a362c17dc6bc0ea648d530",
      "sha": "4cddea752bb56e093ec1b82ba5f3f1858cb5173cab2510059ce0b4fb1c34ff5a"
    },
    {
      "id": "kanton/BS/414.800/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für die Schulbibliotheken (414.800)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "titel": "Zusammensetzung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Arbeitsgruppe Basler Schulbibliotheken setzt sich aus je zwei Vertretungen pro Schulstufe sowie einer Präsidentin oder einem Präsidenten zusammen."
        },
        {
          "absatz": "2",
          "text": "Die Präsidentin oder der Präsident ist die Leiterin oder der Leiter der Pädagogischen Dokumentationsstelle."
        }
      ],
      "stand": "2009-08-10",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/414.800",
      "abgerufen": "2026-06-23",
      "fassungsToken": "ef1eb14704a362c17dc6bc0ea648d530",
      "sha": "c48d17d9297c2c2fa500043584716152ebdd8c2890f77ca023681ca895defed9"
    },
    {
      "id": "kanton/BS/414.800/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für die Schulbibliotheken (414.800)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "titel": "Aufgaben",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Arbeitsgruppe Basler Schulbibliotheken fördert die Entwicklung der Schulbibliotheken."
        },
        {
          "absatz": "2",
          "text": "Sie berät die Leiterinnen und Leiter in der Führung der Schulbibliotheken. Sie unterstützt diese und die Schulleitungen im Bereich der Leseförderung und Medienerziehung und entwickelt entsprechende Projekte."
        },
        {
          "absatz": "3",
          "text": "Sie gibt laufend Buchbesprechungen über Neuerscheinungen heraus."
        }
      ],
      "stand": "2009-08-10",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/414.800",
      "abgerufen": "2026-06-23",
      "fassungsToken": "ef1eb14704a362c17dc6bc0ea648d530",
      "sha": "e3eb9a429a88a3e28143cbea920a811812af9e01ffe0b57dc040b253b72345d2"
    },
    {
      "id": "kanton/BS/414.800/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für die Schulbibliotheken (414.800)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "titel": "Statistik",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Schulbibliotheken reichen der Arbeitsgruppe Basler Schulbibliotheken jährlich eine Bibliotheksstatistik ein."
        }
      ],
      "stand": "2009-08-10",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/414.800",
      "abgerufen": "2026-06-23",
      "fassungsToken": "ef1eb14704a362c17dc6bc0ea648d530",
      "sha": "06bfec0eb5007320fd41de926675b5d2eeb20da153d4ee4c3d800f65efa2034a"
    },
    {
      "id": "kanton/BS/414.800/art_12",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für die Schulbibliotheken (414.800)",
      "artikel": "12",
      "artikelLabel": "§ 12",
      "titel": "Finanzen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Medienangebot wird nach Massgabe der Schulleitung aus der Kopfpauschale für Sachmittel finanziert."
        },
        {
          "absatz": "2",
          "text": "Spezielle Projekte zur Entwicklung der Schulbibliotheken können von der Arbeitsgruppe Basler Schulbibliotheken unterstützt werden."
        }
      ],
      "stand": "2009-08-10",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/414.800",
      "abgerufen": "2026-06-23",
      "fassungsToken": "ef1eb14704a362c17dc6bc0ea648d530",
      "sha": "6d8588681fce9a4813c048ce4d3d0b0cfacced818e7199953c932ef583378d3c"
    },
    {
      "id": "kanton/BS/414.800/art_13",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Ordnung für die Schulbibliotheken (414.800)",
      "artikel": "13",
      "artikelLabel": "§ 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Ordnung ist zu publizieren; sie wird auf den Beginn des Schuljahres 2009/10 am 10. August 2009 wirksam."
        },
        {
          "absatz": "2",
          "text": "Auf diesen Zeitpunkt wird die Ordnung für die Schulbibliotheken vom 21. August 1968 aufgehoben."
        }
      ],
      "stand": "2009-08-10",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/414.800",
      "abgerufen": "2026-06-23",
