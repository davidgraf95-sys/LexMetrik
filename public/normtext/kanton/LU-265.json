{
  "erzeugt": "2026-06-16",
  "eintraege": [
    {
      "id": "kanton/LU/265/art_5",
      "ebene": "kanton",
      "quelle": "LU",
      "erlass": "Justiz-Kostenverordnung, JusKV (SRL Nr. 265)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "In nicht vermögensrechtlichen Streitigkeiten beträgt die Gebühr 1000 bis 12 000 Franken."
        },
        {
          "absatz": "2",
          "text": "In vermögensrechtlichen Streitigkeiten beträgt die Gebühr bei einem Streitwert",
          "items": [
            {
              "marke": "a",
              "text": "bis Fr. 50 000.– Fr. 1500.– bis Fr. 5000.–"
            },
            {
              "marke": "b",
              "text": "über Fr. 50 000.– bis Fr. 100 000.– Fr. 2500.– bis Fr. 8000.–"
            },
            {
              "marke": "c",
              "text": "über Fr. 100 000.– bis Fr. 200 000.– Fr. 5000.– bis Fr. 12 000.–"
            },
            {
              "marke": "d",
              "text": "über Fr. 200 000.– bis Fr. 500 000.– Fr. 7500.– bis Fr. 25 000.–"
            },
            {
              "marke": "e",
              "text": "über Fr. 500 000.– bis Fr. 1 000 000.– Fr. 10 000.– bis Fr. 40 000.–"
            },
            {
              "marke": "f",
              "text": "über Fr. 1 000 000.– bis Fr. 5 000 000.– Fr. 30 000.– bis Fr. 125 000.–"
            },
            {
              "marke": "g",
              "text": "über Fr. 5 000 000.– bis Fr. 10 000 000.– Fr. 50 000.– bis Fr. 250 000.–"
            },
            {
              "marke": "h",
              "text": "über Fr. 10 000 000.– 1–2,5% des Streitwerts"
            }
          ]
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://srl.lu.ch/app/de/texts_of_law/265",
      "abgerufen": "2026-06-16",
      "fassungsToken": "2aa177649f831cf95054a6fefc7b8083",
      "sha": "5262428ead37efc963abb40f5fefeab2070b8fe11bbaffb533a89b56fdb6f8a7"
    },
    {
      "id": "kanton/LU/265/art_4",
      "ebene": "kanton",
      "quelle": "LU",
      "erlass": "Justiz-Kostenverordnung, JusKV (SRL Nr. 265)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühr für den Schlichtungsversuch beträgt",
          "items": [
            {
              "marke": "a",
              "text": "in nichtvermögensrechtlichen Streitigkeiten Fr. 200.– bis Fr. 600.–"
            },
            {
              "marke": "b",
              "text": "in vermögensrechtlichen Streitigkeiten bei einem Streitwert"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Für einen Entscheid nach Artikel 212 ZPO oder einen Urteilsvorschlag nach den Artikeln 210 f. ZPO kann ein Zuschlag von 100 bis 500 Franken erhoben werden."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://srl.lu.ch/app/de/texts_of_law/265",
      "abgerufen": "2026-06-16",
      "fassungsToken": "2aa177649f831cf95054a6fefc7b8083",
      "sha": "b7a213f47eb9a4fd890d4ea506d27bca59090a6d2373bd4a3fc8bdaefa343050"
    },
    {
      "id": "kanton/LU/265/art_31",
      "ebene": "kanton",
      "quelle": "LU",
      "erlass": "Justiz-Kostenverordnung, JusKV (SRL Nr. 265)",
      "artikel": "31",
      "artikelLabel": "§ 31 Abs. 1 (i.V.m. § 5)",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im Verfahren vor der Schlichtungsbehörde, vor erster Instanz oder vor der einzigen kantonalen Instanz beträgt die ordentliche Gebühr 75 bis 150 Prozent der Gebühr nach den §§ 4–8 und 12–13."
        },
        {
          "absatz": "2",
          "text": "Im Rechtsmittelverfahren nach der ZPO beträgt die ordentliche Gebühr 50 bis 120 Prozent der Gebühr nach den §§ 9–12 und 14."
        },
        {
          "absatz": "3",
          "text": "In Verfahren nach VRG beträgt die Gebühr 100 bis 20 000 Franken."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://srl.lu.ch/app/de/texts_of_law/265",
      "abgerufen": "2026-06-16",
      "fassungsToken": "2aa177649f831cf95054a6fefc7b8083",
      "sha": "5bfbd4b5233a8e75a9285e284c0bd1c65dbfbdbb89b39b2c6b0608fc594ab83a"
    }
  ]
}