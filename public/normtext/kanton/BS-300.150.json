{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/300.150/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "VvTabPG (300.150)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Gesundheitsdepartement ist für den Vollzug der eidgenössischen Tabakproduktegesetzgebung zuständig."
        },
        {
          "absatz": "2",
          "text": "Die Zuständigkeit für den Vollzug der Vorschriften über die Plakatwerbung auf öffentlichem Grund und Boden richtet sich nach der Plakatverordnung vom 7. Februar 1933."
        }
      ],
      "stand": "2025-06-05",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/300.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f7ff6bae5a66eb862882c9313f39bc11",
      "sha": "e62edc9213269eff44e86f4948b0da36590e818dd6081a23cf9a62a612b76c6c"
    },
    {
      "id": "kanton/BS/300.150/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "VvTabPG (300.150)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Vollzugsaufgaben können Personen und Organisationen des öffentlichen oder des privaten Rechts übertragen werden."
        }
      ],
      "stand": "2025-06-05",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/300.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "f7ff6bae5a66eb862882c9313f39bc11",
      "sha": "260cd5ff6741fa78ee8669362c066977d9834d86f2aaa2b608dbf9a0ef3ece45"
    },
    {
      "id": "kanton/BS/300.150/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "VvTabPG (300.150)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Vollzugsbehörden erheben Gebühren für die durchgeführten Kontrollen und die getroffenen Mass⁠nahmen, es sei denn, die Kontrollen führen zu keinen Beanstandungen."
        },
        {
          "absatz": "2",
          "text": "Die Gebühren richten sich nach dem Zeitaufwand. Der Stundensatz beträgt Fr. 145."
        },
        {
          "absatz": "3",
          "text": "Für analytische Untersuchungen gilt der Gebührentarif für die amtliche Lebensmittelkontrolle des Verbands der Kantonschemiker der Schweiz."
        }
      ],
      "stand": "2025-06-05",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/300.150",
      "abgerufen": "2026-06-23",
