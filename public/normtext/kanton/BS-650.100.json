      "quelle": "BS",
      "erlass": "Handänderungssteuergesetz (SG 650.100)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Handänderungssteuer unterliegen die zivilrechtlichen und die in diesem Gesetz aufgeführten wirtschaftlichen Handänderungen."
        },
        {
          "absatz": "2",
          "text": "Der Steuersatz beträgt 3 Prozent."
        },
        {
          "absatz": "3",
          "text": "Steuerpflichtig ist, soweit dieses Gesetz nichts anderes vorsieht, der Erwerber oder die Erwerberin."
        },
        {
          "absatz": "4",
          "text": "Die Steuer wird nach der vereinbarten Gegenleistung berechnet, mindestens aber vom Steuerwert des Grundstücks."
        }
      ],
      "stand": "2014-07-01",
