      "ebene": "kanton",
      "quelle": "GR",
      "erlass": "Verordnung über die Gebühren der Grundbuchämter (BR 217.200)",
      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": null,
          "text": "",
          "items": [
            {
              "marke": "a",
              "text": "Auszug aus dem elektronischen Auskunftsportal (Grundbuchgebühr exklusive externe Transaktionskosten)"
            },
            {
              "marke": "1",
              "text": "Basisauszug Fr. 2.–"
            },
            {
              "marke": "2",
              "text": "Erweiterter Auszug Fr. 5.–"
            },
            {
              "marke": "3",
              "text": "Elektronisch beglaubigter Auszug Fr. 50.–"
            },
            {
              "marke": "4",
              "text": "Grundbuchauszug in Papierform je Seite Fr. 25.– (Minimum Fr. 50.–)"
            },
            {
              "marke": "a",
              "text": "Auszug in Form einer Fotokopie des Hauptbuchblattes aus dem Papier-Grundbuch"
            },
            {
              "marke": "1",
              "text": "erste Seite Fr. 25.–"
            },
            {
              "marke": "2",
              "text": "jede weitere Seite Fr. 5.–"
            },
            {
              "marke": "3",
              "text": "Minimum Fr. 50.–"
            },
            {
              "marke": "b",
              "text": "Handänderungsanzeige"
            },
            {
              "marke": "1",
              "text": "Erste Anzeige Fr. 30.–"
            },
            {
              "marke": "2",
              "text": "jede weitere Anzeige Fr. 15.–"
            },
            {
              "marke": "c",
              "text": "Nachführen von Schuldbriefen (inkl. Neuausstellung)"
            },
            {
              "marke": "1",
              "text": "Minimum Fr. 20.–"
            },
            {
              "marke": "2",
              "text": "Maximum Fr. 100.–"
            },
            {
              "marke": "d",
              "text": "Abweisung einer Grundbuchanmelung, Zeitaufwand für zur Prüfung entgegengenommene Entwürfe sowie Zeitaufwand für Auskünfte, Nachforschungen und Verrichtungen, die in diesem Tarif nicht aufgeführt sind: gemäss dem für die 20. Gehaltsklasse festgelegten kantonalen Verrechungsansatz pro Stunde"
            },
            {
              "marke": "e",
              "text": "Porto, Telefonauslagen, Büralkosten, sowie Fahrspesen (letztere gemäss kantonalen Entschädigungsansätzen): werden gesondert berechnet"
            },
            {
              "marke": "f",
              "text": "Korrespondenz: gemäss Stundenansatz (Art. 18 lit. d)"
            }
          ]
        }
