{
  "erzeugt": "2026-06-19",
  "eintraege": [
    {
      "id": "kanton/SZ/280.411/art_1",
      "ebene": "kanton",
      "quelle": "SZ",
      "erlass": "Gebührentarif für Rechtsanwälte (SRSZ 280.411)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "3",
          "text": "Für das Verhältnis des Anwaltes zu seinem Auftraggeber sind die privatrechtlichen Vereinbarungen massgebend."
        }
      ],
      "stand": "2015-01-01",
      "quelleUrl": "https://www.sz.ch/public/upload/assets/5862/280_411.pdf",
      "abgerufen": "2026-06-19",
      "fassungsToken": "2435ceb82c92310515a6f80479075c82b36066d93605aaa0c872476119f3be72",
      "sha": "2c31cae2c9278aa6062768f63fae6a026e29c82952c79dcffed51ffded51ebdc"
    },
    {
      "id": "kanton/SZ/280.411/art_2",
      "ebene": "kanton",
      "quelle": "SZ",
      "erlass": "Gebührentarif für Rechtsanwälte (SRSZ 280.411)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Im Rahmen der in diesem Tarif festgesetzten Mindest- und Höchstansätze ist die Vergütung nach der Wichtigkeit derStreitsache, ihrer Schwierigkeit, dem Umfang und der Art der Arbeitsleistung sowie dem notwendigen Zeitaufwand zu bemessen."
        },
        {
          "absatz": "2",
          "text": "Wird die Vergütung pauschal zugesprochen, gilt die Mehrwertsteuer als in diesem Betrag enthalten. Bemisst sich das Honorar nach dem zeitlichen Aufwand, ist die Mehrwertsteuer zusätzlich zu entschädigen."
        }
      ],
      "stand": "2015-01-01",
      "quelleUrl": "https://www.sz.ch/public/upload/assets/5862/280_411.pdf",
      "abgerufen": "2026-06-19",
      "fassungsToken": "2435ceb82c92310515a6f80479075c82b36066d93605aaa0c872476119f3be72",
      "sha": "bdf2fe360f05609416a89f0be800706f9d5670a36002a4daa09fe2c181b998ad"
    },
    {
      "id": "kanton/SZ/280.411/art_3",
      "ebene": "kanton",
      "quelle": "SZ",
      "erlass": "Gebührentarif für Rechtsanwälte (SRSZ 280.411)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": null,
          "text": "Ist für die Vergütung der Streitwert massgebend, so wird dieser nach den Vorschriften der Schweizerischen Zivilprozessordnung ermittelt; die Streitwerte von Klage und Widerklage werden jedoch zusammengerechnet."
        }
      ],
      "stand": "2015-01-01",
      "quelleUrl": "https://www.sz.ch/public/upload/assets/5862/280_411.pdf",
      "abgerufen": "2026-06-19",
      "fassungsToken": "2435ceb82c92310515a6f80479075c82b36066d93605aaa0c872476119f3be72",
      "sha": "aaf70e09bfd58e48d42548c7b47ed9d932cd83fa75533a2f9ced0f6dc22d3b08"
    },
    {
      "id": "kanton/SZ/280.411/art_4",
      "ebene": "kanton",
      "quelle": "SZ",
      "erlass": "Gebührentarif für Rechtsanwälte (SRSZ 280.411)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wird ein Verfahren durch Vergleich, Rückzug oder Anerkennung erledigt, oder fällt das Anwaltsmandat aus einem anderen Grunde dahin, so ist die Vergütung unter Berücksichtigung des Standes des Verfahrens, des bisherigen Arbeitsaufwandes und des Streitwertes festzusetzen."
        },
        {
          "absatz": "2",
          "text": "Die Mehrkosten wegen eines Anwaltswechsels können der entschädigungspflichtigen Partei nicht belastet werden."
        }
      ],
      "stand": "2015-01-01",
      "quelleUrl": "https://www.sz.ch/public/upload/assets/5862/280_411.pdf",
      "abgerufen": "2026-06-19",
      "fassungsToken": "2435ceb82c92310515a6f80479075c82b36066d93605aaa0c872476119f3be72",
      "sha": "822ffa90b71b7a6386b58d4dc8765a23d5204e10dbc10b2486f7d02a7e211c36"
    },
    {
      "id": "kanton/SZ/280.411/art_6",
      "ebene": "kanton",
      "quelle": "SZ",
      "erlass": "Gebührentarif für Rechtsanwälte (SRSZ 280.411)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "bloecke": [
        {
          "absatz": null,
          "text": "",
          "items": [
            {
              "marke": "b",
              "text": "wenn der Anwalt als amtlicher Verteidiger, unentgeltlicher Rechtsvertreter oder Anwalt der ersten Stunde tätig ist."
            }
          ]
        }
      ],
      "stand": "2015-01-01",
      "quelleUrl": "https://www.sz.ch/public/upload/assets/5862/280_411.pdf",
      "abgerufen": "2026-06-19",
      "fassungsToken": "2435ceb82c92310515a6f80479075c82b36066d93605aaa0c872476119f3be72",
      "sha": "71b2dffc8b1befeaec9915038dc474b01218cfa0f33a79f2275ca0113d48399a"
    },
    {
      "id": "kanton/SZ/280.411/art_7",
      "ebene": "kanton",
      "quelle": "SZ",
      "erlass": "Gebührentarif für Rechtsanwälte (SRSZ 280.411)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zur Kostennormierung gegenüber der eigenen Partei auf Begehren des Anwalts oder der Partei ist jene Instanz befugt, vor der die Streitsache während der Dauer des Anwaltsmandates noch oder zuletzt anhängig war."
        },
        {
          "absatz": "2",
          "text": "Hat der Anwalt die Partei aus demselben Auftrag in verschiedenen Verfahren und vor verschiedenen Instanzen vertreten, so können sich Anwalt und Partei darauf einigen, das Mass des Gesamtanspruches durch das Kantonsgericht bestimmen zu lassen."
        },
        {
          "absatz": "3",
          "text": "In der Regel ist das Moderationsgesuch schriftlich zu begründen und vom Gesuchsgegner schriftlich zu beantworten. Beweismittel sind geltend zua- m chen; sie können von Amtes wegen ergänzt werden."
        },
        {
          "absatz": "4",
          "text": "Der Gesuchsteller trägt die Kosten der Normierung."
        },
        {
          "absatz": "5",
          "text": "Der Moderationsentscheid bildet keinen Rechtsöffnungstitel und ist für den Richter, der in einem Prozess zwischen Anwalt und Auftraggeber die Ansprüche des Anwalts zu beurteilen hat, nicht verbindlich. II. Honorar im Zivilverfahren"
        }
      ],
      "stand": "2015-01-01",
      "quelleUrl": "https://www.sz.ch/public/upload/assets/5862/280_411.pdf",
      "abgerufen": "2026-06-19",
      "fassungsToken": "2435ceb82c92310515a6f80479075c82b36066d93605aaa0c872476119f3be72",
      "sha": "fe644c5519f4358ca835c437b378d77055fb0fe91eb9efc24c91085ab2356d78"
    },
    {
      "id": "kanton/SZ/280.411/art_8",
      "ebene": "kanton",
      "quelle": "SZ",
      "erlass": "Gebührentarif für Rechtsanwälte (SRSZ 280.411)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Führung von Zivilprozessen vor erster oder einziger Instanz ist das Honorar bei einem Streitwert von weniger als Fr. 2 000.- in der Regel nach dem"
        }
      ],
      "stand": "2015-01-01",
      "quelleUrl": "https://www.sz.ch/public/upload/assets/5862/280_411.pdf",
      "abgerufen": "2026-06-19",
      "fassungsToken": "2435ceb82c92310515a6f80479075c82b36066d93605aaa0c872476119f3be72",
      "sha": "dd5fd829de6b2c8a63ef6cff6dd7cc83825ade00471daef5be49ca095c82a813"
    },
    {
      "id": "kanton/SZ/280.411/art_10",
      "ebene": "kanton",
      "quelle": "SZ",
      "erlass": "Gebührentarif für Rechtsanwälte (SRSZ 280.411)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "bloecke": [
        {
          "absatz": null,
          "text": "In summarischen Verfahren beträgt das Honorar Fr. 300.- bis Fr. 4 800.-."
        }
      ],
      "stand": "2015-01-01",
      "quelleUrl": "https://www.sz.ch/public/upload/assets/5862/280_411.pdf",
      "abgerufen": "2026-06-19",
      "fassungsToken": "2435ceb82c92310515a6f80479075c82b36066d93605aaa0c872476119f3be72",
      "sha": "d313037abe3e52942fad450c738112aadc8afc69f0bc72255edff816c0712487"
    },
    {
      "id": "kanton/SZ/280.411/art_11",
      "ebene": "kanton",
      "quelle": "SZ",
      "erlass": "Gebührentarif für Rechtsanwälte (SRSZ 280.411)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "bloecke": [
        {
          "absatz": null,
          "text": "Im Berufungs- und im Revisionsverfahren beträgt das Honorar 20 bis 60 % der in den §§ 8 und 9 festgesetzten Ansätze,wobei der noch vor der Berufungs- und Revisionsinstanz in Frage kommende Streitwert massgebend ist."
        }
      ],
      "stand": "2015-01-01",
      "quelleUrl": "https://www.sz.ch/public/upload/assets/5862/280_411.pdf",
      "abgerufen": "2026-06-19",
      "fassungsToken": "2435ceb82c92310515a6f80479075c82b36066d93605aaa0c872476119f3be72",
      "sha": "02f3d8b928ceb974f1f1856d6f2b0d4489640189eef1c3269a3d4a0a4a21bdff"
    },
    {
      "id": "kanton/SZ/280.411/art_12",
      "ebene": "kanton",
      "quelle": "SZ",
      "erlass": "Gebührentarif für Rechtsanwälte (SRSZ 280.411)",
      "artikel": "12",
      "artikelLabel": "§ 12",
      "bloecke": [
        {
          "absatz": null,
          "text": "Für das Beschwerdeverfahren sowie für das Erläuterungs- und Berichtigungsbegehren beläuft sich das Honorar auf Fr. 180.- bis Fr. 2 400.-. III. Honorar im Strafverfahren"
        }
      ],
      "stand": "2015-01-01",
      "quelleUrl": "https://www.sz.ch/public/upload/assets/5862/280_411.pdf",
      "abgerufen": "2026-06-19",
      "fassungsToken": "2435ceb82c92310515a6f80479075c82b36066d93605aaa0c872476119f3be72",
      "sha": "9157da2fd50b71b266024dc0f2a628a64c34c46513ad8fe0f16ebc05678f0954"
    },
    {
      "id": "kanton/SZ/280.411/art_13",
      "ebene": "kanton",
      "quelle": "SZ",
      "erlass": "Gebührentarif für Rechtsanwälte (SRSZ 280.411)",
      "artikel": "13",
      "artikelLabel": "§ 13",
      "bloecke": [
        {
          "absatz": null,
          "text": "In Strafsachen beträgt das Honorar:",
          "items": [
            {
              "marke": "a",
              "text": "vor der Untersuchungs- und Anklagebehörde, dem Einzelrichter, dem e-B zirksgericht und dem kantonalen Straf- und Jugendgericht Fr. 300.- bis Fr. 20 000.-;"
            },
            {
              "marke": "b",
              "text": "vor dem Zwangsmassnahmengericht Fr. 180.- bis Fr. 5 000.-;"
            },
            {
              "marke": "c",
              "text": "vor dem Kantonsgericht als Berufungs- und Revisionsinstanz Fr. 300.- bis Fr. 12 000.-;"
            }
          ]
        }
      ],
      "stand": "2015-01-01",
      "quelleUrl": "https://www.sz.ch/public/upload/assets/5862/280_411.pdf",
      "abgerufen": "2026-06-19",
      "fassungsToken": "2435ceb82c92310515a6f80479075c82b36066d93605aaa0c872476119f3be72",
      "sha": "896c3a3ea6617697f3184456cc046b9eb5604482486cd890945c7ae351f66e84"
    },
    {
      "id": "kanton/SZ/280.411/art_15",
      "ebene": "kanton",
      "quelle": "SZ",
      "erlass": "Gebührentarif für Rechtsanwälte (SRSZ 280.411)",
      "artikel": "15",
      "artikelLabel": "§ 15",
      "bloecke": [
        {
          "absatz": null,
          "text": "Honorar Fr. 200.- bis Fr. 4 800.-. V. Ausnahmen"
        }
      ],
      "stand": "2015-01-01",
      "quelleUrl": "https://www.sz.ch/public/upload/assets/5862/280_411.pdf",
      "abgerufen": "2026-06-19",
      "fassungsToken": "2435ceb82c92310515a6f80479075c82b36066d93605aaa0c872476119f3be72",
      "sha": "f0cb7a259c0ed9f1f2d60a247e0adf7765f9f2c57501cc5ce72ac42ea3bd4daf"
    },
    {
      "id": "kanton/SZ/280.411/art_16",
      "ebene": "kanton",
      "quelle": "SZ",
      "erlass": "Gebührentarif für Rechtsanwälte (SRSZ 280.411)",
      "artikel": "16",
      "artikelLabel": "§ 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "In Verfahren, die aussergewöhnlich viel Arbeit beanspruchen, namentlich das Studium von fremdem Recht, von Akten, die in einer Fremdsprache abgefasst sind, oder von besonders umfangreichem Aktenmaterial, dürfen die Höchstansätze dieses Tarifs bis 100 % überschritten werden, ebenso, wenn der Anwalt an besonders zeitraubenden Beweiserhebungen oder vor einer Instanz an mehreren Verhandlungen teilnehmen muss."
        },
        {
          "absatz": "2",
          "text": "Die Mindestansätze dürfen unterschritten werden, wenn zwischen dem Streitwert und dem Interesse der Partei am Verfahren oder zwischen dem nach diesem Tarif anwendbaren Honoraransatz und der vom Anwalt tatsächlich geleisteten Arbeit ein offenbares Missverhältnis besteht. VI. Auslagen"
        }
      ],
      "stand": "2015-01-01",
      "quelleUrl": "https://www.sz.ch/public/upload/assets/5862/280_411.pdf",
      "abgerufen": "2026-06-19",
      "fassungsToken": "2435ceb82c92310515a6f80479075c82b36066d93605aaa0c872476119f3be72",
      "sha": "bc835f870b29cbcd75dc7d883f9fb32043b34d316bf6e38db4f1e95809292873"
    },
    {
      "id": "kanton/SZ/280.411/art_17",
      "ebene": "kanton",
      "quelle": "SZ",
      "erlass": "Gebührentarif für Rechtsanwälte (SRSZ 280.411)",
      "artikel": "17",
      "artikelLabel": "§ 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Anwalt hat Anspruch auf Ersatz der Auslagen (Porti, Telefon-und Reisespesen, bezahlte Gerichtskosten und dergleichen)."
        },
        {
          "absatz": "2",
          "text": "Für die Benützung eines Autos beträgt die Kilometer-Entschädigung 70 Rappen."
        }
      ],
      "stand": "2015-01-01",
      "quelleUrl": "https://www.sz.ch/public/upload/assets/5862/280_411.pdf",
      "abgerufen": "2026-06-19",
      "fassungsToken": "2435ceb82c92310515a6f80479075c82b36066d93605aaa0c872476119f3be72",
      "sha": "721d45d1a9c585129c1d97d2981ef7b3e75a4ab0c6142aefc0dd72e8611ee98c"
    },
    {
      "id": "kanton/SZ/280.411/art_18",
      "ebene": "kanton",
      "quelle": "SZ",
      "erlass": "Gebührentarif für Rechtsanwälte (SRSZ 280.411)",
      "artikel": "18",
      "artikelLabel": "§ 18",
      "bloecke": [
        {
          "absatz": "4",
          "text": "wird die Vergütung nach bisherigem Recht bemessen."
        }
      ],
      "stand": "2015-01-01",
      "quelleUrl": "https://www.sz.ch/public/upload/assets/5862/280_411.pdf",
      "abgerufen": "2026-06-19",
      "fassungsToken": "2435ceb82c92310515a6f80479075c82b36066d93605aaa0c872476119f3be72",
      "sha": "147f14ce987318039b959e3fb6704014bd550cbd0da7a5c3b13f4b68c30faba6"
    }
  ]
}