{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/RiE 416.300/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Sportpreises (RiE 416.300)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "titel": "Zweck",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gemeinde Riehen verleiht in Anerkennung besonderer Verdienste auf dem Gebiet des Sports den Riehener Sportpreis."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 416.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "fed3cdea53526760972e2de366668def",
      "sha": "15e280d540e552c138e1d106001d6613f36961de6fb1d087950f81de622585b0"
    },
    {
      "id": "kanton/BS/RiE 416.300/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Sportpreises (RiE 416.300)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Jury",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Ausrichtung des Sportpreises ist eine Jury, bestehend aus sieben Mitgliedern, zuständig. Sie wird vom Gemeinderat gewählt."
        },
        {
          "absatz": "2",
          "text": "Ihre Entscheide trifft sie nach geheimer Beratung mit einfacher Stimmenmehrheit."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 416.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "fed3cdea53526760972e2de366668def",
      "sha": "4ae5871a6ed3fa22b4230fc13a7c3c5342131fa5191cfbb00b47b1b2d6cca33d"
    },
    {
      "id": "kanton/BS/RiE 416.300/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Sportpreises (RiE 416.300)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Amtsdauer",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Amtsdauer der Jury entspricht derjenigen des Gemeinderats."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 416.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "fed3cdea53526760972e2de366668def",
      "sha": "2b5622434e65127c12374b0c36fe22c0badb7c0c0600186fdf5976eafbb9eb7f"
    },
    {
      "id": "kanton/BS/RiE 416.300/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Sportpreises (RiE 416.300)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Organisation",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Jury wählt aus ihren Mitgliedern das Präsidium und Vizepräsidium für eine Amtsdauer von zwei Jahren."
        },
        {
          "absatz": "1bis",
          "text": "Das Sekretariat wird von der zuständigen Verwaltungsabteilung sichergestellt. Die Protokolle werden nur den Mitgliedern zugestellt und sind nicht öffentlich zugänglich."
        },
        {
          "absatz": "2",
          "text": "Die Organisation der Vergabe des Sportpreises erfolgt durch die zuständige Verwaltungsabteilung."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 416.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "fed3cdea53526760972e2de366668def",
      "sha": "670d8657a7a52bbaf81455b9d82c840bcb1bd4d90b481513a16b40bb0c87fb55"
    },
    {
      "id": "kanton/BS/RiE 416.300/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Sportpreises (RiE 416.300)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "titel": "Anerkennungs- oder Förderpreis",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Riehener Sportpreis wird verliehen an erfolgreiche Einzelsportlerinnen bzw. Einzelsportler und Mannschaften oder an Personen, Gruppen oder Institutionen, die sich um den Sport in Riehen besonders verdient gemacht haben. Er kann in Form eines Anerkennungs- oder Förderpreises verliehen werden."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 416.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "fed3cdea53526760972e2de366668def",
      "sha": "29e26e231da962efd68e76c44ca78edc533c9428c1984bbc4fa106a66d657a86"
    },
    {
      "id": "kanton/BS/RiE 416.300/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Sportpreises (RiE 416.300)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "titel": "Bezug zu Riehen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Preisempfängerin oder der Preisempfänger muss in Riehen einen festen Wohnsitz haben oder zur Gemeinde in einer besonderen Beziehung stehen."
        },
        {
          "absatz": "2",
          "text": "Eine Mannschaft oder ein Verein muss den Sitz in Riehen haben."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 416.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "fed3cdea53526760972e2de366668def",
      "sha": "602afc175a306e1a3759d7612be6ad545656d2f1b9768c72ba377d0b2aa5de14"
    },
    {
      "id": "kanton/BS/RiE 416.300/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Sportpreises (RiE 416.300)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "titel": "Ausrichtung des Sportpreises",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Sportpreis wird in der Regel alle zwei Jahre ausgerichtet."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 416.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "fed3cdea53526760972e2de366668def",
      "sha": "40081703bfe079aea0949df9759a8f8ad9c78e604b969d6de6e128105406ef29"
    },
    {
      "id": "kanton/BS/RiE 416.300/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Sportpreises (RiE 416.300)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "titel": "Preissumme",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Ausrichtung des Sportpreises steht jeweils eine Preissumme von CHF 10'000 zur Verfügung."
        },
        {
          "absatz": "2",
          "text": "Im Einzelfall dürfen in der Regel nicht mehr als CHF 10'000.- ausgerichtet werden. Es können auch mehrere Auszeichnungen verliehen werden."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 416.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "fed3cdea53526760972e2de366668def",
      "sha": "dfba19cf5d5d80f2ba0fccfc4179db5815baa0cc9149cfad30096e344e72bd55"
    },
    {
      "id": "kanton/BS/RiE 416.300/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Sportpreises (RiE 416.300)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "titel": "Verzicht auf Vergabe",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Jury kann in begründeten Fällen auf die Vergabe eines Sportpreises verzichten."
        },
        {
          "absatz": "2",
          "text": "…"
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 416.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "fed3cdea53526760972e2de366668def",
      "sha": "ddaa936b6bdc7b7c59f330a2b8081acc0e91307a3113a75e57c9a4c6a4de9d3d"
    },
    {
      "id": "kanton/BS/RiE 416.300/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Sportpreises (RiE 416.300)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "titel": "Vorschlag",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Jury unterbreitet dem Gemeinderat alle zwei Jahre einen Vorschlag für die Vergabe des Sportpreises zur Genehmigung."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 416.300",
      "abgerufen": "2026-06-23",
      "fassungsToken": "fed3cdea53526760972e2de366668def",
      "sha": "76a9152f22540771b7b086cddb2b1e7af4eac89f3eab5cb093d6dfd953d7a35a"
    },
    {
      "id": "kanton/BS/RiE 416.300/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Reglement betreffend Ausrichtung eines Sportpreises (RiE 416.300)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "titel": "Entscheid",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Entscheid betreffend Sportpreis wird in der Regel spätestens bis Ende April getroffen."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/RiE 416.300",
      "abgerufen": "2026-06-23",
