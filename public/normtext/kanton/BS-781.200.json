{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/781.200/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Lufthygiene, LHV (781.200)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Amt für Umwelt und Energie (AUE) ist die für den Vollzug des Luftreinhalterechts zuständige Behörde."
        },
        {
          "absatz": "2",
          "text": "…"
        },
        {
          "absatz": "3",
          "text": "…"
        },
        {
          "absatz": "4",
          "text": "…"
        },
        {
          "absatz": "5",
          "text": "…"
        },
        {
          "absatz": "6",
          "text": "…"
        },
        {
          "absatz": "7",
          "text": "…"
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/781.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62596a861b6ff6473611bd7492b8ece4",
      "sha": "fd609310da67258b800ec2f8ea00b58faf458501ee4429ff1cb7298c76405f49"
    },
    {
      "id": "kanton/BS/781.200/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Lufthygiene, LHV (781.200)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "1. Allgemeines",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das AUE führt eine Liste der Anlagen, die gemäss § 6 Abs. 1 USG BS vor der ersten Inbetriebnahme und bei wesentlichen Änderungen gemeldet werden müssen."
        },
        {
          "absatz": "2",
          "text": "Der Antrag auf Erteilung einer Bewilligung gilt als Meldung. Die Bewilligungsbehörde stellt ein Exemplar der erteilten Bewilligung dem AUE zu."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/781.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62596a861b6ff6473611bd7492b8ece4",
      "sha": "54ddf2ca7f37f9e9a21d3fd074dcf98e4df17a7382710ea076300f7490b9b3fa"
    },
    {
      "id": "kanton/BS/781.200/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Lufthygiene, LHV (781.200)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "2. Neue und geänderte Verfahren",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Neue und geänderte Verfahren müssen dem AUE gemeldet werden, wenn nach der Abluftreinigung:",
          "items": [
            {
              "marke": "a",
              "text": "Stoffe einer anderen Ziff. nach Anhang 1 der Luftreinhalte-Verordnung (LRV) vom 16. Dezember 1985 emittiert werden;"
            },
            {
              "marke": "b",
              "text": "Stoffe der gleichen Ziff., aber einer qualifizierteren Klasse emittiert werden;"
            },
            {
              "marke": "c",
              "text": "sich die Emissionen durchschnittlich um mehr als 30 Prozent erhöhen und die Erhöhung gleichzeitig mehr als die Hälfte des Bagatell-Massenstroms nach Anhang 1 der Luftreinhalte-Verordnung ausmacht."
            }
          ]
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/781.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62596a861b6ff6473611bd7492b8ece4",
      "sha": "9316dfc68ca90ad3581a6a2238045db9c4a37a8aac2b4ffdab2db1fc0a5a4166"
    },
    {
      "id": "kanton/BS/781.200/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Lufthygiene, LHV (781.200)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Emissionen von Feuerungsanlagen werden nach § 37 der Verordnung zum Energiegesetz (Energieverordnung) vom 29. August 2017 gemessen oder kontrolliert."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/781.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62596a861b6ff6473611bd7492b8ece4",
      "sha": "01c74070e5d5a41e30c8832ab6c6a4d496b45d024824843c3623db6605de805b"
    },
    {
      "id": "kanton/BS/781.200/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Lufthygiene, LHV (781.200)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Als schadstoffarme Heizungsanlagen gelten insbesondere der Anschluss an einen Wärmeverbund, Anlagen zur Abwärmenutzung, Wärmepumpen, Anlagen zur Nutzung von Erdwärme und Solarheizungen."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/781.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62596a861b6ff6473611bd7492b8ece4",
      "sha": "cce501e2cfcd2b5298a8bfd349c300d1ce531e6d01844f299373c6a632d2c520"
    },
    {
      "id": "kanton/BS/781.200/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Lufthygiene, LHV (781.200)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "titel": "1. Emissionsfrachten",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Berechnung der Emissionsfrachten für Gutschrift und Verbund sind massgebend die gemessene Emissionskonzentration, der Volumenstrom und die durchschnittliche jährliche Betriebsdauer."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/781.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62596a861b6ff6473611bd7492b8ece4",
      "sha": "56693d685931bced86f07a2b55776ca67d6d6e2b7cd5d1adae6c7edf97e7457c"
    },
    {
      "id": "kanton/BS/781.200/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Lufthygiene, LHV (781.200)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "titel": "2. Erteilung vom Emissionsgutschriften",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das AUE erteilt die Emissionsgutschriften auf Antrag, wenn durch Messungen erwiesen ist, dass die Anlage die Emissionsgrenzwerte im vom Gesetz festgelegten Ausmass unterschreitet."
        },
        {
          "absatz": "2",
          "text": "Emissionsgutschriften für weniger als 200 kg Stickoxide oder für weniger als 500 kg flüchtige organische Stoffe werden nicht erteilt."
        },
        {
          "absatz": "3",
          "text": "Mit der Erteilung der Gutschrift legt das AUE für die betroffene Anlage eine neue Emissionsbegrenzung fest."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/781.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62596a861b6ff6473611bd7492b8ece4",
      "sha": "771f2844107b1538fe43ed23a731727fcd0ceac25183734139cfffdcd9c4cbc5"
    },
    {
      "id": "kanton/BS/781.200/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Lufthygiene, LHV (781.200)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "titel": "3. Einsatz vom Emissionsgutschriften",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer eine Emissionsgutschrift einsetzen will, muss dies dem AUE spätestens dann melden, wenn das Gesuch (Baugesuch, Einrichtungsbegehren) für die neue Anlage eingereicht oder ein Sanierungsvorschlag unterbreitet wird."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/781.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62596a861b6ff6473611bd7492b8ece4",
      "sha": "ec66bae66690b8b6234be2508c6ece8703df8120a33f54defe5113f6c5352d9a"
    },
    {
      "id": "kanton/BS/781.200/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Lufthygiene, LHV (781.200)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "titel": "4. Emissionsverbünde",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das AUE erteilt die Zustimmung zur Bildung eines Emissionsverbundes."
        },
        {
          "absatz": "2",
          "text": "Die Emissionsfracht wird derjenigen Fracht gegenübergestellt, die sich aufgrund der Emissionsgrenzwerte des Volumenstroms und gleicher Betriebsdauer ergeben würde."
        },
        {
          "absatz": "3",
          "text": "Die an einem Emissionsverbund Beteiligten müssen dem AUE jährlich eine Emissionsbilanz der Anlagen liefern."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/781.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62596a861b6ff6473611bd7492b8ece4",
      "sha": "0c77f280cba3bcd2d351cb195f202e747ed0e1ab0ac894922ffab47daa023ad5"
    },
    {
      "id": "kanton/BS/781.200/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Lufthygiene, LHV (781.200)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "titel": "5. Verzeichnis der Emissionsgutschriften und Emissionsverbünde",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das AUE erstellt ein Verzeichnis der Emissionsgutschriften und der Emissionsverbünde. Das Verzeichnis ist öffentlich."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/781.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62596a861b6ff6473611bd7492b8ece4",
      "sha": "027a4de64b0e8a437802760ee6e6d908119b26744ed50c10c03a927b76c8ecec"
    },
    {
      "id": "kanton/BS/781.200/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über die Lufthygiene, LHV (781.200)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "titel": "6. Übergangsbestimmung",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Emissionsgutschriften können erteilt werden für Anlagen, die nach dem Inkrafttreten der Verordnung vom 14. August 1990 über die Verschärfung der Emissionsbegrenzungen für stationäre Anlagen errichtet oder saniert worden sind."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/781.200",
      "abgerufen": "2026-06-23",
      "fassungsToken": "62596a861b6ff6473611bd7492b8ece4",
      "sha": "7ec8acf3fffabbf7692dd463b5641317461c1fde26d2d182ee7d5dfd605c6dc0"
    }
  ]
}