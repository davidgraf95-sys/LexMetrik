      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Als Rekurskommission wird das Obergericht eingesetzt."
        }
      ],
      "stand": "2025-07-01",
