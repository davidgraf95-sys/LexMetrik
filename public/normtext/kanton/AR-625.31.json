      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die kantonale Steuerverwaltung übermittelt dem Amt für Militär und Bevölkerungsschutz die zweckdienlichen Mitteilungen, erteilt die benötigten Auskünfte und gewährt Einsicht in die Akten."
        }
      ],
      "stand": "2025-07-01",
