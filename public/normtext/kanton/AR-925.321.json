{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/925.321/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "VEAV (925.321)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung regelt das Nähere zu den Entschädigungen der Beauftragten des Veterinäramts, zu den Gebühren im Veterinärwesen, zur Tiergesundheitskasse sowie zur Kaution für die gewerbsmässige Wildtierhaltung."
        },
        {
          "absatz": "2",
          "text": "Entschädigungen und Gebühren werden nach Zeitaufwand oder pauschal bemessen. Die Abrechnung bei der Bemessung nach Zeitaufwand erfolgt in Schritten von 0.1 Stunden (6 Minuten)."
        },
        {
          "absatz": "3",
          "text": "Als ordentliche Arbeitszeit gilt die Zeit von Montag bis Freitag von 07.00 Uhr bis 19.00 Uhr. Davon ausgenommen sind Feiertage."
        }
      ],
      "stand": "2016-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/925.321",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93734d9db4a7cdfb2a5eed9d14407e9d",
      "sha": "a493517807213647e515fa3abc82d219e22cb6c716af501ed9789d04d8ca17b5"
    },
    {
      "id": "kanton/AR/925.321/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "VEAV (925.321)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Entschädigung nach Zeitaufwand findet Anwendung bei:",
          "items": [
            {
              "marke": "a",
              "text": "der Schlachttier- und Fleischuntersuchung durch amtlich beauftragte Tierärztinnen und Tierärzte;"
            },
            {
              "marke": "b",
              "text": "den übrigen tierärztlichen Verrichtungen, mit Ausnahme des Vollzugs der Tiergesundheitsgesetzgebung;"
            },
            {
              "marke": "c",
              "text": "den amtlichen Verrichtungen durch Bieneninspektorinnen und Bieneninspektoren, Schätzungsexpertinnen und Schätzungsexperten sowie andere nichttierärztliche Beauftragte;"
            },
            {
              "marke": "d",
              "text": "Kursen und Sitzungen, die vom Veterinäramt angeordnet wurden."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Mit dem Stundenansatz wird die Zeit der Arbeitsverrichtung am Einsatz-, Kurs- oder Sitzungsort sowie die Zeit der An- und Rückfahrt entschädigt."
        },
        {
          "absatz": "3",
          "text": "Die Mehrwertsteuer, Aufwendungen für notwendige Aus- und Weiterbildung, allfällige Sozialversicherungsbeiträge sowie die Bereitstellung und Nutzung des Internets, Telefons und anderer notwendiger Bürogeräte sind mit dem Stundenansatz abgegolten."
        }
      ],
      "stand": "2016-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/925.321",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93734d9db4a7cdfb2a5eed9d14407e9d",
      "sha": "86eff621921f149deec9e1ee098a4f091cf76dadcecf92a5f3f9e477a6fc3ca1"
    },
    {
      "id": "kanton/AR/925.321/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "VEAV (925.321)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Entschädigung für die Schlachttier- und Fleischuntersuchung sowie die übrigen tierärztlichen Verrichtungen beträgt je Stunde:",
          "items": [
            {
              "marke": "a",
              "text": "während der ordentlichen Arbeitszeit Fr. 157.-"
            },
            {
              "marke": "b",
              "text": "ausserhalb der ordentlichen Arbeitszeit (falls angeordnet) Fr. 236.-"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die Entschädigung für Kurse und Sitzungen beträgt:",
          "items": [
            {
              "marke": "a",
              "text": "je Stunde Fr. 119.-"
            },
            {
              "marke": "b",
              "text": "je halber Tag höchstens Fr. 247.-"
            },
            {
              "marke": "c",
              "text": "je Tag höchstens Fr. 474.-"
            }
          ]
        }
      ],
      "stand": "2016-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/925.321",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93734d9db4a7cdfb2a5eed9d14407e9d",
      "sha": "10952132a42734c83ea05862dbbec83240d186ca1fa74640dcb27526ab570e25"
    },
    {
      "id": "kanton/AR/925.321/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "VEAV (925.321)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Entschädigung für amtliche Verrichtungen beträgt je Stunde:",
          "items": [
            {
              "marke": "a",
              "text": "während der ordentlichen Arbeitszeit Fr. 48.-"
            },
            {
              "marke": "b",
              "text": "ausserhalb der ordentlichen Arbeitszeit (falls angeordnet) Fr. 72.-"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die Entschädigung für Kurse und Sitzungen beträgt:",
          "items": [
            {
              "marke": "a",
              "text": "je Stunde Fr. 37.-"
            },
            {
              "marke": "b",
              "text": "je halber Tag höchstens Fr. 132.-"
            },
            {
              "marke": "c",
              "text": "je Tag höchstens Fr. 264.-"
            }
          ]
        }
      ],
      "stand": "2016-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/925.321",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93734d9db4a7cdfb2a5eed9d14407e9d",
      "sha": "6d4d7c905033f00c53cdb86eaf535290d86ec05c55fef1ea7aa1744810617968"
    },
    {
      "id": "kanton/AR/925.321/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "VEAV (925.321)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Entschädigung von Spesen richtet sich nach dem Reglement über die Entschädigung von Inkonvenienzen, Spesen, Pikettdienst und ausserordentliche Arbeitszeit."
        },
        {
          "absatz": "2",
          "text": "Auslagen für Porto und Verbrauchsmaterial sowie übrige Spesen werden nach Vorlage der Belege separat entschädigt."
        }
      ],
      "stand": "2016-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/925.321",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93734d9db4a7cdfb2a5eed9d14407e9d",
      "sha": "d2a06d6ae682236e10f4efa5660cdd9143efd54c8ff4677e99c2916879f17385"
    },
    {
      "id": "kanton/AR/925.321/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "VEAV (925.321)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Grundentschädigung der Tierärztinnen und Tierärzte für den Vollzug der Tiergesundheitsgesetzgebung beträgt Fr. 47.- je Betriebsbesuch. Mit der Grundentschädigung sind die Organisation der Probenahme, die Fahrspesen, die Auslagen für Porto und Verbrauchsmaterial, der übliche administrative Aufwand sowie das Verpacken und Einsenden der Proben abgegolten."
        },
        {
          "absatz": "2",
          "text": "Der Gang zu jedem weiteren Stall desselben Tierhalters (andere TVD-Nr.) wird zusätzlich mit Fr. 20.- entschädigt."
        },
        {
          "absatz": "3",
          "text": "Die Einzelentschädigung beträgt für:",
          "items": [
            {
              "marke": "a",
              "text": "die Schutzimpfung oder Tuberkulinisierung, je Tier Fr. 3.20 bis Fr. 9.60"
            },
            {
              "marke": "b",
              "text": "die Entnahme diverser Proben Fr. 3.20 bis Fr. 32.-"
            },
            {
              "marke": "c",
              "text": "die Sektion inkl. Bericht Fr. 80.- bis Fr. 1'600.-"
            },
            {
              "marke": "d",
              "text": "zusätzlichen administrativen Aufwand Fr. 8.- bis Fr. 24.-"
            },
            {
              "marke": "e",
              "text": "tierärztliche Berichte, je Bericht Fr. 80.- bis Fr. 320.-"
            }
          ]
        },
        {
          "absatz": "4",
          "text": "Innerhalb des Entschädigungsrahmens bemisst das Veterinäramt die Entschädigung anhand des durchschnittlichen Zeitaufwandes."
        },
        {
          "absatz": "5",
          "text": "In besonderen Fällen kann das Veterinäramt anstelle der Pauschalentschädigung die Entschädigung nach Zeitaufwand anordnen."
        }
      ],
      "stand": "2016-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/925.321",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93734d9db4a7cdfb2a5eed9d14407e9d",
      "sha": "2687beaa582d529849244f8a57fff93d2026b7ac96664f2c75d844df3fd0f881"
    },
    {
      "id": "kanton/AR/925.321/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "VEAV (925.321)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Soweit keine besondere Regelung besteht, finden das Gesetz über die Gebühren in Verwaltungssachen, das Gesetz über die Verwaltungsrechtspflege und die Kanzleigebührenverordnung Anwendung."
        },
        {
          "absatz": "2",
          "text": "Laborkosten, Spesen, Porti, Leistungen von Dritten, Verbrauchsmaterial und andere Auslagen werden gesondert nach belegtem Aufwand in Rechnung gestellt."
        },
        {
          "absatz": "3",
          "text": "Tierseuchenpolizeiliche Sperrverfügungen sind in der Regel gebührenfrei. Davon ausgenommen sind Verfügungen im Rahmen von Ein- und Ausfuhren, wenn eine Ausnahmebewilligung auf Antrag der Tierhalterin oder des Tierhalters erteilt wurde oder bei Nichteinhalten der Tierverkehrsvorschriften."
        }
      ],
      "stand": "2016-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/925.321",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93734d9db4a7cdfb2a5eed9d14407e9d",
      "sha": "c2cb885c6f967352531e66e4f7b169d5fa52fece77d3dd6759005008f842f639"
    },
    {
      "id": "kanton/AR/925.321/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "VEAV (925.321)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Grundgebühr je Betriebsbesuch beträgt Fr. 47.-. Die Gebühr für den Gang zu jedem weiteren Stall desselben Tierhalters (andere TVD-Nr.) beträgt zusätzlich Fr. 20.-."
        },
        {
          "absatz": "2",
          "text": "Die Gebühr für Verrichtungen von amtlich beauftragten Tierärztinnen und Tierärzten beträgt je Stunde:",
          "items": [
            {
              "marke": "a",
              "text": "während der ordentlichen Arbeitszeit Fr. 157.-"
            },
            {
              "marke": "b",
              "text": "ausserhalb der ordentlichen Arbeitszeit (falls angeordnet) Fr. 236.-"
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Die Gebühr für Verrichtungen von amtlich beauftragten Bieneninspektorinnen und Bieneninspektoren, Schätzungsexpertinnen und Schätzungsexperten sowie anderen nichttierärztlichen Beauftragten beträgt je Stunde:",
          "items": [
            {
              "marke": "a",
              "text": "während der ordentlichen Arbeitszeit Fr. 48.-"
            },
            {
              "marke": "b",
              "text": "ausserhalb der ordentlichen Arbeitszeit (falls angeordnet) Fr. 72.-"
            }
          ]
        },
        {
          "absatz": "4",
          "text": "Die Gebühr für administrative Verrichtungen des Veterinäramts beträgt Fr. 100.- je Stunde."
        }
      ],
      "stand": "2016-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/925.321",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93734d9db4a7cdfb2a5eed9d14407e9d",
      "sha": "b1a0fabb26b21e78639d26d6720cfb592d4f6d4b814ebf373943cb1dc811b848"
    },
    {
      "id": "kanton/AR/925.321/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "VEAV (925.321)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Grundgebühr je Besuch einer Schlachtanlage beträgt Fr. 20.-."
        },
        {
          "absatz": "2",
          "text": "Die Einzelgebühr je Schlachttier beträgt:",
          "items": [
            {
              "marke": "a",
              "text": "Rind, ab 6 Wochen Fr. 12.-"
            },
            {
              "marke": "b",
              "text": "Kalb, unter 6 Wochen Fr. 8.-"
            },
            {
              "marke": "c",
              "text": "Schwein Fr. 8.-"
            },
            {
              "marke": "d",
              "text": "Schaf, Ziege Fr. 7.-"
            },
            {
              "marke": "e",
              "text": "mehr als 50 Gitzi oder Lämmer pro Schlachttag Fr. 5.-"
            },
            {
              "marke": "f",
              "text": "Pferd Fr. 12.-"
            },
            {
              "marke": "g",
              "text": "anderes Schlachtvieh Fr. 8.-"
            },
            {
              "marke": "h",
              "text": "Hausgeflügel, Hauskaninchen Fr. 0.20"
            },
            {
              "marke": "i",
              "text": "Zucht-Schalenwild Fr. 8.-"
            },
            {
              "marke": "j",
              "text": "Federwild, Hasen Fr. 0.20"
            },
            {
              "marke": "k",
              "text": "anderes Wild Fr. 8.-"
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Die Einzelgebühr je Probe (exkl. Versand- und Laborkosten) beträgt für:",
          "items": [
            {
              "marke": "a",
              "text": "die Trichinellenuntersuchung Fr. 3.-"
            },
            {
              "marke": "b",
              "text": "die Rückstandsuntersuchung Fr. 15.-"
            }
          ]
        },
        {
          "absatz": "4",
          "text": "Bei Grossbetrieben nach Art. 3 lit. k der Verordnung über das Schlachten und die Fleischkontrolle kann das Veterinäramt die Einzelgebühren aufgrund des ermittelten Aufwandes bemessen."
        }
      ],
      "stand": "2016-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/925.321",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93734d9db4a7cdfb2a5eed9d14407e9d",
      "sha": "88bc021a030aa834d1ea3447d3df4f39cc0eabe71f4cf7f44abc1c381aa6f314"
    },
    {
      "id": "kanton/AR/925.321/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "VEAV (925.321)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei einem Aufgebot ausserhalb der ordentlichen Arbeitszeit beträgt der Zuschlag zur Grundgebühr Fr. 30.-."
        },
        {
          "absatz": "2",
          "text": "Bei einem Aufgebot ausserhalb der vereinbarten Schlachtprogrammzeiten beträgt der Zuschlag zu den Einzelgebühren je Stunde:",
          "items": [
            {
              "marke": "a",
              "text": "während der ordentlichen Arbeitszeit Fr. 50.-"
            },
            {
              "marke": "b",
              "text": "ausserhalb der ordentlichen Arbeitszeit Fr. 100.-"
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Bei Notschlachtungen von Tieren aus den Kantonen Appenzell Ausserrhoden und Appenzell Innerrhoden werden keine Zuschläge erhoben."
        }
      ],
      "stand": "2016-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/925.321",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93734d9db4a7cdfb2a5eed9d14407e9d",
      "sha": "4a2fb00220462bfc85a9f50a21e6c5c6565f90fdf726378d4c1b0146fa62e11c"
    },
    {
      "id": "kanton/AR/925.321/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "VEAV (925.321)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühr bemisst sich nach Art. 8:",
          "items": [
            {
              "marke": "a",
              "text": "für die Wartezeit der Fleischkontrolleurin oder des Fleischkontrolleurs, wenn diese mehr als 15 Minuten dauert;"
            },
            {
              "marke": "b",
              "text": "bei Schlachttieruntersuchungen im Herkunftsbetrieb."
            }
          ]
        }
      ],
      "stand": "2016-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/925.321",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93734d9db4a7cdfb2a5eed9d14407e9d",
      "sha": "be7a2bbd215ce39dbb5d2a903797bc713b2ec1fbbb320c4d7e32d017c8a30ca9"
    },
    {
      "id": "kanton/AR/925.321/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "VEAV (925.321)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühren für die Entsorgung von tierischen Nebenprodukten bemessen sich nach den effektiven Entsorgungskosten."
        }
      ],
      "stand": "2016-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/925.321",
      "abgerufen": "2026-06-23",
      "fassungsToken": "93734d9db4a7cdfb2a5eed9d14407e9d",
      "sha": "ca0d5e7d56f1e4e4a75f9b33a14f23efb6d628f8692636d375c13c8529bee5be"
    },
    {
      "id": "kanton/AR/925.321/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "VEAV (925.321)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Beiträge in die Tiergesundheitskasse werden vom Veterinäramt jährlich erhoben."
        },
        {
          "absatz": "2",
          "text": "Der Grundbeitrag je Tierhalter beträgt Fr. 20.-."
        },
        {
          "absatz": "3",
          "text": "Die Beiträge je Tier betragen:",
          "items": [
            {
              "marke": "a",
              "text": "Tiere der Rindergattung und Wasserbüffel, über 1-jährig Fr. 3.-"
            },
            {
              "marke": "b",
              "text": "Tiere der Rindergattung und Wasserbüffel, bis 1-jährig Fr. 2.-"
            },
            {
              "marke": "c",
              "text": "Bisons, über 3-jährig Fr. 3.-"
            },
            {
              "marke": "d",
              "text": "Bisons, bis 3-jährig Fr. 2.-"
            },
            {
              "marke": "e",
              "text": "Tiere der Pferdegattung, über 30 Monate Fr. 3.-"
            },
            {
              "marke": "f",
              "text": "Tiere der Pferdegattung, bis 30 Monate Fr. 2.-"
            },
            {
              "marke": "g",
              "text": "Zuchtsauen und Zuchteber Fr. 2.-"
            },
            {
              "marke": "h",
              "text": "abgesetzte Ferkel, Remonten bis 6 Monate und Mastschweine Fr. 0.50"
            },
            {
              "marke": "i",
              "text": "Wollschweine, Mini-Pigs Fr. 2.-"
            },
            {
              "marke": "j",
              "text": "Schafe, über 1-jährig Fr. 1.50"
            },
            {
              "marke": "k",
              "text": "Ziegen, über 1-jährig Fr. 1.50"
            },
            {
              "marke": "l",
              "text": "Neuweltkameliden, über 2-jährig Fr. 3.-"
            },
            {
              "marke": "m",
              "text": "Neuweltkameliden, bis 2-jährig Fr. 2.-"
            },
            {
              "marke": "n",
              "text": "Zuchthähne und -hennen, Legehennen Fr. 0.10"
            },
            {
              "marke": "o",
              "text": "Küken, Junghähne und -hennen, Mastgeflügel Fr. 0.05"
            },
            {
              "marke": "p",
              "text": "Truten Fr. 0.05"
            },
            {
              "marke": "q",
              "text": "Wachteln, Perlhühner Fr. 0.10"
            },
            {
              "marke": "r",
              "text": "Strausse, Emus Fr. 0.20"
            },
            {
              "marke": "s",
              "text": "Damhirsche, Rothirsche Fr. 2.-"
            }
          ]
        },
        {
          "absatz": "4",
          "text": "Die Beiträge für die Sömmerung von ausserkantonalem Vieh betragen:",
          "items": [
            {
              "marke": "a",
