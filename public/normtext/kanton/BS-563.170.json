{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/563.170/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenverordnung zum Gastgewerbegesetz, GebVGGG (563.170)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "titel": "Gegenstand",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung setzt die Gebühren fest, welche das Bau- und Gastgewerbeinspektorat für die Amtshandlungen und Massnahmen im Rahmen dessen Zuständigkeit für das Gastgewerbe erhebt."
        },
        {
          "absatz": "2",
          "text": "Die Gebührenerhebung durch andere für bauliche und betriebliche Erfordernisse zuständige Behörden bleiben vorbehalten."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/563.170",
      "abgerufen": "2026-06-23",
      "fassungsToken": "1f51c30133aa8d43f7f089e5a1b5524d",
      "sha": "fa141b2190e1dd8427940d95f679795ea9e523c4fc2bcbdde40b30785aac6a7c"
    },
    {
      "id": "kanton/BS/563.170/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenverordnung zum Gastgewerbegesetz, GebVGGG (563.170)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Bemessungsgrundsätze",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Soweit nichts anderes bestimmt ist, werden die durch Gebührenrahmen begrenzten Gebühren nach Zeitaufwand berechnet."
        },
        {
          "absatz": "2",
          "text": "Sind Gebühren nach Zeitaufwand zu bemessen, beträgt der Stundenansatz je nach erforderlicher Sachkenntnis Fr. 90 bis Fr. 250."
        },
        {
          "absatz": "3",
          "text": "Für notwendige Arbeiten zwischen abends 19 Uhr und morgens 7 Uhr sowie an Samstagen, Sonn- und Feiertagen wird auf den Stundenansätzen ein Zuschlag von 50 % erhoben."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/563.170",
      "abgerufen": "2026-06-23",
      "fassungsToken": "1f51c30133aa8d43f7f089e5a1b5524d",
      "sha": "afdbf21feb7d63834fcd3a73d7a1dad778293f7bce96274f6d2689d3ffb55c27"
    },
    {
      "id": "kanton/BS/563.170/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenverordnung zum Gastgewerbegesetz, GebVGGG (563.170)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Beherbergungsbetriebe",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Erteilung einer Betriebsbewilligung zur Führung eines Beherbergungsbetriebs erhebt die Bewilligungsbehörde von den Bewilligungsinhaberinnen oder Bewilligungsinhabern eine Gebühr von Fr. 600."
        },
        {
          "absatz": "2",
          "text": "Für die bloss gelegentliche Beherbergung während zeitlich begrenzter Veranstaltungen beträgt die Gebühr pro Anlass Fr. 150."
        },
        {
          "absatz": "3",
          "text": "Für aufwendige oder besondere Abklärungen können zusätzliche Gebühren nach Zeitaufwand berechnet werden."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/563.170",
      "abgerufen": "2026-06-23",
      "fassungsToken": "1f51c30133aa8d43f7f089e5a1b5524d",
      "sha": "75a5e41953138709d5134065f988b0439f1a9ae664e2141ee6b631a237071968"
    },
    {
      "id": "kanton/BS/563.170/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenverordnung zum Gastgewerbegesetz, GebVGGG (563.170)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Restaurationsbetriebe",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Erteilung einer Bewilligung zur Führung eines Restaurationsbetriebs erhebt die Bewilligungsbehörde von den Bewilligungsinhaberinnen oder Bewilligungsinhabern eine Gebühr von Fr. 600."
        },
        {
          "absatz": "2",
          "text": "Für aufwendige oder besondere Abklärungen können zusätzliche Gebühren nach Zeitaufwand berechnet werden."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/563.170",
      "abgerufen": "2026-06-23",
      "fassungsToken": "1f51c30133aa8d43f7f089e5a1b5524d",
      "sha": "8b6e9ffcadd3214197c8613258e0b994efe7832cc122546d8795d03ef7e9ed21"
    },
    {
      "id": "kanton/BS/563.170/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenverordnung zum Gastgewerbegesetz, GebVGGG (563.170)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "titel": "Vereins- und Klubwirtschaften",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Erteilung einer Bewilligung zur Führung einer Vereins- oder Klubwirtschaft erhebt die Bewilligungsbehörde von den Bewilligungsinhaberinnen oder Bewilligungsinhabern eine Gebühr von Fr. 300."
        },
        {
          "absatz": "2",
          "text": "Für aufwendige oder besondere Abklärungen können zusätzliche Gebühren nach Zeitaufwand berechnet werden."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/563.170",
      "abgerufen": "2026-06-23",
      "fassungsToken": "1f51c30133aa8d43f7f089e5a1b5524d",
      "sha": "4feb7cdb75034a5a68cf56fd68096554ac77dfc7c81d62dc8da5e1604b87ad6e"
    },
    {
      "id": "kanton/BS/563.170/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenverordnung zum Gastgewerbegesetz, GebVGGG (563.170)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "titel": "Gelegenheits- und Festwirtschaften",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Bewilligungsbehörde erhebt pro Anlass eine Gebühr von Fr. 150."
        },
        {
          "absatz": "2",
          "text": "Bei Anlässen und Veranstaltungen für einen gemeinnützigen oder wohltätigen Zweck kann die Bewilligungsbehörde die Gebühr angemessen reduzieren oder auf deren Erhebung verzichten."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/563.170",
      "abgerufen": "2026-06-23",
      "fassungsToken": "1f51c30133aa8d43f7f089e5a1b5524d",
      "sha": "35e3e0cfc00b1503ddf9b388fa9e554e935b49335d4966ad57ce74272928598e"
    },
    {
      "id": "kanton/BS/563.170/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenverordnung zum Gastgewerbegesetz, GebVGGG (563.170)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "titel": "Weitere Gebühren",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Vom Bau- und Gastgewerbeinspektorat werden weitere Gebühren erhoben für:",
          "items": [
            {
              "marke": "a",
              "text": "Änderung der Betriebsinhaberin oder des Betriebsinhabers Fr. 600"
            },
            {
              "marke": "b",
              "text": "Änderung der Grösse des Betriebs Fr. 600"
            },
            {
              "marke": "c",
              "text": "Änderung des Charakters des Betriebs Fr. 600"
            },
            {
              "marke": "d",
              "text": "Änderung der Öffnungszeiten Fr. 600"
            },
            {
              "marke": "e",
              "text": "Änderung des Namens Fr. 300"
            },
            {
              "marke": "f",
              "text": "Abweisung eines Gesuchs Fr. 150 bis Fr. 1’000"
            },
            {
              "marke": "g",
              "text": "Rückzug oder Rückweisung eines Gesuchs Fr. 100 bis Fr. 500"
            },
            {
              "marke": "h",
              "text": "Bearbeitung eines Wiedererwägungsgesuchs Fr. 500 bis Fr. 2’000"
            },
            {
              "marke": "i",
              "text": "Verfügung über die Anerkennung anderer Fähigkeitsausweise und über die Zulassung zu ergänzenden Prüfungen gemäss § 19 Abs. 2 des Gesetzes Fr. 150 bis Fr. 500"
            },
            {
              "marke": "j",
              "text": "Verwarnungen Fr. 300 bis Fr. 1’000"
            },
            {
              "marke": "k",
              "text": "Entzug der Bewilligung Fr. 400 bis Fr. 2’500, in besonderen Fällen bis Fr. 6’000"
            },
            {
              "marke": "l",
              "text": "Schliessung des Betriebs Fr. 400 bis Fr. 2’500"
            },
            {
              "marke": "m",
              "text": "Kontrollen gemäss § 38 des Gesetzes Fr. 300 bis Fr. 1’000"
            },
            {
              "marke": "n",
              "text": "sonstige Verfügungen Fr. 150 bis Fr. 2’500"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Soweit eine Gebühr gemäss Abs. 1 in Zusammenhang mit einer Vereins- oder Klubwirtschaft erhoben wird, wird sie um 50 % reduziert."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/563.170",
      "abgerufen": "2026-06-23",
      "fassungsToken": "1f51c30133aa8d43f7f089e5a1b5524d",
      "sha": "770c49a8fc994bb4c30eac6c1cb26f5e7f37384f1d2522ddece0126a39c870b9"
    },
    {
      "id": "kanton/BS/563.170/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenverordnung zum Gastgewerbegesetz, GebVGGG (563.170)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "titel": "Allgemeine Verwaltungsgebühren",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Porti und Spesen werden gemäss den tatsächlichen Kosten erhoben."
        },
        {
          "absatz": "2",
          "text": "Die Zahlungsfrist von Gebühren beträgt 30 Tage. Nach Ablauf dieser Frist kann ein Verzugszins von 5 % erhoben werden."
        },
        {
          "absatz": "3",
          "text": "Für nicht rechtzeitig bezahlte Gebühren können Mahngebühren und Umtriebsgebühren für Inkassomassnahmen erhoben werden. Diese betragen:",
          "items": [
            {
              "marke": "a",
              "text": "erste Mahnung gratis"
            },
            {
              "marke": "b",
              "text": "Mahngebühr ab zweiter Mahnung je Fr. 40"
            },
            {
              "marke": "c",
              "text": "Umtriebsgebühr für Inkassomassnahmen Fr. 50"
            }
          ]
        },
        {
          "absatz": "4",
          "text": "Vorbehalten bleibt die Einforderung weiterer Gebühren im Zusammenhang mit Betreibungsverfahren."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/563.170",
      "abgerufen": "2026-06-23",
      "fassungsToken": "1f51c30133aa8d43f7f089e5a1b5524d",
      "sha": "7f2a1336ff5d5f45e275bbfd10fe4866113b4b50742597ca7abc2a248f98fe70"
    },
    {
      "id": "kanton/BS/563.170/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenverordnung zum Gastgewerbegesetz, GebVGGG (563.170)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "titel": "Mitwirkungspflicht",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Neben dem allgemeinen Gebot zur Mitwirkung sind die Gesuchstellerinnen und Gesuchsteller insbesondere verpflichtet, der Bewilligungsbehörde die erforderlichen Angaben zur Berechnung der Gebühren einzureichen."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/563.170",
      "abgerufen": "2026-06-23",
      "fassungsToken": "1f51c30133aa8d43f7f089e5a1b5524d",
      "sha": "ae5ff26203bbc5e93f8eab08ea2f68541e6801e18c8792eb24c848a7f50bc1d7"
    },
    {
      "id": "kanton/BS/563.170/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Gebührenverordnung zum Gastgewerbegesetz, GebVGGG (563.170)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "titel": "Fälligkeit und Kostenvorschuss",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gebühren werden bei Erteilung der Bewilligung, mit Eröffnung der Verfügung oder mit Beendigung der erfolgten Bemühungen fällig."
        },
        {
          "absatz": "2",
          "text": "Die Gesuchstellerinnen oder Gesuchsteller können im Bewilligungsverfahren zu einem angemessenen Kostenvorschuss angehalten werden."
        }
      ],
      "stand": "2025-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/563.170",
      "abgerufen": "2026-06-23",
      "fassungsToken": "1f51c30133aa8d43f7f089e5a1b5524d",
      "sha": "b63127f7cd8d2ccf80d3927d5c843a65044648b7605c7a59b3d7773871566a18"
    }
  ]
}