{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/814.01.2/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die im Kanton St.Gallen eingerichteten Chemiewehrstützpunkte St.Gallen und Rorschach übernehmen auf dem Gebiet des Kantons Appenzell A.Rh.die Chemiewehreinsätze."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "9ac4483f6224bac6c4de0853cdeea6151ba528874fbdbebe4f32bc6a9eb71f29"
    },
    {
      "id": "kanton/AR/814.01.2/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die drei Stützpunktfeuerwehren Herisau, Teufen und Heiden leisten im jeweiligen Bezirk bei kleineren Chemieereignissen den Einsatz selbständig und bei grösseren den Ersteinsatz."
        },
        {
          "absatz": "2",
          "text": "Bei der Ölwehr leisten sie den Sekundäreinsatz für die Ortsfeuerwehr."
        },
        {
          "absatz": "3",
          "text": "Der Einbezug des Bezirkes Oberegg von Appenzell Innerrhoden in den Bezirk Vorderland bleibt vorbehalten."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "7d5d8f69c72bde3beeab93b12f2ec7abfbb244554a78a5af1bb4d65e52bced1e"
    },
    {
      "id": "kanton/AR/814.01.2/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Ortsfeuerwehr ist zuständig für Ölwehreinsätze und für erste Sicherungsmassnahmen im Chemiebereich."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "8001813494a1f3c89c7d6b20d2f0ccc408978fdc97b3d23ce3d19492a93b7a41"
    },
    {
      "id": "kanton/AR/814.01.2/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die regionalen Stützpunkte verfügen über ein Schadendienstfahrzeug und sind mit der notwendigen Grundausrüstung für den ersten Chemie- sowie für grössere Ölwehreinsätze ausgerüstet."
        },
        {
          "absatz": "2",
          "text": "Die Einsatzausrüstung ist auf das Material der Chemiewehr des Kantons St.Gallen abzustimmen."
        },
        {
          "absatz": "3",
          "text": "Ersatz und Ergänzung der Ausrüstung erfolgen durch die Assekuranzverwaltung, nach Absprache mit dem Amt für Umwelt und den regionalen Stützpunktkommandos."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "eff4df53fb54d6770c50356a26abffbebc2486d72488b584d42a64c132ed2354"
    },
    {
      "id": "kanton/AR/814.01.2/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Ortsfeuerwehren sind mit einem Notbesteck und Bindemittel für die Ölwehr ausgerüstet."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "fe86fa3a6899b0a461671e941c092e628d5b14f2c4b7ac872ce065252064a60b"
    },
    {
      "id": "kanton/AR/814.01.2/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Assekuranzverwaltung besorgt den Einkauf von Verbrauchsmaterial wie Ölbindemittel, Gasfilter usw. Das Amt für Umwelt steht beratend zur Seite."
        },
        {
          "absatz": "2",
          "text": "Den Gemeinden wird das Material zum Selbstkostenpreis abgegeben."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "aa23c4d8aab6173b0be83773ddc5487922f72cedf176f08fc4f68887a695e095"
    },
    {
      "id": "kanton/AR/814.01.2/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei jedem Chemieereignis ist die Ortsfeuerwehr und der zuständige regionale Stützpunkt zu alarmieren."
        },
        {
          "absatz": "2",
          "text": "Die Alarmierung der Chemiewehr des Kantons St.Gallen erfolgt in der Regel durch den regionalen Stützpunkt."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "d6a689143fdf9282e8546177411d5c13a120ebe0f215474f80189de73a0f16a1"
    },
    {
      "id": "kanton/AR/814.01.2/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei einem Ölwehreinsatz ist die Ortsfeuerwehr zu alarmieren."
        },
        {
          "absatz": "2",
          "text": "Sie fordert bei Bedarf den regionalen Stützpunkt an."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "4e1dda2079adcc9aec6a54276989b272fc690695d304bc76690d2da804afe76f"
    },
    {
      "id": "kanton/AR/814.01.2/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Aufgebot der übrigen Einsatz- und Fachkräfte erfolgt gemäss Alarmdispositiv der Kantonspolizei."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "08190d6b89ef88dd9784537b94221102dd32980542ad785635e8b6a5fc3ef5d3"
    },
    {
      "id": "kanton/AR/814.01.2/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die rechtzeitige Alarmierung und Warnung der Bevölkerung erfolgt gemäss kantonalem Alarmdispositiv."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "6f33ae5e23a91ae17160446b46bff04ec13ba78eeda33bdf449ac778956d58ea"
    },
    {
      "id": "kanton/AR/814.01.2/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Assekuranzverwaltung kann im Einvernehmen mit den regionalen Stützpunktkommandos Weisungen über den Pikettdienst erlassen."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "e2d8fb91d39eacfe54e0bde09ffdcc895f2d5cf868a61097ac12e749e20e187f"
    },
    {
      "id": "kanton/AR/814.01.2/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Einsatzleitung liegt beim regionalen Stützpunkt."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "06fc1c74cbcf1845da94d0cfbb7b4e52ed4667a35cbf6ad0271cfeaf448045f5"
    },
    {
      "id": "kanton/AR/814.01.2/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Einsatzleitung liegt bei der Ortsfeuerwehr."
        },
        {
          "absatz": "2",
          "text": "Wird der regionale Stützpunkt beigezogen, übernimmt dieser die Einsatzleitung."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "44617cd0ce830d986cf752c6a3c78b02467f123bf6a8c19d74a5431fec09d1e0"
    },
    {
      "id": "kanton/AR/814.01.2/art_14",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Assekuranzverwaltung ist für die Ausbildung der Kader für Öl- und Chemiewehreinsätze zuständig."
        },
        {
          "absatz": "2",
          "text": "Der Besuch der angeordneten Kurse ist für alle aufgebotenen Personen obligatorisch."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "48a636a1ee8368e1907b6dd4cbc6e0ef8dfbf15b95943c0aae72181c3b3c755c"
    },
    {
      "id": "kanton/AR/814.01.2/art_15",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "15",
      "artikelLabel": "Art. 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der regionale Stützpunkt ist verantwortlich für die Öl- und Chemiewehrausbildung der Mannschaft."
        },
        {
          "absatz": "2",
          "text": "Er hat periodisch Übungen mit den Ortsfeuerwehren des Bezirkes zu organisieren und daran teilzunehmen."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "2f09901aa788502688371bf2aa37107974954d14d0b32eb6643529f38ef9276d"
    },
    {
      "id": "kanton/AR/814.01.2/art_16",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "16",
      "artikelLabel": "Art. 16",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Ortsfeuerwehr ist verantwortlich für die Ausbildung der Mannschaft im Bereich Ölwehr."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "b2f7799830698a63e262be823a7601579c2e01dadbe2c2b972dcce0b568cd5ff"
    },
    {
      "id": "kanton/AR/814.01.2/art_17",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "17",
      "artikelLabel": "Art. 17",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Einsatzkosten werden dem Verursacher gemäss Tarif für die Schadenbekämpfung verrechnet."
        },
        {
          "absatz": "2",
          "text": "Nicht gedeckte Einsatzkosten gehen zu Lasten der gemeinsamen Betriebsrechnung. Es werden die Selbstkosten vergütet."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "6e07488c83ed863659e101d25751cfaab95e6c0c48627a0de20f774778730cf3"
    },
    {
      "id": "kanton/AR/814.01.2/art_18",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "18",
      "artikelLabel": "Art. 18",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Gemeinden tragen gemeinsam die Kosten für Betrieb und Übungen."
        },
        {
          "absatz": "2",
          "text": "Übungen in der Standortgemeinde des regionalen Stützpunktes und Übungen der Ortsfeuerwehren sind nicht Bestandteil der gemeinsamen Betriebskostenrechnung."
        },
        {
          "absatz": "3",
          "text": "Die Assekuranz übernimmt die Kurskosten der Kader der regionalen Stützpunkte und der Ortsfeuerwehren."
        },
        {
          "absatz": "4",
          "text": "Die Entschädigungen richten sich nach dem Tarif: Entschädigungen für Einsätze."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "2467fbeb4620b191342bd29424f976a1c18dc470b8ac3c03d08924f3d83afdb4"
    },
    {
      "id": "kanton/AR/814.01.2/art_19",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "19",
      "artikelLabel": "Art. 19",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zur Abgeltung der Leistungen für die Ortsfeuerwehren erhalten die regionalen Stützpunkte folgende Jahrespauschalen:",
          "items": [
            {
              "marke": "a",
              "text": "Administration Fr. 1 000.–"
            },
            {
              "marke": "b",
              "text": "Übungs- und Einsatzplanung Fr. 2 000.–"
            },
            {
              "marke": "c",
              "text": "Materialwart Fr. 3 000.–"
            },
            {
              "marke": "d",
              "text": "Platzmiete Schadendienstfahrzeug Fr. 2 500.–"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die Teilnahme an Übungen der Ortsfeuerwehren wird den regionalen Stützpunkten mit folgenden Jahrespauschalen abgegolten:",
          "items": [
            {
              "marke": "a",
              "text": "Herisau Fr. 2 500.–"
            },
            {
              "marke": "b",
              "text": "Teufen Fr. 1 500.–"
            },
            {
              "marke": "c",
              "text": "Heiden Fr. 2 500.–"
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Die Assekuranzverwaltung kann diese Entschädigungen den geänderten Verhältnissen anpassen."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "681b4dfe1644a282f53edd0067f1bc084dacd06066d6fcc3763d67acae05ea13"
    },
    {
      "id": "kanton/AR/814.01.2/art_20",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "20",
      "artikelLabel": "Art. 20",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Einsatzkosten, einschliesslich Kosten von Dritten, werden in der Regel durch diejenige Gemeinde in Rechnung gestellt, in der das Ereignis entstanden ist."
        },
        {
          "absatz": "2",
          "text": "Die Forderungen sind dem Verursacher in Verfügungsform zu eröffnen."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "1b28d3e2f2f707c774cb936fe28c017572f98075d18af0e73b64e561ae13fccd"
    },
    {
      "id": "kanton/AR/814.01.2/art_21",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "21",
      "artikelLabel": "Art. 21",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die regionalen Stützpunkte und die Ortsfeuerwehren erstellen jährlich zuhanden der Assekuranzverwaltung eine Abrechnung über Betriebskosten und vereinnahmte Einsatzentschädigungen."
        },
        {
          "absatz": "2",
          "text": "Die Assekuranzverwaltung erstellt jährlich eine Gesamt-Betriebsrechnung."
        },
        {
          "absatz": "3",
          "text": "Der verbleibende Nettoaufwand wird aufgrund der Einwohnerzahlen auf alle Gemeinden aufgeteilt."
        }
      ],
      "stand": "2005-10-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/814.01.2",
      "abgerufen": "2026-06-23",
      "fassungsToken": "4f482e82c75a39c487458ca17bcea646",
      "sha": "24d74991b9f6bce03235098384a6d7566bd2b001feaed08b88e1876843b4f6f2"
    },
    {
      "id": "kanton/AR/814.01.2/art_22",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Schadenwehrverordnung (814.01.2)",
      "artikel": "22",
      "artikelLabel": "Art. 22",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Differenz der Personalkosten zwischen Schadentarif und Soldtarif und die Grundgebühren der Einsatzmittel fliessen in die jährliche Gesamt-Betriebsrechnung."
        },
        {
          "absatz": "2",
          "text": "Die Grundgebühren der Einsatzmittel, die der Kanton Appenzell A.Rh. angeschafft hat, fliessen in den Erneuerungsfonds."
