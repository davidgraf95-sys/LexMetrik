    },
    {
      "id": "kanton/BS/568.200/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Waffenverordnung (568.200)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Kantonspolizei Basel-Stadt ist die für den Vollzug der Waffengesetzgebung zuständige Behörde und die kantonale Meldestelle im Sinn von Art. 13 des eidgenössischen Waffengesetzes."
        }
      ],
      "stand": "1999-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/568.200",
      "abgerufen": "2026-06-23",
