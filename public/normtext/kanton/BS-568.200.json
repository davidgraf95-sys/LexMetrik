        {
          "absatz": "1",
          "text": "Diese Verordnung regelt den Vollzug der eidgenössischen Waffengesetzgebung."
        }
      ],
      "stand": "1999-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/568.200",
