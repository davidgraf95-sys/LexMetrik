    },
    {
      "id": "kanton/BS/568.200/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Waffenverordnung (568.200)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung ist zu publizieren; sie wird am 1. Januar 1999 wirksam. Auf den gleichen Zeitpunkt wird die Verordnung über den Handel mit Waffen und Munition, das Waffentragen und den Waffenbesitz (Waffenverordnung) vom 5. Juni 1979 aufgehoben."
        }
      ],
