{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/819.878/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Covid-19-GRB-Publikumsanlässe (819.878)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dieser Beschluss regelt die Unterstützung gemäss Covid-19-Verordnung Publikumsanlässe."
        },
        {
          "absatz": "2",
          "text": "Soweit der vorliegende Beschluss keine abweichenden Regelungen enthält, gelten die Bestimmungen der Covid-19-Verordnung Publikumsanlässe."
        }
      ],
      "stand": "2022-05-11",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.878",
      "abgerufen": "2026-06-23",
      "fassungsToken": "625778aa20232a7ba9d19c91f88c2f98",
      "sha": "15f6ea37c02c1a918197596532c2b9e944fa15fe330155869d0d7bde25bf5134"
    },
    {
      "id": "kanton/BS/819.878/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Covid-19-GRB-Publikumsanlässe (819.878)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Zu diesem Zweck wird ein Betrag von Fr. 31.75 Mio. bereitgestellt."
        }
      ],
      "stand": "2022-05-11",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.878",
      "abgerufen": "2026-06-23",
      "fassungsToken": "625778aa20232a7ba9d19c91f88c2f98",
      "sha": "93776acc05d6f9b6c4ce1e612eb30017ac5feb7e274c9651ba1cbb89676b420e"
    },
    {
      "id": "kanton/BS/819.878/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Covid-19-GRB-Publikumsanlässe (819.878)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Präsidialdepartement ist für die Abwicklung zuständig und richtet ein Sekretariat ein."
        }
      ],
      "stand": "2022-05-11",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.878",
      "abgerufen": "2026-06-23",
      "fassungsToken": "625778aa20232a7ba9d19c91f88c2f98",
      "sha": "b07a00747bbd14bc30d9a394bc0c2d2ba0ad78cb4acee4d60b3a8b5728bdd059"
    },
    {
      "id": "kanton/BS/819.878/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Covid-19-GRB-Publikumsanlässe (819.878)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gesuchsberechtigt sind Veranstaltungsunternehmen gemäss Art. 3 Covid-19-Verordnung Publikumsanlässe."
        }
      ],
      "stand": "2022-05-11",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.878",
      "abgerufen": "2026-06-23",
      "fassungsToken": "625778aa20232a7ba9d19c91f88c2f98",
      "sha": "6a1a4b099e7063fe5e95215605e63eae704a7ae0b99b20653d551232c14b411f"
    },
    {
      "id": "kanton/BS/819.878/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Covid-19-GRB-Publikumsanlässe (819.878)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "In Abweichung zur Covid-19-Verordnung Publikumsanlässe werden Veranstaltungen von überkantonaler Bedeutung unterstützt, deren Durchführungen zwischen dem 1. Juli 2021 und dem 31. Dezember 2022 im Kanton Basel-Stadt geplant sind."
        },
        {
          "absatz": "2",
          "text": "Die Veranstaltungen müssen ausserdem",
          "items": [
            {
              "marke": "a",
              "text": "als öffentlich zugängliche Publikumsanlässe für mehr als 5'000 Personen pro Tag oder"
            },
            {
              "marke": "b",
              "text": "als mehrtägige und öffentlich zugängliche Publikumsanlässe konzipiert sein, die an direkt aufeinander folgenden Tagen stattfinden und pro Tag für mehr als 1'000 Personen und insgesamt für mehr als 5'000 Personen konzipiert sind."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Im Übrigen richten sich die Anforderungen nach der Covid-19-Verordnung Publikumsanlässe."
        }
      ],
      "stand": "2022-05-11",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.878",
      "abgerufen": "2026-06-23",
      "fassungsToken": "625778aa20232a7ba9d19c91f88c2f98",
      "sha": "47e4a78dff133496fcf2a27e5131429f8e04cf7f72e1752ccdb88fecbc7576e0"
    },
    {
      "id": "kanton/BS/819.878/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Covid-19-GRB-Publikumsanlässe (819.878)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Über Gesuche gemäss Ziff. 7 und 8 entscheidet der Regierungsrat abschliessend."
        },
        {
          "absatz": "2",
          "text": "Es besteht kein Rechtsanspruch auf Zusicherungen gemäss Ziff. 7."
        }
      ],
      "stand": "2022-05-11",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.878",
      "abgerufen": "2026-06-23",
      "fassungsToken": "625778aa20232a7ba9d19c91f88c2f98",
      "sha": "28b7409c8ff799d7a495d56d918f28664bea2217be8f2b44df31f2f9999a0662"
    },
    {
      "id": "kanton/BS/819.878/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Covid-19-GRB-Publikumsanlässe (819.878)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Sind die Voraussetzungen gemäss diesem Beschluss sowie der Covid-19-Verordnung Publikumsanlässe erfüllt, entscheidet der Regierungsrat vorab der Veranstaltung und in der Planungsphase über die Zusicherung der Beteiligung an ungedeckten Kosten."
        }
      ],
      "stand": "2022-05-11",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.878",
      "abgerufen": "2026-06-23",
      "fassungsToken": "625778aa20232a7ba9d19c91f88c2f98",
      "sha": "448070b1c74f3c94c0bd9dfddebc18b6d8a925b9e4f572c84e3a345ad9b60e13"
    },
    {
      "id": "kanton/BS/819.878/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Covid-19-GRB-Publikumsanlässe (819.878)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Veranstaltungsunternehmen, welche eine Zusicherung gemäss Ziff. 7 haben, müssen bis spätestens am 30. Juni 2023 ein Gesuch um Beteiligung an ungedeckten Kosten stellen, sofern die Voraussetzungen gemäss Art. 2 Covid-19-Verordnung Publikumsanlässe eingetreten sind."
        }
      ],
      "stand": "2022-05-11",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.878",
      "abgerufen": "2026-06-23",
      "fassungsToken": "625778aa20232a7ba9d19c91f88c2f98",
      "sha": "9cb16460cfc51d228543ea9024381dd54ed58227c72977c03d7215e6c45cd6ae"
    },
    {
      "id": "kanton/BS/819.878/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Covid-19-GRB-Publikumsanlässe (819.878)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat kann das Nähere in einer Verordnung regeln."
        }
      ],
      "stand": "2022-05-11",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/819.878",
      "abgerufen": "2026-06-23",
      "fassungsToken": "625778aa20232a7ba9d19c91f88c2f98",
      "sha": "55231c075f9166699466ac52cba4f3a1d3fa8c5376536494432c472fce86c06f"
    }
  ]
}