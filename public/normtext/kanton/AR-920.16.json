{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/920.16/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "kWeinV (920.16)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung bezweckt den Vollzug der Bundesgesetzgebung über die Weinwirtschaft."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.16",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e1502ef68d37d4b2aba5d2c0e4608732",
      "sha": "2dce868d11546558d39ca4720678323027fc86998d83322bde137120020e3e84"
    },
    {
      "id": "kanton/AR/920.16/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "kWeinV (920.16)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Gesuch um Bewilligung einer Neuanpflanzung für die Weinerzeugung enthält:",
          "items": [
            {
              "marke": "a",
              "text": "die Angaben nach Art. 2 Abs. 2 der Verordnung über Rebbau und die Einfuhr von Wein;"
            },
            {
              "marke": "b",
              "text": "eine Planskizze samt Parzellen-Nummer, Rebfläche und Rebsorten."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Vor Erteilung der Bewilligung wird die Fachstelle für Natur und Landschaft angehört."
        },
        {
          "absatz": "3",
          "text": "Neuanpflanzungen, die nicht der Weinerzeugung dienen, sind meldepflichtig."
        },
        {
          "absatz": "4",
          "text": "Neuanpflanzungen bis 400 m2"
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.16",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e1502ef68d37d4b2aba5d2c0e4608732",
      "sha": "3906b6b7ca82fe393e0518c194cd2493cb4b2a9679abe9ef8e746f7cb40efcf4"
    },
    {
      "id": "kanton/AR/920.16/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "kWeinV (920.16)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Meldung einer Erneuerung erfolgt bis 30. Juni des Pflanzjahres an das Landwirtschaftsamt."
        },
        {
          "absatz": "2",
          "text": "Die Meldung enthält folgende Angaben:",
          "items": [
            {
              "marke": "a",
              "text": "Weinbaugemeinde;"
            },
            {
              "marke": "b",
              "text": "Parzellen-Nummer;"
            },
            {
              "marke": "c",
              "text": "Rebfläche;"
            },
            {
              "marke": "d",
              "text": "Rebsorten;"
            },
            {
              "marke": "e",
              "text": "Pflanzjahr."
            }
          ]
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.16",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e1502ef68d37d4b2aba5d2c0e4608732",
      "sha": "da654737f409b3eb05f7e12240f0e01844641a59a4bf2529905ff3dd266b99de"
    },
    {
      "id": "kanton/AR/920.16/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "kWeinV (920.16)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Neuanpflanzung von Rebflächen nach Art. 2 Abs. 4 der Verordnung über Rebbau und die Einfuhr von Wein wird im Rebbaukataster nicht erfasst."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.16",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e1502ef68d37d4b2aba5d2c0e4608732",
      "sha": "edace2a86daaf854be2e3e78704433921974697a8ac2cc16a6226d4d5a173a9c"
    },
    {
      "id": "kanton/AR/920.16/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "kWeinV (920.16)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wein trägt die Bezeichnung \"Kontrollierte Ursprungsbezeichnung Appenzell Ausserrhoden\" oder \"AOC Appenzell Ausserrhoden\", wenn die Voraussetzungen für AOC-Wein nach Art. 6 bis 11 erfüllt sind."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.16",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e1502ef68d37d4b2aba5d2c0e4608732",
      "sha": "3d44968ce0e6ab3e9152c66200d88ded7f0b72abe1364b0712b09f06458fd4bb"
    },
    {
      "id": "kanton/AR/920.16/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "kWeinV (920.16)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "AOC-Wein besteht unter Berücksichtigung von Art. 13 Abs. 3 Bst. a der Verordnung des EDI über alkoholische Getränke zu mindestens 90 Prozent aus Trauben, die aus dem Kanton Appenzell Ausserrhoden stammen."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.16",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e1502ef68d37d4b2aba5d2c0e4608732",
      "sha": "5d73fb33be560043de6bd63395e54c8eeabb550180be4b4e35478707cceecc1d"
    },
    {
      "id": "kanton/AR/920.16/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "kWeinV (920.16)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat bezeichnet die für AOC-Wein zugelassenen Rebsorten."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.16",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e1502ef68d37d4b2aba5d2c0e4608732",
      "sha": "6b9a10c208819297bac2df4138da4f837faaf3c0247fb0e0d83b1034c95bf419"
    },
    {
      "id": "kanton/AR/920.16/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "kWeinV (920.16)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "AOC-Wein wird nach folgenden Anbaumethoden hergestellt:",
          "items": [
            {
              "marke": "a",
              "text": "Stickelbau;"
            },
            {
              "marke": "b",
              "text": "Drahtbau im Direktzug (inkl. Umkehrerziehung);"
            },
            {
              "marke": "c",
              "text": "Drahtbau in Querterrassenanlagen."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Der Regierungsrat kann weitere Anbaumethoden bezeichnen."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.16",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e1502ef68d37d4b2aba5d2c0e4608732",
      "sha": "f1c5b801ad8b69f52f4917bf6bda1f77d26645e1f44363ecb63aa02d868a9045"
    },
    {
      "id": "kanton/AR/920.16/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "kWeinV (920.16)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat bezeichnet den natürlichen Mindestzuckergehalt je Rebsorte sowie den Höchstertrag je Flächeneinheit und Rebsorte für AOC-Wein."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.16",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e1502ef68d37d4b2aba5d2c0e4608732",
      "sha": "2a4c7ec2eb11abf50e06b1ec7b6d6196e182be419d0a43ad66f44600337647e8"
    },
    {
      "id": "kanton/AR/920.16/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "kWeinV (920.16)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "AOC-Wein wird in einem nach der Lebensmittelgesetzgebung zulässigen Verfahren hergestellt."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.16",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e1502ef68d37d4b2aba5d2c0e4608732",
      "sha": "bedfad9ec868675be9167d5e24f629e3753eff9c6978dcaca7b06ece4bcd0b2a"
    },
    {
      "id": "kanton/AR/920.16/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "kWeinV (920.16)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "AOC-Wein unterliegt der stichprobeweisen analytischen und organoleptischen Prüfung."
        },
        {
          "absatz": "2",
          "text": "Die analytische Prüfung umfasst insbesondere:",
          "items": [
            {
              "marke": "a",
              "text": "Alkoholgehalt;"
            },
            {
              "marke": "b",
              "text": "gesamte schweflige Säure."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Die organoleptische Prüfung findet nach den anerkannten Bewertungsschemen statt. Sie umfasst:",
          "items": [
            {
              "marke": "a",
              "text": "Aussehen;"
            },
            {
              "marke": "b",
              "text": "Geruch;"
            },
            {
              "marke": "c",
              "text": "Geschmack;"
            },
            {
              "marke": "d",
              "text": "Gesamteindruck."
            }
          ]
        },
        {
          "absatz": "4",
          "text": "Der Kantonschemiker erhebt stichprobenweise die notwendigen Proben und führt die Prüfung nach Abs. 2 und 3 durch. Er kann Dritte mit der Prüfung beauftragen."
        },
        {
          "absatz": "5",
          "text": "Die Produzentinnen und Produzenten sind verpflichtet, die Proben unentgeltlich zur Verfügung zu stellen und tragen die Kosten der Analyse und der sensorischen Prüfung."
        },
        {
          "absatz": "6",
          "text": "Der Kantonschemiker orientiert Produzentinnen und Produzenten sowie das Landwirtschaftsamt über das Resultat der Prüfung."
        },
        {
          "absatz": "7",
          "text": "Der Kantonschemiker entzieht offensichtlich fehlerhaften Weinen die kontrollierte Ursprungsbezeichnung."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.16",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e1502ef68d37d4b2aba5d2c0e4608732",
      "sha": "b546039226894f14d1b155606199739fe6212c745c3a3fb8fbee7d126d82b7ae"
    },
    {
      "id": "kanton/AR/920.16/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "kWeinV (920.16)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "AOC-Wein kann neben der Bezeichnung gemäss Art. 5 eine der folgenden geografischen Zusatzbezeichnungen tragen:",
          "items": [
            {
              "marke": "a",
              "text": "Der Name der Gemeinde, wenn der nach Art. 6 vorgeschriebene Traubenanteil zu 90 Prozent aus der entsprechenden Gemeinde stammt;"
            },
            {
              "marke": "b",
              "text": "der Name des Ortsteils, wenn der nach Art. 6 vorgeschriebene Traubenanteil zu 90 Prozent aus dem entsprechenden Ortsteil stammt;"
            },
            {
              "marke": "c",
              "text": "der Name der Lage, wenn der nach Art. 6 vorgeschriebene Traubenanteil zu 90 Prozent aus der entsprechenden Lage stammt."
            }
          ]
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.16",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e1502ef68d37d4b2aba5d2c0e4608732",
      "sha": "c6438d0a319ab3350132eaf54e616bf643cc90943999b04e85df865ac9e1d651"
    },
    {
      "id": "kanton/AR/920.16/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "kWeinV (920.16)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Verwendung weinspezifischer Begriffe richtet sich nach Art. 19 Abs. 1 und Anhang 1 der Verordnung über Rebbau und die Einfuhr von Wein. In Ergänzung dazu legt der Regierungsrat die im Kanton ergänzend geltenden weinspezifischen Begriffe fest."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.16",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e1502ef68d37d4b2aba5d2c0e4608732",
      "sha": "b75303ea53590dff211dc2a9ebd13d6ba3c8547e1d54f135ce9e50b14f61a116"
    },
    {
      "id": "kanton/AR/920.16/art_14",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "kWeinV (920.16)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Es findet eine systematische Weinlesekontrolle statt."
        },
        {
          "absatz": "2",
          "text": "Das Landwirtschaftsamt kann die systematische Weinlesekontrolle und die damit verbundenen Aufgaben an Dritte übertragen."
        }
      ],
      "stand": "2016-09-30",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.16",
      "abgerufen": "2026-06-23",
      "fassungsToken": "e1502ef68d37d4b2aba5d2c0e4608732",
      "sha": "e125240affde9e5c4d090583d79e3f3394fb94b6497868b7c4a981c12e8b93d7"
    }
  ]
}