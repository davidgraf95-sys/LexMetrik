{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/920.13/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "AWV (920.13)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung regelt die Bewirtschaftung der Alpen und die Ausübung der an ihnen bestehenden kantonalen Vorpacht- und Vorkaufsrechte."
        },
        {
          "absatz": "2",
          "text": "Die Alpen umfassen das vom Bund festgelegte Sömmerungsgebiet."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d31fc95f72a5d4ea3d362b293a28fb1e",
      "sha": "784b36e49b4763f139acf9878da35dba6768b41a7eb49cf3445140d4f50e3504"
    },
    {
      "id": "kanton/AR/920.13/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "AWV (920.13)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Art und Ausmass der Bewirtschaftung haben sich nach ökologischen Grundsätzen zu richten. Unter diesen Grundvoraussetzungen sollen sie eine nachhaltige Nutzung der Bewirtschaftungsflächen gewährleisten, einen sachgerechten Betrieb ermöglichen und eine ausgewogene und artenreiche Zusammensetzung der Pflanzenbestände fördern. Standorttypische Pflanzengesellschaften sind zu erhalten."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d31fc95f72a5d4ea3d362b293a28fb1e",
      "sha": "a246d8a2aebc2cdbba254283f16aa203eb3eec35d3c3742b94515c9ad717693c"
    },
    {
      "id": "kanton/AR/920.13/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "AWV (920.13)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Anzahl der gesömmerten Tiere und die Dauer der Sömmerung sind dem Standort und der Ertragsfähigkeit der Weideflächen anzupassen. Spätester Termin für den Alpentlad von Rindvieh ist der 30. September."
        },
        {
          "absatz": "2",
          "text": "Das Landwirtschaftsamt kann die zulässige Bestossung durch Verfügung festlegen. Es kann zudem Weisungen für die Überwachung der Tiere erteilen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d31fc95f72a5d4ea3d362b293a28fb1e",
      "sha": "f87cc01f464a0c9cb29aa0a368df3ace0b503bae7f0e273703c8cda41a9c1a6b"
    },
    {
      "id": "kanton/AR/920.13/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "AWV (920.13)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Bestossung mit Schafen und Ziegen ist vorgängig die Bewilligung des Landwirtschaftsamtes einzuholen."
        },
        {
          "absatz": "2",
          "text": "Der Auftrieb von maximal sechs Schafen oder Ziegen und ihrer Jungtiere ist bewilligungsfrei, sofern sie dauernd überwacht werden."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d31fc95f72a5d4ea3d362b293a28fb1e",
      "sha": "4be606eae94b7a1c3c5ca1f3ea137917ee1d5441810e189bd76b4002c145fe26"
    },
    {
      "id": "kanton/AR/920.13/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "AWV (920.13)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die ortsübliche Sömmerungsdauer darf nicht durch Futterzufuhren verlängert werden. Erlaubt ist die Zufuhr von Rauhfutter zur Überbrückung witterungsbedingter Ausnahmesituationen und die Zufuhr von Kraftfutter als übliche Ergänzung für Schweine und Kühe."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d31fc95f72a5d4ea3d362b293a28fb1e",
      "sha": "4300219ca361272f5c4e2de6d53819052c3cf08b3f6eefa62d9e1a8ca77cb410"
    },
    {
      "id": "kanton/AR/920.13/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "AWV (920.13)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Herstellung, Zufuhr und Verfütterung von Silagen und anderer vergorener Futtermittel ist verboten."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d31fc95f72a5d4ea3d362b293a28fb1e",
      "sha": "4edb7687097d72e3548e7eb260fa8ca172bce48814fa23a57022f9853d3d7edb"
    },
    {
      "id": "kanton/AR/920.13/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "AWV (920.13)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Düngung der Bewirtschaftungsflächen ist alpeigener Dünger zu verwenden. Die Zufuhr natürlicher oder synthetischer Dünger ist nicht gestattet."
        },
        {
          "absatz": "2",
          "text": "Ist der Nährstoffbedarf ausgewiesen und sprechen keine ökologischen Gründe dagegen, so kann das Landwirtschaftsamt eine Ausnahmebewilligung für die Düngerzufuhr erteilen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d31fc95f72a5d4ea3d362b293a28fb1e",
      "sha": "c25a4f3d7f88d4c24468a697f1527d5eb27d6b3a13ccf0d39c0366d5b728e7c3"
    },
    {
      "id": "kanton/AR/920.13/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "AWV (920.13)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Herbizide dürfen nur für die Einzelstockbehandlung verwendet werden. Flächenbehandlungen sind unzulässig."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d31fc95f72a5d4ea3d362b293a28fb1e",
      "sha": "ed24411c86ae6b9ad2298a4ab8ba0caf3d30661ee0da0e81b16e11b9a36eae40"
    },
    {
      "id": "kanton/AR/920.13/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "AWV (920.13)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Zweckänderung alpwirtschaftlicher Gebäude bedarf einer raumplanerischen Bewilligung."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d31fc95f72a5d4ea3d362b293a28fb1e",
      "sha": "d661ac4f431e08ec8a165102d1d95b1ce643bb36df7cc42b2bc64416c76a6438"
    },
    {
      "id": "kanton/AR/920.13/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "AWV (920.13)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Pachtverträge an Alpen sind vom Verpächter unmittelbar nach Vertragsschluss im kantonalen Amtsblatt zu veröffentlichen."
        },
        {
          "absatz": "2",
          "text": "Vorpachtrechte sind innert 30 Tagen seit der Veröffentlichung des Pachtvertrages schriftlich beim Verpächter geltend zu machen, spätestens aber drei Monate nach Antritt der Pacht durch den Dritten."
        },
        {
          "absatz": "3",
          "text": "Der Vorpachtberechtigte tritt in den Pachtvertrag ein, wie dieser mit dem Dritten abgeschlossen worden ist."
        },
        {
          "absatz": "4",
          "text": "Das Vorpachtrecht entfällt, wenn die Alp an Nachkommen des Verpächters oder an Nachkommen des bisherigen Pächters verpachtet wird oder wenn sie Teil eines landwirtschaftlichen Gewerbes bildet."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d31fc95f72a5d4ea3d362b293a28fb1e",
      "sha": "6cd39423194926c74b70513badb71ac1d775bf786eb400702afa693568f694ca"
    },
    {
      "id": "kanton/AR/920.13/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "AWV (920.13)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Veräusserer muss die Vorkaufsberechtigten über den Abschluss und den Inhalt des Kaufvertrages in Kenntnis setzen."
        },
        {
          "absatz": "2",
          "text": "Will der Vorkaufsberechtigte sein Recht ausüben, so muss er es innert dreier Monate seit Kenntnis von Abschluss und Inhalt des Vertrages geltend machen. Nach Ablauf von zwei Jahren seit der Eintragung des neuen Eigentümers in das Grundbuch kann das Recht nicht mehr geltend gemacht werden."
        },
        {
          "absatz": "3",
          "text": "Der Vorkaufsberechtigte kann seinen Anspruch innerhalb dieser Fristen gegenüber jedem Eigentümer des Grundstücks geltend machen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d31fc95f72a5d4ea3d362b293a28fb1e",
      "sha": "0b1cefad73fe6f4317bae57497140ea9d6ab401489ed8d85367eb611465572db"
    },
    {
      "id": "kanton/AR/920.13/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "AWV (920.13)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gegen Verfügungen des Landwirtschaftsamtes kann innert 20 Tagen Rekurs an das Departement Bau und Volkswirtschaft erhoben werden."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d31fc95f72a5d4ea3d362b293a28fb1e",
      "sha": "c960c58a20de65adcb84c7b0e3171053641df7a40b1ee52c058b19fc476f4a2b"
    },
    {
      "id": "kanton/AR/920.13/art_14",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "AWV (920.13)",
      "artikel": "14",
      "artikelLabel": "Art. 14",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Departement Bau und Volkswirtschaft erlässt die jährlichen Alpfahrtsvorschriften."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d31fc95f72a5d4ea3d362b293a28fb1e",
      "sha": "4330c786a216d1229f9da088b9735d2688b2c73b1b1a5307d77c98f390cfe262"
    },
    {
      "id": "kanton/AR/920.13/art_15",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "AWV (920.13)",
      "artikel": "15",
      "artikelLabel": "Art. 15",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung tritt auf den 1. Januar 2000 in Kraft."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.13",
      "abgerufen": "2026-06-23",
      "fassungsToken": "d31fc95f72a5d4ea3d362b293a28fb1e",
      "sha": "3f8ed3e91109a17d696727f5ec820a24e6f5f1e72fe4256ebabcac94327cedaf"
    }
  ]
}