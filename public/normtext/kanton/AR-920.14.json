{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/920.14/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "TZV (920.14)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Massnahmen dieser Verordnung bezwecken die Förderung der Zucht landwirtschaftlicher Nutztiere, die Förderung der Bienenzucht und die Erhaltung gefährdeter einheimischer Rassen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.14",
      "abgerufen": "2026-06-23",
      "fassungsToken": "44a537129494477ad2c4dacd00f5b6a8",
      "sha": "3c19f3e9aa11738544468f757b26a6b431a858c70294d6e4ca4e6d09ca686303"
    },
    {
      "id": "kanton/AR/920.14/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "TZV (920.14)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Departement Bau und Volkswirtschaft setzt eine Fachkommission für Tierzucht ein. Diese berät, beschliesst und vollzieht die Förderungsmassnahmen, soweit keine andere Zuständigkeit besteht. Sie ist insbesondere zuständig für die Vergabe von Zuchtbeiträgen gemäss Art. 18 des Gesetzes über die Landwirtschaft."
        },
        {
          "absatz": "2",
          "text": "Das Landwirtschaftsamt führt das Aktuariat der Fachkommission und leistet ihr Unterstützung beim Vollzug der Förderungsmassnahmen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.14",
      "abgerufen": "2026-06-23",
      "fassungsToken": "44a537129494477ad2c4dacd00f5b6a8",
      "sha": "7019818cbde989c23001e5bc7de7943c61c05f21a191c2d34d673a692f191322"
    },
    {
      "id": "kanton/AR/920.14/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "TZV (920.14)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Fachkommission koordiniert die im Kanton stattfindenden Viehschauen. Sie erlässt das jährliche Schauprogramm mit den Schauvorschriften und bestimmt die Experten für die Viehschauen."
        },
        {
          "absatz": "2",
          "text": "Der Kanton richtet im Rahmen der Schauvorschriften Schauprämien aus. Er übernimmt die Kosten für die Viehschauexperten und für eine angemessene Publikation der Viehschauen."
        },
        {
          "absatz": "3",
          "text": "Die Gemeinden stellen die Infrastruktur für die Viehschauen zur Verfügung und tragen bei zu einem möglichst reibungslosen Ablauf der Veranstaltungen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.14",
      "abgerufen": "2026-06-23",
      "fassungsToken": "44a537129494477ad2c4dacd00f5b6a8",
      "sha": "de5de03f2b740b096b8767924ca94b671f5a242b34289a8db32c5b1c94dc11e5"
    },
    {
      "id": "kanton/AR/920.14/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "TZV (920.14)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für Auktionen, Ausstellungen und andere Veranstaltungen, die der Zucht von Nutztieren, der Bienenzucht oder der Erhaltung gefährdeter einheimischer Rassen dienen, können im Rahmen der bewilligten Kredite angemessene Beiträge an die Organisationskosten geleistet werden."
        },
        {
          "absatz": "2",
          "text": "Beitragsgesuche sind mindestens zwei Monate vor der Durchführung der Veranstaltung an die Fachkommission zu stellen."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.14",
      "abgerufen": "2026-06-23",
      "fassungsToken": "44a537129494477ad2c4dacd00f5b6a8",
      "sha": "89492534573df9dc1486cdfb51b8c7db7778f8408b9946c4a131d6a03d9148b5"
    },
    {
      "id": "kanton/AR/920.14/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "TZV (920.14)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Landwirtschaftsamt unterstützt regionale Viehmärkte mit organisatorischer und sachlicher Hilfe."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.14",
      "abgerufen": "2026-06-23",
      "fassungsToken": "44a537129494477ad2c4dacd00f5b6a8",
      "sha": "47009e5e0dcf063152b448808fa7efbb3d074f3a59b312a23facbbf86a8ae7e3"
    },
    {
      "id": "kanton/AR/920.14/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "TZV (920.14)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Gegen Verfügungen der Fachkommission kann innert zwanzig Tagen Rekurs an das Departement Bau und Volkswirtschaft erhoben werden."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.14",
      "abgerufen": "2026-06-23",
      "fassungsToken": "44a537129494477ad2c4dacd00f5b6a8",
      "sha": "6ebf8443f621c78ddfaf4fe14f3204c7f12cb6df51986041f77a2a040186b283"
    },
    {
      "id": "kanton/AR/920.14/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "TZV (920.14)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Verordnung vom 5. Juni 1961 über die Förderung der Tierzucht und die Unterstützung der Viehversicherungsgenossenschaften wird aufgehoben."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.14",
      "abgerufen": "2026-06-23",
      "fassungsToken": "44a537129494477ad2c4dacd00f5b6a8",
      "sha": "3d3846443dde8b3fd91221b9790f1643de96ceb9473b66690d2fae108560483d"
    },
    {
      "id": "kanton/AR/920.14/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "TZV (920.14)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung tritt auf den 1. Januar 2000 in Kraft."
        }
      ],
      "stand": "2016-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/920.14",
