{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/233.21/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "KGV (233.21)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Diese Verordnung regelt die Kanzleigebühren in Verfahren vor kantonalen Behörden, soweit nicht besondere Vorschriften gelten."
        }
      ],
      "stand": "2003-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "7d4d7e4c3f0d024f376b6bb0c8a3e2c3",
      "sha": "b31caf97239496d4feca6bc186df7b33e4aa37b65b7051024ecc1d32c8823d45"
    },
    {
      "id": "kanton/AR/233.21/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "KGV (233.21)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für Nachforschungen in Registern, Akten usw. soll in der Regel keine Gebühr erhoben werden. In zeitintensiven Fällen ist jedoch eine Gebühr von Fr. 10.– bis Fr. 200.–, je nach Umfang und Bedeutung der Beanspruchung, zu verlangen."
        },
        {
          "absatz": "2",
          "text": "Legalisationen: Fr. 10.– bis Fr. 30.–."
        },
        {
          "absatz": "3",
          "text": "Auszüge und Abschriften, Erstellen von Dokumentationen und dergleichen: Fr. 10.– pro Seite."
        },
        {
          "absatz": "4",
          "text": "Einholen von Urkunden und Erteilung von Auskünften: Fr. 60.– pro Stunde."
        },
        {
          "absatz": "5",
          "text": "Fristverlängerungen (im Wiederholungsfall): Fr. 25.–."
        },
        {
          "absatz": "6",
          "text": "",
          "items": [
            {
              "marke": "1",
              "text": "Mahnung: Fr. 10.–; 2. Mahnung und allenfalls weitere Mahnungen: Fr. 25.–"
            }
          ]
        },
        {
          "absatz": "7",
          "text": "Fotokopie: Fr. 1.– pro Kopie."
        }
      ],
      "stand": "2003-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.21",
      "abgerufen": "2026-06-23",
      "fassungsToken": "7d4d7e4c3f0d024f376b6bb0c8a3e2c3",
      "sha": "5b3c65cdbab0842f29e93e9b4261c86e74d78e77a7918396764c4a785f035f99"
    },
    {
      "id": "kanton/AR/233.21/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "KGV (233.21)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "In besonderen Fällen können die Gebühren angemessen reduziert oder ganz erlassen werden."
        }
      ],
      "stand": "2003-01-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/233.21",
