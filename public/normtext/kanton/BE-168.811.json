      "sha": "c228d01e54273936d60d8083981f39a67b9e05e55f53906495703007d768ec2d"
    },
    {
      "id": "kanton/BE/168.811/art_t1-1",
      "ebene": "kanton",
      "quelle": "BE",
      "erlass": "Parteikostenverordnung, PKV (BSG 168.811)",
      "artikel": "t1-1",
      "artikelLabel": "Art. T1-1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das neue Recht ist anwendbar, wenn im betreffenden Verfahren die ZPO oder die StPO zur Anwendung gelangt."
        },
        {
          "absatz": "2",
          "text": "Das bisherige Recht ist anwendbar, wenn im betreffenden Verfahren das Gesetz vom 7. Juli 1918 über die Zivilprozessordnung (ZPO) oder das Gesetz vom 15. März 1995 über das Strafverfahren (StrV) zur Anwendung gelangt."
        }
