      "bloecke": [
        {
          "absatz": "1",
          "text": "Im Verfahren vor dem Kantonsgericht (Art. 35 GOG) beträgt die Gerichtsgebühr (Beträge in Fr.): bei einem Streitwert von",
          "items": [
            {
              "marke": "1",
              "text": "über 30 000.– bis 50 000.– 1 500.– bis 5 000.–"
