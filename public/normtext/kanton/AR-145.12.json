{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/AR/145.12/art_1",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Besoldungsverordnung für die gerichtlichen Organe (145.12)",
      "artikel": "1",
      "artikelLabel": "Art. 1",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Soweit die Anwendung die richterliche Unabhängigkeit nicht beeinträchtigt und diese Verordnung keine Ausnahmen vorsieht, gilt das Personalgesetz mit seinen Ausführungsbestimmungen sinngemäss."
        }
      ],
      "stand": "2023-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "91459ee043b22b5c5b145e355edeb96e",
      "sha": "2c22c15d45717eb9704c9e56ed6f4f705b5d0e4b6700cbf290798f4c4a223447"
    },
    {
      "id": "kanton/AR/145.12/art_2",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Besoldungsverordnung für die gerichtlichen Organe (145.12)",
      "artikel": "2",
      "artikelLabel": "Art. 2",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Für die Entschädigung von Spesen gilt das Reglement über die Entschädigung von Inkonvenienzen, Spesen, Pikettdienst und ausserordentliche Arbeitszeit."
        }
      ],
      "stand": "2023-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "91459ee043b22b5c5b145e355edeb96e",
      "sha": "8d1e565d8247f73d13cd04baf3526c98e303475cc0aabdca02174c6478098c31"
    },
    {
      "id": "kanton/AR/145.12/art_3",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Besoldungsverordnung für die gerichtlichen Organe (145.12)",
      "artikel": "3",
      "artikelLabel": "Art. 3",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Dem Vermittler oder der Vermittlerin wird eine jährliche Grundentschädigung für eine bestimmte Anzahl Vermittlungen ausgerichtet. Für jede weitere Vermittlung wird eine Fallpauschale von Fr. 250.– ausgerichtet."
        },
        {
          "absatz": "1bis",
          "text": "Die jährliche Grundentschädigung beträgt je nach Kreis:",
          "items": [
            {
              "marke": "a",
              "text": "Kreis 1 (inkl. 70 Vermittlungen) Fr. 25'000.–;"
            },
            {
              "marke": "b",
              "text": "Kreis 2 (inkl. 40 Vermittlungen) Fr. 14'500.–;"
            },
            {
              "marke": "c",
              "text": "Kreis 3 (inkl. 40 Vermittlungen) Fr. 14'500.–."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Für Stellvertreterarbeiten ohne Verfahrensabschluss steht dem Vermittler oder der Vermittlerin eine Entschädigung von Fr. 45.– pro Stunde zu."
        },
        {
          "absatz": "3",
          "text": "Die Grundentschädigung wird am Ende eines Quartals, die Fallpauschalen werden am Jahresende ausbezahlt."
        }
      ],
      "stand": "2023-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "91459ee043b22b5c5b145e355edeb96e",
      "sha": "d27704fcd0f037a59d908ac1e19daf0c3359f06f9a873d4f0f51df08f8fc53fd"
    },
    {
      "id": "kanton/AR/145.12/art_3_a",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Besoldungsverordnung für die gerichtlichen Organe (145.12)",
      "artikel": "3_a",
      "artikelLabel": "Art. 3a",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die jährliche Grundentschädigung für den Präsidenten oder die Präsidentin der Schlichtungsstelle für Miete und nichtlandwirtschaftliche Pacht beträgt Fr. 3'000.–."
        }
      ],
      "stand": "2023-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "91459ee043b22b5c5b145e355edeb96e",
      "sha": "c31990c3a155052b7366c526b360478c7df504ef598b7c6ba45c9c745f0481c3"
    },
    {
      "id": "kanton/AR/145.12/art_4",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Besoldungsverordnung für die gerichtlichen Organe (145.12)",
      "artikel": "4",
      "artikelLabel": "Art. 4",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Jahresbesoldung des Präsidenten oder der Präsidentin sowie der Vizepräsidenten und Vizepräsidentinnen des Kantonsgerichtes beträgt",
          "items": [
            {
              "marke": "a",
              "text": "im 1.–4. Dienstjahr 94%,"
            },
            {
              "marke": "b",
              "text": "nach vier Dienstjahren 97%,"
            },
            {
              "marke": "c",
              "text": "nach acht Dienstjahren 100%,"
            },
            {
              "marke": "d",
              "text": "nach zwölf Dienstjahren 103%,"
            },
            {
              "marke": "e",
              "text": "nach sechzehn Dienstjahren 106%"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Der Präsident oder die Präsidentin bezieht zusätzlich eine jährliche Präsidialzulage von Fr. 5 000–."
        }
      ],
      "stand": "2023-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "91459ee043b22b5c5b145e355edeb96e",
      "sha": "7a7be19d4a1f58e71ceeb3cca344e0bf7b56fdb9a8c68b0238f9fb9b3a987265"
    },
    {
      "id": "kanton/AR/145.12/art_5",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Besoldungsverordnung für die gerichtlichen Organe (145.12)",
      "artikel": "5",
      "artikelLabel": "Art. 5",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Jahresbesoldung des Präsidenten oder der Präsidentin des Obergerichtes beträgt",
          "items": [
            {
              "marke": "a",
              "text": "im 1. – 4. Amtsjahr 99%,"
            },
            {
              "marke": "b",
              "text": "nach vier Amtsjahren 102,5%,"
            },
            {
              "marke": "c",
              "text": "nach acht Amtsjahren 106%,"
            },
            {
              "marke": "d",
              "text": "nach zwölf Amtsjahren 109,5%,"
            },
            {
              "marke": "e",
              "text": "nach sechzehn Amtsjahren 113%"
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die Jahresbesoldung der Vizepräsidenten und Vizepräsidentinnen des Obergerichtes beträgt bei vollem Pensum",
          "items": [
            {
              "marke": "a",
              "text": "im 1.–4. Amtsjahr 96%,"
            },
            {
              "marke": "b",
              "text": "nach vier Amtsjahren 99,5%,"
            },
            {
              "marke": "c",
              "text": "nach acht Amtsjahren 103%,"
            },
            {
              "marke": "d",
              "text": "nach zwölf Amtsjahren 106,5%,"
            },
            {
              "marke": "e",
              "text": "nach sechzehn Amtsjahren 110%"
            }
          ]
        }
      ],
      "stand": "2023-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "91459ee043b22b5c5b145e355edeb96e",
      "sha": "fe00b05e6d11c8f77f7f3b9ae42d9ed54e0c73c1f0590eda719a164ce61e72b5"
    },
    {
      "id": "kanton/AR/145.12/art_6",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Besoldungsverordnung für die gerichtlichen Organe (145.12)",
      "artikel": "6",
      "artikelLabel": "Art. 6",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Bei der Anfangseinstufung wird eine frühere Tätigkeit in einem Gerichtspräsidium einer vergleichbaren gerichtlichen Instanz berücksichtigt."
        },
        {
          "absatz": "2",
          "text": "Die Anfangseinstufung wird vom zuständigen Organ des Kantonsrates abschliessend festgelegt."
        }
      ],
      "stand": "2023-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "91459ee043b22b5c5b145e355edeb96e",
      "sha": "0f4d783a9f3b1599e730849d01e2d0b5007c7699ab3136024d3118dd9d9160f5"
    },
    {
      "id": "kanton/AR/145.12/art_7",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Besoldungsverordnung für die gerichtlichen Organe (145.12)",
      "artikel": "7",
      "artikelLabel": "Art. 7",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die nebenamtlichen Richter und Richterinnen beziehen für Gerichts- und Kommissionssitzungen folgende Taggelder:",
          "items": [
            {
              "marke": "a",
              "text": "Ganzer Tag Fr. 250.–;"
            },
            {
              "marke": "b",
              "text": "Halber Tag Fr. 125.–."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Die Mitglieder der Schlichtungsstellen beziehen für Kommissionssitzungen folgende Taggelder:",
          "items": [
            {
              "marke": "a",
              "text": "Ganzer Tag Fr. 320.–;"
            },
            {
              "marke": "b",
              "text": "Halber Tag Fr. 160.–."
            }
          ]
        },
        {
          "absatz": "3",
          "text": "Die Präsidenten und Präsidentinnen der Schlichtungsstellen beziehen für Kommissionssitzungen folgende Taggelder:",
          "items": [
            {
              "marke": "a",
              "text": "Ganzer Tag Fr. 420.–;"
            },
            {
              "marke": "b",
              "text": "Halber Tag Fr. 260.–."
            }
          ]
        }
      ],
      "stand": "2023-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "91459ee043b22b5c5b145e355edeb96e",
      "sha": "087b58ed2e8ec515f5d9d4a7e204f26a18a5c320e342714482e92df8f6c47000"
    },
    {
      "id": "kanton/AR/145.12/art_8",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Besoldungsverordnung für die gerichtlichen Organe (145.12)",
      "artikel": "8",
      "artikelLabel": "Art. 8",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Richter und Richterinnen beziehen folgende Jahresentschädigungen:",
          "items": [
            {
              "marke": "a",
              "text": "Oberrichter, Oberrichterin Fr. 5 000.–;"
            },
            {
              "marke": "b",
              "text": "Kantonsrichter, Kantonsrichterin Fr. 4 000.–;"
            },
            {
              "marke": "c",
              "text": "Mitglieder der Aufsichtsbehörde für Schuldbetreibung und Konkurs Fr. 700.–."
            }
          ]
        }
      ],
      "stand": "2023-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "91459ee043b22b5c5b145e355edeb96e",
      "sha": "65b0f7de9c1c7cda5bb4dd5d757fff6e4549671493e8d6625e01b13aa1d51c2e"
    },
    {
      "id": "kanton/AR/145.12/art_9",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Besoldungsverordnung für die gerichtlichen Organe (145.12)",
      "artikel": "9",
      "artikelLabel": "Art. 9",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Nebenamtliche Stellvertreter und Stellvertreterinnen der Einzelrichter und Einzelrichterinnen des Kantons- und Obergerichtes und Fachrichter oder Fachrichterinnen haben Anspruch auf Entschädigung nach Zeitaufwand."
        },
        {
          "absatz": "2",
          "text": "Der Stundenansatz beträgt Fr. 100.– (exkl. allfällige MWST)."
        }
      ],
      "stand": "2023-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "91459ee043b22b5c5b145e355edeb96e",
      "sha": "6677cb4db1aa77cb494105e5e7281ae52870ce12591b6a317f2bbe8e0d4b5c3a"
    },
    {
      "id": "kanton/AR/145.12/art_10",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Besoldungsverordnung für die gerichtlichen Organe (145.12)",
      "artikel": "10",
      "artikelLabel": "Art. 10",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Entschädigungen gemäss Art. 3 und 7–9 werden vom zuständigen Organ des Kantonsrates in Bezug auf die Anpassung an veränderte Lebenshaltungskosten regelmässig überprüft. Es erstattet dem Kantonsrat Bericht und stellt bei Bedarf Antrag."
        }
      ],
      "stand": "2023-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "91459ee043b22b5c5b145e355edeb96e",
      "sha": "744660e0708f110946ee297b7890b269076c8ee5b476d64b970864bfaa8d56e9"
    },
    {
      "id": "kanton/AR/145.12/art_11",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Besoldungsverordnung für die gerichtlichen Organe (145.12)",
      "artikel": "11",
      "artikelLabel": "Art. 11",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Verordnung vom 12. Mai 2003 über die Anstellung und Besoldung von Gerichtspräsidentinnen und -präsidenten sowie über die Entschädigung an nebenamtliche Richterinnen und Richterwird aufgehoben."
        }
      ],
      "stand": "2023-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "91459ee043b22b5c5b145e355edeb96e",
      "sha": "78a959bad02f9532d77a09aef30d36febef63e9dfd3beb3c99a12b57773953cb"
    },
    {
      "id": "kanton/AR/145.12/art_12",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Besoldungsverordnung für die gerichtlichen Organe (145.12)",
      "artikel": "12",
      "artikelLabel": "Art. 12",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Verordnung vom 30. Oktober 2006 über die Pensionskasse von Appenzell Ausserrhoden wird wie folgt geändert: Text im betreffenden Erlass eingefügt."
        }
      ],
      "stand": "2023-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.12",
      "abgerufen": "2026-06-23",
      "fassungsToken": "91459ee043b22b5c5b145e355edeb96e",
      "sha": "2004dae4bfe682fdcaef59281f6958af5d59e21a4ddee2d767d6640ba4246872"
    },
    {
      "id": "kanton/AR/145.12/art_13",
      "ebene": "kanton",
      "quelle": "AR",
      "erlass": "Besoldungsverordnung für die gerichtlichen Organe (145.12)",
      "artikel": "13",
      "artikelLabel": "Art. 13",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Regierungsrat bestimmt das Inkrafttreten."
        }
      ],
      "stand": "2023-06-01",
      "quelleUrl": "https://ar.clex.ch/app/de/texts_of_law/145.12",
      "abgerufen": "2026-06-23",
