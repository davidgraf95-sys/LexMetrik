{
  "erzeugt": "2026-06-23",
  "eintraege": [
    {
      "id": "kanton/BS/576.150/art_1",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über den Zivilschutz, VZS (576.150)",
      "artikel": "1",
      "artikelLabel": "§ 1",
      "titel": "Zuständigkeit",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Justiz- und Sicherheitsdepartement ist für den Zivilschutz zuständig, soweit nichts anderes bestimmt ist."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b8cee0584751b120279309a88676a859",
      "sha": "2ac368cea8351dd365c3cfa2b4a7c8fa1288703ff9de0f31e13027ab1e52c9e4"
    },
    {
      "id": "kanton/BS/576.150/art_2",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über den Zivilschutz, VZS (576.150)",
      "artikel": "2",
      "artikelLabel": "§ 2",
      "titel": "Aufgaben im Rahmen der Kantonalen Krisenorganisation",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Zivilschutz wird neben seinen Kernaufgaben gemäss Bundesrecht für präventive Massnahmen zur Verhinderung oder Minderung von Schäden und für Instandstellungsarbeiten nach Schadensereignissen eingesetzt, wenn ihm die Kantonale Krisenorganisation solche Aufgaben zuteilt."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b8cee0584751b120279309a88676a859",
      "sha": "44fc9663da9998b2174f1472bf4e36242ce6bf384042b91881afe1ee31e0fcf6"
    },
    {
      "id": "kanton/BS/576.150/art_3",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über den Zivilschutz, VZS (576.150)",
      "artikel": "3",
      "artikelLabel": "§ 3",
      "titel": "Dienstregeln",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die für den Zivilschutz zuständigen Stellen regeln mindestens:",
          "items": [
            {
              "marke": "a",
              "text": "die Organisation;"
            },
            {
              "marke": "b",
              "text": "das Soldwesen;"
            },
            {
              "marke": "c",
              "text": "die Verpflegung;"
            },
            {
              "marke": "d",
              "text": "die Unterkunft;"
            },
            {
              "marke": "e",
              "text": "die Reisen und Transporte."
            }
          ]
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b8cee0584751b120279309a88676a859",
      "sha": "0c887a7e0accdad3e3275b2c63d3f830cb1ced632110151885ca175c504dad48"
    },
    {
      "id": "kanton/BS/576.150/art_4",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über den Zivilschutz, VZS (576.150)",
      "artikel": "4",
      "artikelLabel": "§ 4",
      "titel": "Vertrauensärztinnen und Vertrauensärzte",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Als Vertrauensärztinnen und Vertrauensärzte einsetzbar sind zur Berufsausübung in der Schweiz zugelassene Ärztinnen und Ärzte."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b8cee0584751b120279309a88676a859",
      "sha": "8a94957f7dd5abe726954f7062d47abaede0644ab40c85d9290b095d1b108d5d"
    },
    {
      "id": "kanton/BS/576.150/art_5",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über den Zivilschutz, VZS (576.150)",
      "artikel": "5",
      "artikelLabel": "§ 5",
      "titel": "Zustimmung Arbeitgeberin oder Arbeitgeber für freiwilligen Schutzdienst",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Wer freiwillig Schutzdienst leisten will, bringt mit dem Gesuch die schriftliche Zustimmung der Arbeitgeberin oder des Arbeitgebers bei."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b8cee0584751b120279309a88676a859",
      "sha": "cef34c6d3528525f6fabf48b636d7b8fd235c019f59863daa79ef3d3fa2f012c"
    },
    {
      "id": "kanton/BS/576.150/art_6",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über den Zivilschutz, VZS (576.150)",
      "artikel": "6",
      "artikelLabel": "§ 6",
      "titel": "Aufgebot zu Ausbildungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Aufgebot zu den Ausbildungen erfolgt persönlich in postalischer oder elektronischer Form."
        },
        {
          "absatz": "2",
          "text": "Angehörigen des Zivilschutzes wird spätestens 5 Monate vor einem Ausbildungsdienst eine Dienstanzeige postalisch oder elektronisch zugestellt."
        },
        {
          "absatz": "3",
          "text": "Ersteinsatzformationen können kurzfristig zu Alarmübungen aufgeboten werden. Für die Alarmübungen ist ein Zeitraum festzulegen. Dieser wird den betroffenen Angehörigen des Zivilschutzes spätestens 10 Monate vor seinem Beginn mit einer Dienstanzeige in postalischer oder elektronischer Form übermittelt."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b8cee0584751b120279309a88676a859",
      "sha": "f7a0df1730a1c6dc35ad12966fe3eec7abe79d16f7038dbef7499353cc77c6a7"
    },
    {
      "id": "kanton/BS/576.150/art_7",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über den Zivilschutz, VZS (576.150)",
      "artikel": "7",
      "artikelLabel": "§ 7",
      "titel": "Aufgebot zu Einsätzen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Aufgebot zu Einsätzen kann in jeder geeigneten Form erfolgen."
        },
        {
          "absatz": "2",
          "text": "Dem Aufgebot ist unverzüglich Folge zu leisten, sofern die aufbietende Stelle keinen anderen Zeitpunkt festlegt."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b8cee0584751b120279309a88676a859",
      "sha": "258863de94b53942a3f992539f1d7c5827f3fa6d2891c94efd2ca13d21ae98b9"
    },
    {
      "id": "kanton/BS/576.150/art_8",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über den Zivilschutz, VZS (576.150)",
      "artikel": "8",
      "artikelLabel": "§ 8",
      "titel": "Dauer der Ausbildungen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Dauer der Ausbildungen wird wie folgt festgelegt:",
          "items": [
            {
              "marke": "a",
              "text": "Grundausbildung 12 Tage;"
            },
            {
              "marke": "b",
              "text": "Zusatzausbildung höchstens 5 Tage;"
            },
            {
              "marke": "c",
              "text": "Kaderausbildung 5 bis 12 Tage;"
            },
            {
              "marke": "d",
              "text": "Weiterbildung höchstens 5 Tage pro Jahr;"
            },
            {
              "marke": "e",
              "text": "Wiederholungskurse jährlich 3 bis 21 Tage."
            }
          ]
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b8cee0584751b120279309a88676a859",
      "sha": "134c4df3ae1ef098cdba4398bcf0daecd521484385c7f9504518bbe6c498f09e"
    },
    {
      "id": "kanton/BS/576.150/art_9",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über den Zivilschutz, VZS (576.150)",
      "artikel": "9",
      "artikelLabel": "§ 9",
      "titel": "Ersatzbeitrag nicht erstellte Schutzplätze",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Der Ersatzbeitrag pro nicht erstellten Schutzplatz beträgt Fr. 1'400."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b8cee0584751b120279309a88676a859",
      "sha": "27b0432938da37ccad8114a82e6cc7739263c211b975c56dc594a5cc46c98380"
    },
    {
      "id": "kanton/BS/576.150/art_10",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über den Zivilschutz, VZS (576.150)",
      "artikel": "10",
      "artikelLabel": "§ 10",
      "titel": "Einsichtnahme in Bauakten",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die vom Zivilschutz aufbewahrten Baupläne und statischen Berechnungen von Schutzbauten können von Eigentümerinnen und Eigentümern von Bauten und ihren Bevollmächtigten, Fassadenpläne auch von bauwilligen Nachbarinnen und Nachbarn und ihren Architektinnen und Architekten in den Räumlichkeiten der zuständigen Stelle eingesehen werden."
        },
        {
          "absatz": "2",
          "text": "Alternativ oder ergänzend zur Einsichtnahme vor Ort können Kopien der Bauakten bestellt werden."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b8cee0584751b120279309a88676a859",
      "sha": "94a293f45458b41bdf56e84edd82bb909da1d52b242cd337997656634d05999e"
    },
    {
      "id": "kanton/BS/576.150/art_11",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über den Zivilschutz, VZS (576.150)",
      "artikel": "11",
      "artikelLabel": "§ 11",
      "titel": "Nutzung kantonaler Schutzbauten durch Partnerorganisationen des Bevölkerungsschutzes",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Die Nutzung der kantonalen Schutzbauten ist für Partnerorganisationen des Bevölkerungsschutzes, namentlich auch als Truppenunterkunft bei Einsätzen, zulässig."
        },
        {
          "absatz": "2",
          "text": "Die Bereitstellung erfolgt nach der Verfügbarkeit entsprechender kantonaler Schutzbauten und auf Gesuch der Partnerorganisation hin. Das Gesuch ist an keine besondere Form gebunden."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b8cee0584751b120279309a88676a859",
      "sha": "4d146583f303d85eef8d4d21813fa8cd756b14b4026ff154b215aeb4f93e74fc"
    },
    {
      "id": "kanton/BS/576.150/art_12",
      "ebene": "kanton",
      "quelle": "BS",
      "erlass": "Verordnung über den Zivilschutz, VZS (576.150)",
      "artikel": "12",
      "artikelLabel": "§ 12",
      "titel": "Zuständigkeiten kantonale Schutzanlagen",
      "bloecke": [
        {
          "absatz": "1",
          "text": "Das Justiz- und Sicherheitsdepartement ist betreffend die kantonalen Schutzanlagen unter Einbezug von Immobilien Basel-Stadt für folgende Aufgaben zuständig:",
          "items": [
            {
              "marke": "a",
              "text": "Erstellung sowie betrieblicher und baulicher Unterhalt;"
            },
            {
              "marke": "b",
              "text": "Bewirtschaftung sowie Vermietung;"
            },
            {
              "marke": "c",
              "text": "Durchführung und Begleitung von Projektentwicklungen im Zusammenhang mit den kantonalen Schutzanlagen auf bebauten und unbebauten Parzellen."
            }
          ]
        },
        {
          "absatz": "2",
          "text": "Für die Kontrolle und Sicherstellung der medizinischen Ausrüstung in den geschützten Spitälern ist das Gesundheitsdepartement zuständig."
        }
      ],
      "stand": "2026-01-01",
      "quelleUrl": "https://www.gesetzessammlung.bs.ch/app/de/texts_of_law/576.150",
      "abgerufen": "2026-06-23",
      "fassungsToken": "b8cee0584751b120279309a88676a859",
      "sha": "c8080123d629cb7201886b81cb14810a6e4c80537a331f1844247d146c27f266"
    }
  ]
}