{
 "erzeugt": "2026-06-30",
 "kopf": {
  "srNummer": "0.274.132",
  "titel": "Übereinkommen über die Beweisaufnahme im Ausland in Zivil- oder Handelssachen",
  "erlassdatum": "(Stand am 1. Januar 2026)",
  "praeambel": [
   {
    "rolle": "autor",
    "text": "Die Unterzeichnerstaaten dieses Übereinkommens"
   },
   {
    "rolle": "praeambel",
    "text": "in dem Wunsch, die Übermittlung und Erledigung von Rechtshilfeersuchen zu erleichtern sowie die Angleichung der verschiedenen dabei angewandten Verfahrensweisen zu fördern,"
   },
   {
    "rolle": "praeambel",
    "text": "in der Absicht, die gegenseitige gerichtliche Zusammenarbeit in Zivil- oder Handelssachen wirksamer zu gestalten,"
   },
   {
    "rolle": "verb",
    "text": "haben beschlossen, zu diesem Zweck ein Übereinkommen zu schliessen, und haben die folgenden Bestimmungen vereinbart:"
   }
  ],
  "fussnoten": [
   {
    "nr": "1",
    "text": "Art. 2 Abs. 1 des BB vom 9. Juni 1994 (AS <b>1994</b> 2807)",
    "links": [
     {
      "label": "AS <b>1994</b> 2807",
      "url": "https://fedlex.data.admin.ch/eli/oc/1994/2807_2807_2807"
     }
    ],
    "absatz": null,
    "item": null
   }
  ]
 },
