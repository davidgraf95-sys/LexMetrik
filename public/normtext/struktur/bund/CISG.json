{
 "erzeugt": "2026-06-29",
 "kopf": {
  "srNummer": "0.221.211.1",
  "titel": "Übereinkommen der Vereinten Nationen über Verträge über den internationalen Warenkauf",
  "erlassdatum": "(Stand am 22. Mai 2026)",
  "praeambel": [
   {
    "rolle": "autor",
    "text": "Die Vertragsstaaten dieses Übereinkommens,"
   },
   {
    "rolle": "praeambel",
    "text": "im Hinblick auf die allgemeinen Ziele der Entschliessungen, die von der Sechsten Ausserordentlichen Tagung der Generalversammlung der Vereinten Nationen über die Errichtung einer neuen Weltwirtschaftsordnung angenommen worden sind,"
   },
   {
    "rolle": "praeambel",
    "text": "in der Erwägung, dass die Entwicklung des internationalen Handels auf der Grundlage der Gleichberechtigung und des gegenseitigen Nutzens ein wichtiges Element zur Förderung freundschaftlicher Beziehungen zwischen den Staaten ist,"
   },
   {
    "rolle": "praeambel",
    "text": "in der Meinung, dass die Annahme einheitlicher Bestimmungen, die auf Verträge über den internationalen Warenkauf Anwendung finden und die verschiedenen Gesellschafts-, Wirtschafts- und Rechtsordnungen berücksichtigen, dazu beitragen würde, die rechtlichen Hindernisse im internationalen Handel zu beseitigen und seine Entwicklung zu fördern,"
   },
   {
    "rolle": "verb",
    "text": "haben folgendes vereinbart:"
   }
  ],
  "fussnoten": [
   {
    "nr": "1",
    "text": "AS <b>1991</b> 306",
    "links": [
     {
      "label": "AS <b>1991</b> 306",
      "url": "https://fedlex.data.admin.ch/eli/oc/1991/306_306_306"
     }
    ],
    "absatz": null,
    "item": null
   }
  ]
 },
