 "kopf": {
  "srNummer": "0.211.230.02",
  "titel": "Übereinkommen über die zivilrechtlichen Aspekte internationaler Kindesentführung",
  "erlassdatum": "(Stand am 13. Juni 2024)",
  "praeambel": [
   {
    "rolle": "autor",
    "text": "Die Unterzeichnerstaaten dieses Übereinkommens,"
   },
   {
    "rolle": "praeambel",
    "text": "in der festen Überzeugung, dass das Wohl des Kindes in allen Angelegenheiten des Sorgerechts von vorrangiger Bedeutung ist;"
   },
   {
    "rolle": "praeambel",
    "text": "in dem Wunsch, das Kind vor den Nachteilen eines widerrechtlichen Verbringens oder Zurückhaltens international zu schützen und Verfahren einzuführen, um seine sofortige Rückgabe in den Staat seines gewöhnlichen Aufenthalts sicherzustellen und den Schutz des Rechts zum persönlichen Umgang mit dem Kind zu gewährleisten,"
   },
   {
    "rolle": "verb",
    "text": "haben beschlossen, zu diesem Zweck ein Übereinkommen zu schliessen, und haben die folgenden Bestimmungen vereinbart:"
   }
  ],
  "fussnoten": [
   {
    "nr": "1",
    "text": "Art. 1 Bst. b des BB vom 21. Juni 1983 (AS <b>1983</b> 1680).",
    "links": [
     {
      "label": "AS <b>1983</b> 1680",
      "url": "https://fedlex.data.admin.ch/eli/oc/1983/1680_1680_1680"
     }
    ],
    "absatz": null,
    "item": null
   }
  ]
 },
