  "srNummer": "0.211.213.02",
  "titel": "Übereinkommen über die Anerkennung und Vollstreckung von Unterhaltsentscheidungen",
  "erlassdatum": "(Stand am 15. September 2016)",
  "praeambel": [
   {
    "rolle": "autor",
    "text": "Die Unterzeichnerstaaten dieses Übereinkommens,"
   },
   {
    "rolle": "praeambel",
    "text": "in dem Wunsch, gemeinsame Bestimmungen zur Regelung der gegenseitigen Anerkennung und Vollstreckung von Entscheidungen über die Unterhaltspflicht gegenüber Erwachsenen aufzustellen,"
   },
   {
    "rolle": "praeambel",
    "text": "in dem Wunsch, diese Bestimmungen an die des Übereinkommens vom 15. April 1958 über die Anerkennung und Vollstreckung von Entscheidungen auf dem Gebiet der Unterhaltspflicht gegenüber Kindern anzupassen,",
    "fnNrs": [
     "3"
    ]
   },
   {
    "rolle": "verb",
    "text": "haben beschlossen, zu diesem Zweck ein Übereinkommen zu schliessen, und haben die folgenden Bestimmungen vereinbart:"
   }
  ],
  "fussnoten": [
   {
    "nr": "1",
    "text": "Der französische Originaltext befindet sich unter der gleichen Nummer in der entsprechenden Ausgabe dieser Sammlung.",
    "links": [],
    "absatz": null,
    "item": null
   },
   {
