{
 "erzeugt": "2026-07-11",
 "kopf": {
  "srNummer": "0.231.15",
  "titel": "Berner Übereinkunft zum Schutz von Werken der Literatur und Kunst revidiert in Paris am 24. Juli 1971",
  "erlassdatum": "(Stand am 6. Juni 2024)",
  "praeambel": [
   {
    "rolle": "autor",
    "text": "Die Verbandsländer,"
   },
   {
    "rolle": "praeambel",
    "text": "gleichermassen von dem Wunsch geleitet, die Rechte der Urheber an ihren Werken der Literatur und Kunst in möglichst wirksamer und gleichmässiger Weise zu schützen,"
   },
   {
    "rolle": "praeambel",
    "text": "in Anerkennung der Bedeutung der Arbeitsergebnisse der 1967 in Stockholm abgehaltenen Revisionskonferenz,"
   },
   {
    "rolle": "praeambel",
    "text": "haben beschlossen, die von der Stockholmer Konferenz angenommene Fassung dieser Übereinkunft unter unveränderter Beibehaltung der Artikel 1–20 und 22–26 zu revidieren.",
    "fnNrs": [
     "2"
    ]
   },
   {
    "rolle": "praeambel",
    "text": "Die unterzeichneten Bevollmächtigten haben daher nach Vorlage ihrer in guter und gehöriger Form befundenen Vollmachten folgendes vereinbart:"
   }
  ],
  "fussnoten": [
   {
    "nr": "1",
    "text": "Art. 1 Abs. 1 Bst. a des BB vom 4. Juni 1992 (AS <b>1993</b> 2634)",
