{
 "erzeugt": "2026-07-11",
 "kopf": {
  "srNummer": "0.211.231.011",
  "titel": "Übereinkommen über die Zuständigkeit, das anzuwendende Recht, die Anerkennung, Vollstreckung und Zusammenarbeit auf dem Gebiet der elterlichen Verantwortung und der Massnahmen zum Schutz von Kindern",
  "erlassdatum": "(Stand am 19. Januar 2026)",
  "praeambel": [
   {
    "rolle": "autor",
    "text": "Die Unterzeichnerstaaten dieses Übereinkommens,"
   },
   {
    "rolle": "praeambel",
    "text": "in der Erwägung, dass der Schutz von Kindern im internationalen Bereich verbessert werden muss;"
   },
   {
    "rolle": "praeambel",
    "text": "in dem Wunsch, Konflikte zwischen ihren Rechtssystemen in Bezug auf die Zuständigkeit, das anzuwendende Recht, die Anerkennung und Vollstreckung von Massnahmen zum Schutz von Kindern zu vermeiden;"
   },
   {
    "rolle": "praeambel",
    "text": "eingedenk der Bedeutung der internationalen Zusammenarbeit für den Schutz von Kindern;"
   },
   {
    "rolle": "praeambel",
    "text": "bekräftigend, dass das Wohl des Kindes vorrangig zu berücksichtigen ist;"
   },
   {
    "rolle": "praeambel",
    "text": "angesichts der Notwendigkeit, das Übereinkommen vom 5. Oktober 1961 über die Zuständigkeit der Behörden und das anzuwendende Recht auf dem Gebiet des Schutzes von Minderjährigen zu überarbeiten;",
    "fnNrs": [
     "3"
    ]
   },
   {
    "rolle": "praeambel",
    "text": "in dem Wunsch, zu diesem Zweck unter Berücksichtigung des Übereinkommens der Vereinten Nationen vom 20. November 1989 über die Rechte des Kindes gemeinsame Bestimmungen festzulegen,",
    "fnNrs": [
     "4"
    ]
   },
   {
    "rolle": "verb",
    "text": "haben die folgenden Bestimmungen vereinbart:"
   }
  ],
  "fussnoten": [
   {
    "nr": "1",
    "text": "Gemeinsame deutsche Übersetzung nach dem Ergebnis der Übersetzungskonferenz in Bern vom 10. bis 14. Februar 1997.",
    "links": [],
    "absatz": null,
    "item": null
   },
   {
    "nr": "2",
    "text": "Art. 1 Abs. 1 Bst. a des BB vom 21. Dez. 2007 (AS <b>2009</b> 3077).",
    "links": [
