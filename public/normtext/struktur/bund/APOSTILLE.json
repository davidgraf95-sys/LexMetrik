 "kopf": {
  "srNummer": "0.172.030.4",
  "titel": "Übereinkommen zur Befreiung ausländischer öffentlicher Urkunden von der Beglaubigung",
  "erlassdatum": "(Stand am 4. September 2024)",
  "praeambel": [
   {
    "rolle": "autor",
    "text": "Die Unterzeichnerstaaten dieses Übereinkommens,"
   },
   {
    "rolle": "praeambel",
    "text": "vom Wunsche geleitet, ausländische öffentliche Urkunden von der diplomatischen oder konsularischen Beglaubigung zu befreien,"
   },
   {
    "rolle": "praeambel",
    "text": "haben beschlossen, zu diesem Zweck ein Übereinkommen zu schliessen, und haben die folgenden Bestimmungen vereinbart:"
   }
  ],
