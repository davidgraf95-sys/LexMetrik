 "kopf": {
  "titel": "Wasserrechtskonzession für die St. Gallisch-Appenzellische Kraftwerke AG",
  "erlassdatum": "vom 09.06.1969 (Stand 22.06.2021)",
  "praeambel": [
   {
    "rolle": "autor",
    "text": "Der Kantonsrat des Kantons Appenzell A.Rh.,"
   },
   {
    "rolle": "ingress",
    "text": "gestützt auf das Bundesgesetz vom 22. Dezember 1916 über die Nutzbarmachung der Wasserkräfte (insbes. auf Art. 38 Abs. 1) sowie auf die Art.139–156 des Einführungsgesetzes vom 30. April 1911 zum ZGB und auf die Art. 203–220 (insbes. Art. 214) des Einführungsgesetzes vom 27. April 1969 zum ZGB, beschliesst, der St.Gallisch-Appenzellischen Kraftwerke AG die Konzession zur Ausnützung 1. der Wasserkraft der Urnäsch vom bestehenden Wehr bei der Hundwilertobelbrücke (Gemeinden Herisau und Hundwil) bis zum Zusammenfluss mit der Sitter, 2. des ausserrhodischen Anteils der Wasserkraft der Sitter vom bestehenden Wehr im List (Gemeinde Stein AR und Bezirk Haslen Al) bis zum Zusammenfluss mit der Urnäsch, in der bestehenden Wasserkraftanlage Kubel",
    "fnNrs": [
     "1",
     "2",
     "3"
    ]
   },
   {
    "rolle": "verb",
    "text": "zu erteilen."
   }
  ],
