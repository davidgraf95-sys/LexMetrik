  "titel": "Sömmerungsvorschriften des Kantons Basel-Stadt",
  "erlassdatum": "Vom 13. Mai 2008 (Stand 18. Mai 2008)",
  "praeambel": [
   {
    "rolle": "autor",
    "text": "Das Gesundheitsdepartement des Kantons Basel-Stadt,"
   },
   {
    "rolle": "ingress",
    "text": "gestützt auf Art. 32 der eidgenössischen Tierseuchenverordnung (TSV) vom 27. Juni 1995 und gestützt auf § 1 Abs. 1 der kantonalen Verordnung betreffend die Bekämpfung von Tierseuchen vom 26. März 1980, erlässt folgende Vorschriften für die Sömmerung von Tieren der Rinder-, Schaf- und Schweinegattung aus dem oder im Kanton Basel-Stadt:",
    "fnNrs": [
     "2",
     "3"
    ]
   }
  ],
  "fussnoten": [
   {
    "nr": "2",
    "text": "SR 916.401.",
