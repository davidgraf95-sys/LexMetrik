{
 "erzeugt": "2026-07-18",
 "kopf": {
  "titel": "Vertrag zwischen dem Kanton Basel-Stadt einerseits und der Einwohnergemeinde Riehen anderseits betreffend den Gottesacker Riehen",
  "erlassdatum": "Vom 22. Februar 1982 (Stand 1. Juli 1982)",
  "praeambel": [
   {
    "rolle": "ingress",
    "text": "Der Kanton Basel-Stadt, nachfolgend kurz Kanton genannt, vertreten durch das Sanitätsdepartement, handelnd unter dem Vorbehalt der Genehmigung durch den Regierungsrat und den Grossen Rat, und die Einwohnergemeinde Riehen, nachfolgend kurz Gemeinde genannt, vertreten durch den Gemeinderat, handelnd unter dem Vorbehalt der Genehmigung durch den Weiteren Gemeinderat, vereinbaren bezüglich des Gottesackers Riehen und damit verbunden bezüglich der Aufgaben im Bereiche des Bestattungswesens Folgendes:",
    "fnNrs": [
     "3"
    ]
   }
  ],
  "fussnoten": [
   {
    "nr": "3",
    "text": "Mit RRB vom 8. 2. 1994 ist die Zuständigkeit im Bereich Friedhof- und Bestattungswesen vom Sanitäts- aufs Baudepartement (heutige Bezeichnung: Bau- und Verkehrsdepartement) übertragen worden.",
    "links": [],
    "absatz": null,
    "item": null
   }
  ]
 },
