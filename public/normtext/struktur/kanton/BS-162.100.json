   "fussnoten": [
    {
     "nr": "2",
     "text": "§ 34 Abs. 1: Mit Urteil vom 7. August 2017 hat das Bundesgericht festgestellt, dass die automatische Beendigung des Arbeitsverhältnisses ohne Kündigung ausschliesslich dann eintritt, wenn ein Anspruch auf Rentenzahlungen der Invalidenversicherung besteht. Damit entfällt die automatische Beendigung des Arbeitsverhältnisses nach blossem Ablauf von 16 Monaten (Urteil 8C_46/2017 ).",
     "links": [
      {
       "label": "8C_46/2017",
       "url": "https://www.bger.ch/ext/eurospider/live/de/php/aza/http/index.php?highlight_docid=aza%3A%2F%2Faza://07-08-2017-8C_46-2017&amp;lang=de&amp;zoom=&amp;type=show_document"
      }
     ],
     "absatz": "1",
     "item": null
    }
   ]
